@model IEnumerable<Web_Stadium.EFCore.SanBong>
@{
    ViewData["Title"] = "Tìm sân bóng";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <style>
        /* ── SEARCH AUTOCOMPLETE ── */
        .search-wrap {
            position: relative;
            flex: 1;
            min-width: 220px;
            max-width: 320px;
        }

        .search-inp {
            width: 100%;
            padding: 10px 16px 10px 38px;
            border: 1.5px solid var(--border2);
            border-radius: 10px;
            font-family: var(--ff-b);
            font-size: 14px;
            color: var(--text);
            background: #fff;
            outline: none;
            transition: border-color .2s;
        }

            .search-inp:focus {
                border-color: var(--green);
                box-shadow: 0 0 0 3px rgba(14,168,106,0.10);
            }

        .search-icon {
            position: absolute;
            left: 12px;
            top: 50%;
            transform: translateY(-50%);
            font-size: 15px;
            pointer-events: none;
        }

        .ac-box {
            position: absolute;
            top: calc(100% + 6px);
            left: 0;
            right: 0;
            background: #fff;
            border: 1px solid var(--border2);
            border-radius: 12px;
            box-shadow: 0 8px 24px rgba(15,23,42,0.12);
            z-index: 500;
            overflow: hidden;
            display: none;
        }

            .ac-box.show {
                display: block;
            }

        .ac-item {
            padding: 10px 14px;
            cursor: pointer;
            font-size: 13px;
            color: var(--text);
            transition: background .12s;
            display: flex;
            align-items: center;
            gap: 10px;
            border-bottom: 1px solid var(--border);
        }

            .ac-item:last-child {
                border-bottom: none;
            }

            .ac-item:hover {
                background: #F0FAF6;
            }

        .ac-match {
            color: var(--green);
            font-weight: 700;
        }

        .ac-sub {
            font-size: 11px;
            color: var(--muted);
            margin-top: 2px;
        }

        /* ── MAP ── */
        #map {
            height: 100%;
            border-radius: 14px;
        }

        .leaflet-popup-content-wrapper {
            border-radius: 12px;
            font-family: var(--ff-b);
        }

        .map-popup .pname {
            font-family: var(--ff-h);
            font-size: 14px;
            color: #0F172A;
            margin-bottom: 3px;
            text-transform: uppercase;
            letter-spacing: .5px;
        }

        .map-popup .paddr {
            font-size: 12px;
            color: rgba(15,23,42,0.55);
            margin-bottom: 8px;
        }

        .map-popup .pbtn {
            display: inline-block;
            background: #0EA86A;
            color: #fff;
            font-family: var(--ff-h);
            font-size: 10px;
            font-weight: 700;
            letter-spacing: 1px;
            text-transform: uppercase;
            padding: 5px 14px;
            border-radius: 999px;
            text-decoration: none;
        }

        /* ── SAN LIST ── */
        .san-list-wrap {
            max-height: 480px;
            overflow-y: auto;
            padding-right: 4px;
        }

            .san-list-wrap::-webkit-scrollbar {
                width: 4px;
            }

            .san-list-wrap::-webkit-scrollbar-thumb {
                background: rgba(14,168,106,0.30);
                border-radius: 2px;
            }

        .san-item {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: var(--r-lg);
            padding: 12px 14px;
            margin-bottom: 10px;
            cursor: pointer;
            transition: all .2s;
            display: flex;
            gap: 12px;
            align-items: center;
        }

            .san-item:hover, .san-item.active {
                border-color: rgba(14,168,106,0.35);
                background: #F0FAF6;
            }

        .san-item-img {
            width: 52px;
            height: 52px;
            border-radius: 9px;
            background: #1a3d2b;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 22px;
            flex-shrink: 0;
            overflow: hidden;
        }

            .san-item-img img {
                width: 100%;
                height: 100%;
                object-fit: cover;
            }

        .san-item-info {
            flex: 1;
            min-width: 0;
        }

        .san-item-name {
            font-family: var(--ff-h);
            font-size: 13px;
            text-transform: uppercase;
            letter-spacing: .5px;
            color: var(--text);
            margin-bottom: 3px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .san-item-addr {
            font-size: 11px;
            color: var(--muted);
            margin-bottom: 6px;
        }

        .san-item-tags {
            display: flex;
            gap: 4px;
            flex-wrap: wrap;
        }

        .stag {
            font-size: 9px;
            padding: 2px 8px;
            border-radius: 999px;
            font-family: var(--ff-h);
            letter-spacing: .5px;
        }

        .stag-g {
            background: rgba(14,168,106,0.10);
            color: var(--green);
            border: 1px solid rgba(14,168,106,0.20);
        }

        .stag-b {
            background: var(--bg4);
            color: var(--muted);
            border: 1px solid var(--border2);
        }

        .san-item-rating {
            font-family: var(--ff-h);
            font-size: 12px;
            font-weight: 700;
            color: #b37800;
            flex-shrink: 0;
        }

        .san-hidden {
            display: none !important;
        }
    </style>
}

@{
    var tuKhoa = ViewBag.TuKhoa as string ?? "";
    var loaiSan = ViewBag.LoaiSan as string ?? "";
    var loaiCo = ViewBag.LoaiCo as string ?? "";
    var coFilter = !string.IsNullOrEmpty(tuKhoa) || !string.IsNullOrEmpty(loaiSan) || !string.IsNullOrEmpty(loaiCo);
}

<!-- COMPACT HEADER + FILTER -->
<div style="background:linear-gradient(135deg,#edf7f2 0%,#F7F9FC 100%);
            padding:80px 40px 24px; border-bottom:1px solid var(--border); position:relative; overflow:hidden;">
    <div style="position:absolute;inset:0;pointer-events:none;opacity:.04;
         background-image:url('data:image/svg+xml,%3Csvg width=\'52\' height=\'52\' viewBox=\'0 0 52 52\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cg fill=\'none\' stroke=\'%230EA86A\' stroke-width=\'0.5\'%3E%3Crect x=\'4\' y=\'4\' width=\'44\' height=\'44\'/%3E%3Cline x1=\'26\' y1=\'4\' x2=\'26\' y2=\'48\'/%3E%3Ccircle cx=\'26\' cy=\'26\' r=\'9\'/%3E%3C/g%3E%3C/svg%3E');"></div>

    <div style="display:flex; align-items:center; justify-content:space-between; gap:24px; flex-wrap:wrap; position:relative; z-index:2;">
        <!-- Tiêu đề compact -->
        <div style="flex-shrink:0;">
            <div class="section-label" style="margin-bottom:6px;">Hệ thống sân bóng</div>
            <h1 style="font-style:italic; line-height:0.92; color:#0F172A; font-size:clamp(1.6rem,3vw,2.2rem);">
                TÌM SÂN <span class="text-green">BÓNG ĐÁ</span>
            </h1>
            <div style="font-size:12px; color:var(--muted); margin-top:4px;">
                @Model.Count() sân đang hoạt động
            </div>
        </div>

        <!-- Filter inline -->
        <div style="display:flex; gap:8px; align-items:center; flex-wrap:wrap; flex:1; justify-content:flex-end;" id="filterRow">

            <!-- Autocomplete search -->
            <div class="search-wrap">
                <span class="search-icon">🔍</span>
                <input class="search-inp" id="searchInp"
                       placeholder="Tìm tên sân, quận..."
                       value="@tuKhoa"
                       autocomplete="off"
                       oninput="handleSearch(this.value)"
                       onfocus="handleSearch(this.value)"
                       onkeydown="handleKey(event)" />
                <div class="ac-box" id="acBox"></div>
            </div>

            <!-- Select loại sân -->
            <select id="selLoaiSan"
                    style="padding:10px 14px; border:1.5px solid var(--border2); border-radius:10px;
                           font-family:var(--ff-b); font-size:13px; background:#fff; color:var(--text);
                           cursor:pointer; min-width:130px;">
                <option value="">Loại sân</option>
                @if (loaiSan == "5")
                {
                    <option value="5" selected="selected">Sân 5 người</option>
                }
                else
                {
                    <option value="5">Sân 5 người</option>
                }
                @if (loaiSan == "7")
                {
                    <option value="7" selected="selected">Sân 7 người</option>
                }
                else
                {
                    <option value="7">Sân 7 người</option>
                }
                @if (loaiSan == "11")
                {
                    <option value="11" selected="selected">Sân 11 người</option>
                }
                else
                {
                    <option value="11">Sân 11 người</option>
                }
            </select>

            <!-- Select loại cỏ -->
            <select id="selLoaiCo"
                    style="padding:10px 14px; border:1.5px solid var(--border2); border-radius:10px;
                           font-family:var(--ff-b); font-size:13px; background:#fff; color:var(--text);
                           cursor:pointer; min-width:140px;">
                <option value="">Loại cỏ</option>
                @if (loaiCo == "Nhan tao")
                {
                    <option value="Nhan tao" selected="selected">Cỏ nhân tạo</option>
                }
                else
                {
                    <option value="Nhan tao">Cỏ nhân tạo</option>
                }
                @if (loaiCo == "Tu nhien")
                {
                    <option value="Tu nhien" selected="selected">Cỏ tự nhiên</option>
                }
                else
                {
                    <option value="Tu nhien">Cỏ tự nhiên</option>
                }
            </select>

            <!-- Nút Tìm -->
            <button onclick="applyFilter()"
                    style="padding:10px 20px; background:var(--green); color:#fff; border:none;
                           border-radius:10px; font-family:var(--ff-h); font-size:12px; font-weight:700;
                           letter-spacing:1.5px; text-transform:uppercase; cursor:pointer;
                           transition:all .2s; white-space:nowrap;"
                    onmouseover="this.style.background='var(--green-deep)'"
                    onmouseout="this.style.background='var(--green)'">
                🔍 Tìm
            </button>

            @if (coFilter)
            {
                <a href="/Venues"
                   style="font-family:var(--ff-h); font-size:10px; font-weight:700; letter-spacing:1px;
                                  text-transform:uppercase; padding:10px 16px; border-radius:10px;
                                  border:1.5px solid var(--border2); background:#fff; color:var(--muted);
                                  text-decoration:none; white-space:nowrap;">
                    ✕ Xoá lọc
                </a>
            }
        </div>
    </div>

    <!-- Filter tags -->
    @if (coFilter)
    {
        <div style="display:flex; gap:6px; flex-wrap:wrap; margin-top:12px; position:relative; z-index:2;">
            @if (!string.IsNullOrEmpty(tuKhoa))
            {
                <span style="background:rgba(14,168,106,0.10); border:1px solid rgba(14,168,106,0.25); color:#0EA86A;
                                             font-family:var(--ff-h); font-size:9px; letter-spacing:1px; padding:3px 10px; border-radius:999px;">
                    🔍 "@tuKhoa"
                </span>
            }
            @if (!string.IsNullOrEmpty(loaiSan))
            {
                <span style="background:rgba(14,168,106,0.10); border:1px solid rgba(14,168,106,0.25); color:#0EA86A;
                                             font-family:var(--ff-h); font-size:9px; letter-spacing:1px; padding:3px 10px; border-radius:999px;">
                    ⚽ Sân @loaiSan người
                </span>
            }
            @if (!string.IsNullOrEmpty(loaiCo))
            {
                <span style="background:rgba(14,168,106,0.10); border:1px solid rgba(14,168,106,0.25); color:#0EA86A;
                                             font-family:var(--ff-h); font-size:9px; letter-spacing:1px; padding:3px 10px; border-radius:999px;">
                    🌱 @(loaiCo == "Nhan tao" ? "Cỏ nhân tạo" : "Cỏ tự nhiên")
                </span>
            }
        </div>
    }
</div>

<!-- BODY: 2 cột MAP + DANH SÁCH -->
<div style="display:grid; grid-template-columns:1fr 1fr; gap:16px; padding:20px 40px; min-height:520px;">

    <!-- BẢN ĐỒ -->
    <div style="position:sticky; top:90px; height:500px;">
        <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:8px;">
            <div style="font-family:var(--ff-h); font-size:10px; letter-spacing:2px; text-transform:uppercase; color:var(--muted);">
                📍 Bản đồ · <span id="mapCount">@Model.Count()</span> sân
            </div>
        </div>
        <div id="map" style="height:480px; border-radius:14px; border:1px solid var(--border); box-shadow:var(--shadow-sm);"></div>
    </div>

    <!-- DANH SÁCH SÂN -->
    <div>
        <div style="font-family:var(--ff-h); font-size:10px; letter-spacing:2px; text-transform:uppercase;
                    color:var(--muted); margin-bottom:10px;">
            Danh sách · <span id="listCount">@Model.Count()</span> sân
        </div>

        @if (!Model.Any())
        {
            <div style="text-align:center; padding:60px 16px;">
                <div style="font-size:48px; margin-bottom:12px;">⚽</div>
                <div style="font-family:var(--ff-h); font-size:16px; margin-bottom:8px;">Không tìm thấy sân nào</div>
                <a href="/Venues" class="btn-outline" style="padding:8px 20px;">Xem tất cả</a>
            </div>
        }
        else
        {
            <div id="emptyState" style="display:none; text-align:center; padding:60px 16px;">
                <div style="font-size:48px; margin-bottom:12px;">🔍</div>
                <div style="font-family:var(--ff-h); font-size:16px; color:var(--text); margin-bottom:8px;">Không tìm thấy sân nào</div>
                <div style="font-size:13px; color:var(--muted); margin-bottom:16px;">Thử thay đổi bộ lọc hoặc từ khoá</div>
                <button onclick="resetFilter()" style="padding:8px 20px; background:transparent; border:1.5px solid var(--border2); border-radius:8px; font-family:var(--ff-h); font-size:11px; letter-spacing:1px; text-transform:uppercase; cursor:pointer; color:var(--muted);">✕ Xoá bộ lọc</button>
            </div>
            <div class="san-list-wrap" id="sanListWrap">
                @foreach (var san in Model)
                {
                    <div class="san-item"
                         id="san-card-@san.Id"
                         data-id="@san.Id"
                         data-name="@san.TenSan.ToLower()"
                         data-quan="@san.Quan.ToLower()"
                         data-loaisan="@san.LoaiSan"
                         data-loaico="@san.LoaiCo"
                         onclick="focusMap(@san.Id)">
                        <div class="san-item-img">
                            @if (!string.IsNullOrEmpty(san.HinhAnh))
                            {
                                <img src="@san.HinhAnh" alt="@san.TenSan" />
                            }
                            else
                            {

                                <span>⚽</span>
                            }
                        </div>
                        <div class="san-item-info">
                            <div class="san-item-name">@san.TenSan</div>
                            <div class="san-item-addr">📍 @san.DiaChi — @san.Quan</div>
                            <div class="san-item-tags">
                                <span class="stag stag-g">Sân @san.LoaiSan</span>
                                <span class="stag stag-b">🌱 @san.LoaiCo</span>
                            </div>
                        </div>
                        <div>
                            <div class="san-item-rating">★ @san.DanhGiaTrungBinh.ToString("F1")</div>
                            <a href="/Venues/Details/@san.Id"
                               onclick="event.stopPropagation()"
                               style="display:block; margin-top:8px; font-family:var(--ff-h); font-size:9px; font-weight:700;
                                                      letter-spacing:1px; text-transform:uppercase; padding:5px 10px; border-radius:6px;
                                                      background:var(--green); color:#fff; text-decoration:none; text-align:center; white-space:nowrap;">
                                Đặt sân
                            </a>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

<!-- Dữ liệu sân cho JS -->
<script id="san-data" type="application/json">
    @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Select((s, i) => new {
        id = s.Id,
                                ten = s.TenSan,
                                tenLow = s.TenSan.ToLower(),
                                quan = s.Quan,
                                quanLow = s.Quan.ToLower(),
                                diaChi = s.DiaChi + " — " + s.Quan,
                                loaiSan = s.LoaiSan.ToString(),
                                loaiCo = s.LoaiCo,
                                rating = s.DanhGiaTrungBinh,
                                lat = 21.0285 + (i % 5) * 0.012 + (s.Id % 3) * 0.005,
                                lng = 105.8542 + (i % 4) * 0.015 + (s.Id % 3) * 0.006
                })))
</script>

@section Scripts {
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script>
        (function(){
          var SANS    = JSON.parse(document.getElementById('san-data').textContent);
          var map     = null;
          var markers = {};
          var acIdx   = -1;

          // ── Init Leaflet map ──
          function initMap(){
            map = L.map('map', {zoomControl:true}).setView([21.0285, 105.8542], 12);
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
              attribution:'© OpenStreetMap', maxZoom:19
            }).addTo(map);

            SANS.forEach(function(s){
              var icon = L.divIcon({
                className:'',
                html:'<div style="width:28px;height:28px;background:#0EA86A;border-radius:50% 50% 50% 0;transform:rotate(-45deg);border:3px solid white;box-shadow:0 3px 10px rgba(14,168,106,0.45);"></div>',
                iconSize:[28,28], iconAnchor:[14,28], popupAnchor:[0,-32]
              });
              var m = L.marker([s.lat, s.lng], {icon:icon}).addTo(map);
              m.bindPopup(
                '<div class="map-popup">'+
                '<div class="pname">'+s.ten+'</div>'+
                '<div class="paddr">📍 '+s.diaChi+'</div>'+
                '<div style="font-size:11px;color:rgba(15,23,42,0.55);margin-bottom:8px;">Sân '+s.loaiSan+' · 🌱 '+s.loaiCo+' · ★ '+s.rating.toFixed(1)+'</div>'+
                '<a href="/Venues/Details/'+s.id+'" class="pbtn">Xem & Đặt sân →</a>'+
                '</div>',
                {maxWidth:240}
              );
              m.on('click', function(){ highlightCard(s.id); });
              markers[s.id] = m;
            });

            fitVisible();
          }

          function fitVisible(){
            var vis = SANS.filter(function(s){ return !document.getElementById('san-card-'+s.id)?.classList.contains('san-hidden'); });
            if(vis.length === 0) return;
            if(vis.length === 1){
              map.setView([vis[0].lat, vis[0].lng], 15);
            } else {
              var grp = new L.featureGroup(vis.map(function(s){ return markers[s.id]; }));
              map.fitBounds(grp.getBounds().pad(0.15));
            }
            document.getElementById('mapCount').textContent = vis.length;
            document.getElementById('listCount').textContent = vis.length;
          }

          // ── Focus map khi click card ──
          window.focusMap = function(id){
            var s = SANS.find(function(x){ return x.id === id; });
            if(!s) return;
            map.setView([s.lat, s.lng], 16, {animate:true});
            markers[id].openPopup();
            highlightCard(id);
          };

          function highlightCard(id){
            document.querySelectorAll('.san-item').forEach(function(c){ c.classList.remove('active'); });
            var card = document.getElementById('san-card-'+id);
            if(card){ card.classList.add('active'); card.scrollIntoView({behavior:'smooth', block:'nearest'}); }
          }

          // ── Filter CHỈ chạy khi bấm nút Tìm ──
          window.applyFilter = function(){
            var kw  = document.getElementById('searchInp').value.trim().toLowerCase();
            var ls  = document.getElementById('selLoaiSan').value;
            var lc  = document.getElementById('selLoaiCo').value;
            var lcNorm = lc === 'Nhan tao' ? 'nhan tao' : lc === 'Tu nhien' ? 'tu nhien' : '';
            var visCount = 0;

            SANS.forEach(function(s){
              var card    = document.getElementById('san-card-'+s.id);
              var marker  = markers[s.id];
              var kwMatch = !kw || s.tenLow.includes(kw) || s.quanLow.includes(kw);
              var lsMatch = !ls || s.loaiSan === ls;
              var lcMatch = !lcNorm || s.loaiCo.toLowerCase().replace(' ','').includes(lcNorm.replace(' ',''));
              var show    = kwMatch && lsMatch && lcMatch;
              if(show) visCount++;
              if(card){ card.classList.toggle('san-hidden', !show); }
              if(marker){ show ? marker.addTo(map) : map.removeLayer(marker); }
            });

            // Hiện/ẩn empty state
            var empty = document.getElementById('emptyState');
            var wrap  = document.getElementById('sanListWrap');
            if(empty && wrap){
              empty.style.display = visCount === 0 ? 'block' : 'none';
              wrap.style.display  = visCount === 0 ? 'none'  : '';
            }

            fitVisible();
            closeAC();
          };

          // Reset bộ lọc
          window.resetFilter = function(){
            document.getElementById('searchInp').value = '';
            document.getElementById('selLoaiSan').value = '';
            document.getElementById('selLoaiCo').value = '';
            applyFilter();
          };

          // ── Autocomplete — CHỈ gợi ý, không tự lọc ──
          window.handleSearchInput = function(val){
            acIdx = -1;
            var kw = val.trim().toLowerCase();
            if(!kw){ closeAC(); return; }
            showACItems(kw);
          };

          window.showAC = function(val){
            var kw = val.trim().toLowerCase();
            if(kw) showACItems(kw);
          };

          function showACItems(kw){
            var matches = SANS.filter(function(s){
              return s.tenLow.includes(kw) || s.quanLow.includes(kw);
            }).slice(0, 6);

            var box = document.getElementById('acBox');
            if(matches.length === 0){ closeAC(); return; }

            box.innerHTML = matches.map(function(s){
              var hl = function(str){
                var idx = str.toLowerCase().indexOf(kw);
                if(idx < 0) return str;
                return str.substring(0,idx)+'<span class="ac-match">'+str.substring(idx,idx+kw.length)+'</span>'+str.substring(idx+kw.length);
              };
              var isQuan = s.quanLow.includes(kw) && !s.tenLow.includes(kw);
              return '<div class="ac-item" data-id="'+s.id+'" onmousedown="pickAC('+s.id+',\''+s.ten.replace(/'/g,"\\'")+'\')">'+(isQuan?'📍':'🏟️')+' <div><div>'+hl(s.ten)+'</div><div class="ac-sub">'+s.diaChi+'</div></div></div>';
            }).join('');

            box.classList.add('show');
            // KHÔNG gọi applyFilter() ở đây
          };

          window.pickAC = function(id, name){
            document.getElementById('searchInp').value = name;
            closeAC();
            applyFilter();
            setTimeout(function(){ focusMap(id); }, 150);
          };

          window.handleKey = function(e){
            var items = document.querySelectorAll('#acBox .ac-item');
            if(e.key === 'ArrowDown'){ acIdx = Math.min(acIdx+1, items.length-1); highlightAC(items); e.preventDefault(); }
            else if(e.key === 'ArrowUp'){ acIdx = Math.max(acIdx-1, 0); highlightAC(items); e.preventDefault(); }
            else if(e.key === 'Enter'){
              if(acIdx >= 0 && items[acIdx]){ items[acIdx].dispatchEvent(new MouseEvent('mousedown')); }
              else { applyFilter(); }
              e.preventDefault();
            }
            else if(e.key === 'Escape'){ closeAC(); }
          };

          function highlightAC(items){
            items.forEach(function(el,i){ el.style.background = i===acIdx ? '#F0FAF6':''; });
          }
          function closeAC(){ document.getElementById('acBox').classList.remove('show'); }

          document.addEventListener('click', function(e){
            if(!e.target.closest('.search-wrap')) closeAC();
          });

          // ── Đồng bộ select với ViewBag (đã render selected từ server) ──
          // Nếu có filter từ server, apply lại để ẩn marker không khớp
          window.addEventListener('load', function(){
            initMap();
            var ls = document.getElementById('selLoaiSan').value;
            var lc = document.getElementById('selLoaiCo').value;
            var kw = document.getElementById('searchInp').value;
            if(ls || lc || kw) applyFilter();
          });
        })();
    </script>
}
