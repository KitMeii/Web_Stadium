@model IEnumerable<Web_Stadium.EFCore.DatSan>
@{
    ViewData["Title"] = "Lịch đặt sân của tôi";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/mybookings.css" />
    <link rel="stylesheet" href="~/css/mybookings-cal.css" />
}

@{
    var dangKyTim = Context.Request.Query["dangKyTim"].ToString() == "1";
    var daTim = (ViewBag.DaTim as System.Collections.Generic.HashSet<int>)
                    ?? new System.Collections.Generic.HashSet<int>();
    var mmIdMap = (ViewBag.MmIdMap as System.Collections.Generic.Dictionary<int, int>)
                    ?? new System.Collections.Generic.Dictionary<int, int>();
    var soXN = Model.Count(d => d.TrangThai == "DaXacNhan");
    var soCho = Model.Count(d => d.TrangThai == "ChoDuyet");
    var soHuy = Model.Count(d => d.TrangThai == "DaHuy");
    var tongCoc = Model.Where(d => d.TrangThai != "DaHuy").Sum(d => d.TienCoc);
    var sapToi = Model
                  .Where(d => d.NgayThiDau >= DateTime.Today && d.TrangThai != "DaHuy")
                  .OrderBy(d => d.NgayThiDau).FirstOrDefault();
    var sanSap = sapToi?.KhungGio?.SanBong;
    var kgSap = sapToi?.KhungGio;

    var allBookings = Model.Select(d => new
    {
        day = d.NgayThiDau.Day,
        month = d.NgayThiDau.Month,
        year = d.NgayThiDau.Year,
        status = d.TrangThai,
        ma = d.MaXacNhan
    });
}

<script id="bookings-data" type="application/json">
    @Html.Raw(System.Text.Json.JsonSerializer.Serialize(allBookings))
</script>

<!-- HEADER -->
<div class="my-header" style="background:linear-gradient(135deg,#edf7f2 0%,#F7F9FC 100%) !important; padding:0;">
    <div style="display:grid;grid-template-columns:1fr 1.25fr 1fr;align-items:center;
                gap:0;padding:44px 40px 40px;position:relative;overflow:hidden;min-height:330px;">

        <div style="position:absolute;inset:0;pointer-events:none;opacity:.035;
             background-image:url('data:image/svg+xml,%3Csvg width=\'44\' height=\'44\' viewBox=\'0 0 44 44\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Ccircle cx=\'22\' cy=\'22\' r=\'8\' fill=\'none\' stroke=\'%230EA86A\' stroke-width=\'0.7\'/%3E%3C/svg%3E');"></div>

        <!-- TRÁI -->
        <div style="display:flex;flex-direction:column;justify-content:center;gap:13px;
                    position:relative;z-index:2;padding-right:20px;">
            <div class="section-label" style="margin-bottom:2px;">Tài khoản</div>
            <h1 style="font-style:italic;line-height:0.9;color:#0F172A;font-size:clamp(2rem,3.5vw,2.8rem);">
                LỊCH ĐẶT<br><span class="text-green">CỦA TÔI</span>
            </h1>
            <p style="color:var(--muted);font-size:15px;line-height:1.6;max-width:230px;">
                Quản lý lịch đặt sân và trạng thái xác nhận.
            </p>
            <div style="display:flex;flex-direction:column;gap:8px;">
                <div style="display:flex;align-items:center;gap:10px;background:rgba(255,255,255,0.88);
                            border:1px solid rgba(14,168,106,0.22);border-radius:12px;padding:9px 16px;">
                    <div style="width:10px;height:10px;border-radius:50%;background:#0EA86A;flex-shrink:0;"></div>
                    <span style="font-size:14px;font-weight:600;color:#0F172A;flex:1;">Đã xác nhận</span>
                    <span style="font-family:var(--ff-h);font-size:16px;font-weight:700;color:#0EA86A;">@soXN</span>
                </div>
                <div style="display:flex;align-items:center;gap:10px;background:rgba(255,255,255,0.88);
                            border:1px solid rgba(245,158,11,0.28);border-radius:12px;padding:9px 16px;">
                    <div style="width:10px;height:10px;border-radius:50%;background:#F59E0B;flex-shrink:0;"></div>
                    <span style="font-size:14px;font-weight:600;color:#0F172A;flex:1;">Chờ duyệt</span>
                    <span style="font-family:var(--ff-h);font-size:16px;font-weight:700;color:#F59E0B;">@soCho</span>
                </div>
                <div style="display:flex;align-items:center;gap:10px;background:rgba(255,255,255,0.88);
                            border:1px solid rgba(239,68,68,0.20);border-radius:12px;padding:9px 16px;">
                    <div style="width:10px;height:10px;border-radius:50%;background:#EF4444;flex-shrink:0;"></div>
                    <span style="font-size:14px;font-weight:600;color:#0F172A;flex:1;">Đã hủy</span>
                    <span style="font-family:var(--ff-h);font-size:16px;font-weight:700;color:rgba(15,23,42,0.32);">@soHuy</span>
                </div>
            </div>
        </div>

        <!-- GIỮA: Calendar -->
        <div style="display:flex;align-items:center;justify-content:center;
                    padding:0 14px;position:relative;z-index:2;">
            <div style="background:white;border-radius:18px;overflow:visible;width:100%;
                        border:1px solid rgba(15,23,42,0.08);box-shadow:0 4px 20px rgba(15,23,42,0.08);
                        position:relative;">

                <!-- Cal header -->
                <div style="background:#0EA86A;padding:0 16px;height:54px;display:flex;
                            align-items:center;justify-content:space-between;
                            border-radius:18px 18px 0 0;position:relative;">
                    <div style="position:absolute;top:0;left:16px;display:flex;gap:14px;">
                        <div style="width:6px;height:17px;background:#097A4E;border-radius:0 0 3px 3px;"></div>
                        <div style="width:6px;height:17px;background:#097A4E;border-radius:0 0 3px 3px;"></div>
                        <div style="width:6px;height:17px;background:#097A4E;border-radius:0 0 3px 3px;"></div>
                    </div>
                    <div style="position:absolute;top:0;right:16px;display:flex;gap:14px;">
                        <div style="width:6px;height:17px;background:#097A4E;border-radius:0 0 3px 3px;"></div>
                        <div style="width:6px;height:17px;background:#097A4E;border-radius:0 0 3px 3px;"></div>
                        <div style="width:6px;height:17px;background:#097A4E;border-radius:0 0 3px 3px;"></div>
                    </div>
                    <button class="cal-nav-btn" id="prevMonth">&#8249;</button>
                    <div class="cal-label-btn" id="calLabelBtn">
                        <span id="calLabelText"></span>
                        <span class="caret">&#9660;</span>
                    </div>
                    <button class="cal-nav-btn" id="nextMonth">&#8250;</button>
                </div>

                <!-- DOW -->
                <div style="display:grid;grid-template-columns:repeat(7,1fr);padding:12px 16px 4px;gap:2px;">
                    <div style="text-align:center;font-family:var(--ff-h);font-size:15px;font-weight:600;color:rgba(15,23,42,0.38);">T2</div>
                    <div style="text-align:center;font-family:var(--ff-h);font-size:15px;font-weight:600;color:rgba(15,23,42,0.38);">T3</div>
                    <div style="text-align:center;font-family:var(--ff-h);font-size:15px;font-weight:600;color:rgba(15,23,42,0.38);">T4</div>
                    <div style="text-align:center;font-family:var(--ff-h);font-size:15px;font-weight:600;color:rgba(15,23,42,0.38);">T5</div>
                    <div style="text-align:center;font-family:var(--ff-h);font-size:15px;font-weight:600;color:rgba(15,23,42,0.38);">T6</div>
                    <div style="text-align:center;font-family:var(--ff-h);font-size:15px;font-weight:600;color:rgba(15,23,42,0.30);">T7</div>
                    <div style="text-align:center;font-family:var(--ff-h);font-size:15px;font-weight:600;color:rgba(15,23,42,0.24);">CN</div>
                </div>

                <!-- Day grid -->
                <div id="calDayGrid"
                     style="display:grid;grid-template-columns:repeat(7,1fr);padding:4px 12px 12px;gap:3px;">
                </div>

                <!-- Legend -->
                <div style="display:flex;align-items:center;gap:14px;padding:10px 16px 12px;
                            border-top:1px solid rgba(15,23,42,0.06);">
                    <div style="display:flex;align-items:center;gap:5px;">
                        <div style="width:11px;height:11px;background:#0EA86A;border-radius:3px;"></div>
                        <span style="font-size:14px;color:rgba(15,23,42,0.50);">Đã xác nhận</span>
                    </div>
                    <div style="display:flex;align-items:center;gap:5px;">
                        <div style="width:11px;height:11px;background:rgba(245,158,11,0.50);
                                    border:1px solid rgba(245,158,11,0.40);border-radius:3px;"></div>
                        <span style="font-size:14px;color:rgba(15,23,42,0.50);">Chờ duyệt</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Month picker popup — đặt ngoài calendar để tránh overflow:hidden -->
        <div class="month-popup" id="monthPopup" style="position:fixed;display:none;z-index:9999;">
            <div class="mp-year-row">
                <button class="mp-year-nav" id="popPrevYear">&#8249;</button>
                <div class="mp-year-lbl" id="popYearLabel"></div>
                <button class="mp-year-nav" id="popNextYear">&#8250;</button>
            </div>
            <div class="mp-grid" id="mpGrid"></div>
        </div>

        <!-- PHẢI -->
        <div style="display:flex;flex-direction:column;justify-content:center;gap:12px;
                    position:relative;z-index:2;padding-left:20px;">
            <div style="font-family:var(--ff-h);font-size:15px;letter-spacing:2px;
                        text-transform:uppercase;color:rgba(15,23,42,0.38);margin-bottom:2px;">
                Sắp diễn ra
            </div>
            @if (sapToi != null && sanSap != null)
            {
                <div style="background:rgba(255,255,255,0.92);border:1px solid rgba(14,168,106,0.22);
                                        border-radius:14px;padding:14px 16px;">
                    <div style="display:flex;align-items:center;gap:10px;margin-bottom:10px;">
                        <div style="width:40px;height:40px;background:#0EA86A;border-radius:10px;
                                                display:flex;align-items:center;justify-content:center;
                                                font-size:20px;flex-shrink:0;box-shadow:0 3px 10px rgba(14,168,106,0.28);">
                            &#9917;
                        </div>
                        <div>
                            <div style="font-size:15px;font-weight:700;color:#0F172A;line-height:1.2;">@sanSap.TenSan</div>
                            <div style="font-size:14px;color:var(--muted);margin-top:2px;">@sanSap.Quan</div>
                        </div>
                    </div>
                    <div style="font-size:14px;color:var(--muted);margin-bottom:8px;">
                        &#128197; @sapToi.NgayThiDau.ToString("dd/MM/yyyy")
                        &nbsp;&middot;&nbsp;
                        @kgSap?.GioBatDau.ToString(@"hh\:mm")&ndash;@kgSap?.GioKetThuc.ToString(@"hh\:mm")
                    </div>
                    <div style="display:flex;gap:6px;flex-wrap:wrap;">
                        <span class="bc-status @(sapToi.TrangThai == "DaXacNhan" ? "st-xn" : "st-cho")"
                              style="font-size:15px;">
                            @(sapToi.TrangThai == "DaXacNhan" ? "Đã xác nhận" : "Chờ duyệt")
                        </span>
                        <span style="font-size:15px;padding:4px 10px;background:#F0F4F8;
                                                 border-radius:999px;color:var(--muted);">
                            Sân @sanSap.LoaiSan người
                        </span>
                    </div>
                </div>
            }
            else
            {
                <div style="background:rgba(255,255,255,0.70);border:1px dashed rgba(15,23,42,0.14);
                                        border-radius:14px;padding:18px 16px;text-align:center;">
                    <div style="font-size:24px;margin-bottom:10px;opacity:.4;">&#128197;</div>
                    <div style="font-size:14px;color:var(--muted);margin-bottom:10px;">Chưa có lịch sắp tới</div>
                    <a href="/Venues" style="font-family:var(--ff-h);font-size:15px;font-weight:700;
                                   letter-spacing:1.5px;text-transform:uppercase;color:var(--green);text-decoration:none;
                                   border:1px solid rgba(14,168,106,0.35);padding:5px 14px;border-radius:999px;display:inline-block;">
                        Tìm sân ngay
                    </a>
                </div>
            }
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;">
                <div style="background:rgba(255,255,255,0.80);border:1px solid rgba(15,23,42,0.08);
                            border-radius:12px;padding:12px;text-align:center;">
                    <div style="font-family:var(--ff-h);font-size:1.8rem;font-weight:700;color:#0EA86A;line-height:1;">@Model.Count()</div>
                    <div style="font-size:15px;color:var(--muted);letter-spacing:1.5px;text-transform:uppercase;margin-top:3px;">Tổng đặt</div>
                </div>
                <div style="background:rgba(255,255,255,0.80);border:1px solid rgba(15,23,42,0.08);
                            border-radius:12px;padding:12px;text-align:center;">
                    <div style="font-family:var(--ff-h);font-size:1.8rem;font-weight:700;color:#F59E0B;line-height:1;">@soCho</div>
                    <div style="font-size:15px;color:var(--muted);letter-spacing:1.5px;text-transform:uppercase;margin-top:3px;">Chờ duyệt</div>
                </div>
            </div>
            <div style="background:rgba(255,255,255,0.80);border:1px solid rgba(15,23,42,0.08);
                        border-radius:12px;padding:11px 16px;
                        display:flex;align-items:center;justify-content:space-between;">
                <span style="font-size:14px;color:var(--muted);">Tổng tiền cọc</span>
                <span style="font-family:var(--ff-h);font-size:15px;font-weight:700;color:#0EA86A;">
                    @tongCoc.ToString("N0")đ
                </span>
            </div>
        </div>

    </div>
</div>

<!-- TABS + DANH SÁCH -->
<div class="container section" style="padding-top:32px">
    @if (dangKyTim)
    {
        <div style="background:rgba(14,168,106,0.07);border:1px solid rgba(14,168,106,0.22);
                        border-radius:14px;padding:16px 20px;margin-bottom:20px;
                        display:flex;align-items:center;gap:14px;">
            <div style="font-size:28px;flex-shrink:0;">👆</div>
            <div>
                <div style="font-size:13px;font-weight:700;letter-spacing:1.5px;
                                text-transform:uppercase;color:var(--green);margin-bottom:4px;">
                    Chọn đơn để tìm đội
                </div>
                <div style="font-size:14px;color:var(--muted);line-height:1.5;">
                    Nhấn nút <strong style="color:var(--green);">🔍 Tìm đối thủ</strong>
                    trên đơn đặt sân muốn đăng tin tìm đội bên dưới.
                </div>
            </div>
            <button onclick="this.closest('div').style.display='none'"
                    style="margin-left:auto;background:none;border:none;font-size:20px;
                               cursor:pointer;color:var(--muted);flex-shrink:0;">
                ✕
            </button>
        </div>
    }
    <div class="booking-tabs">
        <a href="/Booking/MyBookings" class="b-tab active">Tất cả (@Model.Count())</a>
        <a href="/Booking/MyBookings?trangThai=ChoDuyet" class="b-tab">Chờ duyệt (@soCho)</a>
        <a href="/Booking/MyBookings?trangThai=DaXacNhan" class="b-tab">Đã xác nhận (@soXN)</a>
        <a href="/Booking/MyBookings?trangThai=DaHuy" class="b-tab">Đã hủy (@soHuy)</a>
    </div>

    @if (!Model.Any())
    {
        <div class="empty-booking">
            <div class="empty-booking-icon">&#9917;</div>
            <h3 style="font-family:var(--ff-h);margin-bottom:8px">Chưa có lịch đặt sân nào</h3>
            <p style="color:var(--muted);margin-bottom:24px">Hãy tìm sân và đặt lịch đầu tiên!</p>
            <a href="/Venues" class="btn-primary-glow">Tìm sân ngay</a>
        </div>
    }
    else
    {
        foreach (var ds in Model)
        {
            var san = ds.KhungGio?.SanBong;
            var kg = ds.KhungGio;
            var stClass = ds.TrangThai switch
            {
                "ChoDuyet" => "st-cho",
                "DaXacNhan" => "st-xn",
                "DaHuy" => "st-huy",
                _ => "st-ht"
            };
            var stText = ds.TrangThai switch
            {
                "ChoDuyet" => "Chờ duyệt",
                "DaXacNhan" => "Đã xác nhận",
                "DaHuy" => "Đã hủy",
                "HoanThanh" => "Hoàn thành",
                _ => ds.TrangThai
            };
            <div class="booking-card">
                <div class="bc-top">
                    <div class="bc-code">#@ds.MaXacNhan</div>
                    <div class="bc-san">
                        <div class="bc-san-name">@san?.TenSan</div>
                        <div class="bc-san-addr">&#128205; @san?.DiaChi &mdash; @san?.Quan</div>
                    </div>
                    <div class="bc-status @stClass">@stText</div>
                </div>
                <div class="bc-body">
                    <div>
                        <div class="bc-info-label">Ngày thi đấu</div>
                        <div class="bc-info-val">@ds.NgayThiDau.ToString("dd/MM/yyyy")</div>
                    </div>
                    <div>
                        <div class="bc-info-label">Khung giờ</div>
                        <div class="bc-info-val">
                            @kg?.GioBatDau.ToString(@"hh\:mm") &ndash; @kg?.GioKetThuc.ToString(@"hh\:mm")
                        </div>
                    </div>
                    <div>
                        <div class="bc-info-label">Loại sân</div>
                        <div class="bc-info-val">Sân @san?.LoaiSan người</div>
                    </div>
                    <div>
                        <div class="bc-info-label">Tiền cọc</div>
                        <div class="bc-info-val highlight">@ds.TienCoc.ToString("N0")đ</div>
                    </div>
                    <div>
                        <div class="bc-info-label">Đặt lúc</div>
                        <div class="bc-info-val">@ds.ThoiGianTao.ToString("HH:mm dd/MM")</div>
                    </div>
                </div>
                <div class="bc-footer">
                    <div class="dv-chips">
                        @if (ds.DatSanDichVus != null && ds.DatSanDichVus.Any())
                        {
                            foreach (var dv in ds.DatSanDichVus)
                            {
                                <span class="dv-chip">@dv.DichVu?.TenDichVu &times;@dv.SoLuong</span>
                            }
                        }
                        else
                        {

                            <span style="font-size:14px;color:var(--muted2)">Không có dịch vụ kèm</span>
                        }
                    </div>
                    <div class="bc-footer-actions">
                        @if (ds.TrangThai is "ChoDuyet" or "DaXacNhan")
                        {
                            @if (daTim.Contains(ds.Id))
                            {
                                <span style="display:inline-flex;align-items:center;gap:5px;
                                                             padding:7px 14px;font-size:14px;border-radius:999px;
                                                             background:rgba(14,168,106,0.10);
                                                             border:1px solid rgba(14,168,106,0.25);
                                                             color:var(--green);font-weight:600;">
                                    ✅ Đã đăng tin
                                </span>
                                @if (mmIdMap.ContainsKey(ds.Id))
                                {
                                    <form method="post" action="/Matchmaking/Dong"
                                          style="display:inline">
                                        <input type="hidden" name="id"
                                               value="@mmIdMap[ds.Id]" />
                                        <button type="submit"
                                                style="padding:7px 14px;font-size:14px;
                                                                           border-radius:999px;
                                                                           border:1px solid rgba(239,68,68,0.3);
                                                                           background:rgba(239,68,68,0.07);
                                                                           color:#EF4444;cursor:pointer;
                                                                           font-weight:600;"
                                                onclick="return confirm('Hủy tin tìm đội này?')">
                                            ✕ Hủy tin
                                        </button>
                                    </form>
                                }
                            }
                            else
                            {
                                <a href="/Matchmaking/Create?datSanId=@ds.Id"
                                   class="btn-outline-green"
                                   style="padding:7px 14px;font-size:14px;
                                                          @(dangKyTim ? "background:var(--green);color:#fff;border-color:var(--green);" : "")">
                                    🔍 Tìm đối thủ
                                </a>
                            }
                        }
                        @if (ds.TrangThai == "ChoDuyet")
                        {
                            <form method="post" action="/Booking/Huy" style="display:inline">
                                <input type="hidden" name="id" value="@ds.Id" />
                                <button type="submit" class="btn-danger"
                                        style="padding:7px 14px;font-size:14px"
                                        onclick="return confirm('Bạn chắc chắn muốn hủy?')">
                                    Hủy đặt
                                </button>
                            </form>
                        }
                    </div>
                </div>
            </div>
        }
    }
</div>

@section Scripts {
    <script>
        (function(){
          var BOOKINGS = JSON.parse(document.getElementById('bookings-data').textContent);
          var MONTHS_VI = ['T1','T2','T3','T4','T5','T6','T7','T8','T9','T10','T11','T12'];
          var today    = new Date();
          var curYear  = today.getFullYear();
          var curMonth = today.getMonth() + 1;
          var popYear  = curYear;
          var popOpen  = false;

          function getBookingsForYear(year){
            var xn={}, cho={};
            BOOKINGS.forEach(function(b){
              if(b.year !== year) return;
              if(b.status==='DaXacNhan') xn[b.month]=true;
              if(b.status==='ChoDuyet')  cho[b.month]=true;
            });
            return {xn:xn,cho:cho};
          }

          function renderPopup(year){
            document.getElementById('popYearLabel').textContent = year;
            var data = getBookingsForYear(year);
            var grid = document.getElementById('mpGrid');
            grid.innerHTML = '';
            for(var m=1;m<=12;m++){
              (function(m){
                var btn = document.createElement('div');
                var cls = 'mp-m';
                if(m===curMonth && year===curYear) cls+=' active';
                if(data.xn[m])       cls+=' has-xn';
                else if(data.cho[m]) cls+=' has-cho';
                btn.className   = cls;
                btn.textContent = MONTHS_VI[m-1];
                btn.addEventListener('click',function(){
                  curYear=year; curMonth=m; renderCal(); closePopup();
                });
                grid.appendChild(btn);
              })(m);
            }
          }

          function renderCal(){
            document.getElementById('calLabelText').textContent =
              'THÁNG '+curMonth+' · '+curYear;

            var firstDay    = new Date(curYear,curMonth-1,1).getDay();
            var offset      = firstDay===0 ? 6 : firstDay-1;
            var daysInMonth = new Date(curYear,curMonth,0).getDate();
            var xnDays={}, choDays={};
            BOOKINGS.forEach(function(b){
              if(b.year!==curYear||b.month!==curMonth) return;
              if(b.status==='DaXacNhan') xnDays[b.day]=true;
              if(b.status==='ChoDuyet')  choDays[b.day]=true;
            });

            var grid=document.getElementById('calDayGrid');
            grid.innerHTML='';

            for(var i=0;i<offset;i++){
              var el=document.createElement('div');
              el.className='cal-day empty';
              grid.appendChild(el);
            }

            for(var d=1;d<=daysInMonth;d++){
              (function(d){
                var el  = document.createElement('div');
                var col = (offset+d-1)%7;
                var isTd= (d===today.getDate()&&curMonth===today.getMonth()+1&&curYear===today.getFullYear());
                var cls = 'cal-day';
                if(xnDays[d])       cls+=' xn';
                else if(choDays[d]) cls+=' cho';
                else if(col>=5)     cls+=' wknd';
                if(isTd&&!xnDays[d]&&!choDays[d]) cls+=' today-mark';
                el.className   = cls;
                el.textContent = d;
                if(xnDays[d]||choDays[d]){
                  el.title='Xem lịch ngày '+d;
                  el.addEventListener('click',function(){
                    var dd=String(d).padStart(2,'0');
                    var mm=String(curMonth).padStart(2,'0');
                    var dateStr=dd+'/'+mm+'/'+curYear;
                    var target=null;
                    document.querySelectorAll('.booking-card').forEach(function(c){
                      if(c.textContent.indexOf(dateStr)>-1) target=c;
                    });
                    if(target){
                      target.scrollIntoView({behavior:'smooth',block:'center'});
                      target.style.outline='2.5px solid #0EA86A';
                      target.style.outlineOffset='3px';
                      setTimeout(function(){target.style.outline='';target.style.outlineOffset='';},2000);
                    }
                  });
                }
                grid.appendChild(el);
              })(d);
            }
          }

          function openPopup(){
            popYear=curYear; renderPopup(popYear);
            var popup = document.getElementById('monthPopup');
            var btn   = document.getElementById('calLabelBtn');
            var rect  = btn.getBoundingClientRect();
            popup.style.display  = 'block';
            popup.style.top      = (rect.bottom + 8) + 'px';
            popup.style.left     = (rect.left + rect.width/2 - 140) + 'px';
            popup.classList.add('open');
            document.getElementById('calLabelBtn').classList.add('open');
            popOpen=true;
          }
          function closePopup(){
            var popup = document.getElementById('monthPopup');
            popup.classList.remove('open');
            popup.style.display='none';
            document.getElementById('calLabelBtn').classList.remove('open');
            popOpen=false;
          }

          document.getElementById('calLabelBtn').addEventListener('click',function(e){
            e.stopPropagation(); popOpen?closePopup():openPopup();
          });
          document.getElementById('popPrevYear').addEventListener('click',function(e){
            e.stopPropagation(); popYear--; renderPopup(popYear);
          });
          document.getElementById('popNextYear').addEventListener('click',function(e){
            e.stopPropagation(); popYear++; renderPopup(popYear);
          });
          document.addEventListener('click',function(){ if(popOpen) closePopup(); });
          document.getElementById('monthPopup').addEventListener('click',function(e){ e.stopPropagation(); });
          document.getElementById('prevMonth').addEventListener('click',function(){
            curMonth--; if(curMonth<1){curMonth=12;curYear--;} renderCal();
          });
          document.getElementById('nextMonth').addEventListener('click',function(){
            curMonth++; if(curMonth>12){curMonth=1;curYear++;} renderCal();
          });

          renderCal();
        })();
    </script>
}
