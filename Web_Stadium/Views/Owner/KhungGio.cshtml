@* ============================================================
   Views/Owner/KhungGio.cshtml
   ============================================================ *@
@model List<Web_Stadium.EFCore.KhungGio>
@{
    ViewData["Title"] = "Khung giờ & Bảng giá";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var san = ViewBag.San as Web_Stadium.EFCore.SanBong;
}
<div style="background:var(--bg2);padding:100px 0 36px;border-bottom:1px solid var(--border)">
    <div class="container">
        <div class="section-label">@san?.TenSan</div>
        <h1 style="font-style:italic;line-height:0.9">KHUNG GIỜ<br><span class="text-green">& BẢNG GIÁ</span></h1>
    </div>
</div>
<div style="background:var(--bg3);border-bottom:1px solid var(--border);padding:10px 0;position:sticky;top:0;z-index:100">
    <div class="container d-flex justify-content-between align-items-center flex-wrap gap-2">
        <a href="/Owner/DanhSachSan" class="btn btn-outline-success rounded-pill">← Danh sách sân</a>
        <div class="d-flex gap-2 flex-wrap">
            <button class="btn btn-success rounded-pill" data-bs-toggle="modal" data-bs-target="#modalThemKG">+ Thêm khung giờ</button>
        </div>
    </div>
</div>
<div class="container py-5">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">✅ @TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">❌ @TempData["Error"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    }

    <div class="section-card p-0 overflow-hidden">
        <table class="table table-hover mb-0">
            <thead style="background:var(--bg3)">
                <tr>
                    <th style="color:var(--muted);font-size:11px;padding:12px 16px">Giờ</th>
                    <th style="color:var(--muted);font-size:11px">Loại ngày</th>
                    <th style="color:var(--muted);font-size:11px">Giá thường</th>
                    <th style="color:var(--muted);font-size:11px">Giờ vàng</th>
                    <th style="color:var(--muted);font-size:11px">Cuối tuần</th>
                    <th style="color:var(--muted);font-size:11px">Trạng thái</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var kg in Model)
                {
                    <tr>
                        <td style="padding:12px 16px;font-weight:600">@kg.GioBatDau.ToString(@"hh\:mm") – @kg.GioKetThuc.ToString(@"hh\:mm")</td>
                        <td style="font-size:12px;color:var(--muted2)">@kg.LoaiNgay</td>
                        <td>@kg.Gia.ToString("N0")đ</td>
                        <td style="color:#f39c12">@kg.GiaGioVang.ToString("N0")đ</td>
                        <td style="color:#6caee0">@kg.GiaCuoiTuan.ToString("N0")đ</td>
                        <td>
                            <span class="badge @(kg.TrangThai == "Trong" ? "bg-success" : kg.TrangThai == "DaDat" ? "bg-primary" : "bg-warning text-dark")">
                                @kg.TrangThai
                            </span>
                        </td>
                        <td>
                            <button class="btn btn-sm btn-outline-secondary rounded-pill"
                                    onclick="moSuaKG(@kg.Id,@kg.Gia,@kg.GiaGioVang,@kg.GiaCuoiTuan)">
                                Sửa giá
                            </button>
                            @if (kg.TrangThai == "Trong")
                            {
                                <form method="post" action="/Owner/XoaKhungGio" style="display:inline">
                                    <input type="hidden" name="id" value="@kg.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill"
                                            onclick="return confirm('Xoá khung giờ này?')">
                                        Xoá
                                    </button>
                                </form>
                            }
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="7" style="text-align:center;padding:40px;color:var(--muted)">Chưa có khung giờ nào</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Modal Thêm -->
<div class="modal fade" id="modalThemKG" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content" style="background:var(--bg2);border:1px solid var(--border)">
            <div class="modal-header" style="border-color:var(--border)"><h5 class="modal-title">Thêm Khung Giờ</h5><button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button></div>
            <form method="post" action="/Owner/ThemKhungGio">
                <input type="hidden" name="sanId" value="@san?.Id" />
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-6"><label style="color:var(--muted);font-size:12px">GIỜ BẮT ĐẦU</label><input type="time" name="gioBatDau" class="form-control" required style="background:var(--bg3);border-color:var(--border);color:white" /></div>
                        <div class="col-6"><label style="color:var(--muted);font-size:12px">GIỜ KẾT THÚC</label><input type="time" name="gioKetThuc" class="form-control" required style="background:var(--bg3);border-color:var(--border);color:white" /></div>
                        <div class="col-12">
                            <label style="color:var(--muted);font-size:12px">LOẠI NGÀY</label>
                            <select name="loaiNgay" class="form-select" style="background:var(--bg3);border-color:var(--border);color:white">
                                <option value="TatCa">Tất cả các ngày</option>
                                <option value="ThuThuong">Thứ 2 – Thứ 6</option>
                                <option value="CuoiTuan">Thứ 7 – Chủ nhật</option>
                            </select>
                        </div>
                        <div class="col-4"><label style="color:var(--muted);font-size:12px">GIÁ THƯỜNG (đ)</label><input type="number" name="gia" class="form-control" required min="0" style="background:var(--bg3);border-color:var(--border);color:white" /></div>
                        <div class="col-4"><label style="color:var(--muted);font-size:12px">GIỜ VÀNG (đ)</label><input type="number" name="giaGioVang" class="form-control" min="0" value="0" style="background:var(--bg3);border-color:var(--border);color:white" /></div>
                        <div class="col-4"><label style="color:var(--muted);font-size:12px">CUỐI TUẦN (đ)</label><input type="number" name="giaCuoiTuan" class="form-control" min="0" value="0" style="background:var(--bg3);border-color:var(--border);color:white" /></div>
                    </div>
                </div>
                <div class="modal-footer" style="border-color:var(--border)"><button type="button" class="btn btn-outline-secondary rounded-pill" data-bs-dismiss="modal">Huỷ</button><button type="submit" class="btn btn-success rounded-pill">Thêm</button></div>
            </form>
        </div>
    </div>
</div>
<!-- Modal Sửa giá -->
<div class="modal fade" id="modalSuaKG" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content" style="background:var(--bg2);border:1px solid var(--border)">
            <div class="modal-header" style="border-color:var(--border)"><h5 class="modal-title">Sửa bảng giá</h5><button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button></div>
            <form method="post" action="/Owner/SuaKhungGio">
                <input type="hidden" name="id" id="suaKgId" />
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-4"><label style="color:var(--muted);font-size:12px">GIÁ THƯỜNG</label><input type="number" name="gia" id="suaKgGia" class="form-control" style="background:var(--bg3);border-color:var(--border);color:white" /></div>
                        <div class="col-4"><label style="color:var(--muted);font-size:12px">GIỜ VÀNG</label><input type="number" name="giaGioVang" id="suaKgVang" class="form-control" style="background:var(--bg3);border-color:var(--border);color:white" /></div>
                        <div class="col-4"><label style="color:var(--muted);font-size:12px">CUỐI TUẦN</label><input type="number" name="giaCuoiTuan" id="suaKgCT" class="form-control" style="background:var(--bg3);border-color:var(--border);color:white" /></div>
                    </div>
                </div>
                <div class="modal-footer" style="border-color:var(--border)"><button type="button" class="btn btn-outline-secondary rounded-pill" data-bs-dismiss="modal">Huỷ</button><button type="submit" class="btn btn-warning rounded-pill">Cập nhật</button></div>
            </form>
        </div>
    </div>
</div>
@section Scripts {
    <script>
        function moSuaKG(id,gia,vang,ct){
            document.getElementById('suaKgId').value=id;
            document.getElementById('suaKgGia').value=gia;
            document.getElementById('suaKgVang').value=vang;
            document.getElementById('suaKgCT').value=ct;
            new bootstrap.Modal(document.getElementById('modalSuaKG')).show();
        }
    </script>
}