@* Views/Owner/KhungGio.cshtml *@
@model List<Web_Stadium.EFCore.KhungGio>
@{
    ViewData["Title"] = "Khung giờ & Bảng giá";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var san = ViewBag.San as Web_Stadium.EFCore.SanBong;
}

<style>
    :root {
        --db-bg: #f8fafc;
        --db-surface: #ffffff;
        --db-card: #ffffff;
        --db-border: #e2e8f0;
        --db-muted: #475569;
        --db-text: #0f172a;
        --db-green: #0f6e4a;
        --db-green-bg: rgba(15,110,74,0.08);
        --db-green-border: rgba(15,110,74,0.2);
    }

    body {
        background: var(--db-bg);
        color: var(--db-text);
        font-family: 'Inter', system-ui, sans-serif;
    }

    .page-header {
        background: var(--db-surface);
        border-bottom: 1px solid var(--db-border);
        padding: 24px 0 20px;
    }

    .sticky-nav {
        background: var(--db-surface);
        border-bottom: 1px solid var(--db-border);
        padding: 12px 0;
        position: sticky;
        top: 0;
        z-index: 100;
    }

    .nav-btn {
        font-size: 12px;
        padding: 5px 14px;
        border-radius: 30px;
        border: 1px solid var(--db-border);
        background: transparent;
        color: var(--db-muted);
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 5px;
    }

        .nav-btn:hover {
            background: var(--db-bg);
            color: var(--db-text);
            border-color: #cbd5e1;
        }

    .btn-green {
        background: var(--db-green);
        border: none;
        border-radius: 40px;
        padding: 6px 20px;
        font-weight: 500;
        color: white;
        transition: 0.2s;
    }

        .btn-green:hover {
            background: #0a5338;
            transform: translateY(-1px);
        }

    .btn-outline-sm {
        background: transparent;
        border: 1px solid var(--db-border);
        border-radius: 30px;
        padding: 4px 12px;
        font-size: 11px;
        font-weight: 500;
        transition: 0.15s;
        cursor: pointer;
    }

        .btn-outline-sm:hover {
            background: var(--db-green-bg);
            border-color: var(--db-green-border);
            color: var(--db-green);
        }

    .table-wrapper {
        background: var(--db-card);
        border: 1px solid var(--db-border);
        border-radius: 20px;
        overflow-x: auto;
        margin-top: 16px;
    }

    .time-table {
        width: 100%;
        border-collapse: collapse;
        min-width: 700px;
    }

        .time-table th {
            background: var(--db-surface);
            font-size: 11px;
            font-weight: 600;
            text-transform: uppercase;
            color: var(--db-muted);
            padding: 12px 16px;
            border-bottom: 1px solid var(--db-border);
            text-align: left;
        }

        .time-table td {
            padding: 12px 16px;
            border-bottom: 1px solid var(--db-border);
            font-size: 13px;
            vertical-align: middle;
        }

        .time-table tr:last-child td {
            border-bottom: none;
        }

    .badge-status {
        background: var(--db-green-bg);
        color: var(--db-green);
        border-radius: 30px;
        padding: 3px 10px;
        font-size: 11px;
        display: inline-block;
    }

    .badge-booked {
        background: #e0f2fe;
        color: #0369a1;
    }

    .badge-hold {
        background: #fef3c7;
        color: #b45309;
    }

    .modal-content-custom {
        background: var(--db-surface);
        border: 1px solid var(--db-border);
        border-radius: 24px;
    }

    .modal-header, .modal-footer {
        border-color: var(--db-border);
    }

    .form-control-custom, .form-select-custom {
        background: var(--db-surface);
        border: 1px solid var(--db-border);
        border-radius: 12px;
        padding: 8px 12px;
        font-size: 14px;
        width: 100%;
    }

        .form-control-custom:focus, .form-select-custom:focus {
            border-color: var(--db-green);
            outline: none;
            box-shadow: 0 0 0 3px rgba(15,110,74,0.1);
        }

    .empty-state {
        text-align: center;
        padding: 60px 0;
        color: var(--db-muted);
    }
</style>

<div class="page-header">
    <div class="container">
        <div class="d-flex justify-content-between align-items-end flex-wrap gap-3">
            <div>
                <div class="text-muted mb-1" style="font-size: 11px; letter-spacing: 1px;">OWNER / BẢNG GIÁ</div>
                <h1 style="font-size: 2rem; font-weight: 700; margin: 0;">Khung giờ <span style="color: var(--db-green);">@san?.TenSan</span></h1>
                <p class="text-muted mt-2 mb-0">Quản lý khung giờ, giá theo loại ngày và trạng thái đặt sân</p>
            </div>
        </div>
    </div>
</div>

<div class="sticky-nav">
    <div class="container">
        <div class="d-flex gap-2 flex-wrap">
            <a href="/Owner/DanhSachSan" class="nav-btn">
                <i class="fas fa-arrow-left me-1"></i> Danh sách sân
            </a>
            <button class="btn-green" data-bs-toggle="modal" data-bs-target="#modalThemKG">
                <i class="fas fa-plus-circle me-2"></i>Thêm khung giờ
            </button>
        </div>
    </div>
</div>

<div class="container py-5">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm rounded-3">
            <i class="fas fa-check-circle me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm rounded-3">
            <i class="fas fa-exclamation-triangle me-2"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="empty-state">
            <div class="empty-icon" style="font-size: 4rem; opacity: 0.4;">⏰</div>
            <h4 class="fw-semibold">Chưa có khung giờ nào</h4>
            <p class="text-muted">Thêm khung giờ để người dùng có thể đặt sân trực tuyến</p>
            <button class="btn-green mt-2" data-bs-toggle="modal" data-bs-target="#modalThemKG">
                <i class="fas fa-plus-circle me-2"></i>Thêm khung giờ
            </button>
        </div>
    }
    else
    {
        <div class="table-wrapper">
            <table class="time-table">
                <thead>
                    <tr>
                        <th>Giờ</th>
                        <th>Loại ngày</th>
                        <th>Giá thường</th>
                        <th>Giờ vàng</th>
                        <th>Cuối tuần</th>
                        <th>Trạng thái</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var kg in Model)
                    {
                        // SỬA LỖI HIỂN THỊ: dùng HH (24h) thay vì hh (12h)
                        var gioHienThi = kg.GioBatDau.ToString(@"HH\:mm") + " – " + kg.GioKetThuc.ToString(@"HH\:mm");
                        var statusClass = kg.TrangThai == "Trong" ? "badge-status" : (kg.TrangThai == "DaDat" ? "badge-booked" : "badge-hold");
                        var statusText = kg.TrangThai == "Trong" ? "Còn trống" : (kg.TrangThai == "DaDat" ? "Đã đặt" : "Đang giữ");
                        <tr>
                            <td><span class="fw-semibold">@gioHienThi</span></td>
                            <td>@kg.LoaiNgay</td>
                            <td>@kg.Gia.ToString("N0")đ</td>
                            <td style="color: #f59e0b;">@kg.GiaGioVang.ToString("N0")đ</td>
                            <td style="color: #3b82f6;">@kg.GiaCuoiTuan.ToString("N0")đ</td>
                            <td><span class="@statusClass">@statusText</span></td>
                            <td>
                                <div class="d-flex gap-2">
                                    <button class="btn-outline-sm" onclick="moSuaKG(@kg.Id, @kg.Gia, @kg.GiaGioVang, @kg.GiaCuoiTuan)">
                                        <i class="fas fa-edit"></i> Sửa giá
                                    </button>
                                    @if (kg.TrangThai == "Trong")
                                    {
                                        <form method="post" action="/Owner/XoaKhungGio" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@kg.Id" />
                                            <button type="submit" class="btn-outline-sm" style="border-color: #fecaca; color: #dc2626;" onclick="return confirm('Xoá khung giờ này?')">
                                                <i class="fas fa-trash-alt"></i> Xoá
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<!-- Modal Thêm khung giờ (đã sửa lỗi time) -->
<div class="modal fade" id="modalThemKG" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content modal-content-custom">
            <div class="modal-header">
                <h5 class="modal-title fw-semibold">Thêm khung giờ mới</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" action="/Owner/ThemKhungGio" id="formThemKG">
                @Html.AntiForgeryToken()
                <input type="hidden" name="sanId" value="@san?.Id" />
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-6">
                            <label class="form-label">GIỜ BẮT ĐẦU</label>
                            <input type="time" name="gioBatDau" class="form-control-custom" required step="60" />
                        </div>
                        <div class="col-6">
                            <label class="form-label">GIỜ KẾT THÚC</label>
                            <input type="time" name="gioKetThuc" class="form-control-custom" required step="60" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">LOẠI NGÀY</label>
                            <select name="loaiNgay" class="form-select-custom">
                                <option value="TatCa">Tất cả các ngày</option>
                                <option value="ThuThuong">Thứ 2 – Thứ 6</option>
                                <option value="CuoiTuan">Thứ 7 – Chủ nhật</option>
                            </select>
                        </div>
                        <div class="col-4">
                            <label class="form-label">GIÁ THƯỜNG (đ)</label>
                            <input type="number" name="gia" class="form-control-custom" required min="0" step="1000" />
                        </div>
                        <div class="col-4">
                            <label class="form-label">GIỜ VÀNG (đ)</label>
                            <input type="number" name="giaGioVang" class="form-control-custom" min="0" step="1000" value="0" />
                        </div>
                        <div class="col-4">
                            <label class="form-label">CUỐI TUẦN (đ)</label>
                            <input type="number" name="giaCuoiTuan" class="form-control-custom" min="0" step="1000" value="0" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn-outline-sm" data-bs-dismiss="modal">Huỷ</button>
                    <button type="submit" class="btn-green">Thêm khung giờ</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal Sửa giá -->
<div class="modal fade" id="modalSuaKG" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content modal-content-custom">
            <div class="modal-header">
                <h5 class="modal-title fw-semibold">Sửa giá khung giờ</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" action="/Owner/SuaKhungGio">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" id="suaKgId" />
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-4">
                            <label class="form-label">GIÁ THƯỜNG (đ)</label>
                            <input type="number" name="gia" id="suaKgGia" class="form-control-custom" step="1000" />
                        </div>
                        <div class="col-4">
                            <label class="form-label">GIỜ VÀNG (đ)</label>
                            <input type="number" name="giaGioVang" id="suaKgVang" class="form-control-custom" step="1000" />
                        </div>
                        <div class="col-4">
                            <label class="form-label">CUỐI TUẦN (đ)</label>
                            <input type="number" name="giaCuoiTuan" id="suaKgCT" class="form-control-custom" step="1000" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn-outline-sm" data-bs-dismiss="modal">Huỷ</button>
                    <button type="submit" class="btn-green">Cập nhật</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function moSuaKG(id, gia, vang, ct) {
            document.getElementById('suaKgId').value = id;
            document.getElementById('suaKgGia').value = gia;
            document.getElementById('suaKgVang').value = vang;
            document.getElementById('suaKgCT').value = ct;
            new bootstrap.Modal(document.getElementById('modalSuaKG')).show();
        }

        // Kiểm tra nếu thời gian vẫn lệch, có thể do controller parse TimeSpan sai
        // Hãy sửa action ThemKhungGio trong OwnerController như sau:
        /*
        [HttpPost]
        public async Task<IActionResult> ThemKhungGio(int sanId, string gioBatDau, string gioKetThuc, ...)
        {
            var gioBD = TimeSpan.Parse(gioBatDau);
            var gioKT = TimeSpan.Parse(gioKetThuc);
            // hoặc dùng TimeOnly.Parse(gioBatDau)
        }
        */
    </script>
}