@{
    ViewData["Title"] = "Xem hợp đồng";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var hopDong = TempData["HopDong"]?.ToString() ?? "";
    var tenVung = TempData["San_TenVung"]?.ToString();
    var tyLeHH = TempData["San_TyLeHH"]?.ToString();
    var tenSan = TempData["San_TenSan"]?.ToString();
    // Giữ TempData cho action XacNhanDangKy
    TempData.Keep();
}

<div style="background:var(--bg2);padding:100px 0 40px;border-bottom:1px solid var(--border)">
    <div class="container">
        <div class="section-label">Owner — Bước 2/2</div>
        <h1 style="font-style:italic;line-height:0.9">HỢP ĐỒNG<br><span class="text-green">ĐIỆN TỬ</span></h1>
        <p style="color:var(--muted)">Vui lòng đọc kỹ trước khi xác nhận đăng ký</p>
    </div>
</div>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">

            <!-- Thông tin vùng -->
            <div style="display:flex;align-items:center;gap:12px;padding:14px 20px;border-radius:8px;background:rgba(22,196,127,0.06);border:1px solid rgba(22,196,127,0.3);margin-bottom:24px">
                <div>
                    <div style="font-size:11px;color:var(--muted)">KHU VỰC ÁP DỤNG</div>
                    <div style="font-weight:600;color:var(--green)">@tenVung</div>
                </div>
                <div style="margin-left:auto;text-align:right">
                    <div style="font-size:11px;color:var(--muted)">TỶ LỆ HOA HỒNG</div>
                    <div style="font-family:var(--ff-h);font-size:1.8rem;color:var(--green)">
                        @((decimal.Parse(tyLeHH ?? "0.10") * 100).ToString("F0"))%
                    </div>
                </div>
            </div>

            <!-- Nội dung hợp đồng -->
            <div class="section-card p-0 overflow-hidden mb-4">
                <div style="background:var(--bg2);padding:14px 20px;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid var(--border)">
                    <span style="font-family:var(--ff-h);font-size:14px;color:var(--text)">📄 NỘI DUNG HỢP ĐỒNG</span>
                    <span style="font-size:12px;color:var(--muted)">Sân: @tenSan</span>
                </div>
                <div style="padding:28px;max-height:500px;overflow-y:auto;font-family:'Courier New',monospace;font-size:13px;line-height:1.9;color:var(--text2);white-space:pre-wrap;background:var(--bg3)">@hopDong</div>
            </div>

            <!-- Form xác nhận -->
            <form method="post" action="/Owner/XacNhanDangKy">
                <div style="padding:20px;border:1px solid var(--border);border-radius:8px;margin-bottom:20px">
                    <label style="display:flex;align-items:flex-start;gap:12px;cursor:pointer">
                        <input type="checkbox" name="daDocVaDongY" value="true" id="checkDongY"
                               style="width:18px;height:18px;margin-top:2px;accent-color:var(--green)" required />
                        <div>
                            <div style="font-weight:600;margin-bottom:4px">Tôi đã đọc và đồng ý toàn bộ điều khoản hợp đồng</div>
                            <div style="font-size:12px;color:var(--muted)">
                                Bằng cách tick vào ô này, tôi xác nhận hợp đồng có hiệu lực pháp lý
                                tương đương hợp đồng giấy ký tay. Tỷ lệ hoa hồng
                                <strong style="color:var(--green)">@((decimal.Parse(tyLeHH ?? "0.10") * 100).ToString("F0"))%</strong>
                                sẽ được áp dụng ngay khi Admin phê duyệt.
                            </div>
                        </div>
                    </label>
                </div>

                <div style="display:flex;justify-content:space-between;align-items:center">
                    <a href="/Owner/DangKySan" class="btn btn-outline-secondary rounded-pill">
                        ← Quay lại sửa thông tin
                    </a>
                    <button type="submit" id="btnXacNhan" class="btn btn-success rounded-pill px-5"
                            style="opacity:0.5;pointer-events:none">
                        ✅ Xác nhận & Gửi đăng ký
                    </button>
                </div>
            </form>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('checkDongY').addEventListener('change', function() {
            var btn = document.getElementById('btnXacNhan');
            btn.style.opacity = this.checked ? '1' : '0.5';
            btn.style.pointerEvents = this.checked ? 'auto' : 'none';
        });
    </script>
}
