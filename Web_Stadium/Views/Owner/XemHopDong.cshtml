@model Web_Stadium.EFCore.SanBong?
@{
    ViewData["Title"] = "Xem hợp đồng";
    Layout = "~/Views/Shared/_Layout.cshtml";

    // GET flow: doc tu Model (hop dong da ky)
    // POST flow: doc tu TempData (dang ky moi)
    var laDaKy = Model != null && Model.DaKyHopDong;
    var hopDong = laDaKy ? Model!.NoiDungHopDong : TempData["HopDong"]?.ToString() ?? "";
    var tenSan = laDaKy ? Model!.TenSan : TempData["San_TenSan"]?.ToString() ?? "";
    var tenVung = laDaKy ? "" : TempData["San_TenVung"]?.ToString() ?? "";
    var tyLeHH = laDaKy ? "" : TempData["San_TyLeHH"]?.ToString() ?? "0.10";
    var tyLePct = laDaKy ? 0 : (int)(decimal.Parse(tyLeHH) * 100);
    if (!laDaKy) TempData.Keep();
}

<div style="background:var(--bg2);padding:100px 0 36px;border-bottom:1px solid var(--border)">
    <div class="container">
        <div class="section-label">Owner — @(laDaKy ? "Hợp đồng đã ký" : "Bước 2/2")</div>
        <h1 style="font-style:italic;line-height:0.9">
            HỢP ĐỒNG<br>
            <span class="text-green">@(laDaKy ? "ĐÃ KÝ" : "ĐIỆN TỬ")</span>
        </h1>
        <p style="color:var(--muted)">
            @(laDaKy ? "Hợp đồng đã có hiệu lực pháp lý" : "Đọc kỹ toàn bộ điều khoản trước khi xác nhận")
        </p>
    </div>
</div>

@if (laDaKy)
{
    <!-- Nav cho trang xem hợp đồng đã ký -->
    <div style="background:var(--bg3);border-bottom:1px solid var(--border);padding:10px 0;position:sticky;top:0;z-index:100">
        <div class="container d-flex justify-content-between align-items-center gap-2">
            <a href="/Owner/DanhSachSan" class="btn btn-outline-success rounded-pill">← Danh sách sân</a>
            <div class="d-flex gap-2">
                <a href="/Owner/SuaSan?sanId=@Model!.Id" class="btn btn-outline-secondary rounded-pill">✏️ Sửa sân</a>
                <a href="/Owner/QuanLyAnh?sanId=@Model!.Id" class="btn btn-outline-info rounded-pill">📷 Quản lý ảnh</a>
                <button onclick="window.print()" class="btn btn-outline-success rounded-pill">🖨 In hợp đồng</button>
            </div>
        </div>
    </div>
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-9">

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show">
                    ❌ @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @if (laDaKy)
            {
                <!-- Thông tin hợp đồng đã ký -->
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:24px;">
                    <div style="padding:16px 20px;border-radius:12px;background:rgba(14,168,106,0.06);border:1px solid rgba(14,168,106,0.25);">
                        <div style="font-size:11px;color:var(--muted);letter-spacing:1.5px;text-transform:uppercase;margin-bottom:6px;">Sân bóng</div>
                        <div style="font-weight:700;font-size:16px;">@Model!.TenSan</div>
                        <div style="font-size:13px;color:var(--muted);margin-top:3px;">@Model.DiaChi — @Model.Quan</div>
                    </div>
                    <div style="padding:16px 20px;border-radius:12px;background:rgba(14,168,106,0.06);border:1px solid rgba(14,168,106,0.25);">
                        <div style="font-size:11px;color:var(--muted);letter-spacing:1.5px;text-transform:uppercase;margin-bottom:6px;">Ngày ký</div>
                        <div style="font-weight:700;font-size:16px;color:var(--green);">@(Model.NgayKyHopDong?.ToString("dd/MM/yyyy") ?? "—")</div>
                        <div style="font-size:13px;color:var(--muted);margin-top:3px;">✅ Đã xác nhận và có hiệu lực</div>
                    </div>
                </div>
            }
            else
            {
                <!-- Tóm tắt khi đăng ký mới -->
                <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;margin-bottom:24px;">
                    <div style="padding:16px 18px;border-radius:12px;background:rgba(14,168,106,0.06);border:1px solid rgba(14,168,106,0.25);text-align:center;">
                        <div style="font-size:11px;color:var(--muted);letter-spacing:1.5px;text-transform:uppercase;margin-bottom:6px;">Khu vực</div>
                        <div style="font-weight:700;color:var(--green);font-size:15px;">@tenVung</div>
                    </div>
                    <div style="padding:16px 18px;border-radius:12px;background:rgba(14,168,106,0.06);border:1px solid rgba(14,168,106,0.25);text-align:center;">
                        <div style="font-size:11px;color:var(--muted);letter-spacing:1.5px;text-transform:uppercase;margin-bottom:6px;">Hoa hồng PitchHub</div>
                        <div style="font-family:var(--ff-h);font-size:2rem;color:var(--green);line-height:1;">@tyLePct%</div>
                    </div>
                    <div style="padding:16px 18px;border-radius:12px;background:rgba(14,168,106,0.06);border:1px solid rgba(14,168,106,0.25);text-align:center;">
                        <div style="font-size:11px;color:var(--muted);letter-spacing:1.5px;text-transform:uppercase;margin-bottom:6px;">Bạn nhận</div>
                        <div style="font-family:var(--ff-h);font-size:2rem;color:var(--green);line-height:1;">@(100 - tyLePct)%</div>
                    </div>
                </div>
            }

            <!-- Nội dung hợp đồng -->
            <div class="section-card p-0 overflow-hidden mb-4">
                <div style="background:#1a1a2e;padding:14px 22px;display:flex;align-items:center;justify-content:space-between;">
                    <span style="font-family:var(--ff-h);font-size:13px;letter-spacing:1px;">📄 NỘI DUNG HỢP ĐỒNG — @tenSan</span>
                    <button onclick="window.print()" style="font-size:12px;color:var(--muted);background:none;border:1px solid var(--border);border-radius:6px;padding:4px 12px;cursor:pointer;">🖨 In</button>
                </div>
                <div style="padding:32px;max-height:560px;overflow-y:auto;
                            font-family:'Courier New',monospace;font-size:13px;
                            line-height:2.0;color:var(--muted2);
                            white-space:pre-wrap;background:rgba(0,0,0,0.25);">
                    @hopDong
                </div>
            </div>

            @if (laDaKy)
            {
                <!-- Trạng thái đã ký -->
                <div style="text-align:center;padding:20px;border:1px solid rgba(14,168,106,.3);border-radius:12px;background:rgba(14,168,106,.05);">
                    <div style="font-size:22px;margin-bottom:8px;">✅</div>
                    <div style="font-weight:700;font-size:15px;color:var(--green);margin-bottom:4px;">Hợp đồng đã ký kết và có hiệu lực</div>
                    <div style="font-size:13px;color:var(--muted);">Ký lúc @(Model!.NgayKyHopDong?.ToString("HH:mm — dd/MM/yyyy") ?? "—")</div>
                </div>
            }
            else
            {
                <!-- Form xác nhận ký -->
                <form method="post" action="/Owner/XacNhanDangKy">
                    <div style="padding:20px 22px;border:1px solid var(--border);border-radius:12px;margin-bottom:20px;background:var(--card);">
                        <label style="display:flex;align-items:flex-start;gap:12px;cursor:pointer;">
                            <input type="checkbox" name="daDocVaDongY" value="true" required
                                   style="width:18px;height:18px;margin-top:2px;accent-color:var(--green);flex-shrink:0;" />
                            <span style="font-size:14px;line-height:1.6;color:var(--text);">
                                Tôi <strong>@tenSan</strong> đã đọc kỹ, hiểu rõ và
                                <strong>đồng ý toàn bộ</strong> các điều khoản trong Hợp đồng hợp tác kinh doanh.
                                Hợp đồng điện tử này có giá trị pháp lý tương đương hợp đồng giấy có chữ ký.
                            </span>
                        </label>
                    </div>
                    <div style="display:flex;gap:12px;justify-content:space-between;align-items:center;">
                        <a href="javascript:history.back()" class="btn btn-outline-secondary rounded-pill" style="padding:10px 24px;">← Quay lại chỉnh sửa</a>
                        <button type="submit" class="btn-primary-glow" style="padding:13px 36px;font-size:15px;font-weight:700;">✅ Xác nhận ký hợp đồng & Đăng ký sân</button>
                    </div>
                </form>
            }

        </div>
    </div>
</div>
