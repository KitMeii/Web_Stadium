@model Web_Stadium.EFCore.SanBong
@{
    ViewData["Title"] = "Cấu hình sân";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var loaiSans = ViewBag.LoaiSans as List<Web_Stadium.EFCore.DanhMucLoaiSan> ?? new();
    var loaiCos = ViewBag.LoaiCos as List<Web_Stadium.EFCore.DanhMucLoaiCo> ?? new();
}

<style>
    :root {
        --db-bg: #f8fafc;
        --db-surface: #ffffff;
        --db-card: #ffffff;
        --db-border: #e2e8f0;
        --db-muted: #475569;
        --db-text: #0f172a;
        --db-green: #0f6e4a;
        --db-green-bg: rgba(15,110,74,0.08);
        --db-green-border: rgba(15,110,74,0.2);
    }
    body { background: var(--db-bg); color: var(--db-text); font-family: 'Inter', sans-serif; }
    .page-header { background: var(--db-surface); border-bottom: 1px solid var(--db-border); padding: 24px 0 20px; }
    .form-card { background: var(--db-card); border: 1px solid var(--db-border); border-radius: 20px; padding: 28px; max-width: 800px; margin: 0 auto; }
    .form-label { font-size: 13px; font-weight: 500; color: var(--db-muted); margin-bottom: 6px; }
    .form-control, .form-select {
        background: var(--db-surface); border: 1px solid var(--db-border); border-radius: 12px;
        padding: 8px 12px; font-size: 14px; color: var(--db-text);
    }
    .form-control:focus, .form-select:focus {
        border-color: var(--db-green); box-shadow: 0 0 0 3px rgba(15,110,74,0.1);
    }
        .sticky-nav {
        background: var(--db-surface);
        border-bottom: 1px solid var(--db-border);
        padding: 12px 0;
        position: sticky;
        top: 0;
        z-index: 100;
    }

    .btn-save { background: var(--db-green); border: none; border-radius: 40px; padding: 8px 28px; color: white; font-weight: 500; }
    .btn-save:hover { background: #0a5338; transform: translateY(-1px); }
    .info-note { background: #eff6ff; border-radius: 12px; padding: 12px 16px; font-size: 12px; color: #1e40af; margin-top: 20px; }
</style>

<div class="page-header">
    <div class="container">
        <div class="d-flex justify-content-between align-items-end flex-wrap gap-3">
            <div>
                <div class="text-muted mb-1" style="font-size: 11px; letter-spacing: 1px;">OWNER / CẤU HÌNH SÂN</div>
                <h1 style="font-size: 2rem; font-weight: 700; margin: 0;">Chỉnh sửa <span style="color: var(--db-green);">@Model.TenSan</span></h1>
                <p class="text-muted mt-2 mb-0">Điều chỉnh thông tin, chính sách hủy và thời gian giữ chỗ</p>
            </div>
        </div>
    </div>
</div>

<div class="sticky-nav">
    <div class="container">
        <a href="/Owner/DanhSachSan" class="nav-btn">
            <i class="fas fa-arrow-left me-1"></i> Danh sách sân
        </a>
    </div>
</div>

<div class="container py-5">
    <div class="form-card">
        <form method="post" action="/Owner/SuaSan/@Model.Id">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.Id" />

            <div class="row g-4">
                <!-- Thông tin cơ bản (chỉ hiển thị) -->
                <div class="col-12">
                    <h6 class="fw-semibold mb-3">Thông tin cơ bản</h6>
                </div>
                <div class="col-md-6">
                    <div class="form-label">Loại sân</div>
                    <select class="form-select" disabled>
                        @foreach (var ls in loaiSans)
                        {
                            <option value="@ls.MaLoai" selected="@(ls.MaLoai == Model.LoaiSan)">@ls.TenLoai</option>
                        }
                    </select>
                </div>
                <div class="col-md-6">
                    <div class="form-label">Loại cỏ</div>
                    <select class="form-select" disabled>
                        @foreach (var lc in loaiCos)
                        {
                            <option value="@lc.MaLoai" selected="@(lc.MaLoai == Model.LoaiCo)">@lc.TenLoai</option>
                        }
                    </select>
                </div>
                <div class="col-12">
                    <div class="form-label">Mô tả sân</div>
                    <textarea name="moTa" class="form-control" rows="2">@Model.MoTa</textarea>
                </div>
                <div class="col-md-6">
                    <div class="form-label">Tỷ lệ cọc (%)</div>
                    <select name="tyLeCoc" class="form-select">
                        <option value="0.30" selected="@(Model.TyLeCoc == 0.30m)">30%</option>
                        <option value="0.40" selected="@(Model.TyLeCoc == 0.40m)">40%</option>
                        <option value="0.50" selected="@(Model.TyLeCoc == 0.50m)">50%</option>
                    </select>
                </div>


                <!-- Cấu hình giữ chỗ & hủy -->
                <div class="col-12 mt-4">
                    <h6 class="fw-semibold mb-3">⏱️ Cấu hình giữ chỗ & chính sách hủy</h6>
                </div>
                <div class="col-md-6">
                    <div class="form-label">Thời gian giữ chỗ (phút)</div>
                    <input type="number" name="thoiGianGiuCho" class="form-control" value="@Model.ThoiGianGiuCho" min="0" step="5" required />
                    <div class="text-muted small mt-1">Số phút hệ thống giữ chỗ sau khi khách đặt (chưa cọc).</div>
                </div>
                <div class="col-md-6">
                    <div class="form-label">Thời gian hủy tối thiểu trước giờ đá (phút)</div>
                    <input type="number" name="thoiGianHuyTruocGioDa" class="form-control" value="@Model.ThoiGianHuyTruocGioDa" min="0" step="15" required />
                    <div class="text-muted small mt-1">Khách cần hủy trước thời gian này để được hoàn cọc theo tỷ lệ "đúng hạn".</div>
                </div>
                <div class="col-md-6">
                    <div class="form-label">Tỷ lệ hoàn cọc khi hủy đúng hạn (%)</div>
                    <input type="number" name="phanTramHoanCocDungHan" class="form-control" value="@(Model.PhanTramHoanCocDungHan * 100)" step="5" min="0" max="100" required />
                    <div class="text-muted small mt-1">Ví dụ: 100% hoàn toàn bộ cọc.</div>
                </div>
                <div class="col-md-6">
                    <div class="form-label">Tỷ lệ hoàn cọc khi hủy trễ (%)</div>
                    <input type="number" name="phanTramHoanCocTreHan" class="form-control" value="@(Model.PhanTramHoanCocTreHan * 100)" step="5" min="0" max="100" required />
                    <div class="text-muted small mt-1">Khách hủy sau thời gian quy định sẽ chỉ được hoàn % này.</div>
                </div>

                <div class="info-note">
                    <i class="fas fa-info-circle me-2"></i>
                    Các cài đặt này sẽ áp dụng cho tất cả các khung giờ của sân. Khách hàng sẽ thấy chính sách hủy khi đặt sân.
                </div>
            </div>

            <div class="text-end mt-4">
                <a href="/Owner/DanhSachSan" class="btn btn-outline-secondary rounded-pill px-4 me-2">Hủy</a>
                <button type="submit" class="btn-save px-4">Lưu cấu hình</button>
            </div>
        </form>
    </div>
</div>