@model Web_Stadium.EFCore.SanBong
@{
    ViewData["Title"] = "Sửa thông tin sân";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div style="background:var(--bg2);padding:100px 0 36px;border-bottom:1px solid var(--border)">
    <div class="container">
        <div class="section-label">Owner — Chỉnh sửa</div>
        <h1 style="font-style:italic;line-height:0.9">SỬA THÔNG TIN<br><span class="text-green">@Model.TenSan</span></h1>
        <p style="color:var(--muted)">Chỉ có thể sửa mô tả, tỷ lệ cọc và trạng thái hiển thị. Thông tin địa chỉ đã ký trong hợp đồng không thể thay đổi.</p>
    </div>
</div>

<div style="background:var(--bg3);border-bottom:1px solid var(--border);padding:12px 0;position:sticky;top:0;z-index:100">
    <div class="container d-flex gap-2 flex-wrap align-items-left">
        <a href="/Owner/DanhSachSan" class="btn btn-outline-success rounded-pill">← Danh sách sân</a>
    </div>
</div>

<div class="container py-5">
    @{
        var tyLeMap = ViewBag.TyLeMap as Dictionary<string, decimal> ?? new Dictionary<string, decimal>();
        var tyLe = tyLeMap.TryGetValue(Model.Quan ?? "", out var tl) ? tl : 0.10m;
    }
    <div class="row justify-content-center">
        <div class="col-lg-7">

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show">✅ @TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
            }

            <!-- Thông tin đã ký — chỉ đọc -->
            <div style="padding:16px 20px;border:1px solid var(--border);border-radius:8px;background:rgba(0,0,0,0.2);margin-bottom:24px">
                <div style="font-size:11px;color:var(--muted);letter-spacing:1px;margin-bottom:10px">
                    🔒 THÔNG TIN ĐÃ KÝ TRONG HỢP ĐỒNG — KHÔNG THỂ THAY ĐỔI
                </div>
                <div class="row g-2" style="font-size:13px">
                    <div class="col-md-6"><span style="color:var(--muted)">Địa chỉ:</span> @Model.DiaChi</div>
                    <div class="col-md-6"><span style="color:var(--muted)">Khu vực:</span> @Model.Quan, @Model.ThanhPho</div>
                    <div class="col-md-6"><span style="color:var(--muted)">Loại sân:</span> @Model.LoaiSan người</div>
                    <div class="col-md-6"><span style="color:var(--muted)">Loại cỏ:</span> @Model.LoaiCo</div>
                    <div class="col-md-6"><span style="color:var(--muted)">Hoa hồng:</span> <span style="color:var(--green);font-weight:600">@((tyLe * 100).ToString("F0"))%</span></div>
                    <div class="col-md-6">
                        <span style="color:var(--muted)">Trạng thái duyệt:</span>
                        <span style="color:@(Model.TrangThaiDuyet == "DaDuyet" ? "var(--green)" : Model.TrangThaiDuyet == "TuChoi" ? "#e74c3c" : "#f39c12");font-weight:600">
                            @Model.TrangThaiDuyet
                        </span>
                    </div>
                </div>
            </div>

            <!-- Form sửa được -->
            <div class="section-card p-4">
                <div style="font-size:11px;color:var(--green);letter-spacing:1px;margin-bottom:20px">
                    ✏️ CÁC THÔNG TIN CÓ THỂ CHỈNH SỬA
                </div>

                <form method="post" action="/Owner/SuaSan/@Model.Id">

                    <div class="mb-4">
                        <label style="color:var(--muted);font-size:12px;margin-bottom:6px;display:block">MÔ TẢ CƠ SỞ</label>
                        <textarea name="moTa" rows="4" class="form-control"
                                  placeholder="Giới thiệu ngắn về cơ sở, tiện ích, ưu điểm..."
                                  style="background:var(--bg3);border-color:var(--border);color:white">@Model.MoTa</textarea>
                        <div style="font-size:12px;color:var(--muted);margin-top:4px">Hiển thị trên trang chi tiết sân cho User xem</div>
                    </div>

                    <div class="mb-4">
                        <label style="color:var(--muted);font-size:12px;margin-bottom:6px;display:block">TỶ LỆ ĐẶT CỌC</label>
                        <div style="display:flex;gap:12px;flex-wrap:wrap">
                            @foreach (var opt in new[] { (0.30m, "30%", "Phổ biến"), (0.40m, "40%", ""), (0.50m, "50%", "Cao") })
                            {
                                <label style="display:flex;align-items:center;gap:8px;padding:10px 16px;border:1px solid @(Model.TyLeCoc == opt.Item1 ? "var(--green)" : "var(--border)");border-radius:8px;cursor:pointer;background:@(Model.TyLeCoc == opt.Item1 ? "rgba(30,215,96,0.08)" : "transparent")">
                                    <input type="radio" name="tyLeCoc" value="@opt.Item1"
                                           @(Model.TyLeCoc == opt.Item1 ? "checked" : "")
                                           style="accent-color:var(--green)" />
                                    <div>
                                        <div style="font-weight:700;color:@(Model.TyLeCoc == opt.Item1 ? "var(--green)" : "white")">@opt.Item2</div>
                                        @if (!string.IsNullOrEmpty(opt.Item3))
                                        {
                                            <div style="font-size:11px;color:var(--muted)">@opt.Item3</div>
                                        }
                                    </div>
                                </label>
                            }
                        </div>
                        <div style="font-size:12px;color:var(--muted);margin-top:8px">
                            Khách hàng phải thanh toán % này khi đặt sân. Phần còn lại trả khi đến sân.
                        </div>
                    </div>

                    <div class="mb-4">
                        <label style="display:flex;align-items:center;gap:10px;cursor:pointer">
                            <input type="checkbox" name="isHidden" value="true"
                                   @(Model.IsHidden ? "checked" : "")
                                   style="width:18px;height:18px;accent-color:#f39c12" />
                            <div>
                                <div style="font-weight:600">Tạm ẩn sân</div>
                                <div style="font-size:12px;color:var(--muted)">Sân sẽ không hiển thị cho User đặt. Dùng khi bảo trì hoặc tạm dừng hoạt động.</div>
                            </div>
                        </label>
                    </div>

                    <div style="display:flex;justify-content:space-between;align-items:center;padding-top:16px;border-top:1px solid var(--border)">
                        <a href="/Owner/DanhSachSan" class="btn btn-outline-secondary rounded-pill">← Huỷ</a>
                        <button type="submit" class="btn btn-success rounded-pill px-4">
                            💾 Lưu thay đổi
                        </button>
                    </div>
                </form>
            </div>

        </div>
    </div>
</div>
