@* ============================================================
   Views/Owner/DanhSachSan.cshtml
   ============================================================ *@
@model List<Web_Stadium.EFCore.SanBong>
@{
    ViewData["Title"] = "Danh sách sân";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div style="background:var(--bg2);padding:100px 0 36px;border-bottom:1px solid var(--border)">
    <div class="container d-flex justify-content-between align-items-end">
        <div>
            <div class="section-label">Owner</div>
            <h1 style="font-style:italic;line-height:0.9;margin:0">DANH SÁCH<br><span class="text-green">CƠ SỞ SÂN</span></h1>
        </div>
        <a href="/Owner/DangKySan" class="btn btn-success rounded-pill">➕ Đăng ký sân mới</a>
    </div>
</div>
<div style="background:var(--bg3);border-bottom:1px solid var(--border);padding:12px 0;position:sticky;top:0;z-index:100">
    <div class="container d-flex gap-2 flex-wrap">
        <a href="/Owner" class="btn btn-sm btn-outline-light rounded-pill">📊 Tổng quan</a>
        <a href="/Owner/DanhSachSan" class="btn btn-sm btn-success rounded-pill">🏟️ Danh sách sân</a>
        <a href="/Owner/DangKySan" class="btn btn-sm btn-outline-warning rounded-pill">➕ Đăng ký sân mới</a>
        <a href="/Owner/QuanLyStaff" class="btn btn-sm btn-outline-info rounded-pill">👷 Nhân viên</a>
        <a href="/Owner/BaoCao" class="btn btn-sm btn-outline-light rounded-pill">📈 Báo cáo</a>
    </div>
</div>

<div class="container py-5">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">✅ @TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    }

    @if (!Model.Any())
    {
        <div style="text-align:center;padding:80px 0">
            <div style="font-size:3rem;margin-bottom:16px">🏟️</div>
            <div style="font-family:var(--ff-h);font-size:1.4rem;margin-bottom:8px">Chưa có sân nào</div>
            <a href="/Owner/DangKySan" class="btn btn-success rounded-pill mt-2">Đăng ký sân đầu tiên</a>
        </div>
    }

    @{
        var tyLeMap = ViewBag.TyLeMap as Dictionary<string, decimal> ?? new Dictionary<string, decimal>();
    }
    <div class="row g-4">
        @foreach (var san in Model)
        {
            var tyLe = tyLeMap.TryGetValue(san.Quan ?? "", out var tl) ? tl : 0.10m;
            var statusColor = san.TrangThaiDuyet switch
            {
                "DaDuyet" => "var(--green)",
                "TuChoi" => "#e74c3c",
                _ => "#f39c12"
            };
            var statusLabel = san.TrangThaiDuyet switch
            {
                "DaDuyet" => "✅ Đã duyệt",
                "TuChoi" => "❌ Từ chối",
                _ => "⏳ Chờ duyệt"
            };
            <div class="col-md-6" data-aos="fade-up">
                <div class="section-card p-0 overflow-hidden @(san.IsHidden ? "opacity-50" : "")">
                    <div style="padding:16px 20px;display:flex;justify-content:space-between;align-items:flex-start">
                        <div>
                            <h5 style="margin:0;font-family:var(--ff-h)">@san.TenSan</h5>
                            <div style="font-size:12px;color:var(--muted);margin-top:4px">📍 @san.DiaChi, @san.Quan</div>
                            <div style="margin-top:8px;display:flex;gap:6px;flex-wrap:wrap">
                                <span class="badge b-blue">@san.LoaiSan người</span>
                                <span class="badge bg-secondary">@san.LoaiCo</span>
                                <span style="font-size:11px;color:@statusColor;font-weight:600">@statusLabel</span>
                                @if (san.IsHidden)
                                {
                                    <span class="badge bg-secondary">Đang ẩn</span>
                                }
                            </div>
                        </div>
                        <div style="text-align:right;font-size:12px">
                            <div style="color:var(--muted)">Hoa hồng</div>
                            <div style="color:var(--green);font-weight:700">@((tyLe * 100).ToString("F0"))%</div>
                            <div style="color:var(--muted);margin-top:2px">Cọc: @((san.TyLeCoc * 100).ToString("F0"))%</div>
                        </div>
                    </div>
                    <div style="padding:12px 20px;border-top:1px solid var(--border);display:flex;gap:8px;flex-wrap:wrap">
                        <a href="/Owner/KhungGio?sanId=@san.Id" class="btn btn-sm btn-outline-light rounded-pill">⏰ Khung giờ (@san.KhungGios?.Count ?? 0)</a>
                        <a href="/Owner/KhoDichVu?sanId=@san.Id" class="btn btn-sm btn-outline-light rounded-pill">💼 Dịch vụ</a>
                        <a href="/Owner/SuaSan?sanId=@san.Id" class="btn btn-sm btn-outline-secondary rounded-pill">✏️ Sửa</a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
