@* ============================================================
   Views/Owner/DangKySan.cshtml
   ============================================================ *@
@{
    ViewData["Title"] = "Đăng ký sân mới";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var quans = ViewBag.Quans as List<Web_Stadium.EFCore.DanhMucQuan> ?? new();
    var loaiSans = ViewBag.LoaiSans as List<Web_Stadium.EFCore.DanhMucLoaiSan> ?? new();
    var loaiCos = ViewBag.LoaiCos as List<Web_Stadium.EFCore.DanhMucLoaiCo> ?? new();
}

<div style="background:var(--bg2);padding:100px 0 40px;border-bottom:1px solid var(--border)">
    <div class="container">
        <div class="section-label">Owner — Đăng ký sân</div>
        <h1 style="font-style:italic;line-height:0.9">ĐĂNG KÝ<br><span class="text-green">SÂN MỚI</span></h1>
        <p style="color:var(--muted)">Điền đầy đủ thông tin → Xem hợp đồng → Xác nhận đăng ký</p>
    </div>
</div>

<div style="background:var(--bg3);border-bottom:1px solid var(--border);padding:12px 0;position:sticky;top:0;z-index:100">
    <div class="container d-flex gap-2 flex-wrap justify-content-center">
        <a href="/Owner" class="btn btn-outline-success rounded-pill">📊 Tổng quan</a>
        <a href="/Owner/DanhSachSan" class="btn btn-outline-green rounded-pill">🏟️ Danh sách sân</a>
        <a href="/Owner/DangKySan" class="btn btn-outline-warning rounded-pill">➕ Đăng ký sân mới</a>
        <a href="/Owner/QuanLyStaff" class="btn btn-outline-info rounded-pill">👷 Nhân viên</a>
        <a href="/Owner/BaoCao" class="btn btn-outline-primary rounded-pill">📈 Báo cáo</a>
    </div>
</div>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show">❌ @TempData["Error"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
            }

            <div class="section-card p-4">
                <form method="post" action="/Owner/XemHopDong">

                    <!-- Tỷ lệ hoa hồng preview -->
                    <div id="hopDongPreview" style="display:none;padding:14px;margin-bottom:24px;border-radius:8px;background:rgba(30,215,96,0.06);border:1px solid rgba(30,215,96,0.3)">
                        <div style="font-size:12px;color:var(--muted);margin-bottom:4px">KHU VỰC ĐÃ CHỌN</div>
                        <div style="display:flex;align-items:center;gap:10px">
                            <div id="vungDot" style="width:12px;height:12px;border-radius:50%;background:#aaa"></div>
                            <span id="tenVung" style="color:var(--green);font-weight:600"></span>
                            <span style="color:var(--muted)">→</span>
                            <span style="color:var(--green);font-family:var(--ff-h);font-size:1.2rem" id="tyLeHH"></span>
                            <span style="color:var(--muted);font-size:13px">hoa hồng/tháng</span>
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-12">
                            <label style="color:var(--muted);font-size:12px">TÊN CƠ SỞ *</label>
                            <input type="text" name="tenSan" class="form-control" required
                                   placeholder="VD: Sân Bóng Cầu Giấy Sport"
                                   style="background:var(--bg3);border-color:var(--border);color:white" />
                        </div>
                        <div class="col-12">
                            <label style="color:var(--muted);font-size:12px">ĐỊA CHỈ *</label>
                            <input type="text" name="diaChi" class="form-control" required
                                   placeholder="Số nhà, tên đường"
                                   style="background:var(--bg3);border-color:var(--border);color:white" />
                        </div>
                        <div class="col-md-6">
                            <label style="color:var(--muted);font-size:12px">QUẬN/HUYỆN *</label>
                            <select name="quan" id="selectQuan" class="form-select" required
                                    style="background:var(--bg3);border-color:var(--border);color:white">
                                <option value="">-- Chọn quận/huyện --</option>
                                @foreach (var q in quans)
                                {
                                    <option value="@q.TenQuan"
                                            data-vung="@(q.VungKhuVuc?.TenVung ?? "Chưa phân vùng")"
                                            data-tyle="@(q.VungKhuVuc?.TyLeHoaHong ?? 0.10m)"
                                            data-mau="@(q.VungKhuVuc?.MauSac ?? "#aaa")">
                                        @q.TenQuan
                                        @if (q.VungKhuVuc != null)
                                        {
                                            <text>(@((q.VungKhuVuc.TyLeHoaHong * 100).ToString("F0"))% HH)</text>
                                        }
                                    </option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label style="color:var(--muted);font-size:12px">THÀNH PHỐ *</label>
                            <input type="text" name="thanhPho" class="form-control" value="Hà Nội"
                                   style="background:var(--bg3);border-color:var(--border);color:white" />
                        </div>
                        <div class="col-md-6">
                            <label style="color:var(--muted);font-size:12px">LOẠI SÂN *</label>
                            <select name="loaiSan" class="form-select" required
                                    style="background:var(--bg3);border-color:var(--border);color:white">
                                @foreach (var ls in loaiSans)
                                {
                                    <option value="@ls.MaLoai">@ls.TenLoai</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label style="color:var(--muted);font-size:12px">LOẠI CỎ *</label>
                            <select name="loaiCo" class="form-select" required
                                    style="background:var(--bg3);border-color:var(--border);color:white">
                                @foreach (var lc in loaiCos)
                                {
                                    <option value="@lc.MaLoai">@lc.TenLoai</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label style="color:var(--muted);font-size:12px">TỶ LỆ CỌC (%)</label>
                            <select name="tyLeCoc" class="form-select"
                                    style="background:var(--bg3);border-color:var(--border);color:white">
                                <option value="0.30">30% (phổ biến)</option>
                                <option value="0.40">40%</option>
                                <option value="0.50">50%</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label style="color:var(--muted);font-size:12px">VĨ ĐỘ (Lat)</label>
                            <input type="number" name="latitude" step="0.0001" value="21.0285" class="form-control"
                                   style="background:var(--bg3);border-color:var(--border);color:white" />
                        </div>
                        <div class="col-md-3">
                            <label style="color:var(--muted);font-size:12px">KINH ĐỘ (Lng)</label>
                            <input type="number" name="longitude" step="0.0001" value="105.8542" class="form-control"
                                   style="background:var(--bg3);border-color:var(--border);color:white" />
                        </div>
                        <div class="col-12">
                            <label style="color:var(--muted);font-size:12px">MÔ TẢ CƠ SỞ</label>
                            <textarea name="moTa" rows="3" class="form-control"
                                      placeholder="Giới thiệu ngắn về cơ sở của bạn..."
                                      style="background:var(--bg3);border-color:var(--border);color:white"></textarea>
                        </div>
                    </div>

                    <div style="margin-top:24px;padding:14px;background:rgba(108,174,224,0.06);border:1px solid rgba(108,174,224,0.3);border-radius:8px;font-size:13px;color:var(--muted2)">
                        📋 Sau khi điền xong, bạn sẽ được xem <strong style="color:white">Hợp đồng Điện tử</strong>
                        với tỷ lệ hoa hồng theo khu vực của sân. Vui lòng đọc kỹ trước khi xác nhận.
                    </div>

                    <div style="margin-top:20px;display:flex;justify-content:flex-end">
                        <button type="submit" class="btn btn-success rounded-pill px-4">
                            Tiếp theo — Xem hợp đồng →
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('selectQuan').addEventListener('change', function() {
            var opt = this.options[this.selectedIndex];
            var vung = opt.dataset.vung;
            var tyle = parseFloat(opt.dataset.tyle || 0);
            var mau  = opt.dataset.mau || '#aaa';
            if (vung && tyle) {
                document.getElementById('tenVung').textContent = vung;
                document.getElementById('tyLeHH').textContent = (tyle * 100).toFixed(0) + '%';
                document.getElementById('vungDot').style.background = mau;
                document.getElementById('hopDongPreview').style.display = 'block';
            } else {
                document.getElementById('hopDongPreview').style.display = 'none';
            }
        });
    </script>
}
