@* ============================================================
   Views/Owner/QuanLyStaff.cshtml
   ============================================================ *@
@model List<Web_Stadium.EFCore.User>
@{
    ViewData["Title"] = "Quản lý Nhân viên";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var danhSachSan = ViewBag.DanhSachSan as List<Web_Stadium.EFCore.SanBong> ?? new();
}
<div style="background:var(--bg2);padding:100px 0 36px;border-bottom:1px solid var(--border)">
    <div class="container d-flex justify-content-between align-items-end">
        <div>
            <div class="section-label">Owner</div>
            <h1 style="font-style:italic;line-height:0.9;margin:0">NHÂN VIÊN<br><span class="text-green">TRỰC SÂN</span></h1>
        </div>
        <button class="btn btn-success rounded-pill" data-bs-toggle="modal" data-bs-target="#modalTaoStaff">+ Tạo nhân viên</button>
    </div>
</div>
<div style="background:var(--bg3);border-bottom:1px solid var(--border);padding:12px 0;position:sticky;top:0;z-index:100">
    <div class="container d-flex gap-2 flex-wrap justify-content-center">
        <a href="/Owner" class="btn btn-outline-success rounded-pill">📊 Tổng quan</a>
        <a href="/Owner/DanhSachSan" class="btn btn-outline-green rounded-pill">🏟️ Danh sách sân</a>
        <a href="/Owner/DangKySan" class="btn btn-outline-warning rounded-pill">➕ Đăng ký sân mới</a>
        <a href="/Owner/QuanLyStaff" class="btn btn-outline-info rounded-pill">👷 Nhân viên</a>
        <a href="/Owner/BaoCao" class="btn btn-outline-primary rounded-pill">📈 Báo cáo</a>
    </div>
</div>
<div class="container py-5">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">✅ @TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    }

    <div class="section-card p-0 overflow-hidden">
        <table class="table table-hover mb-0">
            <thead style="background:var(--bg3)">
                <tr>
                    <th style="color:var(--muted);font-size:11px;padding:12px 16px">Nhân viên</th>
                    <th style="color:var(--muted);font-size:11px">Sân phụ trách</th>
                    <th style="color:var(--muted);font-size:11px">Trạng thái</th>
                    <th style="color:var(--muted);font-size:11px">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var staff in Model)
                {
                    <tr style="@(!staff.IsActive ? "opacity:0.5" : "")">
                        <td style="padding:12px 16px">
                            <div style="font-weight:600">@staff.HoTen</div>
                            <div style="font-size:12px;color:var(--muted)">@staff.Email | @staff.SoDienThoai</div>
                        </td>
                        <td>
                            @foreach (var p in staff.StaffSanPhanCongs ?? new List<Web_Stadium.EFCore.StaffSanPhanCong>())
                            {
                                <span class="badge b-blue me-1">@p.SanBong?.TenSan</span>
                            }
                        </td>
                        <td>
                            <span class="badge @(staff.IsActive ? "bg-success" : "bg-secondary")">
                                @(staff.IsActive ? "Đang làm" : "Đã nghỉ")
                            </span>
                        </td>
                        <td>
                            <div style="display:flex;gap:6px;flex-wrap:wrap">
                                <!-- Gán thêm sân -->
                                <form method="post" action="/Owner/GanSanChoStaff" style="display:flex;gap:4px">
                                    <input type="hidden" name="staffId" value="@staff.Id" />
                                    <select name="sanBongId" class="form-select form-select-sm" style="background:var(--bg3);border-color:var(--border);color:white;font-size:12px;width:160px">
                                        @foreach (var s in danhSachSan)
                                        {
                                            <option value="@s.Id">@s.TenSan</option>
                                        }
                                    </select>
                                    <button type="submit" class="btn btn-sm btn-outline-success rounded-pill">+ Gán</button>
                                </form>
                                <!-- Khoá/mở -->
                                <form method="post" action="/Owner/KhoaStaff" style="display:inline">
                                    <input type="hidden" name="staffId" value="@staff.Id" />
                                    <input type="hidden" name="isActive" value="@(!staff.IsActive)" />
                                    <button type="submit" class="btn btn-sm @(staff.IsActive ? "btn-outline-danger" : "btn-outline-success") rounded-pill">
                                        @(staff.IsActive ? "Khoá" : "Mở khoá")
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="4" style="text-align:center;padding:40px;color:var(--muted)">Chưa có nhân viên nào</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
<!-- Modal Tạo Staff -->
<div class="modal fade" id="modalTaoStaff" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content" style="background:var(--bg2);border:1px solid var(--border)">
            <div class="modal-header" style="border-color:var(--border)"><h5 class="modal-title">Tạo Tài khoản Nhân viên</h5><button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button></div>
            <form method="post" action="/Owner/TaoStaff">
                <div class="modal-body">
                    <div class="mb-3"><label style="color:var(--muted);font-size:12px">HỌ TÊN *</label><input type="text" name="hoTen" class="form-control" required style="background:var(--bg3);border-color:var(--border);color:white" /></div>
                    <div class="mb-3"><label style="color:var(--muted);font-size:12px">EMAIL *</label><input type="email" name="email" class="form-control" required style="background:var(--bg3);border-color:var(--border);color:white" /></div>
                    <div class="mb-3"><label style="color:var(--muted);font-size:12px">MẬT KHẨU *</label><input type="password" name="matKhau" class="form-control" required style="background:var(--bg3);border-color:var(--border);color:white" /></div>
                    <div class="mb-3"><label style="color:var(--muted);font-size:12px">SỐ ĐIỆN THOẠI</label><input type="text" name="soDienThoai" class="form-control" style="background:var(--bg3);border-color:var(--border);color:white" /></div>
                    <div class="mb-3">
                        <label style="color:var(--muted);font-size:12px">GÁN VÀO SÂN *</label>
                        <select name="sanBongId" class="form-select" required style="background:var(--bg3);border-color:var(--border);color:white">
                            @foreach (var s in danhSachSan)
                            {
                                <option value="@s.Id">@s.TenSan</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="modal-footer" style="border-color:var(--border)"><button type="button" class="btn btn-outline-secondary rounded-pill" data-bs-dismiss="modal">Huỷ</button><button type="submit" class="btn btn-success rounded-pill">Tạo</button></div>
            </form>
        </div>
    </div>
</div>