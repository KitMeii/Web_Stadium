@{
    ViewData["Title"] = "Báo cáo chi nhánh";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var data = (ViewBag.Data as IEnumerable<dynamic>) ?? Enumerable.Empty<dynamic>();
    var tyLeLapDay = (ViewBag.TyLeLapDay as IEnumerable<dynamic>) ?? Enumerable.Empty<dynamic>();
    var hieuSuat = (ViewBag.HieuSuatStaff as IEnumerable<dynamic>) ?? Enumerable.Empty<dynamic>();
    double tongThuThuan = ViewBag.TongThuThuan ?? 0.0;
    int tongLuot = ViewBag.TongLuot ?? 0;
    string loai = ViewBag.Loai ?? "thang";
    int nam = ViewBag.Nam ?? DateTime.Now.Year;
    int thang = ViewBag.Thang ?? DateTime.Now.Month;
    string tieuDe = ViewBag.TieuDe ?? "";
}
<div style="background:var(--bg2);padding:100px 0 36px;border-bottom:1px solid var(--border)">
    <div class="container">
        <div class="section-label">Owner — Tài chính chi nhánh</div>
        <h1 style="font-style:italic;line-height:0.9">BÁO CÁO<br><span class="text-green">KINH DOANH</span></h1>
        <p style="color:var(--muted)">@tieuDe</p>
    </div>
</div>
<div style="background:var(--bg3);border-bottom:1px solid var(--border);padding:12px 0;position:sticky;top:0;z-index:100">
    <div class="container d-flex gap-2 flex-wrap justify-content-center">
        <a href="/Owner" class="btn btn-outline-success rounded-pill">📊 Tổng quan</a>
        <a href="/Owner/DanhSachSan" class="btn btn-outline-green rounded-pill">🏟️ Danh sách sân</a>
        <a href="/Owner/DangKySan" class="btn btn-outline-warning rounded-pill">➕ Đăng ký sân mới</a>
        <a href="/Owner/QuanLyStaff" class="btn btn-outline-info rounded-pill">👷 Nhân viên</a>
        <a href="/Owner/BaoCao" class="btn btn-outline-primary rounded-pill">📈 Báo cáo</a>
    </div>
</div>

<div class="container section">

    <!-- TOP BAR -->
    <div class="report-topbar">
        <div class="report-tabs">
            @foreach (var tab in new[] { ("ngay", "📅 Ngày"), ("tuan", "📆 Tuần"), ("thang", "🗓️ Tháng"), ("quy", "📊 Quý"), ("nam", "📈 Năm") })
            {
                var active = loai == tab.Item1;
                <a href="/Owner/BaoCao?loai=@tab.Item1&nam=@nam&thang=@thang"
                   class="report-tab @(active ? "active" : "")">@tab.Item2</a>
            }
        </div>

        <div class="report-filter">
            @if (loai == "ngay" || loai == "tuan")
            {
                <form method="get" action="/Owner/BaoCao" class="d-flex gap-2">
                    <input type="hidden" name="loai" value="@loai" />

                    <select name="thang" onchange="this.form.submit()" class="report-select">
                        @for (int t = 1; t <= 12; t++)
                        {
                            <option value="@t" selected="@(t == thang)">@($"Tháng {t}")</option>
                        }
                    </select>

                    <select name="nam" onchange="this.form.submit()" class="report-select">
                        @for (int y = DateTime.Now.Year; y >= DateTime.Now.Year - 4; y--)
                        {
                            <option value="@y" selected="@(y == nam)">@y</option>
                        }
                    </select>
                </form>
            }
            else if (loai == "thang" || loai == "quy")
            {
                <a href="/Owner/BaoCao?loai=@loai&nam=@(nam - 1)" class="year-nav">←</a>
                <span class="year-label">@nam</span>
                <a href="/Owner/BaoCao?loai=@loai&nam=@(nam + 1)" class="year-nav">→</a>
            }
        </div>
    </div>

    <!-- KPI -->
    <div class="summary-grid mb-4">

        <div class="report-kpi report-kpi-green">
            <div class="kpi-title">THU THUẦN</div>
            <div class="kpi-value">@((tongThuThuan / 1_000_000).ToString("F1"))M</div>
            <div class="kpi-sub">Sau khi trừ hoa hồng PitchHub</div>
        </div>

        <div class="report-kpi">
            <div class="kpi-title">LƯỢT ĐẶT</div>
            <div class="kpi-value">@tongLuot</div>
            <div class="kpi-sub">Đơn thành công</div>
        </div>

        <div class="report-kpi">
            <div class="kpi-title">TB / LƯỢT</div>
            <div class="kpi-value small">
                @(tongLuot > 0 ? ((tongThuThuan / tongLuot) / 1000).ToString("F0") : "0")K
            </div>
            <div class="kpi-sub">Thu thuần / đơn</div>
        </div>

        <div class="report-kpi">
            <div class="kpi-title">NHÂN VIÊN</div>
            <div class="kpi-value">@hieuSuat.Count()</div>
            <div class="kpi-sub">Đã xử lý đơn</div>
        </div>

    </div>

    <!-- CHART -->
    <div class="chart-card mb-4">
        <div class="chart-title">@tieuDe</div>
        <div class="chart-sub">Thu thuần & doanh thu sân theo thời gian</div>
        <div class="chart-wrap">
            <canvas id="chartMain"></canvas>
        </div>
    </div>

    <div class="row g-4">

        <!-- LẤP ĐẦY -->
        <div class="col-md-6">
            <div class="chart-card h-100">
                <div class="chart-title">Tỷ lệ lấp đầy sân</div>

                @foreach (var san in tyLeLapDay)
                {
                    var pct = san.Tong > 0 ? (int)((double)san.DaDat / san.Tong * 100) : 0;
                    var color = pct >= 80 ? "var(--green)" : pct >= 50 ? "#f59e0b" : "#ef4444";

                    <div class="report-bar">
                        <div class="bar-label">@san.Ten</div>

                        <div class="bar-track">
                            <div class="bar-fill" style="width:@pct%;background:@color"></div>
                        </div>

                        <div class="bar-value" style="color:@color">@pct%</div>
                    </div>
                }
            </div>
        </div>

        <!-- STAFF -->
        <div class="col-md-6">
            <div class="chart-card h-100">
                <div class="chart-title">Hiệu suất nhân viên</div>
                <div class="chart-sub">Số đơn xử lý trong kỳ</div>

                @foreach (var s in hieuSuat)
                {
                    var maxDon = hieuSuat.Any() ? (int)hieuSuat.Max(x => (int)x.SoDon) : 1;
                    var pct = maxDon > 0 ? (int)((double)(int)s.SoDon / maxDon * 100) : 0;

                    <div class="report-bar">
                        <div class="bar-label">@s.TenStaff</div>

                        <div class="bar-track">
                            <div class="bar-fill blue" style="width:@pct%"></div>
                        </div>

                        <div class="bar-value blue-text">@s.SoDon đơn</div>
                    </div>
                }

                @if (!hieuSuat.Any())
                {
                    <div class="empty-report">Chưa có dữ liệu</div>
                }
            </div>
        </div>

    </div>
</div>

<style>

    .report-topbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 20px;
        margin-bottom: 30px;
        flex-wrap: wrap
    }

    .report-tabs {
        display: flex;
        gap: 10px;
        flex-wrap: wrap
    }

    .report-tab {
        padding: 8px 18px;
        border-radius: 999px;
        background: var(--bg3);
        border: 1px solid var(--border);
        color: var(--muted);
        font-size: 13px;
        font-weight: 600;
        transition: .25s
    }

        .report-tab:hover {
            transform: translateY(-2px);
            border-color: rgba(14,168,106,.3)
        }

        .report-tab.active {
            background: var(--green);
            color: #fff;
            border-color: var(--green);
            box-shadow: 0 0 18px rgba(14,168,106,.25)
        }

    .report-select {
        background: var(--bg2);
        color: var(--text);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 8px 14px;
        font-size: 13px;
        outline: none
    }

    .year-nav {
        color: var(--green);
        font-size: 24px;
        text-decoration: none
    }

    .year-label {
        font-family: var(--ff-h);
        font-size: 22px;
        color: var(--green)
    }

    .summary-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit,minmax(220px,1fr));
        gap: 18px
    }

    .report-kpi {
        background: linear-gradient(135deg,#fff,#f7fafc);
        border: 1px solid var(--border);
        border-radius: 24px;
        padding: 24px;
        box-shadow: var(--shadow-sm);
        transition: .3s
    }

        .report-kpi:hover {
            transform: translateY(-6px);
            box-shadow: var(--shadow-lg)
        }

    .report-kpi-green {
        border-color: rgba(14,168,106,.3);
        background: linear-gradient(135deg,rgba(14,168,106,.08),#fff)
    }

    .kpi-title {
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 2px;
        color: var(--muted);
        margin-bottom: 10px
    }

    .kpi-value {
        font-family: var(--ff-h);
        font-size: 2.4rem;
        color: var(--text);
        line-height: 1;
        margin-bottom: 8px
    }

        .kpi-value.small {
            font-size: 1.8rem
        }

    .report-kpi-green .kpi-value {
        color: var(--green)
    }

    .kpi-sub {
        font-size: 13px;
        color: var(--muted)
    }

    .chart-card {
        background: linear-gradient(135deg,#fff,#f8fbfd);
        border: 1px solid rgba(14,168,106,.10);
        border-radius: 28px;
        padding: 28px;
        box-shadow: var(--shadow-md)
    }

    .chart-title {
        font-family: var(--ff-h);
        font-size: 28px;
        color: var(--text);
        letter-spacing: 1px;
        margin-bottom: 6px
    }

    .chart-sub {
        color: var(--muted);
        font-size: 13px;
        margin-bottom: 22px
    }

    .chart-wrap {
        position: relative;
        height: 320px
    }

    .report-bar {
        display: grid;
        grid-template-columns: 120px 1fr 60px;
        gap: 14px;
        align-items: center;
        margin-bottom: 18px
    }

    .bar-label {
        font-weight: 700;
        color: var(--text)
    }

    .bar-track {
        height: 12px;
        border-radius: 999px;
        background: #edf2f7;
        overflow: hidden
    }

    .bar-fill {
        height: 100%;
        border-radius: 999px;
        box-shadow: 0 0 14px rgba(14,168,106,.25)
    }

        .bar-fill.blue {
            background: #6caee0
        }

    .bar-value {
        font-size: 13px;
        font-weight: 700
    }

    .blue-text {
        color: #6caee0
    }

    .empty-report {
        text-align: center;
        padding: 24px;
        color: var(--muted)
    }

</style>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>

    <script>
        @{
                var lbls = System.Text.Json.JsonSerializer.Serialize(data.Select(d => (string)d.nhan));
                var thuThuan = System.Text.Json.JsonSerializer.Serialize(data.Select(d => Math.Round((double)d.thuThuan / 1_000_000, 2)));
                var tongDT = System.Text.Json.JsonSerializer.Serialize(data.Select(d => Math.Round((double)d.tongDT / 1_000_000, 2)));
        }

        new Chart(document.getElementById('chartMain'),{
            type:'bar',
            data:{
                labels:@Html.Raw(lbls),
                datasets:[
                    {
                        label:'Thu thuần',
                        data:@Html.Raw(thuThuan),
                        backgroundColor:'rgba(14,168,106,.75)',
                        borderRadius:12,
                        borderSkipped:false
                    },
                    {
                        label:'Doanh thu sân',
                        data:@Html.Raw(tongDT),
                        backgroundColor:'rgba(108,174,224,.30)',
                        borderColor:'#6caee0',
                        borderWidth:1,
                        borderRadius:12,
                        borderSkipped:false
                    }
                ]
            },
            options:{
                responsive:true,
                maintainAspectRatio:false,
                interaction:{mode:'index',intersect:false},
                plugins:{
                    legend:{
                        labels:{
                            color:'#64748b',
                            font:{size:12,weight:'600'},
                            padding:18
                        }
                    }
                },
                scales:{
                    x:{
                        grid:{display:false},
                        ticks:{
                            color:'#64748b',
                            font:{weight:'600'}
                        }
                    },
                    y:{
                        beginAtZero:true,
                        grid:{color:'rgba(15,23,42,.05)'},
                        ticks:{
                            color:'#64748b',
                            callback:v=>v+'M'
                        }
                    }
                }
            }
        });
    </script>
}
