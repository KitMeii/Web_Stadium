@{
    ViewData["Title"] = "Báo cáo chi nhánh";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var data = (ViewBag.Data as IEnumerable<dynamic>) ?? Enumerable.Empty<dynamic>();
    var tyLeLapDay = (ViewBag.TyLeLapDay as IEnumerable<dynamic>) ?? Enumerable.Empty<dynamic>();
    var hieuSuat = (ViewBag.HieuSuatStaff as IEnumerable<dynamic>) ?? Enumerable.Empty<dynamic>();
    double tongThuThuan = ViewBag.TongThuThuan ?? 0.0;
    int tongLuot = ViewBag.TongLuot ?? 0;
    string loai = ViewBag.Loai ?? "thang";
    int nam = ViewBag.Nam ?? DateTime.Now.Year;
    int thang = ViewBag.Thang ?? DateTime.Now.Month;
    string tieuDe = ViewBag.TieuDe ?? "";
}
<div style="background:var(--bg2);padding:100px 0 36px;border-bottom:1px solid var(--border)">
    <div class="container">
        <div class="section-label">Owner — Tài chính chi nhánh</div>
        <h1 style="font-style:italic;line-height:0.9">BÁO CÁO<br><span class="text-green">KINH DOANH</span></h1>
        <p style="color:var(--muted)">@tieuDe</p>
    </div>
</div>
<div style="background:var(--bg3);border-bottom:1px solid var(--border);padding:12px 0;position:sticky;top:0;z-index:100">
    <div class="container d-flex gap-2 flex-wrap">
        <a href="/Owner" class="btn btn-sm btn-outline-light rounded-pill">📊 Tổng quan</a>
        <a href="/Owner/DanhSachSan" class="btn btn-sm btn-outline-light rounded-pill">🏟️ Sân</a>
        <a href="/Owner/QuanLyStaff" class="btn btn-sm btn-outline-info rounded-pill">👷 Staff</a>
        <a href="/Owner/BaoCao" class="btn btn-sm btn-success rounded-pill">📈 Báo cáo</a>
    </div>
</div>

<div class="container section">

    <!-- TABS -->
    <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:24px;align-items:center">
        @foreach (var tab in new[] { ("ngay", "📅 Ngày"), ("tuan", "📆 Tuần"), ("thang", "🗓️ Tháng"), ("quy", "📊 Quý"), ("nam", "📈 Năm") })
        {
            var active = loai == tab.Item1;
            <a href="/Owner/BaoCao?loai=@tab.Item1&nam=@nam&thang=@thang"
               style="padding:6px 16px;border-radius:20px;font-size:13px;text-decoration:none;
                          background:@(active ? "var(--green)" : "var(--bg3)");color:@(active ? "#000" : "var(--muted2)");
                          border:1px solid @(active ? "var(--green)" : "var(--border)");font-weight:@(active ? "700" : "400")">@tab.Item2</a>
        }
        <div style="margin-left:auto;display:flex;gap:6px;align-items:center">
            @if (loai == "ngay" || loai == "tuan")
            {
                <form method="get" action="/Owner/BaoCao" style="display:flex;gap:6px">
                    <input type="hidden" name="loai" value="@loai" />
                    <select name="thang" onchange="this.form.submit()" style="background:var(--bg3);color:white;border:1px solid var(--border);border-radius:6px;padding:4px 8px;font-size:12px">
                        @for (int t = 1; t <= 12; t++)
                        {
                            <option value="@t" selected="@(t == thang)">T@t</option>
                        }
                    </select>
                    <select name="nam" onchange="this.form.submit()" style="background:var(--bg3);color:white;border:1px solid var(--border);border-radius:6px;padding:4px 8px;font-size:12px">
                        @for (int y = DateTime.Now.Year; y >= DateTime.Now.Year - 4; y--)
                        {
                            <option value="@y" selected="@(y == nam)">@y</option>
                        }
                    </select>
                </form>
            }
            else if (loai == "thang" || loai == "quy")
            {
                <a href="/Owner/BaoCao?loai=@loai&nam=@(nam - 1)" style="color:var(--muted);font-size:20px;text-decoration:none">←</a>
                <span style="font-family:var(--ff-h);font-size:18px;color:var(--green)">@nam</span>
                <a href="/Owner/BaoCao?loai=@loai&nam=@(nam + 1)" style="color:var(--muted);font-size:20px;text-decoration:none">→</a>
            }
        </div>
    </div>

    <!-- KPI -->
    <div class="summary-grid" style="margin-bottom:32px">
        <div class="s-card" style="border:1px solid var(--green);background:rgba(30,215,96,0.05)">
            <div style="font-size:11px;color:var(--green);letter-spacing:1px;margin-bottom:4px">THU THUẦN</div>
            <div class="s-num" style="color:var(--green)">@((tongThuThuan / 1_000_000).ToString("F1"))M</div>
            <div class="s-lbl" style="color:var(--green)">Sau khi trừ hoa hồng PitchHub</div>
        </div>
        <div class="s-card">
            <div style="font-size:11px;color:var(--muted);letter-spacing:1px;margin-bottom:4px">LƯỢT ĐẶT</div>
            <div class="s-num">@tongLuot</div>
            <div class="s-lbl">Đơn thành công</div>
        </div>
        <div class="s-card">
            <div style="font-size:11px;color:var(--muted);letter-spacing:1px;margin-bottom:4px">TB MỖI LƯỢT</div>
            <div class="s-num" style="font-size:1.6rem">@(tongLuot > 0 ? ((tongThuThuan / tongLuot) / 1000).ToString("F0") : "0")K</div>
            <div class="s-lbl">VND thu thuần / đơn</div>
        </div>
        <div class="s-card">
            <div style="font-size:11px;color:var(--muted);letter-spacing:1px;margin-bottom:4px">SỐ NHÂN VIÊN</div>
            <div class="s-num">@hieuSuat.Count()</div>
            <div class="s-lbl">Đã xử lý đơn trong kỳ</div>
        </div>
    </div>

    <!-- Biểu đồ -->
    <div class="chart-card" style="margin-bottom:32px">
        <div class="chart-title">@tieuDe</div>
        <div class="chart-sub">Xanh lá = Thu thuần | Xanh dương mờ = Tổng DT sân</div>
        <div style="position:relative;height:260px"><canvas id="chartMain"></canvas></div>
    </div>

    <div class="row g-4">
        <!-- Tỷ lệ lấp đầy -->
        <div class="col-md-6">
            <div class="chart-card h-100">
                <div class="chart-title">Tỷ lệ lấp đầy sân</div>
                @foreach (var san in tyLeLapDay)
                {
                    var pct = san.Tong > 0 ? (int)((double)san.DaDat / (double)san.Tong * 100) : 0;
                    var bc = pct >= 80 ? "var(--green)" : pct >= 50 ? "#f39c12" : "#e74c3c";
                    <div class="lap-day-bar">
                        <div class="lap-name">@san.Ten</div>
                        <div class="lap-bar-wrap"><div class="lap-bar-fill" style="width:@pct%;background:@bc"></div></div>
                        <div class="lap-pct" style="color:@bc">@pct%</div>
                    </div>
                }
            </div>
        </div>
        <!-- Hiệu suất Staff -->
        <div class="col-md-6">
            <div class="chart-card h-100">
                <div class="chart-title">Hiệu suất Nhân viên</div>
                <div class="chart-sub">Số đơn xử lý trong kỳ</div>
                @foreach (var s in hieuSuat)
                {
                    var maxDon = hieuSuat.Any() ? (int)hieuSuat.Max(x => (int)x.SoDon) : 1;
                    var pct = maxDon > 0 ? (int)((double)(int)s.SoDon / maxDon * 100) : 0;
                    <div class="lap-day-bar">
                        <div class="lap-name">@s.TenStaff</div>
                        <div class="lap-bar-wrap"><div class="lap-bar-fill" style="width:@pct%;background:#6caee0"></div></div>
                        <div class="lap-pct" style="color:#6caee0">@s.SoDon đơn</div>
                    </div>
                }
                @if (!hieuSuat.Any())
                {
                    <div style="text-align:center;padding:20px;color:var(--muted);font-size:13px">Chưa có dữ liệu</div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
    <script>
        @{
                var lbls = System.Text.Json.JsonSerializer.Serialize(data.Select(d => (string)d.nhan));
                var thuThuan = System.Text.Json.JsonSerializer.Serialize(data.Select(d => Math.Round((double)d.thuThuan / 1_000_000, 2)));
                var tongDT = System.Text.Json.JsonSerializer.Serialize(data.Select(d => Math.Round((double)d.tongDT / 1_000_000, 2)));
        }
        new Chart(document.getElementById('chartMain'),{
            type:'bar',
            data:{
                labels:@Html.Raw(lbls),
                datasets:[
                    {label:'Thu thuần (triệu)',data:@Html.Raw(thuThuan),backgroundColor:'rgba(30,215,96,0.6)',borderColor:'#1ed760',borderWidth:1,borderRadius:4,order:1},
                    {label:'Tổng DT sân (triệu)',data:@Html.Raw(tongDT),backgroundColor:'rgba(108,174,224,0.12)',borderColor:'#6caee0',borderWidth:1,borderRadius:4,order:2}
                ]
            },
            options:{
                responsive:true,maintainAspectRatio:false,
                plugins:{legend:{display:true,position:'top',labels:{color:'#ffffff80',font:{size:11},padding:14}}},
                scales:{
                    x:{grid:{color:'rgba(255,255,255,0.04)'},ticks:{color:'#ffffff80',font:{size:11}}},
                    y:{grid:{color:'rgba(255,255,255,0.04)'},ticks:{color:'#ffffff80',font:{size:11},callback:v=>v+'M'}}
                }
            }
        });
    </script>
}
