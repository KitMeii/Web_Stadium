@{
    ViewData["Title"] = "Báo cáo kinh doanh";
    Layout = "~/Views/Shared/_Layout.cshtml";

    // --- Lấy dữ liệu từ ViewBag, xử lý null an toàn ---
    var data = (ViewBag.Data as IEnumerable<dynamic>) ?? Enumerable.Empty<dynamic>();
    var tyLeLapDay = (ViewBag.TyLeLapDay as IEnumerable<dynamic>) ?? Enumerable.Empty<dynamic>();
    var hieuSuat = (ViewBag.HieuSuatStaff as IEnumerable<dynamic>) ?? Enumerable.Empty<dynamic>();
    double tongThuThuan = ViewBag.TongThuThuan ?? 0.0;
    int tongLuot = ViewBag.TongLuot ?? 0;
    string loai = ViewBag.Loai ?? "thang";
    int nam = ViewBag.Nam ?? DateTime.Now.Year;
    int thang = ViewBag.Thang ?? DateTime.Now.Month;
    string tieuDe = ViewBag.TieuDe ?? "";
    int? selectedSanId = ViewBag.SanId;
    var dsSan = (ViewBag.DanhSachSan as List<Web_Stadium.EFCore.SanBong>) ?? new List<Web_Stadium.EFCore.SanBong>();
    var selectedSan = dsSan.FirstOrDefault(s => s.Id == selectedSanId);
}

<style>
    :root {
        --db-bg: #f8fafc;
        --db-surface: #ffffff;
        --db-card: #ffffff;
        --db-border: #e2e8f0;
        --db-muted: #475569;
        --db-text: #0f172a;
        --db-green: #0f6e4a;
        --db-green-bg: rgba(15,110,74,0.08);
        --db-green-border: rgba(15,110,74,0.2);
    }
    body {
        background: var(--db-bg);
        color: var(--db-text);
        font-family: 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
    }
    .page-header {
        background: var(--db-surface);
        border-bottom: 1px solid var(--db-border);
        padding: 24px 0 20px;
    }
    .sticky-nav {
        background: var(--db-surface);
        border-bottom: 1px solid var(--db-border);
        padding: 12px 0;
        position: sticky;
        top: 0;
        z-index: 100;
    }
    .nav-btn {
        font-size: 12px;
        padding: 5px 14px;
        border-radius: 30px;
        border: 1px solid var(--db-border);
        background: transparent;
        color: var(--db-muted);
        text-decoration: none;
        transition: 0.15s;
        display: inline-flex;
        align-items: center;
        gap: 5px;
    }
    .nav-btn:hover {
        background: var(--db-bg);
        color: var(--db-text);
        border-color: #cbd5e1;
    }
    .nav-btn-active {
        background: var(--db-green-bg);
        color: var(--db-green);
        border-color: var(--db-green-border);
    }
    .filter-bar {
        display: flex;
        gap: 16px;
        flex-wrap: wrap;
        align-items: center;
        background: var(--db-card);
        padding: 16px 20px;
        border-radius: 20px;
        border: 1px solid var(--db-border);
        margin-bottom: 28px;
    }
    .filter-select {
        background: var(--db-surface);
        border: 1px solid var(--db-border);
        border-radius: 30px;
        padding: 6px 16px;
        font-size: 13px;
        color: var(--db-text);
        cursor: pointer;
    }
    .kpi-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
        margin-bottom: 32px;
    }
    .kpi-card {
        background: var(--db-card);
        border: 1px solid var(--db-border);
        border-radius: 20px;
        padding: 18px 16px;
        transition: 0.2s;
    }
    .kpi-card:hover {
        transform: translateY(-2px);
        border-color: var(--db-green-border);
    }
    .kpi-accent .kpi-value {
        color: var(--db-green);
    }
    .kpi-label {
        font-size: 11px;
        letter-spacing: 0.5px;
        color: var(--db-muted);
        margin-bottom: 8px;
    }
    .kpi-value {
        font-size: 28px;
        font-weight: 700;
        color: var(--db-text);
    }
    .kpi-sub {
        font-size: 12px;
        color: var(--db-muted);
        margin-top: 4px;
    }
    .chart-card {
        background: var(--db-card);
        border: 1px solid var(--db-border);
        border-radius: 20px;
        padding: 20px;
        margin-bottom: 32px;
    }
    .chart-title {
        font-size: 16px;
        font-weight: 600;
        margin-bottom: 4px;
    }
    .chart-sub {
        font-size: 12px;
        color: var(--db-muted);
        margin-bottom: 16px;
    }
    .chart-container {
        height: 280px;
        position: relative;
    }
    .two-col-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
    }
    .stat-card {
        background: var(--db-card);
        border: 1px solid var(--db-border);
        border-radius: 20px;
        padding: 20px;
    }
    .stat-title {
        font-size: 16px;
        font-weight: 600;
        margin-bottom: 16px;
    }
    .stat-row {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 12px;
    }
    .stat-name {
        width: 120px;
        font-size: 13px;
        font-weight: 500;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
    .stat-bar-wrap {
        flex: 1;
        height: 8px;
        background: var(--db-border);
        border-radius: 10px;
        overflow: hidden;
    }
    .stat-bar-fill {
        height: 100%;
        border-radius: 10px;
    }
    .stat-percent {
        width: 45px;
        font-size: 13px;
        font-weight: 600;
        text-align: right;
    }
    .empty-state {
        text-align: center;
        padding: 40px 0;
        color: var(--db-muted);
    }
    @@media (max-width: 768px) {
        .kpi-grid { grid-template-columns: repeat(2, 1fr); gap: 12px; }
        .two-col-grid { grid-template-columns: 1fr; }
        .stat-name { width: 100px; }
    }
</style>

<div class="page-header">
    <div class="container">
        <div class="d-flex justify-content-between align-items-end flex-wrap gap-3">
            <div>
                <div class="text-muted mb-1" style="font-size: 11px; letter-spacing: 1px;">OWNER / BÁO CÁO</div>
                <h1 style="font-size: 2rem; font-weight: 700; margin: 0;">
                    Báo cáo <span style="color: var(--db-green);">kinh doanh</span>
                    @if (selectedSan != null)
                    {
                        <span style="font-size: 1.2rem;"> — @selectedSan.TenSan</span>
                    }
                </h1>
                <p class="text-muted mt-2 mb-0">@tieuDe</p>
            </div>
        </div>
    </div>
</div>

<div class="sticky-nav">
    <div class="container">
        <div class="d-flex gap-2 flex-wrap">
            <a href="/Owner" class="nav-btn">📊 Tổng quan</a>
            <a href="/Owner/DanhSachSan" class="nav-btn">🏟️ Danh sách sân</a>
            <a href="/Owner/DangKySan" class="nav-btn">➕ Đăng ký sân</a>
            <a href="/Owner/DanhSachDonDat" class="nav-btn">📋 Duyệt lịch</a>
            <a href="/Owner/QuanLyStaff" class="nav-btn">👷 Nhân viên</a>
            <a href="/Owner/BaoCao" class="nav-btn nav-btn-active">📈 Báo cáo </a>
            <a href="/Owner/DanhSachDanhGia" class="nav-btn">⭐ Đánh giá</a>

        </div>
    </div>
</div>

<div class="container py-5">

    <!-- Bộ lọc -->
    <div class="filter-bar">
        <form method="get" action="/Owner/BaoCao" style="display: flex; gap: 12px; flex-wrap: wrap; align-items: center; width: 100%;">
            <select name="loai" class="filter-select" onchange="this.form.submit()">
                <option value="ngay" selected="@(loai == "ngay")">📅 Ngày</option>
                <option value="tuan" selected="@(loai == "tuan")">📆 Tuần</option>
                <option value="thang" selected="@(loai == "thang")">🗓️ Tháng</option>
                <option value="quy" selected="@(loai == "quy")">📊 Quý</option>
                <option value="nam" selected="@(loai == "nam")">📈 Năm</option>
            </select>

            <select name="sanId" class="filter-select" onchange="this.form.submit()">
                <option value="">-- Tất cả sân --</option>
                @foreach (var s in dsSan)
                {
                    <option value="@s.Id" selected="@(selectedSanId == s.Id)">@s.TenSan</option>
                }
            </select>

            @if (loai == "ngay" || loai == "tuan")
            {
                <select name="thang" class="filter-select" onchange="this.form.submit()">
                    @for (int t = 1; t <= 12; t++)
                    {
                        <option value="@t" selected="@(t == thang)">Tháng @t</option>
                    }
                </select>
                <select name="nam" class="filter-select" onchange="this.form.submit()">
                    @for (int y = DateTime.Now.Year; y >= DateTime.Now.Year - 4; y--)
                    {
                        <option value="@y" selected="@(y == nam)">Năm @y</option>
                    }
                </select>
            }
            else if (loai == "thang" || loai == "quy")
            {
                <span class="text-muted">Năm</span>
                <div style="display: flex; gap: 6px; align-items: center;">
                    <a href="/Owner/BaoCao?loai=@loai&nam=@(nam - 1)&sanId=@selectedSanId" class="filter-select">←</a>
                    <span style="font-weight: 600; min-width: 50px; text-align: center;">@nam</span>
                    <a href="/Owner/BaoCao?loai=@loai&nam=@(nam + 1)&sanId=@selectedSanId" class="filter-select">→</a>
                </div>
            }

            @if (!string.IsNullOrEmpty(loai) && (selectedSanId.HasValue || nam != DateTime.Now.Year || thang != DateTime.Now.Month))
            {
                <a href="/Owner/BaoCao" class="filter-select">🔄 Xóa lọc</a>
            }
        </form>
    </div>

    <!-- 4 KPI -->
    <div class="kpi-grid">
        <div class="kpi-card kpi-accent">
            <div class="kpi-label">THU THUẦN</div>
            <div class="kpi-value">@((tongThuThuan / 1_000_000).ToString("F1"))M</div>
            <div class="kpi-sub">Sau khi trừ hoa hồng</div>
        </div>
        <div class="kpi-card">
            <div class="kpi-label">LƯỢT ĐẶT</div>
            <div class="kpi-value">@tongLuot</div>
            <div class="kpi-sub">Đơn thành công</div>
        </div>
        <div class="kpi-card">
            <div class="kpi-label">TB MỖI LƯỢT</div>
            <div class="kpi-value">@(tongLuot > 0 ? ((tongThuThuan / tongLuot) / 1000).ToString("F0") : "0")K</div>
            <div class="kpi-sub">VNĐ thu thuần / đơn</div>
        </div>
        <div class="kpi-card">
            <div class="kpi-label">NHÂN VIÊN</div>
            <div class="kpi-value">@hieuSuat.Count()</div>
            <div class="kpi-sub">Đã xử lý đơn trong kỳ</div>
        </div>
    </div>

    <!-- Biểu đồ -->
    @if (data.Any())
    {
        <div class="chart-card">
            <div class="chart-title">@tieuDe</div>
            <div class="chart-sub">Xanh đậm = Thu thuần | Xanh nhạt = Tổng doanh thu sân</div>
            <div class="chart-container">
                <canvas id="chartMain"></canvas>
            </div>
        </div>
    }
    else
    {
        <div class="chart-card">
            <div class="empty-state">📊 Không có dữ liệu cho kỳ báo cáo này</div>
        </div>
    }

    <!-- Tỷ lệ lấp đầy và hiệu suất staff -->
    <div class="two-col-grid">
        <div class="stat-card">
            <div class="stat-title">🏟️ Tỷ lệ lấp đầy sân</div>
            @if (tyLeLapDay.Any())
            {
                foreach (var san in tyLeLapDay)
                {
                    var pct = san.Tong > 0 ? (int)((double)san.DaDat / (double)san.Tong * 100) : 0;
                    var barColor = pct >= 80 ? "#0f6e4a" : (pct >= 50 ? "#f59e0b" : "#ef4444");
                    <div class="stat-row">
                        <div class="stat-name">@san.Ten</div>
                        <div class="stat-bar-wrap"><div class="stat-bar-fill" style="width:@pct%; background: @barColor;"></div></div>
                        <div class="stat-percent" style="color: @barColor;">@pct%</div>
                    </div>
                }
            }
            else
            {
                <div class="empty-state">Chưa có dữ liệu lấp đầy</div>
            }
        </div>

        <div class="stat-card">
            <div class="stat-title">👥 Hiệu suất nhân viên</div>
            <div class="chart-sub">Số đơn xử lý trong kỳ</div>
            @if (hieuSuat.Any())
            {
                var maxDon = hieuSuat.Max(x => (int)x.SoDon);
                foreach (var s in hieuSuat)
                {
                    var pct = maxDon > 0 ? (int)((double)(int)s.SoDon / maxDon * 100) : 0;
                    <div class="stat-row">
                        <div class="stat-name">@s.TenStaff</div>
                        <div class="stat-bar-wrap"><div class="stat-bar-fill" style="width:@pct%; background: #3b82f6;"></div></div>
                        <div class="stat-percent" style="color: #3b82f6;">@s.SoDon đơn</div>
                    </div>
                }
            }
            else
            {
                <div class="empty-state">Chưa có dữ liệu nhân viên</div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script>
        @{
            var labels = System.Text.Json.JsonSerializer.Serialize(data.Select(d => (string)d.nhan));
            var thuThuanData = System.Text.Json.JsonSerializer.Serialize(data.Select(d => Math.Round((double)d.thuThuan / 1_000_000, 2)));
            var tongDTData = System.Text.Json.JsonSerializer.Serialize(data.Select(d => Math.Round((double)d.tongDT / 1_000_000, 2)));
        }
        const ctx = document.getElementById('chartMain')?.getContext('2d');
        if (ctx) {
            new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: @Html.Raw(labels),
                    datasets: [
                        {
                            label: 'Thu thuần (triệu VND)',
                            data: @Html.Raw(thuThuanData),
                            backgroundColor: 'rgba(15,110,74,0.6)',
                            borderColor: '#0f6e4a',
                            borderWidth: 1.5,
                            borderRadius: 6,
                            barPercentage: 0.65
                        },
                        {
                            label: 'Tổng doanh thu sân (triệu VND)',
                            data: @Html.Raw(tongDTData),
                            backgroundColor: 'rgba(59,130,246,0.15)',
                            borderColor: '#3b82f6',
                            borderWidth: 1,
                            borderRadius: 6,
                            barPercentage: 0.65
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { position: 'top', labels: { color: '#475569', font: { size: 11 } } },
                        tooltip: {
                            backgroundColor: '#ffffff',
                            titleColor: '#0f172a',
                            bodyColor: '#475569',
                            borderColor: '#e2e8f0',
                            borderWidth: 1,
                            callbacks: { label: (ctx) => `${ctx.dataset.label}: ${ctx.raw} triệu VND` }
                        }
                    },
                    scales: {
                        x: { grid: { display: false }, ticks: { color: '#475569', font: { size: 11 } } },
                        y: { grid: { color: '#e2e8f0' }, ticks: { color: '#475569', callback: (val) => val + 'M' } }
                    }
                }
            });
        }
    </script>
}