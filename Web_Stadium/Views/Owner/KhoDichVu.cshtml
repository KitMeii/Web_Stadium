@* ============================================================
   Views/Owner/KhoDichVu.cshtml
   ============================================================ *@
@model List<Web_Stadium.EFCore.DichVu>
@{
    ViewData["Title"] = "Kho dịch vụ";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var san = ViewBag.San as Web_Stadium.EFCore.SanBong;
    var dmChuaBat = ViewBag.DanhMucChuaBat as List<Web_Stadium.EFCore.DanhMucDichVu> ?? new();
}
<div style="background:var(--bg2);padding:100px 0 36px;border-bottom:1px solid var(--border)">
    <div class="container">
        <div class="section-label">@san?.TenSan</div>
        <h1 style="font-style:italic;line-height:0.9">KHO<br><span class="text-green">DỊCH VỤ</span></h1>
        <p style="color:var(--muted)">Quản lý dịch vụ kèm theo đơn đặt sân — User chọn khi booking</p>
    </div>
</div>
<<div style="background:var(--bg3);border-bottom:1px solid var(--border);padding:10px 0;position:sticky;top:0;z-index:100">
    <div class="container d-flex justify-content-between align-items-center gap-2">
        <a href="/Owner/DanhSachSan" class="btn btn-outline-success rounded-pill">← Danh sách sân</a>
        @if (dmChuaBat.Any())
        {
            <button class="btn btn-success rounded-pill" data-bs-toggle="modal" data-bs-target="#modalBatDV">+ Bật dịch vụ</button>
        }
    </div>
</div>
<div class="container py-5">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">✅ @TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    }

    <!-- Danh sách dịch vụ đang bật -->
    <div class="section-card p-0 overflow-hidden mb-4">
        <div style="padding:14px 20px;font-family:var(--ff-h);font-size:14px;border-bottom:1px solid var(--border)">Dịch vụ đang cung cấp</div>
        <table class="table table-hover mb-0">
            <thead style="background:var(--bg3)">
                <tr>
                    <th style="color:var(--muted);font-size:11px;padding:10px 16px">Dịch vụ</th>
                    <th style="color:var(--muted);font-size:11px">Giá</th>
                    <th style="color:var(--muted);font-size:11px">Tồn kho</th>
                    <th style="color:var(--muted);font-size:11px">Trạng thái</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var dv in Model)
                {
                    <tr style="@(!dv.IsActive ? "opacity:0.5" : "")">
                        <td style="padding:10px 16px">
                            <span style="font-size:18px">@dv.DanhMucDichVu?.Icon</span>
                            <strong style="margin-left:8px">@dv.TenDichVu</strong>
                        </td>
                        <td>@dv.Gia.ToString("N0")đ</td>
                        <td>
                            <span style="color:@(dv.TonKho < 5 ? "#e74c3c" : dv.TonKho < 20 ? "#f39c12" : "var(--green)")">
                                @dv.TonKho
                            </span>
                        </td>
                        <td><span class="badge @(dv.IsActive ? "bg-success" : "bg-secondary")">@(dv.IsActive ? "Đang bán" : "Tạm tắt")</span></td>
                        <td>
                            <form method="post" action="/Owner/CapNhatDichVu" style="display:flex;gap:4px;align-items:center">
                                <input type="hidden" name="dichVuId" value="@dv.Id" />
                                <input type="number" name="gia" value="@dv.Gia" style="width:90px;background:var(--bg3);border:1px solid var(--border);color:white;border-radius:4px;padding:2px 6px;font-size:12px" />
                                <input type="number" name="tonKho" value="@dv.TonKho" style="width:60px;background:var(--bg3);border:1px solid var(--border);color:white;border-radius:4px;padding:2px 6px;font-size:12px" />
                                <input type="hidden" name="isActive" value="@(!dv.IsActive)" />
                                <button type="submit" class="btn btn-sm @(dv.IsActive ? "btn-outline-warning" : "btn-outline-success") rounded-pill" style="font-size:11px">
                                    @(dv.IsActive ? "Tắt" : "Bật")
                                </button>
                            </form>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="5" style="text-align:center;padding:30px;color:var(--muted)">Chưa có dịch vụ nào. Bật dịch vụ từ danh mục bên trên.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
<!-- Modal Bật dịch vụ mới -->
<div class="modal fade" id="modalBatDV" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content" style="background:var(--bg2);border:1px solid var(--border)">
            <div class="modal-header" style="border-color:var(--border)"><h5 class="modal-title">Bật dịch vụ mới</h5><button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button></div>
            <form method="post" action="/Owner/BatDichVu">
                <input type="hidden" name="sanId" value="@san?.Id" />
                <div class="modal-body">
                    <div class="mb-3">
                        <label style="color:var(--muted);font-size:12px">CHỌN DỊCH VỤ</label>
                        <select name="danhMucId" class="form-select" required style="background:var(--bg3);border-color:var(--border);color:white">
                            @foreach (var dm in dmChuaBat)
                            {
                                <option value="@dm.Id">@dm.Icon @dm.TenDichVu</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3"><label style="color:var(--muted);font-size:12px">GIÁ BÁN (đ) *</label><input type="number" name="gia" class="form-control" required min="0" style="background:var(--bg3);border-color:var(--border);color:white" /></div>
                    <div class="mb-3"><label style="color:var(--muted);font-size:12px">TỒN KHO BAN ĐẦU</label><input type="number" name="tonKho" class="form-control" value="0" min="0" style="background:var(--bg3);border-color:var(--border);color:white" /></div>
                </div>
                <div class="modal-footer" style="border-color:var(--border)"><button type="button" class="btn btn-outline-secondary rounded-pill" data-bs-dismiss="modal">Huỷ</button><button type="submit" class="btn btn-success rounded-pill">Bật</button></div>
            </form>
        </div>
    </div>
</div>