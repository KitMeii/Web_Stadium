@{
    ViewData["Title"] = "Dashboard Owner";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var donHomNay = ViewBag.DonHomNay as List<Web_Stadium.EFCore.DatSan> ?? new();
    var bieu = (ViewBag.Bieu6Thang as IEnumerable<dynamic>) ?? Enumerable.Empty<dynamic>();
}

<style>
    /* ========== LIGHT THEME – NỀN TRẮNG, CHỮ ĐEN ========== */
    :root {
        --db-bg: #f8fafc;
        --db-surface: #ffffff;
        --db-card: #ffffff;
        --db-border: #e2e8f0;
        --db-muted: #475569;
        --db-text: #0f172a;
        --db-green: #0f6e4a;
        --db-green-bg: rgba(15,110,74,0.08);
        --db-green-border: rgba(15,110,74,0.2);
        --db-radius-sm: 8px;
        --db-radius-md: 16px;
        --grid-gap: 20px;
    }

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        background: var(--db-bg);
        color: var(--db-text);
        font-family: 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
    }

    /* Hero */
    .db-hero {
        background: white;
        background-image: url(https://cdn-media.sforum.vn/storage/app/media/wp-content/uploads/2023/06/hinh-nen-bong-da-thumb.jpg);
        background-size: cover; /* Ảnh phủ kín vùng chứa */
        background-repeat: no-repeat; /* Không lặp ảnh */
        background-position: center; /* Căn giữa ảnh */
        border-bottom: 1px solid var(--db-border);
        padding: 96px 0 28px;
    }

    .db-hero__inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 12px;
    }

    .db-hero__left {
        display: flex;
        align-items: center;
        gap: 14px;

    }

    .db-hero__avatar {
        width: 52px;
        height: 52px;
        border-radius: 50%;
        background: #eef2ff;
        border: 1px solid #cbd5e1;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 17px;
        font-weight: 600;
        color: var(--db-text);
        flex-shrink: 0;
    }

    .db-hero__title {
        font-size: 16px;
        font-weight: 600;
        color: white;
    }

    .db-hero__sub {
        font-size: 12px;
        color: white;
        margin-top: 3px;
    }

    .db-hero__badge {
        font-size: 11px;
        padding: 5px 12px;
        border-radius: 20px;
        background: var(--db-green-bg);
        color: white;
        border: 1px solid var(--db-green-border);
        font-weight: 600;
        white-space: nowrap;
    }

    /* Sticky nav */
    .db-nav {
        background: var(--db-surface);
        border-bottom: 1px solid var(--db-border);
        padding: 10px 0;
        position: sticky;
        top: 0;
        z-index: 100;
    }

    .db-nav__inner {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
    }

    .db-nav__btn {
        font-size: 12px;
        padding: 5px 14px;
        border-radius: 20px;
        border: 1px solid var(--db-border);
        background: transparent;
        color: var(--db-muted);
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 5px;
        transition: 0.15s;
    }

        .db-nav__btn:hover {
            background: var(--db-bg);
            color: var(--db-text);
            border-color: #cbd5e1;
        }

    .db-nav__btn--active {
        background: var(--db-green-bg);
        color: var(--db-green);
        border-color: var(--db-green-border);
    }

    /* Main content */
    .db-content {
        padding: 32px 0;
        display: flex;
        flex-direction: column;
        gap: 32px;
    }

    /* Section label */
    .db-section-label {
        font-size: 10px;
        letter-spacing: 1.2px;
        text-transform: uppercase;
        color: var(--db-muted);
        font-weight: 600;
        margin-bottom: 16px;
    }

    /* KPI grid */
    .db-kpi-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: var(--grid-gap);
    }

    .db-kpi {
        background: var(--db-card);
        border: 1px solid var(--db-border);
        border-radius: var(--db-radius-md);
        padding: 18px 20px;
        position: relative;
        overflow: hidden;
        transition: 0.2s;
    }

        .db-kpi:hover {
            box-shadow: 0 8px 20px rgba(0,0,0,0.03);
            border-color: #cbd5e1;
        }

    .db-kpi--accent {
        background: var(--db-green-bg);
        border-color: var(--db-green-border);
    }

    .db-kpi__label {
        font-size: 10px;
        letter-spacing: 0.8px;
        text-transform: uppercase;
        color: var(--db-muted);
        margin-bottom: 6px;
    }

    .db-kpi--accent .db-kpi__label {
        color: var(--db-green);
    }

    .db-kpi__num {
        font-size: 26px;
        font-weight: 700;
        color: var(--db-text);
        line-height: 1.1;
    }

    .db-kpi--accent .db-kpi__num {
        color: var(--db-green);
    }

    .db-kpi__sub {
        font-size: 11px;
        color: var(--db-muted);
        margin-top: 6px;
    }

    .db-kpi__icon {
        position: absolute;
        right: 16px;
        top: 16px;
        font-size: 24px;
        opacity: 0.15;
    }

    /* Divider */
    .db-divider {
        height: 1px;
        background: var(--db-border);
        margin: 8px 0;
    }

    /* Two column */
    .db-two-col {
        display: grid;
        grid-template-columns: 3fr 2fr;
        gap: var(--grid-gap);
    }

    /* Card */
    .db-card {
        background: var(--db-card);
        border: 1px solid var(--db-border);
        border-radius: var(--db-radius-md);
        padding: 20px;
    }

    .db-card__title {
        font-size: 14px;
        font-weight: 600;
        color: var(--db-text);
    }

    .db-card__sub {
        font-size: 11px;
        color: var(--db-muted);
        margin-top: 4px;
    }

    .db-card__header {
        margin-bottom: 16px;
    }

    /* Chart */
    .db-chart-wrap {
        position: relative;
        height: 220px;
    }

    /* Booking list */
    .db-booking {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 8px;
        padding: 12px 0;
        border-bottom: 1px solid var(--db-border);
        font-size: 13px;
    }

        .db-booking:last-child {
            border-bottom: none;
        }

    .db-booking__name {
        font-weight: 600;
        color: var(--db-text);
    }

    .db-booking__meta {
        font-size: 11px;
        color: var(--db-muted);
        margin-top: 2px;
    }

    .db-booking__tag {
        font-size: 10px;
        padding: 3px 9px;
        border-radius: 20px;
        font-weight: 600;
        white-space: nowrap;
        flex-shrink: 0;
    }

    .db-tag--confirmed {
        background: rgba(15,110,74,0.12);
        color: #0f6e4a;
        border: 1px solid rgba(15,110,74,0.25);
    }

    .db-tag--using {
        background: rgba(142,68,173,0.08);
        color: #6c2e9e;
        border: 1px solid rgba(142,68,173,0.2);
    }

    .db-tag--done {
        background: rgba(59,130,246,0.08);
        color: #2563eb;
        border: 1px solid rgba(59,130,246,0.2);
    }

    .db-tag--pending {
        background: rgba(245,158,11,0.08);
        color: #b45309;
        border: 1px solid rgba(245,158,11,0.2);
    }

    .db-booking__empty {
        padding: 32px 0;
        text-align: center;
        color: var(--db-muted);
        font-size: 13px;
    }

    /* Quick actions */
    .db-actions-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: var(--grid-gap);
    }

    .db-action {
        background: var(--db-card);
        border: 1px solid var(--db-border);
        border-radius: var(--db-radius-md);
        padding: 20px 16px;
        text-decoration: none;
        display: block;
        transition: all 0.2s;
    }

        .db-action:hover {
            border-color: var(--db-green-border);
            background: var(--db-green-bg);
            transform: translateY(-2px);
        }

    .db-action__icon {
        font-size: 24px;
        margin-bottom: 12px;
    }

    .db-action__title {
        font-size: 13px;
        font-weight: 700;
        color: var(--db-text);
        margin-bottom: 6px;
        letter-spacing: 0.3px;
    }

    .db-action__desc {
        font-size: 11px;
        color: var(--db-muted);
        line-height: 1.4;
    }

    /* Responsive */
    @@media (max-width: 768px) {
        .db-kpi-grid, .db-actions-grid {
            grid-template-columns: repeat(2, 1fr);
        }

        .db-two-col {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 480px) {
        .db-kpi-grid {
            grid-template-columns: 1fr;
        }

        .db-actions-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<!-- Hero -->
<div class="db-hero">
    <div class="container">
        <div class="db-hero__inner">
            <div class="db-hero__left">
                <div class="db-hero__avatar">@(User.Identity?.Name?.Substring(0, 2).ToUpper() ?? "OW")</div>
                <div>
                    <div class="db-hero__title">@(User.Identity?.Name ?? "Chủ sân") — Owner Portal</div>
                    <div class="db-hero__sub">PitchHub · Cập nhật lúc @DateTime.Now.ToString("HH:mm, dd/MM/yyyy")</div>
                </div>
            </div>
            <span class="db-hero__badge">✓ Đang hoạt động</span>
        </div>
    </div>
</div>

<!-- Sticky Nav -->
<div class="db-nav">
    <div class="container">
        <div class="db-nav__inner">
            <a href="/Owner" class="db-nav__btn db-nav__btn--active">📊 Tổng quan</a>
            <a href="/Owner/DanhSachSan" class="db-nav__btn">🏟️ Danh sách sân</a>
            <a href="/Owner/DangKySan" class="db-nav__btn">➕ Đăng ký sân</a>
            <a href="/Owner/DanhSachDonDat" class="db-nav__btn">📋 Duyệt lịch</a>
            <a href="/Owner/QuanLyStaff" class="db-nav__btn">👷 Nhân viên</a>
            <a href="/Owner/BaoCao" class="db-nav__btn">📈 Báo cáo</a>
            <a href="/Owner/DanhSachDanhGia" class="db-nav__btn">⭐ Đánh giá</a>
        </div>
    </div>
</div>

<!-- Main content -->
<div class="container db-content">

    <!-- KPI 4 ô -->
    <div>
        <div class="db-section-label">Hiệu suất tháng này</div>
        <div class="db-kpi-grid">
            <div class="db-kpi db-kpi--accent">
                <div class="db-kpi__label">Tổng sân</div>
                <div class="db-kpi__num">@ViewBag.TongSan</div>
                <div class="db-kpi__sub">@ViewBag.SanDaDuyet đã duyệt · @ViewBag.SanChoDuyet chờ</div>
                <span class="db-kpi__icon" style="color: #3b82f6; font-size: 1.8rem;">🏟️</span>
            </div>
            <div class="db-kpi db-kpi--accent">
                <div class="db-kpi__label">Thu thuần tháng này</div>
                <div class="db-kpi__num">@(((decimal)ViewBag.DoanhThuThang / 1_000_000m).ToString("F1"))M</div>
                <div class="db-kpi__sub">Sau khi trừ hoa hồng</div>
                <span class="db-kpi__icon" style="color: #10b981; font-size: 1.8rem;">💰</span>
            </div>
            <div class="db-kpi db-kpi--accent">
                <div class="db-kpi__label">Hoa hồng đã trừ</div>
                <div class="db-kpi__num">@(((decimal)ViewBag.HoaHongThang / 1_000_000m).ToString("F2"))M</div>
                <div class="db-kpi__sub">Phí nền tảng PitchHub</div>
                <span class="db-kpi__icon" style="color: #f59e0b; font-size: 1.8rem;">🧾</span>
            </div>
            <div class="db-kpi db-kpi--accent">
                <div class="db-kpi__label">Đơn hôm nay</div>
                <div class="db-kpi__num">@donHomNay.Count</div>
                <div class="db-kpi__sub">Lịch đặt trong ngày</div>
                <span class="db-kpi__icon" style="color: #8b5cf6; font-size: 1.8rem;">📅</span>
            </div>
        </div>
    </div>

    <div class="db-divider"></div>

    <!-- Biểu đồ + Lịch hôm nay -->
    <div>
        <div class="db-section-label">Phân tích & lịch đặt</div>
        <div class="db-two-col">
            <!-- Chart -->
            <div class="db-card">
                <div class="db-card__header">
                    <div class="db-card__title">Doanh thu thuần 6 tháng gần nhất</div>
                    <div class="db-card__sub">Đơn vị: triệu VND — sau khi trừ hoa hồng PitchHub</div>
                </div>
                <div class="db-chart-wrap"><canvas id="chartBieu"></canvas></div>
            </div>
            <!-- Today bookings -->
            <div class="db-card">
                <div class="db-card__header">
                    <div class="db-card__title">Lịch đặt hôm nay</div>
                    <div class="db-card__sub">@DateTime.Now.ToString("dddd, dd/MM/yyyy")</div>
                </div>
                @if (!donHomNay.Any())
                {
                    <div class="db-booking__empty">Chưa có lịch đặt hôm nay</div>
                }
                @foreach (var don in donHomNay)
                {
                    var tagClass = don.TrangThai switch
                    {
                        "DaXacNhan" => "db-tag--confirmed",
                        "DangSuDung" => "db-tag--using",
                        "HoanThanh" => "db-tag--done",
                        _ => "db-tag--pending"
                    };
                    var tagLabel = don.TrangThai switch
                    {
                        "DaXacNhan" => "Đã xác nhận",
                        "DangSuDung" => "Đang dùng",
                        "HoanThanh" => "Hoàn thành",
                        _ => "Chờ xác nhận"
                    };
                    <div class="db-booking">
                        <div>
                            <div class="db-booking__name">@don.KhungGio?.SanBong?.TenSan</div>
                            <div class="db-booking__meta">
                                @don.KhungGio?.GioBatDau.ToString(@"hh\:mm")–@don.KhungGio?.GioKetThuc.ToString(@"hh\:mm")
                                · @don.User?.HoTen
                            </div>
                        </div>
                        <span class="db-booking__tag @tagClass">@tagLabel</span>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="db-divider"></div>

    <!-- Quick actions -->
    <div>
        <div class="db-section-label">Thao tác nhanh</div>
        <div class="db-actions-grid">
            @foreach (var item in new[] {
                ("/Owner/DangKySan",   "➕", "ĐĂNG KÝ SÂN MỚI", "Thêm cơ sở mới vào hệ thống PitchHub"),
                ("/Owner/DanhSachSan", "🏟️", "QUẢN LÝ SÂN",     "Sửa thông tin, bật / ẩn sân"),
                ("/Owner/QuanLyStaff", "👷", "NHÂN VIÊN",        "Tạo tài khoản và gán sân cho Staff"),
                ("/Owner/BaoCao",      "📈", "BÁO CÁO",          "Doanh thu, lấp đầy, hiệu suất Staff"),
            })
            {
                <a href="@item.Item1" class="db-action">
                    <div class="db-action__icon">@item.Item2</div>
                    <div class="db-action__title">@item.Item3</div>
                    <div class="db-action__desc">@item.Item4</div>
                </a>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
    <script>
        @{
            var lbls = System.Text.Json.JsonSerializer.Serialize(bieu.Select(d => (string)d.thang));
            var dts = System.Text.Json.JsonSerializer.Serialize(bieu.Select(d => Math.Round((double)d.dt / 1_000_000, 2)));
        }
        new Chart(document.getElementById('chartBieu'), {
        type: 'bar',
        data: {
        labels: @Html.Raw(lbls),
        datasets: [{
        label: 'Thu thuần (triệu VND)',
        data: @Html.Raw(dts),
        backgroundColor: 'rgba(15,110,74,0.12)',
        borderColor: '#0f6e4a',
        borderWidth: 1.5,
        borderRadius: 6,
        borderSkipped: false
        }]
        },
        options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
        legend: { display: false },
        tooltip: {
        callbacks: { label: ctx => ' ' + ctx.parsed.y.toFixed(1) + 'M VND' }
        }
        },
        scales: {
        x: {
        grid: { color: '#e9eef3' },
        ticks: { color: '#475569', font: { size: 11 } }
        },
        y: {
        grid: { color: '#e9eef3' },
        ticks: {
        color: '#475569',
        font: { size: 11 },
        callback: v => v + 'M'
        },
        beginAtZero: true
        }
        }
        }
        });
    </script>
}