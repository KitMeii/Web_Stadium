@{
    ViewData["Title"] = "Dashboard Owner";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var donHomNay = ViewBag.DonHomNay as List<Web_Stadium.EFCore.DatSan> ?? new();
    var bieu = (ViewBag.Bieu6Thang as IEnumerable<dynamic>) ?? Enumerable.Empty<dynamic>();
}

<div style="background:var(--bg2);padding:100px 0 40px;border-bottom:1px solid var(--border)">
    <div class="container">
        <div class="section-label">Chủ sân</div>
        <h1 style="font-style:italic;line-height:0.9;margin-bottom:8px">
            DASHBOARD<br><span class="text-green">OWNER PORTAL</span>
        </h1>
        <p style="color:var(--muted)">Quản lý cơ sở sân bóng của bạn</p>
    </div>
</div>

<!-- MENU OWNER -->
<div style="background:var(--bg3);border-bottom:1px solid var(--border);padding:12px 0;position:sticky;top:0;z-index:100">
    <div class="container d-flex gap-2 flex-wrap">
        <a href="/Owner" class="btn btn-sm btn-success rounded-pill">📊 Tổng quan</a>
        <a href="/Owner/DanhSachSan" class="btn btn-sm btn-outline-light rounded-pill">🏟️ Danh sách sân</a>
        <a href="/Owner/DangKySan" class="btn btn-sm btn-outline-warning rounded-pill">➕ Đăng ký sân mới</a>
        <a href="/Owner/QuanLyStaff" class="btn btn-sm btn-outline-info rounded-pill">👷 Nhân viên</a>
        <a href="/Owner/BaoCao" class="btn btn-sm btn-outline-light rounded-pill">📈 Báo cáo</a>
    </div>
</div>

<div class="container py-5">

    <!-- KPI 4 Ô -->
    <div class="summary-grid" style="margin-bottom:32px">
        <div class="s-card">
            <div style="font-size:11px;color:var(--muted);letter-spacing:1px;margin-bottom:4px">TỔNG SÂN</div>
            <div class="s-num">@ViewBag.TongSan</div>
            <div class="s-lbl">@ViewBag.SanDaDuyet đã duyệt / @ViewBag.SanChoDuyet chờ</div>
        </div>
        <div class="s-card" style="border:1px solid var(--green);background:rgba(30,215,96,0.05)">
            <div style="font-size:11px;color:var(--green);letter-spacing:1px;margin-bottom:4px">THU THUẦN THÁNG NÀY</div>
            <div class="s-num" style="color:var(--green)">@(((decimal)ViewBag.DoanhThuThang / 1_000_000m).ToString("F1"))M</div>
            <div class="s-lbl" style="color:var(--green)">Sau khi trừ hoa hồng PitchHub</div>
        </div>
        <div class="s-card">
            <div style="font-size:11px;color:var(--muted);letter-spacing:1px;margin-bottom:4px">HOA HỒNG ĐÃ TRỪ</div>
            <div class="s-num" style="font-size:1.8rem">@(((decimal)ViewBag.HoaHongThang / 1_000_000m).ToString("F2"))M</div>
            <div class="s-lbl">Phí nền tảng tháng này</div>
        </div>
        <div class="s-card">
            <div style="font-size:11px;color:var(--muted);letter-spacing:1px;margin-bottom:4px">ĐƠN HÔM NAY</div>
            <div class="s-num">@donHomNay.Count</div>
            <div class="s-lbl">Lịch đặt sân ngày hôm nay</div>
        </div>
    </div>

    <div class="row g-4 mb-4">

        <!-- Biểu đồ 6 tháng -->
        <div class="col-md-7" data-aos="fade-up">
            <div class="chart-card h-100">
                <div class="chart-title">Doanh thu thuần 6 tháng gần nhất</div>
                <div class="chart-sub">Sau khi trừ hoa hồng PitchHub</div>
                <div style="position:relative;height:220px"><canvas id="chartBieu"></canvas></div>
            </div>
        </div>

        <!-- Lịch hôm nay -->
        <div class="col-md-5" data-aos="fade-up" data-aos-delay="100">
            <div class="chart-card h-100">
                <div class="chart-title">Lịch đặt hôm nay</div>
                <div class="chart-sub">@DateTime.Now.ToString("dd/MM/yyyy")</div>
                @if (!donHomNay.Any())
                {
                    <div style="text-align:center;padding:30px;color:var(--muted);font-size:13px">
                        Chưa có lịch đặt hôm nay
                    </div>
                }
                @foreach (var don in donHomNay)
                {
                    var statusColor = don.TrangThai switch
                    {
                        "DaXacNhan" => "#1D9E75",
                        "DangSuDung" => "#8E44AD",
                        "HoanThanh" => "#6caee0",
                        _ => "var(--muted)"
                    };
                    <div style="display:flex;align-items:center;justify-content:space-between;padding:8px 0;border-bottom:1px solid var(--border);font-size:13px">
                        <div>
                            <div style="font-weight:600">@don.KhungGio?.SanBong?.TenSan</div>
                            <div style="color:var(--muted);font-size:12px">
                                @don.KhungGio?.GioBatDau.ToString(@"hh\:mm")–@don.KhungGio?.GioKetThuc.ToString(@"hh\:mm")
                                — @don.User?.HoTen
                            </div>
                        </div>
                        <span style="color:@statusColor;font-size:11px;font-weight:600">@don.TrangThai</span>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Shortcut actions -->
    <div data-aos="fade-up">
        <div style="color:var(--muted);font-size:11px;letter-spacing:1px;margin-bottom:16px">THAO TÁC NHANH</div>
        <div class="row g-3">
            @foreach (var item in new[] {
                        ("/Owner/DangKySan", "➕", "ĐĂNG KÝ SÂN MỚI", "Thêm cơ sở vào hệ thống PitchHub"),
                        ("/Owner/DanhSachSan", "🏟️", "QUẢN LÝ SÂN", "Sửa thông tin, bật/ẩn sân"),
                        ("/Owner/QuanLyStaff", "👷", "NHÂN VIÊN", "Tạo tài khoản và gán sân cho Staff"),
                        ("/Owner/BaoCao", "📈", "BÁO CÁO", "Doanh thu, lấp đầy, hiệu suất Staff"),
                        })
            {
                <div class="col-6 col-md-3">
                    <a href="@item.Item1" class="section-card p-3 d-block text-decoration-none"
                       style="transition:border-color 0.2s"
                       onmouseover="this.style.borderColor='var(--green)'"
                       onmouseout="this.style.borderColor='var(--border)'">
                        <div style="font-size:1.6rem;margin-bottom:8px">@item.Item2</div>
                        <div style="font-family:var(--ff-h);font-size:13px;margin-bottom:4px">@item.Item3</div>
                        <div style="font-size:12px;color:var(--muted)">@item.Item4</div>
                    </a>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
    <script>
        @{
                var lbls = System.Text.Json.JsonSerializer.Serialize(bieu.Select(d => (string)d.thang));
                var dts = System.Text.Json.JsonSerializer.Serialize(bieu.Select(d => Math.Round((double)d.dt / 1_000_000, 2)));
        }
        new Chart(document.getElementById('chartBieu'),{
            type:'bar',
            data:{
                labels:@Html.Raw(lbls),
                datasets:[{
                    label:'Thu thuần (triệu VND)',
                    data:@Html.Raw(dts),
                    backgroundColor:'rgba(30,215,96,0.2)',
                    borderColor:'#1ed760',borderWidth:1,borderRadius:5
                }]
            },
            options:{
                responsive:true,maintainAspectRatio:false,
                plugins:{legend:{display:false}},
                scales:{
                    x:{grid:{color:'rgba(255,255,255,0.04)'},ticks:{color:'#ffffff80',font:{size:11}}},
                    y:{grid:{color:'rgba(255,255,255,0.04)'},ticks:{color:'#ffffff80',font:{size:11},callback:v=>v+'M'}}
                }
            }
        });
    </script>
}
