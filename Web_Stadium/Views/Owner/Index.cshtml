@{
    ViewData["Title"] = "Dashboard Owner";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var donHomNay = ViewBag.DonHomNay as List<Web_Stadium.EFCore.DatSan> ?? new();
    var bieu = (ViewBag.Bieu6Thang as IEnumerable<dynamic>) ?? Enumerable.Empty<dynamic>();
}

<div style="background:var(--bg2);padding:100px 0 40px;border-bottom:1px solid var(--border)">
    <div class="container">
        <div class="section-label">Chủ sân</div>
        <h1 style="font-style:italic;line-height:0.9;margin-bottom:8px">
            DASHBOARD<br><span class="text-green">OWNER PORTAL</span>
        </h1>
        <p style="color:var(--muted)">Quản lý cơ sở sân bóng của bạn</p>
    </div>
</div>

<!-- MENU OWNER -->
<div style="background:var(--bg3);border-bottom:1px solid var(--border);padding:12px 0;position:sticky;top:0;z-index:100">
    <div class="container d-flex gap-2 flex-wrap justify-content-center">
        <a href="/Owner" class="btn btn-outline-success rounded-pill">📊 Tổng quan</a>
        <a href="/Owner/DanhSachSan" class="btn btn-outline-green rounded-pill">🏟️ Danh sách sân</a>
        <a href="/Owner/DangKySan" class="btn btn-outline-warning rounded-pill">➕ Đăng ký sân mới</a>
        <a href="/Owner/QuanLyStaff" class="btn btn-outline-info rounded-pill">👷 Nhân viên</a>
        <a href="/Owner/BaoCao" class="btn btn-outline-primary rounded-pill">📈 Báo cáo</a>
    </div>
</div>

<div class="container py-5">

    <!-- KPI -->
    <div class="row g-4 mb-4">

        <div class="col-12 col-md-6 col-xl-3">
            <div class="owner-kpi-card">
                <div class="owner-kpi-top">
                    <div>
                        <div class="owner-kpi-label">TỔNG SÂN</div>
                        <div class="owner-kpi-value">@ViewBag.TongSan</div>
                    </div>

                    <div class="owner-kpi-icon">
                        🏟️
                    </div>
                </div>

                <div class="owner-kpi-desc">
                    @ViewBag.SanDaDuyet đã duyệt /
                    @ViewBag.SanChoDuyet chờ duyệt
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-xl-3">
            <div class="owner-kpi-card active-green">
                <div class="owner-kpi-top">
                    <div>
                        <div class="owner-kpi-label text-green">
                            THU THUẦN THÁNG
                        </div>

                        <div class="owner-kpi-value text-green">
                            @(((decimal)ViewBag.DoanhThuThang / 1_000_000m).ToString("F1"))M
                        </div>
                    </div>

                    <div class="owner-kpi-icon green">
                        💰
                    </div>
                </div>

                <div class="owner-kpi-desc text-green">
                    Sau khi trừ hoa hồng PitchHub
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-xl-3">
            <div class="owner-kpi-card">
                <div class="owner-kpi-top">
                    <div>
                        <div class="owner-kpi-label">
                            HOA HỒNG
                        </div>

                        <div class="owner-kpi-value">
                            @(((decimal)ViewBag.HoaHongThang / 1_000_000m).ToString("F2"))M
                        </div>
                    </div>

                    <div class="owner-kpi-icon orange">
                        📉
                    </div>
                </div>

                <div class="owner-kpi-desc">
                    Phí nền tảng tháng này
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-xl-3">
            <div class="owner-kpi-card">
                <div class="owner-kpi-top">
                    <div>
                        <div class="owner-kpi-label">
                            ĐƠN HÔM NAY
                        </div>

                        <div class="owner-kpi-value">
                            @donHomNay.Count
                        </div>
                    </div>

                    <div class="owner-kpi-icon blue">
                        📅
                    </div>
                </div>

                <div class="owner-kpi-desc">
                    Lịch đặt sân hôm nay
                </div>
            </div>
        </div>

    </div>

    <!-- CHART + BOOKING -->
    <div class="row g-4 mb-5">

        <!-- Chart -->
        <div class="col-lg-7">

            <div class="owner-panel h-100">

                <div class="owner-panel-head">
                    <div>
                        <div class="owner-panel-title">
                            Doanh thu 6 tháng
                        </div>

                        <div class="owner-panel-sub">
                            Sau khi trừ hoa hồng PitchHub
                        </div>
                    </div>
                </div>

                <div style="position:relative;height:320px">
                    <canvas id="chartBieu"></canvas>
                </div>

            </div>

        </div>

        <!-- Booking -->
        <div class="col-lg-5">

            <div class="owner-panel h-100">

                <div class="owner-panel-head">
                    <div>
                        <div class="owner-panel-title">
                            Lịch đặt hôm nay
                        </div>

                        <div class="owner-panel-sub">
                            @DateTime.Now.ToString("dd/MM/yyyy")
                        </div>
                    </div>
                </div>

                @if (!donHomNay.Any())
                {
                    <div class="empty-owner">
                        Chưa có lịch đặt hôm nay
                    </div>
                }

                @foreach (var don in donHomNay)
                {
                    var statusColor = don.TrangThai switch
                    {
                        "DaXacNhan" => "#0EA86A",
                        "DangSuDung" => "#8E44AD",
                        "HoanThanh" => "#0EA5E9",
                        _ => "#64748B"
                    };

                    var statusBg = don.TrangThai switch
                    {
                        "DaXacNhan" => "rgba(14,168,106,.10)",
                        "DangSuDung" => "rgba(142,68,173,.12)",
                        "HoanThanh" => "rgba(14,165,233,.12)",
                        _ => "rgba(100,116,139,.08)"
                    };

                    <div class="booking-modern-item">

                        <div class="booking-modern-left">

                            <div class="booking-modern-time">
                                <strong>
                                    @don.KhungGio?.GioBatDau.ToString(@"hh\:mm")
                                </strong>

                                <span>
                                    @don.KhungGio?.GioKetThuc.ToString(@"hh\:mm")
                                </span>
                            </div>

                            <div>

                                <div class="booking-modern-title">
                                    @don.KhungGio?.SanBong?.TenSan
                                </div>

                                <div class="booking-modern-user">
                                    @don.User?.HoTen
                                </div>

                            </div>

                        </div>

                        <div class="booking-status"
                             style="background:@statusBg;color:@statusColor">
                            @don.TrangThai
                        </div>

                    </div>
                }

            </div>

        </div>

    </div>

    <!-- QUICK ACTION -->
    <div class="mb-3">
        <div class="section-label">QUICK ACTION</div>

        <h2 class="section-title">
            Quản lý <span class="em">hệ thống sân</span>
        </h2>
    </div>

    <div class="row g-4">

        @foreach (var item in new[] {
                ("/Owner/DangKySan", "➕", "ĐĂNG KÝ SÂN", "Thêm cơ sở mới vào hệ thống"),
                ("/Owner/DanhSachSan", "🏟️", "QUẢN LÝ SÂN", "Chỉnh sửa và cập nhật sân bóng"),
                ("/Owner/QuanLyStaff", "👷", "NHÂN VIÊN", "Phân quyền và quản lý Staff"),
                ("/Owner/BaoCao", "📈", "BÁO CÁO", "Xem thống kê và hiệu suất"),
                })
        {
            <div class="col-12 col-md-6 col-xl-3">

                <a href="@item.Item1"
                   class="owner-action-card text-decoration-none">

                    <div class="owner-action-icon">
                        @item.Item2
                    </div>

                    <div class="owner-action-title">
                        @item.Item3
                    </div>

                    <div class="owner-action-desc">
                        @item.Item4
                    </div>

                </a>

            </div>
        }

    </div>

</div>

<style>

    .owner-kpi-card {
        background: rgba(255,255,255,.92);
        border: 1px solid rgba(15,23,42,.06);
        border-radius: 28px;
        padding: 24px;
        height: 100%;
        transition: .3s;
        box-shadow: 0 10px 30px rgba(15,23,42,.05);
    }

        .owner-kpi-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 18px 40px rgba(15,23,42,.08);
        }

        .owner-kpi-card.active-green {
            border-color: rgba(14,168,106,.25);
            background: linear-gradient(180deg,#ffffff 0%,rgba(14,168,106,.04) 100%);
        }

    .owner-kpi-top {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 18px;
    }

    .owner-kpi-label {
        font-size: 11px;
        letter-spacing: 1.5px;
        color: var(--muted);
        font-weight: 700;
    }

    .owner-kpi-value {
        font-family: var(--ff-h);
        font-size: 3rem;
        line-height: 1;
        margin-top: 10px;
    }

    .owner-kpi-desc {
        font-size: 13px;
        color: var(--muted);
    }

    .owner-kpi-icon {
        width: 58px;
        height: 58px;
        border-radius: 20px;
        background: rgba(15,23,42,.05);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
    }

        .owner-kpi-icon.green {
            background: rgba(14,168,106,.10);
        }

        .owner-kpi-icon.orange {
            background: rgba(255,138,0,.10);
        }

        .owner-kpi-icon.blue {
            background: rgba(14,165,233,.10);
        }

    .owner-panel {
        background: rgba(255,255,255,.94);
        border: 1px solid rgba(15,23,42,.06);
        border-radius: 30px;
        padding: 26px;
        box-shadow: 0 10px 30px rgba(15,23,42,.05);
    }

    .owner-panel-head {
        margin-bottom: 24px;
    }

    .owner-panel-title {
        font-family: var(--ff-h);
        font-size: 24px;
    }

    .owner-panel-sub {
        color: var(--muted);
        font-size: 13px;
    }

    .booking-modern-item {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 14px;
        padding: 14px;
        border-radius: 18px;
        transition: .25s;
    }

        .booking-modern-item:hover {
            background: rgba(14,168,106,.04);
        }

    .booking-modern-left {
        display: flex;
        align-items: center;
        gap: 14px;
    }

    .booking-modern-time {
        width: 72px;
        border-radius: 16px;
        background: rgba(14,168,106,.08);
        text-align: center;
        padding: 10px;
    }

        .booking-modern-time strong {
            display: block;
            color: var(--green);
            font-size: 15px;
        }

        .booking-modern-time span {
            font-size: 11px;
            color: var(--muted);
        }

    .booking-modern-title {
        font-weight: 700;
        margin-bottom: 3px;
    }

    .booking-modern-user {
        font-size: 12px;
        color: var(--muted);
    }

    .booking-status {
        padding: 8px 12px;
        border-radius: 999px;
        font-size: 11px;
        font-weight: 700;
        white-space: nowrap;
    }

    .owner-action-card {
        display: block;
        background: #fff;
        border: 1px solid rgba(15,23,42,.06);
        border-radius: 28px;
        padding: 24px;
        height: 100%;
        transition: .3s;
        box-shadow: 0 10px 30px rgba(15,23,42,.04);
    }

        .owner-action-card:hover {
            transform: translateY(-8px);
            border-color: rgba(14,168,106,.2);
            box-shadow: 0 22px 42px rgba(15,23,42,.08);
        }

    .owner-action-icon {
        width: 70px;
        height: 70px;
        border-radius: 22px;
        background: rgba(14,168,106,.08);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 32px;
        margin-bottom: 20px;
    }

    .owner-action-title {
        font-family: var(--ff-h);
        font-size: 18px;
        margin-bottom: 8px;
    }

    .owner-action-desc {
        font-size: 13px;
        color: var(--muted);
        line-height: 1.7;
    }

    .empty-owner {
        padding: 60px 20px;
        text-align: center;
        color: var(--muted);
    }

    @@media(max-width:768px) {

        .owner-kpi-value {
            font-size: 2.3rem;
        }

        .booking-modern-item {
            flex-direction: column;
            align-items: flex-start;
        }
    }
</style>

@section Scripts {

    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>

    <script>

        @{
                var lbls = System.Text.Json.JsonSerializer.Serialize(
                        bieu.Select(d => (string)d.thang)
                );

                var dts = System.Text.Json.JsonSerializer.Serialize(
                        bieu.Select(d => Math.Round((double)d.dt / 1_000_000, 2))
                );
        }

        const ctx = document.getElementById('chartBieu');

        const gradient = ctx.getContext('2d').createLinearGradient(0,0,0,320);

        gradient.addColorStop(0,'rgba(14,168,106,.45)');
        gradient.addColorStop(.5,'rgba(14,168,106,.12)');
        gradient.addColorStop(1,'rgba(14,168,106,0)');

        new Chart(ctx, {

            type: 'line',

            data: {

                labels: @Html.Raw(lbls),

                datasets: [{

                    label: 'Doanh thu',

                    data: @Html.Raw(dts),

                    fill: true,

                    backgroundColor: gradient,

                    borderColor: '#0EA86A',

                    borderWidth: 3,

                    tension: .42,

                    pointRadius: 5,

                    pointHoverRadius: 8,

                    pointBorderWidth: 3,

                    pointBackgroundColor: '#fff',

                    pointBorderColor: '#0EA86A',

                    pointHoverBackgroundColor: '#0EA86A',

                    pointHoverBorderColor: '#fff'
                }]
            },

            options: {

                responsive: true,

                maintainAspectRatio: false,

                interaction: {
                    intersect: false,
                    mode: 'index'
                },

                plugins: {

                    legend: {
                        display: false
                    },

                    tooltip: {

                        backgroundColor: '#111827',

                        titleColor: '#fff',

                        bodyColor: '#d1d5db',

                        padding: 14,

                        cornerRadius: 16,

                        displayColors: false,

                        callbacks: {
                            label: function(context) {
                                return context.raw + ' triệu VNĐ';
                            }
                        }
                    }
                },

                scales: {

                    x: {

                        grid: {
                            display: false
                        },

                        border: {
                            display: false
                        },

                        ticks: {
                            color: '#64748B',
                            font: {
                                size: 12,
                                weight: 600
                            }
                        }
                    },

                    y: {

                        beginAtZero: true,

                        grid: {
                            color: 'rgba(15,23,42,.05)'
                        },

                        border: {
                            display: false
                        },

                        ticks: {

                            color: '#64748B',

                            callback: function(value) {
                                return value + 'M';
                            }
                        }
                    }
                }
            }
        });

    </script>
}