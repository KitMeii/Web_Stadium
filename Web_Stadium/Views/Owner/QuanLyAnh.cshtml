@model List<Web_Stadium.EFCore.AnhSanBong>
@{
    ViewData["Title"] = "Quản lý ảnh sân";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var san = ViewBag.San as Web_Stadium.EFCore.SanBong;
}

<style>
    .anh-page {
        max-width: 900px;
        margin: 0 auto;
        padding: 40px 0 72px;
    }

    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 13px;
        color: var(--muted);
        text-decoration: none;
        letter-spacing: 1px;
        text-transform: uppercase;
        margin-bottom: 24px;
        transition: color .2s;
    }

        .back-link:hover {
            color: var(--green);
        }

    /* Upload card */
    .upload-card {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 16px;
        overflow: hidden;
        margin-bottom: 24px;
    }

    .upload-card-header {
        padding: 16px 22px;
        border-bottom: 1px solid var(--border);
        font-size: 13px;
        font-weight: 700;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        color: var(--muted);
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .upload-card-body {
        padding: 22px;
    }

    /* Tabs */
    .upload-tabs {
        display: flex;
        gap: 8px;
        margin-bottom: 20px;
    }

    .utab {
        padding: 8px 20px;
        border-radius: 999px;
        font-size: 13px;
        font-weight: 700;
        cursor: pointer;
        border: 1.5px solid var(--border2);
        background: var(--bg);
        color: var(--muted);
        font-family: 'Segoe UI', Arial, sans-serif;
        transition: all .2s;
    }

        .utab.on {
            background: var(--green);
            border-color: var(--green);
            color: #fff;
        }

    /* Form inputs */
    .form-lbl {
        font-size: 12px;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        color: var(--muted);
        font-weight: 700;
        margin-bottom: 6px;
        display: block;
    }

    .form-inp {
        width: 100%;
        font-size: 15px;
        padding: 11px 14px;
        border: 1.5px solid var(--border2);
        border-radius: 10px;
        background: var(--bg);
        color: var(--text);
        font-family: 'Segoe UI', Arial, sans-serif;
        transition: border-color .2s;
        outline: none;
    }

        .form-inp:focus {
            border-color: var(--green);
            box-shadow: 0 0 0 3px rgba(14,168,106,.10);
        }

    /* File drop zone */
    .drop-zone {
        border: 2px dashed var(--border2);
        border-radius: 14px;
        padding: 36px;
        text-align: center;
        cursor: pointer;
        transition: all .2s;
        background: var(--bg3);
    }

        .drop-zone:hover, .drop-zone.drag-over {
            border-color: var(--green);
            background: rgba(14,168,106,0.04);
        }

        .drop-zone input[type=file] {
            display: none;
        }

    .drop-icon {
        font-size: 40px;
        margin-bottom: 10px;
        opacity: .5;
    }

    .drop-text {
        font-size: 14px;
        color: var(--muted);
        margin-bottom: 8px;
    }

    .drop-hint {
        font-size: 12px;
        color: var(--muted2);
    }

    /* Preview */
    #filePreview {
        display: none;
        margin-top: 16px;
        text-align: center;
    }

        #filePreview img {
            max-width: 100%;
            max-height: 280px;
            border-radius: 12px;
            border: 1px solid var(--border);
            object-fit: contain;
        }

    /* Gallery grid */
    .anh-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
        gap: 14px;
    }

    .anh-card {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 14px;
        overflow: hidden;
        position: relative;
        transition: border-color .2s, box-shadow .2s;
    }

        .anh-card:hover {
            border-color: rgba(14,168,106,.3);
            box-shadow: 0 4px 16px rgba(0,0,0,.08);
        }

    .anh-thumb {
        width: 100%;
        height: 150px;
        object-fit: cover;
        background: var(--bg3);
        display: block;
        cursor: zoom-in;
    }

    .anh-info {
        padding: 10px 12px;
        font-size: 12px;
        color: var(--muted);
        border-top: 1px solid var(--border);
    }

    .anh-badge {
        display: inline-block;
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 1px;
        padding: 2px 8px;
        border-radius: 999px;
        margin-bottom: 4px;
    }

    .badge-url {
        background: rgba(59,130,246,.10);
        color: #60a5fa;
    }

    .badge-upload {
        background: rgba(14,168,106,.10);
        color: var(--green);
    }

    .anh-actions {
        padding: 8px 12px;
        display: flex;
        gap: 6px;
        border-top: 1px solid var(--border);
    }

    .btn-xoa {
        flex: 1;
        padding: 6px;
        font-size: 12px;
        font-weight: 700;
        border: 1px solid rgba(239,68,68,.3);
        border-radius: 8px;
        background: rgba(239,68,68,.06);
        color: #ef4444;
        cursor: pointer;
        font-family: 'Segoe UI', Arial, sans-serif;
    }

        .btn-xoa:hover {
            background: #ef4444;
            color: #fff;
        }

    /* Drag order handle */
    .drag-handle {
        position: absolute;
        top: 8px;
        left: 8px;
        background: rgba(0,0,0,0.50);
        color: #fff;
        border-radius: 6px;
        padding: 3px 7px;
        font-size: 11px;
        cursor: grab;
        user-select: none;
    }

    .thu-tu-badge {
        position: absolute;
        top: 8px;
        right: 8px;
        background: rgba(0,0,0,0.55);
        color: #fff;
        border-radius: 999px;
        padding: 2px 10px;
        font-size: 12px;
        font-weight: 700;
    }

    /* Lightbox */
    #lightbox {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.88);
        z-index: 9999;
        align-items: center;
        justify-content: center;
    }

        #lightbox img {
            max-width: 92vw;
            max-height: 88vh;
            border-radius: 12px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.5);
        }

        #lightbox button {
            position: absolute;
            top: 16px;
            right: 20px;
            background: rgba(255,255,255,0.15);
            border: none;
            color: #fff;
            font-size: 28px;
            cursor: pointer;
            border-radius: 50%;
            width: 44px;
            height: 44px;
            display: flex;
            align-items: center;
            justify-content: center;
        }
    /* Nav arrows */
    .lb-prev, .lb-next {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        background: rgba(255,255,255,0.15);
        border: none;
        color: #fff;
        font-size: 24px;
        cursor: pointer;
        border-radius: 50%;
        width: 48px;
        height: 48px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .lb-prev {
        left: 16px;
    }

    .lb-next {
        right: 16px;
    }

    .empty-gallery {
        text-align: center;
        padding: 48px 24px;
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 16px;
    }
</style>

<!-- HEADER -->
<div style="background:var(--bg2);padding:88px 0 32px;border-bottom:1px solid var(--border)">
    <div class="container">
        <a href="/Owner/DanhSachSan" class="back-link">← Danh sách sân</a>
        <div style="font-size:12px;letter-spacing:2px;text-transform:uppercase;
                    color:var(--green);margin-bottom:8px;">
            Quản lý ảnh
        </div>
        <h1 style="font-family:'Segoe UI',Arial,sans-serif;font-size:clamp(24px,4vw,36px);
                   font-weight:800;margin:0;">
            @san?.TenSan
        </h1>
        <p style="color:var(--muted);font-size:14px;margin-top:6px;">
            Thêm ảnh thực tế của sân — người dùng sẽ xem ảnh trước khi đặt sân
        </p>
    </div>
</div>

<div class="container">
    <div class="anh-page">

        <!-- THÊM ẢNH MỚI -->
        <div class="upload-card">
            <div class="upload-card-header">
                📷 Thêm ảnh mới
            </div>
            <div class="upload-card-body">

                <!-- Tabs chon loai -->
                <div class="upload-tabs">
                    <button class="utab on" onclick="switchTab('file', this)">
                        💻 Upload từ máy
                    </button>
                    <button class="utab" onclick="switchTab('url', this)">
                        🔗 Dán đường dẫn URL
                    </button>
                </div>

                <!-- Tab Upload file -->
                <div id="tabFile">
                    <form method="post" action="/Owner/ThemAnhFile"
                          enctype="multipart/form-data">
                        <input type="hidden" name="sanId" value="@san?.Id" />

                        <div class="drop-zone" id="dropZone" onclick="document.getElementById('fileInput').click()">
                            <input type="file" id="fileInput" name="file"
                                   accept=".jpg,.jpeg,.png,.webp"
                                   onchange="previewFile(this)" />
                            <div class="drop-icon">🖼️</div>
                            <div class="drop-text">Kéo thả ảnh vào đây hoặc <strong style="color:var(--green)">bấm để chọn</strong></div>
                            <div class="drop-hint">JPG, PNG, WEBP · Tối đa 10MB</div>
                        </div>

                        <div id="filePreview">
                            <img id="previewImg" src="" alt="Preview" />
                            <div style="font-size:13px;color:var(--muted);margin-top:8px;" id="fileName"></div>
                        </div>

                        <div style="margin-top:14px;">
                            <label class="form-lbl">Mô tả ảnh (tùy chọn)</label>
                            <input type="text" name="moTa" class="form-inp"
                                   placeholder="VD: Mặt cỏ nhân tạo, góc sân phải..." />
                        </div>

                        <button type="submit" class="btn-primary-glow"
                                style="margin-top:16px;padding:12px 28px;font-size:14px;font-weight:700;">
                            ⬆️ Upload ảnh
                        </button>
                    </form>
                </div>

                <!-- Tab URL -->
                <div id="tabUrl" style="display:none;">
                    <form method="post" action="/Owner/ThemAnhURL">
                        <input type="hidden" name="sanId" value="@san?.Id" />

                        <div style="margin-bottom:14px;">
                            <label class="form-lbl">Đường dẫn ảnh *</label>
                            <input type="text" name="duongDan" id="urlInput"
                                   class="form-inp" required
                                   placeholder="https://example.com/anh-san.jpg"
                                   oninput="previewUrl(this.value)" />
                        </div>

                        <!-- Preview URL -->
                        <div id="urlPreview" style="display:none;margin-bottom:14px;text-align:center;">
                            <img id="urlPreviewImg" src="" alt="Preview"
                                 style="max-width:100%;max-height:240px;border-radius:12px;
                                        border:1px solid var(--border);object-fit:contain;"
                                 onerror="document.getElementById('urlPreview').style.display='none'" />
                        </div>

                        <div>
                            <label class="form-lbl">Mô tả ảnh (tùy chọn)</label>
                            <input type="text" name="moTa" class="form-inp"
                                   placeholder="VD: Nhìn từ khán đài..." />
                        </div>

                        <button type="submit" class="btn-primary-glow"
                                style="margin-top:16px;padding:12px 28px;font-size:14px;font-weight:700;">
                            ➕ Thêm ảnh từ URL
                        </button>
                    </form>
                </div>

            </div>
        </div>

        <!-- GALLERY HIỆN TẠI -->
        <div style="font-size:11px;letter-spacing:2px;text-transform:uppercase;
                    color:var(--muted);font-weight:700;margin-bottom:14px;">
            Ảnh hiện tại (@Model.Count ảnh)
            @if (Model.Count > 1)
            {
                <span style="font-size:11px;color:var(--muted2);font-weight:400;
                                 letter-spacing:0;text-transform:none;">
                    — Kéo thả để đổi thứ tự hiển thị
                </span>
            }
        </div>

        @if (!Model.Any())
        {
            <div class="empty-gallery">
                <div style="font-size:48px;opacity:.3;margin-bottom:12px;">📷</div>
                <div style="font-size:16px;font-weight:700;color:var(--text);margin-bottom:6px;">
                    Chưa có ảnh nào
                </div>
                <div style="font-size:14px;color:var(--muted);">
                    Thêm ảnh thực tế của sân để người dùng xem trước khi đặt
                </div>
            </div>
        }
        else
        {
            <div class="anh-grid" id="anhGrid">
                @foreach (var anh in Model)
                {
                    <div class="anh-card" data-id="@anh.Id">
                        <div class="drag-handle" title="Kéo để sắp xếp">⠿</div>
                        <div class="thu-tu-badge">@anh.ThuTu</div>
                        <img class="anh-thumb"
                             src="@anh.DuongDan"
                             alt="@(anh.MoTa ?? "Ảnh sân")"
                             onclick="openLightbox('@anh.DuongDan')"
                             onerror="this.src='/images/placeholder.png';this.style.opacity='.4'" />
                        <div class="anh-info">
                            <div class="anh-badge @(anh.LoaiAnh == "URL" ? "badge-url" : "badge-upload")">
                                @(anh.LoaiAnh == "URL" ? "🔗 URL" : "💻 Upload")
                            </div>
                            @if (!string.IsNullOrEmpty(anh.MoTa))
                            {
                                <div style="font-size:12px;color:var(--muted2);
                                                        overflow:hidden;text-overflow:ellipsis;
                                                        white-space:nowrap;">
                                    @anh.MoTa
                                </div>
                            }
                            <div style="font-size:11px;color:var(--muted2);margin-top:3px;">
                                @anh.NgayThem.ToString("dd/MM/yyyy")
                            </div>
                        </div>
                        <div class="anh-actions">
                            <form method="post" action="/Owner/XoaAnh" style="flex:1">
                                <input type="hidden" name="anhId" value="@anh.Id" />
                                <input type="hidden" name="sanId" value="@san?.Id" />
                                <button type="submit" class="btn-xoa"
                                        onclick="return confirm('Xóa ảnh này?')">
                                    🗑 Xóa
                                </button>
                            </form>
                        </div>
                    </div>
                }
            </div>
        }

    </div>
</div>

<!-- LIGHTBOX -->
<div id="lightbox" onclick="closeLightbox()">
    <button onclick="closeLightbox()">✕</button>
    <button class="lb-prev" onclick="event.stopPropagation();lbNav(-1)">‹</button>
    <button class="lb-next" onclick="event.stopPropagation();lbNav(1)">›</button>
    <img id="lbImg" src="" alt="Ảnh sân" onclick="event.stopPropagation()" />
</div>

@section Scripts {
    <script>
        (function(){
          // Tab switch
          window.switchTab = function(tab, btn){
            document.querySelectorAll('.utab').forEach(function(b){ b.classList.remove('on'); });
            btn.classList.add('on');
            document.getElementById('tabFile').style.display = tab==='file' ? '' : 'none';
            document.getElementById('tabUrl').style.display  = tab==='url'  ? '' : 'none';
          };

          // File preview
          window.previewFile = function(input){
            if(!input.files || !input.files[0]) return;
            var file = input.files[0];
            var reader = new FileReader();
            reader.onload = function(e){
              document.getElementById('previewImg').src = e.target.result;
              document.getElementById('fileName').textContent = file.name + ' (' + (file.size/1024/1024).toFixed(2) + 'MB)';
              document.getElementById('filePreview').style.display = 'block';
            };
            reader.readAsDataURL(file);
          };

          // URL preview - debounce 500ms
          var urlTimer;
          window.previewUrl = function(val){
            clearTimeout(urlTimer);
            if(!val || !val.startsWith('http')){ document.getElementById('urlPreview').style.display='none'; return; }
            urlTimer = setTimeout(function(){
              var img = document.getElementById('urlPreviewImg');
              img.src = val;
              document.getElementById('urlPreview').style.display = 'block';
            }, 500);
          };

          // Drag drop file
          var dz = document.getElementById('dropZone');
          if(dz){
            ['dragenter','dragover'].forEach(function(ev){
              dz.addEventListener(ev, function(e){ e.preventDefault(); dz.classList.add('drag-over'); });
            });
            ['dragleave','drop'].forEach(function(ev){
              dz.addEventListener(ev, function(e){ e.preventDefault(); dz.classList.remove('drag-over'); });
            });
            dz.addEventListener('drop', function(e){
              var files = e.dataTransfer.files;
              if(files.length){
                var fi = document.getElementById('fileInput');
                fi.files = files;
                previewFile(fi);
              }
            });
          }

          // Lightbox
          var lbSrcs = Array.from(document.querySelectorAll('.anh-thumb')).map(function(i){ return i.src; });
          var lbIdx = 0;
          window.openLightbox = function(src){
            lbIdx = lbSrcs.indexOf(src);
            document.getElementById('lbImg').src = src;
            document.getElementById('lightbox').style.display = 'flex';
            document.body.style.overflow = 'hidden';
          };
          window.closeLightbox = function(){
            document.getElementById('lightbox').style.display = 'none';
            document.body.style.overflow = '';
          };
          window.lbNav = function(dir){
            lbIdx = (lbIdx + dir + lbSrcs.length) % lbSrcs.length;
            document.getElementById('lbImg').src = lbSrcs[lbIdx];
          };
          document.addEventListener('keydown', function(e){
            if(document.getElementById('lightbox').style.display !== 'flex') return;
            if(e.key === 'Escape') closeLightbox();
            if(e.key === 'ArrowLeft') lbNav(-1);
            if(e.key === 'ArrowRight') lbNav(1);
          });

        })();
    </script>
}
