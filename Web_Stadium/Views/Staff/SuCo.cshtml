@{
    ViewData["Title"] = "Báo cáo Sự cố";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var donCoThe = ViewBag.DonCoThe as List<Web_Stadium.EFCore.DatSan> ?? new();
    var lichSuSuCo = ViewBag.LichSuSuCo as List<Web_Stadium.EFCore.DatSan> ?? new();
}

<div style="background:var(--bg2);padding:100px 0 36px;border-bottom:1px solid var(--border)">
    <div class="container">
        <div class="section-label">Staff — Báo cáo</div>
        <h1 style="font-style:italic;line-height:0.9">SỰ CỐ<br><span class="text-green">& BÁO CÁO</span></h1>
        <p style="color:var(--muted)">Ghi nhận No-show hoặc hỏng hóc để Owner xử lý</p>
    </div>
</div>

<div style="background:var(--bg3);border-bottom:1px solid var(--border);padding:12px 0;position:sticky;top:0;z-index:100">
    <div class="container d-flex gap-2">
        <a href="/Staff" class="btn btn-sm btn-outline-light rounded-pill">📋 Ca trực</a>
        <a href="/Staff/CheckIn" class="btn btn-sm btn-outline-warning rounded-pill">✅ Check-in</a>
        <a href="/Staff/SuCo" class="btn btn-sm btn-danger rounded-pill">⚠️ Sự cố</a>
    </div>
</div>

<div class="container py-5">

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">✅ @TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    }

    <div class="row g-4">

        <!-- CỘT TRÁI: Đơn có thể báo sự cố -->
        <div class="col-md-7">
            <div style="font-size:11px;color:#e74c3c;letter-spacing:1px;margin-bottom:12px">⚠️ ĐƠN CÓ THỂ BÁO SỰ CỐ</div>

            @if (!donCoThe.Any())
            {
                <div class="section-card p-4 text-center" style="color:var(--muted)">
                    <div style="font-size:2rem;margin-bottom:8px">✅</div>
                    Không có sự cố nào cần báo cáo.
                </div>
            }

            @foreach (var don in donCoThe)
            {
                <div class="section-card p-0 overflow-hidden mb-3">
                    <div style="padding:12px 16px;border-bottom:1px solid var(--border);display:flex;justify-content:space-between">
                        <div>
                            <strong style="font-size:13px">@don.KhungGio?.SanBong?.TenSan</strong>
                            <span style="color:var(--muted);font-size:12px;margin-left:8px">
                                @don.KhungGio?.GioBatDau.ToString(@"hh\:mm")–@don.KhungGio?.GioKetThuc.ToString(@"hh\:mm")
                                | @don.NgayThiDau.ToString("dd/MM/yyyy")
                            </span>
                            <br />
                            <span style="font-size:12px;color:var(--muted2)">
                                @don.User?.HoTen — @don.User?.SoDienThoai
                                — Cọc: <span style="color:var(--green)">@don.TienCoc.ToString("N0")đ</span>
                            </span>
                        </div>
                        <span style="color:@(don.TrangThai == "DangSuDung" ? "#8E44AD" : "var(--green)");font-size:11px;font-weight:600;white-space:nowrap">
                            @don.TrangThai
                        </span>
                    </div>
                    <form method="post" action="/Staff/GhiNhanSuCo" style="padding:12px 16px">
                        <input type="hidden" name="datSanId" value="@don.Id" />
                        <div class="row g-2 align-items-end">
                            <div class="col-auto">
                                <label style="font-size:11px;color:var(--muted);display:block;margin-bottom:4px">LOẠI SỰ CỐ</label>
                                <select name="loaiSuCo" class="form-select form-select-sm" required
                                        style="background:var(--bg3);border-color:var(--border);color:white;font-size:12px">
                                    <option value="NoShow">🚫 No-show (khách không đến)</option>
                                    <option value="HongHoc">🔧 Hỏng hóc cơ sở vật chất</option>
                                </select>
                            </div>
                            <div class="col">
                                <label style="font-size:11px;color:var(--muted);display:block;margin-bottom:4px">GHI CHÚ</label>
                                <input type="text" name="ghiChu" class="form-control form-control-sm"
                                       placeholder="Mô tả chi tiết sự cố..."
                                       style="background:var(--bg3);border-color:var(--border);color:white;font-size:12px" />
                            </div>
                            <div class="col-auto">
                                <button type="submit" class="btn btn-sm btn-danger rounded-pill"
                                        onclick="return confirm('Xác nhận báo sự cố cho đơn này?')">
                                    Ghi nhận
                                </button>
                            </div>
                        </div>
                        <div style="font-size:11px;color:var(--muted);margin-top:6px">
                            ⚠️ No-show sẽ chuyển đơn sang Đã huỷ — Owner sẽ được thông báo xử lý
                        </div>
                    </form>
                </div>
            }
        </div>

        <!-- CỘT PHẢI: Lịch sử sự cố -->
        <div class="col-md-5">
            <div style="font-size:11px;color:var(--muted);letter-spacing:1px;margin-bottom:12px">📋 LỊCH SỬ SỰ CỐ GẦN ĐÂY</div>

            @if (!lichSuSuCo.Any())
            {
                <div style="text-align:center;padding:30px;color:var(--muted);font-size:13px;border:1px solid var(--border);border-radius:8px">
                    Chưa có sự cố nào được ghi nhận
                </div>
            }

            @foreach (var don in lichSuSuCo)
            {
                var iconSuCo = don.LoaiSuCo == "NoShow" ? "🚫" : "🔧";
                var colorSuCo = don.LoaiSuCo == "NoShow" ? "#e74c3c" : "#f39c12";
                <div style="padding:12px;border:1px solid var(--border);border-radius:8px;margin-bottom:8px;border-left:3px solid @colorSuCo">
                    <div style="display:flex;justify-content:space-between;margin-bottom:4px">
                        <span style="font-size:13px;font-weight:600">
                            @iconSuCo @don.LoaiSuCo
                        </span>
                        <span style="font-size:11px;color:var(--muted)">@don.NgayThiDau.ToString("dd/MM/yyyy")</span>
                    </div>
                    <div style="font-size:12px;color:var(--muted2)">@don.KhungGio?.SanBong?.TenSan — @don.User?.HoTen</div>
                    @if (!string.IsNullOrEmpty(don.GhiChuSuCo))
                    {
                        <div style="font-size:12px;color:var(--muted);margin-top:4px;font-style:italic">"@don.GhiChuSuCo"</div>
                    }
                </div>
            }

            <!-- Lưu ý quyền hạn -->
            <div style="margin-top:20px;padding:14px;border:1px solid #633806;border-radius:8px;background:rgba(99,56,6,0.1)">
                <div style="font-size:11px;color:#f39c12;font-weight:600;margin-bottom:8px">⚠️ GIỚI HẠN QUYỀN HẠN STAFF</div>
                <div style="font-size:12px;color:var(--muted2);line-height:1.6">
                    Staff <strong>không được phép</strong>:
                    <ul style="margin:6px 0 0;padding-left:16px">
                        <li>Sửa đơn giá sân hoặc dịch vụ</li>
                        <li>Thay đổi khung giờ hoạt động</li>
                        <li>Xem báo cáo tài chính của Owner</li>
                        <li>Truy cập dữ liệu sân khác</li>
                    </ul>
                </div>
            </div>
        </div>

    </div>
</div>
