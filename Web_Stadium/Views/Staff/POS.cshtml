@model Web_Stadium.EFCore.DatSan
@{
    ViewData["Title"] = "POS Mini";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var danhSachDV = ViewBag.DanhSachDichVu as List<Web_Stadium.EFCore.DichVu> ?? new();
    var tongDichVu = Model.DatSanDichVus?.Sum(x => (x.DichVu?.Gia ?? 0) * x.SoLuong) ?? 0;
    var tongTatCa = (Model.KhungGio?.Gia ?? 0) + tongDichVu;
    var conLai = tongTatCa - Model.TienCoc;
}

<div style="background:var(--bg2);padding:100px 0 36px;border-bottom:1px solid var(--border)">
    <div class="container">
        <div class="section-label">Staff — POS Mini</div>
        <h1 style="font-style:italic;line-height:0.9">BÁN HÀNG<br><span class="text-green">TẠI QUẦY</span></h1>
        <p style="color:var(--muted)">Đơn #@Model.MaXacNhan — @Model.User?.HoTen</p>
    </div>
</div>

<div style="background:var(--bg3);border-bottom:1px solid var(--border);padding:12px 0;position:sticky;top:0;z-index:100">
    <div class="container d-flex gap-2">
        <a href="/Staff" class="btn btn-sm btn-outline-light rounded-pill">← Ca trực</a>
        <a href="/Staff/CheckOut/@Model.Id" class="btn btn-sm btn-success rounded-pill">✓ Check-out ngay</a>
    </div>
</div>

<div class="container py-4">

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">✅ @TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">❌ @TempData["Error"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    }

    <div class="row g-4">

        <!-- CỘT TRÁI: Dịch vụ có thể thêm -->
        <div class="col-md-7">
            <div style="font-size:11px;color:var(--muted);letter-spacing:1px;margin-bottom:12px">DANH MỤC DỊCH VỤ TẠI SÂN</div>

            @if (!danhSachDV.Any())
            {
                <div class="section-card p-4 text-center" style="color:var(--muted)">
                    <div style="font-size:2rem;margin-bottom:8px">📦</div>
                    Không có dịch vụ nào trong kho. Liên hệ Owner để cập nhật tồn kho.
                </div>
            }

            <div class="row g-3">
                @foreach (var dv in danhSachDV)
                {
                    <div class="col-6">
                        <div class="section-card p-3">
                            <div style="font-size:11px;color:var(--muted);margin-bottom:4px">
                                Còn: <span style="color:@(dv.TonKho < 5 ? "#e74c3c" : "var(--green)")">@dv.TonKho</span>
                            </div>
                            <div style="font-weight:600;margin-bottom:2px">@dv.TenDichVu</div>
                            <div style="color:var(--green);font-size:14px;margin-bottom:12px">@dv.Gia.ToString("N0")đ</div>
                            <form method="post" action="/Staff/ThemDichVuPOS" style="display:flex;gap:6px">
                                <input type="hidden" name="datSanId" value="@Model.Id" />
                                <input type="hidden" name="dichVuId" value="@dv.Id" />
                                <input type="number" name="soLuong" value="1" min="1" max="@dv.TonKho"
                                       style="width:56px;background:var(--bg3);border:1px solid var(--border);color:white;border-radius:6px;padding:4px 8px;font-size:13px" />
                                <button type="submit" class="btn btn-sm btn-warning rounded-pill flex-fill">
                                    + Thêm
                                </button>
                            </form>
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- CỘT PHẢI: Tổng kết đơn -->
        <div class="col-md-5">
            <div style="font-size:11px;color:var(--muted);letter-spacing:1px;margin-bottom:12px">TỔNG KẾT ĐƠN HIỆN TẠI</div>

            <div class="section-card p-4">
                <!-- Tiền sân -->
                <div style="display:flex;justify-content:space-between;font-size:13px;margin-bottom:10px;padding-bottom:10px;border-bottom:1px solid var(--border)">
                    <span style="color:var(--muted2)">
                        Tiền sân<br />
                        <small>@Model.KhungGio?.GioBatDau.ToString(@"hh\:mm") – @Model.KhungGio?.GioKetThuc.ToString(@"hh\:mm")</small>
                    </span>
                    <span style="font-weight:600">@(Model.KhungGio?.Gia.ToString("N0") ?? "0")đ</span>
                </div>

                <!-- Dịch vụ -->
                @if (Model.DatSanDichVus?.Any() == true)
                {
                    @foreach (var x in Model.DatSanDichVus)
                    {
                        <div style="display:flex;justify-content:space-between;font-size:13px;margin-bottom:6px">
                            <span style="color:var(--muted2)">@x.DichVu?.TenDichVu × @x.SoLuong</span>
                            <span>@(((x.DichVu?.Gia ?? 0) * x.SoLuong).ToString("N0"))đ</span>
                        </div>
                    }
                    <div style="display:flex;justify-content:space-between;font-size:13px;margin-bottom:10px;padding-bottom:10px;border-bottom:1px solid var(--border)">
                        <span style="color:var(--muted)">Tổng dịch vụ</span>
                        <span>@tongDichVu.ToString("N0")đ</span>
                    </div>
                }

                <!-- Tổng & còn lại -->
                <div style="display:flex;justify-content:space-between;font-size:14px;margin-bottom:6px">
                    <span>Tổng cộng</span>
                    <span style="font-weight:700">@tongTatCa.ToString("N0")đ</span>
                </div>
                <div style="display:flex;justify-content:space-between;font-size:13px;margin-bottom:6px">
                    <span style="color:var(--muted)">Đã cọc</span>
                    <span style="color:#6caee0">-@Model.TienCoc.ToString("N0")đ</span>
                </div>
                <div style="display:flex;justify-content:space-between;font-size:16px;font-weight:700;padding-top:10px;border-top:1px solid var(--border)">
                    <span>Còn lại phải thu</span>
                    <span style="color:var(--green)">@conLai.ToString("N0")đ</span>
                </div>

                <a href="/Staff/CheckOut/@Model.Id"
                   class="btn btn-success w-100 rounded-pill mt-3"
                   style="font-size:14px;padding:10px">
                    ✓ Tiến hành Check-out
                </a>
            </div>
        </div>
    </div>
</div>
