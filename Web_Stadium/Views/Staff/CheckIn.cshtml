@{
    ViewData["Title"] = "Check-in";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var ketQua = ViewBag.KetQua as Web_Stadium.EFCore.DatSan;
}

<div style="background:var(--bg2);padding:100px 0 36px;border-bottom:1px solid var(--border)">
    <div class="container">
        <div class="section-label">Staff — Nghiệp vụ</div>
        <h1 style="font-style:italic;line-height:0.9">CHECK-IN<br><span class="text-green">XÁC NHẬN KHÁCH ĐẾN SÂN</span></h1>
    </div>
</div>

<div style="background:var(--bg3);border-bottom:1px solid var(--border);padding:12px 0;position:sticky;top:0;z-index:100">
    <div class="container d-flex gap-2">
        <a href="/Staff" class="btn btn-sm btn-outline-light rounded-pill">📋 Ca trực</a>
        <a href="/Staff/CheckIn" class="btn btn-sm btn-warning rounded-pill">✅ Check-in</a>
        <a href="/Staff/SuCo" class="btn btn-sm btn-outline-danger rounded-pill">⚠️ Sự cố</a>
    </div>
</div>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-6">

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show">✅ @TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show">❌ @TempData["Error"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
            }

            <!-- Form tra cứu -->
            <div class="section-card p-4 mb-4">
                <div style="font-size:11px;color:var(--muted);letter-spacing:1px;margin-bottom:16px">TRA CỨU ĐƠN ĐẶT SÂN</div>
                <form method="get" action="/Staff/CheckIn">
                    <div style="display:flex;gap:8px">
                        <input type="text" name="tuKhoa"
                               value="@ViewBag.TuKhoa"
                               class="form-control"
                               placeholder="Nhập mã xác nhận (VD: ABC12345) hoặc số điện thoại..."
                               style="background:var(--bg3);border-color:var(--border);color:white;font-size:14px"
                               autofocus />
                        <button type="submit" class="btn btn-warning rounded-pill px-3">Tìm</button>
                    </div>
                </form>
                <div style="font-size:12px;color:var(--muted);margin-top:8px">
                    Có thể tìm bằng <strong>Mã xác nhận</strong> hoặc <strong>Số điện thoại</strong> của khách
                </div>
            </div>

            <!-- Kết quả tra cứu -->
            @if (ViewBag.TuKhoa != null && ketQua == null)
            {
                <div class="section-card p-4 text-center" style="border:1px solid #e74c3c">
                    <div style="font-size:2rem;margin-bottom:8px">🔍</div>
                    <div style="color:#e74c3c;font-weight:600">@ViewBag.ThongBao</div>
                </div>
            }

            @if (ketQua != null)
            {
                var statusColor = ketQua.TrangThai switch
                {
                    "DaXacNhan" => "var(--green)",
                    "DangSuDung" => "#8E44AD",
                    "HoanThanh" => "var(--muted)",
                    "DaHuy" => "#e74c3c",
                    _ => "var(--muted)"
                };

                <div class="section-card p-0 overflow-hidden" style="border:1px solid var(--green)">
                    <!-- Header -->
                    <div style="background:rgba(30,215,96,0.08);padding:16px 20px;display:flex;justify-content:space-between;align-items:center">
                        <div>
                            <div style="font-family:var(--ff-h);font-size:16px">@ketQua.KhungGio?.SanBong?.TenSan</div>
                            <div style="font-size:13px;color:var(--muted)">
                                @ketQua.KhungGio?.GioBatDau.ToString(@"hh\:mm") – @ketQua.KhungGio?.GioKetThuc.ToString(@"hh\:mm")
                                | @ketQua.NgayThiDau.ToString("dd/MM/yyyy")
                            </div>
                        </div>
                        <span style="color:@statusColor;font-weight:700;font-size:13px">@ketQua.TrangThai</span>
                    </div>

                    <!-- Thông tin khách -->
                    <div style="padding:16px 20px;border-bottom:1px solid var(--border)">
                        <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;font-size:13px">
                            <div><span style="color:var(--muted)">Khách hàng:</span><br /><strong>@ketQua.User?.HoTen</strong></div>
                            <div><span style="color:var(--muted)">SĐT:</span><br /><strong>@ketQua.User?.SoDienThoai</strong></div>
                            <div><span style="color:var(--muted)">Mã đơn:</span><br /><code style="color:var(--green);font-size:14px">@ketQua.MaXacNhan</code></div>
                            <div><span style="color:var(--muted)">Tiền cọc đã trả:</span><br /><strong style="color:var(--green)">@ketQua.TienCoc.ToString("N0")đ</strong></div>
                        </div>
                    </div>

                    <!-- Dịch vụ đặt trước -->
                    @if (ketQua.DatSanDichVus?.Any() == true)
                    {
                        <div style="padding:12px 20px;border-bottom:1px solid var(--border);background:rgba(0,0,0,0.15)">
                            <div style="font-size:11px;color:var(--muted);margin-bottom:8px">DỊCH VỤ ĐẶT TRƯỚC</div>
                            @foreach (var dv in ketQua.DatSanDichVus)
                            {
                                <div style="display:flex;justify-content:space-between;font-size:13px;margin-bottom:4px">
                                    <span>@dv.DichVu?.TenDichVu × @dv.SoLuong</span>
                                    <span style="color:var(--green)">@((dv.DichVu?.Gia ?? 0) * dv.SoLuong).ToString("N0")đ</span>
                                </div>
                            }
                        </div>
                    }

                    <!-- Hành động -->
                    <div style="padding:16px 20px">
                        @if (ketQua.TrangThai == "DaXacNhan")
                        {
                            <form method="post" action="/Staff/ThucHienCheckIn">
                                <input type="hidden" name="datSanId" value="@ketQua.Id" />
                                <button type="submit" class="btn btn-success w-100 rounded-pill"
                                        style="font-size:14px;padding:10px"
                                        onclick="return confirm('Xác nhận check-in cho @ketQua.User?.HoTen?')">
                                    ✅ Xác nhận Check-in — Chuyển sang Đang sử dụng
                                </button>
                            </form>
                        }
                        else if (ketQua.TrangThai == "DangSuDung")
                        {
                            <div style="display:flex;gap:8px">
                                <a href="/Staff/POS/@ketQua.Id" class="btn btn-warning rounded-pill flex-fill">🛒 POS mini</a>
                                <a href="/Staff/CheckOut/@ketQua.Id" class="btn btn-success rounded-pill flex-fill">✓ Check-out</a>
                            </div>
                        }
                        else
                        {
                            <div style="text-align:center;color:var(--muted);font-size:13px">
                                Đơn này ở trạng thái <strong>@ketQua.TrangThai</strong> — không thể thao tác
                            </div>
                        }
                    </div>
                </div>
            }

        </div>
    </div>
</div>
