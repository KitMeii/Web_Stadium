@model List<Web_Stadium.EFCore.DatSan>
@{
    ViewData["Title"] = "Dashboard Ca Trực";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var dangDien = ViewBag.DangDien as List<Web_Stadium.EFCore.DatSan> ?? new();
    var sapDen = ViewBag.SapDen as List<Web_Stadium.EFCore.DatSan> ?? new();
    var hoanThanh = ViewBag.HoanThanh as List<Web_Stadium.EFCore.DatSan> ?? new();
    var danhSachSan = ViewBag.DanhSachSan as List<Web_Stadium.EFCore.SanBong> ?? new();
    var now = (DateTime)(ViewBag.Now ?? DateTime.Now);
}

<div style="background:var(--bg2);padding:100px 0 36px;border-bottom:1px solid var(--border)">
    <div class="container d-flex justify-content-between align-items-end">
        <div>
            <div class="section-label">Nhân viên trực sân</div>
            <h1 style="font-style:italic;line-height:0.9;margin:0">
                CA TRỰC<br><span class="text-green">@now.ToString("dd/MM/yyyy")</span>
            </h1>
        </div>
        <div style="text-align:right;font-family:var(--ff-h);font-size:2rem;color:var(--green)" id="dongHo">
            @now.ToString("HH:mm")
        </div>
    </div>
</div>

<!-- MENU STAFF — chỉ có 4 mục, không có báo cáo tài chính -->
<div style="background:var(--bg3);border-bottom:1px solid var(--border);padding:12px 0;position:sticky;top:0;z-index:100">
    <div class="container d-flex gap-2 flex-wrap">
        <a href="/Staff" class="btn btn-sm btn-success rounded-pill">📋 Ca trực</a>
        <a href="/Staff/CheckIn" class="btn btn-sm btn-outline-warning rounded-pill">✅ Check-in</a>
        <a href="/Staff/SuCo" class="btn btn-sm btn-outline-danger rounded-pill">⚠️ Báo sự cố</a>
    </div>
</div>

<div class="container py-4">

    <!-- KPI nhanh -->
    <div class="row g-3 mb-4">
        <div class="col-4">
            <div class="section-card text-center p-3" style="border:1px solid #8E44AD">
                <div style="font-size:2rem;font-family:var(--ff-h);color:#8E44AD">@dangDien.Count</div>
                <div style="font-size:12px;color:var(--muted)">Đang sử dụng</div>
            </div>
        </div>
        <div class="col-4">
            <div class="section-card text-center p-3" style="border:1px solid var(--green)">
                <div style="font-size:2rem;font-family:var(--ff-h);color:var(--green)">@sapDen.Count</div>
                <div style="font-size:12px;color:var(--muted)">Sắp đến hôm nay</div>
            </div>
        </div>
        <div class="col-4">
            <div class="section-card text-center p-3">
                <div style="font-size:2rem;font-family:var(--ff-h);color:var(--muted2)">@hoanThanh.Count</div>
                <div style="font-size:12px;color:var(--muted)">Đã xong hôm nay</div>
            </div>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">✅ @TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">❌ @TempData["Error"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    }

    <!-- ĐANG SỬ DỤNG -->
    @if (dangDien.Any())
    {
        <div style="margin-bottom:28px">
            <div style="font-size:11px;color:#8E44AD;letter-spacing:1px;margin-bottom:12px">🟣 ĐANG SỬ DỤNG (@dangDien.Count)</div>
            @foreach (var don in dangDien)
            {
                <div class="section-card p-0 overflow-hidden mb-3" style="border:1px solid #8E44AD">
                    <div style="background:rgba(142,68,173,0.1);padding:12px 16px;display:flex;justify-content:space-between;align-items:center">
                        <div>
                            <strong>@don.KhungGio?.SanBong?.TenSan</strong>
                            <span style="color:var(--muted);font-size:13px;margin-left:10px">
                                @don.KhungGio?.GioBatDau.ToString(@"hh\:mm") – @don.KhungGio?.GioKetThuc.ToString(@"hh\:mm")
                            </span>
                        </div>
                        <span style="background:#8E44AD;color:white;padding:2px 10px;border-radius:10px;font-size:12px">Đang đá</span>
                    </div>
                    <div style="padding:12px 16px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:8px">
                        <div style="font-size:13px">
                            <span style="color:var(--muted)">Khách:</span> <strong>@don.User?.HoTen</strong>
                            <span style="color:var(--muted);margin-left:12px">Mã:</span> <code style="color:var(--green)">@don.MaXacNhan</code>
                        </div>
                        <div style="display:flex;gap:6px">
                            <a href="/Staff/POS/@don.Id" class="btn btn-sm btn-outline-warning rounded-pill">🛒 POS</a>
                            <a href="/Staff/CheckOut/@don.Id" class="btn btn-sm btn-success rounded-pill">✓ Check-out</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    <!-- SẮP ĐẾN -->
    @if (sapDen.Any())
    {
        <div style="margin-bottom:28px">
            <div style="font-size:11px;color:var(--green);letter-spacing:1px;margin-bottom:12px">🟢 SẮP ĐẾN HÔM NAY (@sapDen.Count)</div>
            @foreach (var don in sapDen)
            {
                <div class="section-card p-0 overflow-hidden mb-2">
                    <div style="padding:12px 16px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:8px">
                        <div>
                            <strong style="font-size:13px">@don.KhungGio?.SanBong?.TenSan</strong>
                            <span style="color:var(--muted);font-size:12px;margin-left:8px">
                                @don.KhungGio?.GioBatDau.ToString(@"hh\:mm") – @don.KhungGio?.GioKetThuc.ToString(@"hh\:mm")
                            </span>
                            <br />
                            <span style="font-size:12px;color:var(--muted2)">
                                @don.User?.HoTen — <code style="color:#6caee0">@don.MaXacNhan</code>
                                — Cọc: <span style="color:var(--green)">@don.TienCoc.ToString("N0")đ</span>
                            </span>
                        </div>
                        <div style="display:flex;gap:6px">
                            <form method="post" action="/Staff/ThucHienCheckIn">
                                <input type="hidden" name="datSanId" value="@don.Id" />
                                <button type="submit" class="btn btn-sm btn-warning rounded-pill"
                                        onclick="return confirm('Check-in cho @don.User?.HoTen?')">
                                    ✅ Check-in
                                </button>
                            </form>
                            <a href="/Staff/SuCo" class="btn btn-sm btn-outline-danger rounded-pill">⚠️ Sự cố</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    <!-- ĐÃ HOÀN THÀNH -->
    @if (hoanThanh.Any())
    {
        <div>
            <div style="font-size:11px;color:var(--muted);letter-spacing:1px;margin-bottom:12px">✓ ĐÃ XONG HÔM NAY (@hoanThanh.Count)</div>
            @foreach (var don in hoanThanh)
            {
                <div style="padding:10px 16px;border:1px solid var(--border);border-radius:8px;margin-bottom:6px;opacity:0.6;display:flex;justify-content:space-between;font-size:13px">
                    <span>@don.KhungGio?.SanBong?.TenSan — @don.User?.HoTen</span>
                    <span style="color:var(--muted)">@don.KhungGio?.GioBatDau.ToString(@"hh\:mm") – @don.KhungGio?.GioKetThuc.ToString(@"hh\:mm")</span>
                </div>
            }
        </div>
    }

    @if (!Model.Any())
    {
        <div style="text-align:center;padding:80px 0;color:var(--muted)">
            <div style="font-size:3rem;margin-bottom:16px">📋</div>
            <div style="font-family:var(--ff-h);font-size:1.2rem">Chưa có lịch đặt sân hôm nay</div>
            <div style="font-size:13px;margin-top:8px">Các sân phụ trách: @string.Join(", ", danhSachSan.Select(s => s.TenSan))</div>
        </div>
    }

</div>

@section Scripts {
    <script>
        // Đồng hồ realtime
        function capNhatGio() {
            var now = new Date();
            var h = String(now.getHours()).padStart(2,'0');
            var m = String(now.getMinutes()).padStart(2,'0');
            var el = document.getElementById('dongHo');
            if(el) el.textContent = h + ':' + m;
        }
        setInterval(capNhatGio, 1000);
        // Tự reload trang mỗi 2 phút để cập nhật trạng thái
        setTimeout(() => location.reload(), 120000);
    </script>
}
