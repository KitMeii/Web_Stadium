@model Web_Stadium.EFCore.DatSan
@{
    ViewData["Title"] = "Check-out";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var tongTienDichVu = (decimal)(ViewBag.TongTienDichVu ?? 0m);
    var tongTatCa = (decimal)(ViewBag.TongTatCa ?? 0m);
    var conLai = (decimal)(ViewBag.ConLai ?? 0m);
}

<div style="background:var(--bg2);padding:100px 0 36px;border-bottom:1px solid var(--border)">
    <div class="container">
        <div class="section-label">Staff — Kết thúc ca</div>
        <h1 style="font-style:italic;line-height:0.9">CHECK-OUT<br><span class="text-green">THU TIỀN & KẾT THÚC</span></h1>
    </div>
</div>

<div style="background:var(--bg3);border-bottom:1px solid var(--border);padding:12px 0;position:sticky;top:0;z-index:100">
    <div class="container d-flex gap-2">
        <a href="/Staff/POS/@Model.Id" class="btn btn-sm btn-outline-warning rounded-pill">← POS mini</a>
        <a href="/Staff" class="btn btn-sm btn-outline-light rounded-pill">Ca trực</a>
    </div>
</div>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-6">

            <!-- Thông tin đơn -->
            <div class="section-card p-4 mb-4">
                <div style="font-size:11px;color:var(--muted);letter-spacing:1px;margin-bottom:16px">TỔNG KẾT ĐƠN #@Model.MaXacNhan</div>

                <!-- Khách hàng -->
                <div style="display:flex;align-items:center;gap:12px;padding:12px;background:rgba(0,0,0,0.2);border-radius:8px;margin-bottom:16px">
                    <div style="width:36px;height:36px;border-radius:50%;background:var(--green);display:flex;align-items:center;justify-content:center;font-weight:700;font-size:16px;flex-shrink:0">
                        @(Model.User?.HoTen?.FirstOrDefault())
                    </div>
                    <div>
                        <div style="font-weight:600">@Model.User?.HoTen</div>
                        <div style="font-size:12px;color:var(--muted)">@Model.User?.SoDienThoai</div>
                    </div>
                    <div style="margin-left:auto;text-align:right;font-size:12px;color:var(--muted)">
                        <div>@Model.KhungGio?.SanBong?.TenSan</div>
                        <div>@Model.KhungGio?.GioBatDau.ToString(@"hh\:mm") – @Model.KhungGio?.GioKetThuc.ToString(@"hh\:mm")</div>
                    </div>
                </div>

                <!-- Chi tiết tiền -->
                <div style="font-size:13px">
                    <div style="display:flex;justify-content:space-between;margin-bottom:8px">
                        <span style="color:var(--muted2)">Tiền thuê sân</span>
                        <span>@(Model.KhungGio?.Gia.ToString("N0") ?? "0")đ</span>
                    </div>

                    @if (Model.DatSanDichVus?.Any() == true)
                    {
                        @foreach (var x in Model.DatSanDichVus)
                        {
                            <div style="display:flex;justify-content:space-between;margin-bottom:6px;color:var(--muted2)">
                                <span>@x.DichVu?.TenDichVu × @x.SoLuong</span>
                                <span>@(((x.DichVu?.Gia ?? 0) * x.SoLuong).ToString("N0"))đ</span>
                            </div>
                        }
                        <div style="display:flex;justify-content:space-between;margin-bottom:8px;color:var(--muted)">
                            <span>Tổng dịch vụ</span>
                            <span>@tongTienDichVu.ToString("N0")đ</span>
                        </div>
                    }

                    <div style="border-top:1px solid var(--border);padding-top:10px;margin-top:4px">
                        <div style="display:flex;justify-content:space-between;margin-bottom:6px">
                            <span style="font-weight:600">TỔNG CỘNG</span>
                            <span style="font-weight:700;font-size:15px">@tongTatCa.ToString("N0")đ</span>
                        </div>
                        <div style="display:flex;justify-content:space-between;margin-bottom:6px;color:var(--muted)">
                            <span>Khách đã cọc</span>
                            <span style="color:#6caee0">−@Model.TienCoc.ToString("N0")đ</span>
                        </div>
                    </div>
                </div>

                <!-- Số tiền cần thu -->
                <div style="padding:16px;border-radius:8px;background:rgba(30,215,96,0.08);border:1px solid rgba(30,215,96,0.3);text-align:center;margin-top:8px">
                    <div style="font-size:12px;color:var(--muted);margin-bottom:4px">SỐ TIỀN CẦN THU TẠI QUẦY</div>
                    <div style="font-family:var(--ff-h);font-size:2.4rem;color:var(--green)">
                        @conLai.ToString("N0")đ
                    </div>
                </div>
            </div>

            <!-- Xác nhận checkout -->
            <div class="section-card p-4">
                <div style="font-size:12px;color:var(--muted2);margin-bottom:16px">
                    Sau khi bấm <strong>Xác nhận Check-out</strong>:
                    <ul style="margin-top:8px;padding-left:18px">
                        <li>Đơn chuyển sang trạng thái <strong style="color:var(--green)">Hoàn thành</strong></li>
                        <li>Khung giờ được <strong>giải phóng</strong> cho lượt đặt tiếp theo</li>
                        <li>Khách hàng có thể <strong>đánh giá sân</strong></li>
                    </ul>
                </div>

                <form method="post" action="/Staff/ThucHienCheckOut">
                    <input type="hidden" name="datSanId" value="@Model.Id" />
                    <button type="submit" class="btn btn-success w-100 rounded-pill"
                            style="font-size:15px;padding:12px;font-weight:700"
                            onclick="return confirm('Xác nhận đã thu @conLai.ToString("N0")đ và hoàn tất check-out?')">
                        ✅ Xác nhận Check-out — Thu @conLai.ToString("N0")đ
                    </button>
                </form>

                <a href="/Staff/POS/@Model.Id" class="btn btn-outline-warning w-100 rounded-pill mt-2"
                   style="font-size:13px">
                    ← Quay lại thêm dịch vụ
                </a>
            </div>

        </div>
    </div>
</div>
