@{
    ViewData["Title"] = "Đăng tin tìm đội";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var datSan = ViewBag.DatSan as Web_Stadium.EFCore.DatSan;
    var san = datSan?.KhungGio?.SanBong;
    var kg = datSan?.KhungGio;
}

<style>
    .create-wrap {
        max-width: 660px;
        margin: 0 auto;
        padding: 40px 0 72px;
    }

    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 13px;
        color: var(--muted);
        text-decoration: none;
        letter-spacing: 1px;
        text-transform: uppercase;
        margin-bottom: 28px;
        transition: color .2s;
    }

        .back-link:hover {
            color: var(--green);
        }

    .create-hdr {
        margin-bottom: 32px;
    }

        .create-hdr .lbl {
            font-size: 12px;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: var(--green);
            margin-bottom: 8px;
        }

        .create-hdr h1 {
            font-family: 'Segoe UI',Arial,sans-serif;
            font-size: clamp(26px,4vw,38px);
            font-weight: 800;
            font-style: normal;
            line-height: 1.05;
            color: var(--text);
            margin: 0;
        }

    /* San da dat card */
    .san-card {
        background: rgba(14,168,106,0.05);
        border: 1px solid rgba(14,168,106,0.18);
        border-radius: 14px;
        padding: 18px 20px;
        margin-bottom: 24px;
    }

    .san-card-lbl {
        font-size: 11px;
        letter-spacing: 2px;
        text-transform: uppercase;
        color: var(--green);
        margin-bottom: 10px;
        font-weight: 700;
    }

    .san-card-name {
        font-size: 18px;
        font-weight: 700;
        color: var(--text);
        margin-bottom: 8px;
        font-family: 'Segoe UI',Arial,sans-serif;
    }

    .san-card-meta {
        display: flex;
        gap: 16px;
        flex-wrap: wrap;
        font-size: 14px;
        color: var(--muted);
    }

        .san-card-meta span {
            display: flex;
            align-items: center;
            gap: 5px;
        }

    /* Form card */
    .form-card {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 28px;
    }

    .form-lbl {
        font-size: 12px;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        color: var(--muted);
        font-weight: 700;
        margin-bottom: 6px;
        display: block;
    }

    .form-field {
        margin-bottom: 20px;
    }

        .form-field input, .form-field textarea, .form-field select {
            width: 100%;
            font-size: 15px;
            padding: 11px 14px;
            border: 1.5px solid var(--border2);
            border-radius: 10px;
            background: var(--bg);
            color: var(--text);
            font-family: 'Segoe UI',Arial,sans-serif;
            transition: border-color .2s;
            outline: none;
        }

            .form-field input:focus, .form-field textarea:focus {
                border-color: var(--green);
                box-shadow: 0 0 0 3px rgba(14,168,106,0.10);
            }

        .form-field textarea {
            resize: vertical;
        }

    /* Notice box */
    .notice-box {
        background: rgba(251,191,36,0.07);
        border: 1px solid rgba(251,191,36,0.22);
        border-radius: 10px;
        padding: 14px 16px;
        font-size: 13px;
        color: var(--muted);
        line-height: 1.6;
        margin-top: 16px;
    }

    /* Empty state */
    .empty-guide {
        text-align: center;
        padding: 60px 24px;
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 16px;
    }

        .empty-guide .icon {
            font-size: 52px;
            margin-bottom: 16px;
        }

        .empty-guide h3 {
            font-family: 'Segoe UI',Arial,sans-serif;
            font-size: 20px;
            font-weight: 700;
            margin-bottom: 10px;
            color: var(--text);
        }

        .empty-guide p {
            font-size: 15px;
            color: var(--muted);
            line-height: 1.6;
            max-width: 360px;
            margin: 0 auto 24px;
        }

        .empty-guide .btn-row {
            display: flex;
            gap: 12px;
            justify-content: center;
            flex-wrap: wrap;
        }

    .btn-outline-grey {
        display: inline-flex;
        align-items: center;
        padding: 12px 24px;
        border: 1.5px solid var(--border2);
        border-radius: 999px;
        font-size: 14px;
        font-weight: 700;
        letter-spacing: 1px;
        text-decoration: none;
        color: var(--muted);
        font-family: 'Segoe UI',Arial,sans-serif;
        transition: all .2s;
    }

        .btn-outline-grey:hover {
            border-color: var(--green);
            color: var(--green);
        }

    .auto-cancel-notice {
        background: rgba(14,168,106,0.05);
        border: 1px solid rgba(14,168,106,0.15);
        border-radius: 10px;
        padding: 14px 16px;
        font-size: 13px;
        color: var(--muted);
        line-height: 1.6;
        margin-top: 12px;
    }
</style>

<!-- HEADER -->
<div style="background:var(--bg2);padding:88px 0 36px;border-bottom:1px solid var(--border);">
    <div class="container">
        <a href="/Matchmaking" class="back-link">← Danh sách tìm đội</a>
        <div class="create-hdr">
            <div class="lbl">Cộng đồng</div>
            <h1>ĐĂNG TIN<br><span class="text-green">TÌM ĐỘI</span></h1>
        </div>
    </div>
</div>

<div class="container">
    <div class="create-wrap">

        @if (datSan != null && san != null)
        {
            <!-- Sân đã đặt -->
            <div class="san-card">
                <div class="san-card-lbl">✅ Sân đã đặt</div>
                <div class="san-card-name">@san.TenSan</div>
                <div class="san-card-meta">
                    <span>📍 @san.DiaChi — @san.Quan</span>
                    <span>🕐 @kg?.GioBatDau.ToString(@"hh\:mm") – @kg?.GioKetThuc.ToString(@"hh\:mm")</span>
                    <span>📅 @datSan.NgayThiDau.ToString("dd/MM/yyyy")</span>
                    <span>⚽ Sân @san.LoaiSan người · @san.LoaiCo</span>
                </div>
            </div>

            <!-- Form đăng tin -->
            <div class="form-card">
                <div style="font-size:13px;letter-spacing:1.5px;text-transform:uppercase;
                                color:var(--muted);font-weight:700;margin-bottom:20px;">
                    Thông tin tin đăng
                </div>

                <form method="post" action="/Matchmaking/Create">
                    <input type="hidden" name="datSanId" value="@datSan.Id" />

                    <div class="form-field">
                        <label class="form-lbl">Tiêu đề *</label>
                        <input type="text" name="tieuDe" required
                               placeholder="VD: Cần thêm 2 tiền đạo — Sân Cầu Giấy 18h tối mai" />
                    </div>

                    <div class="form-field">
                        <label class="form-lbl">Mô tả thêm</label>
                        <textarea name="moTa" rows="4"
                              placeholder="Trình độ yêu cầu, phong cách chơi, cách liên hệ..."></textarea>
                    </div>

                    <div class="form-field">
                        <label class="form-lbl">Số người cần thêm *</label>
                        <input type="number" name="soNguoiCanThem" required
                               min="1" max="20" value="2" />
                    </div>

                    <button type="submit" class="btn-primary-glow"
                            style="width:100%;padding:15px;font-size:15px;
                                       font-family:'Segoe UI',Arial,sans-serif;font-weight:700;">
                        📢 Đăng tin tìm đội
                    </button>
                </form>

                <div class="auto-cancel-notice">
                    ℹ️ Số điện thoại tài khoản của bạn sẽ hiển thị để đội khác liên hệ.
                </div>
                <div class="notice-box">
                    ⚠️ <strong style="color:var(--text)">Lưu ý:</strong> Tin sẽ tự động hủy
                    <strong style="color:var(--text)">2 giờ trước</strong> trận đấu nếu chưa có đội nào liên hệ.
                </div>
            </div>
        }
        else
        {
            <!-- Không có datSan — hướng dẫn thân thiện -->
            <div class="empty-guide">
                <div class="icon">📋</div>
                <h3>Chọn đơn đặt sân trước</h3>
                <p>
                    Để đăng tin tìm đội, bạn cần chọn một đơn đặt sân đã xác nhận.
                    Vào <strong>Lịch đặt sân</strong> và nhấn nút
                    <strong style="color:var(--green)">"Tìm đội"</strong> trên đơn muốn đăng.
                </p>
                <div class="btn-row">
                    <a href="/Booking/MyBookings" class="btn-primary-glow"
                       style="display:inline-block;padding:13px 28px;font-size:14px;">
                        📅 Xem lịch đặt sân
                    </a>
                    <a href="/Matchmaking" class="btn-outline-grey">← Quay lại</a>
                </div>
                <div style="margin-top:24px;padding:16px 20px;
                                background:rgba(14,168,106,0.05);
                                border:1px solid rgba(14,168,106,0.15);
                                border-radius:12px;max-width:400px;margin-inline:auto;">
                    <div style="font-size:11px;letter-spacing:2px;text-transform:uppercase;
                                    color:var(--green);font-weight:700;margin-bottom:8px;">
                        Cơ chế tự động hủy
                    </div>
                    <div style="font-size:13px;color:var(--muted);line-height:1.6;">
                        Tin tìm đội sẽ tự động bị hủy
                        <strong style="color:var(--text)">2 giờ trước</strong>
                        trận đấu nếu chưa có đội nào liên hệ — đảm bảo danh sách luôn cập nhật.
                    </div>
                </div>
            </div>
        }

    </div>
</div>
