@model IEnumerable<Web_Stadium.EFCore.Matchmaking>
@{
    ViewData["Title"] = "Tìm đội đối thủ";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var tinMoiNhat = Model.FirstOrDefault();
    var sanMoiNhat = tinMoiNhat?.DatSan?.KhungGio?.SanBong;
    var kgMoiNhat = tinMoiNhat?.DatSan?.KhungGio;
    var initial = tinMoiNhat?.User?.HoTen?.Length > 0
                        ? tinMoiNhat.User.HoTen.Substring(0, 1).ToUpper() : "?";
    var tongTin = (int)(ViewBag.TongTin ?? Model.Count());
    var daDangNhap = Context.Request.Cookies["jwt"] != null;
    var tinHomNay = Model.Count(m => m.NgayDang.Date == DateTime.Today);
    var currentUserId = ViewBag.CurrentUserId as int?;
    var tongNguoi = Model.Sum(m => m.SoNguoiCanThem);
    var tongQuan = Model.Where(m => m.DatSan?.KhungGio?.SanBong?.Quan != null)
                             .Select(m => m.DatSan!.KhungGio!.SanBong!.Quan).Distinct().Count();
}

@section Styles {
    <link rel="stylesheet" href="~/css/matchmaking.css" />
    <style>
        /* ── AUTOCOMPLETE ── */
        .mm-search-wrap {
            position: relative;
            flex: 1;
            min-width: 200px;
            max-width: 280px;
        }

        .mm-search-inp {
            width: 100%;
            padding: 10px 16px 10px 36px;
            border: 1.5px solid var(--border2);
            border-radius: 10px;
            font-family: var(--ff-b);
            font-size: 13px;
            color: var(--text);
            background: #fff;
            outline: none;
            transition: border-color .2s;
        }

            .mm-search-inp:focus {
                border-color: var(--green);
                box-shadow: 0 0 0 3px rgba(14,168,106,0.10);
            }

        .mm-search-icon {
            position: absolute;
            left: 11px;
            top: 50%;
            transform: translateY(-50%);
            font-size: 14px;
            pointer-events: none;
        }

        .mm-ac-box {
            position: absolute;
            top: calc(100% + 6px);
            left: 0;
            right: 0;
            background: #fff;
            border: 1px solid var(--border2);
            border-radius: 12px;
            box-shadow: 0 8px 24px rgba(15,23,42,0.12);
            z-index: 500;
            overflow: hidden;
            display: none;
        }

            .mm-ac-box.show {
                display: block;
            }

        .mm-ac-item {
            padding: 9px 14px;
            cursor: pointer;
            font-size: 13px;
            color: var(--text);
            transition: background .12s;
            display: flex;
            align-items: center;
            gap: 10px;
            border-bottom: 1px solid var(--border);
        }

            .mm-ac-item:last-child {
                border-bottom: none;
            }

            .mm-ac-item:hover, .mm-ac-item.ac-hl {
                background: #F0FAF6;
            }

        .mm-ac-match {
            color: var(--green);
            font-weight: 700;
        }

        .mm-ac-sub {
            font-size: 11px;
            color: var(--muted);
            margin-top: 2px;
        }

        /* ── CARD hidden khi filter ── */
        .mm-card.mm-hidden {
            display: none !important;
        }

        /* ── Không có kết quả ── */
        .mm-no-result {
            display: none;
            text-align: center;
            padding: 60px 24px;
        }

            .mm-no-result.show {
                display: block;
            }
    </style>
}



<!-- HEADER -->
<div class="mm-header" style="background:linear-gradient(135deg,#edf7f2 0%,#F7F9FC 100%) !important; padding:0;">
    <div style="display:grid;grid-template-columns:1fr 1.15fr 1fr;align-items:center;
                padding:44px 40px 40px;position:relative;overflow:hidden;min-height:320px;">

        <div style="position:absolute;inset:0;pointer-events:none;opacity:.04;
             background-image:url('data:image/svg+xml,%3Csvg width=\'52\' height=\'52\' viewBox=\'0 0 52 52\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cg fill=\'none\' stroke=\'%230EA86A\' stroke-width=\'0.5\'%3E%3Crect x=\'4\' y=\'4\' width=\'44\' height=\'44\'/%3E%3Cline x1=\'26\' y1=\'4\' x2=\'26\' y2=\'48\'/%3E%3Ccircle cx=\'26\' cy=\'26\' r=\'9\'/%3E%3C/g%3E%3C/svg%3E');"></div>

        <!-- TRÁI -->
        <div style="display:flex;flex-direction:column;align-items:center;gap:16px;position:relative;z-index:2;padding:0 16px 0 0;">
            @if (tinMoiNhat != null)
            {
                <div style="position:relative;display:inline-block;">
                    <svg width="150" height="170" viewBox="0 0 130 148" fill="none">
                        <path d="M36 14 L8 36 L24 44 L24 136 L106 136 L106 44 L122 36 L94 14 L80 24 C74 28 56 28 50 24 Z" fill="#0EA86A" stroke="#097A4E" stroke-width="2" />
                        <path d="M50 24 C54 36 76 36 80 24" fill="none" stroke="#097A4E" stroke-width="1.5" />
                        <text x="65" y="92" text-anchor="middle" fill="white" font-family="Oswald,sans-serif" font-size="40" font-weight="700">@initial</text>
                    </svg>
                    @if (tongTin > 1)
                    {
                        <div style="position:absolute;top:-6px;right:-6px;background:#EF4444;color:white;
                                                            font-family:var(--ff-h);font-size:14px;font-weight:700;
                                                            width:26px;height:26px;border-radius:50%;
                                                            display:flex;align-items:center;justify-content:center;
                                                            border:2.5px solid white;box-shadow:0 2px 8px rgba(239,68,68,0.35);">
                            @tongTin
                        </div>
                    }
                </div>
                <div style="text-align:center;">
                    <div style="font-family:var(--ff-h);font-size:15px;font-weight:700;color:#0F172A;letter-spacing:1.5px;text-transform:uppercase;margin-bottom:8px;">Tin mới nhất</div>
                    @if (sanMoiNhat != null)
                    {
                        <div style="font-size:15px;color:var(--green);font-weight:600;margin-bottom:8px;">📍 @sanMoiNhat.TenSan</div>
                    }
                    @if (kgMoiNhat != null && tinMoiNhat?.DatSan != null)
                    {
                        <div style="font-size:14px;color:var(--muted);">
                            @tinMoiNhat.DatSan.NgayThiDau.ToString("dd/MM") &nbsp;·&nbsp;
                            @kgMoiNhat.GioBatDau.ToString(@"hh\:mm")–@kgMoiNhat.GioKetThuc.ToString(@"hh\:mm")
                            &nbsp;·&nbsp; Cần @tinMoiNhat.SoNguoiCanThem người
                        </div>
                    }
                    @if (tongTin > 1)
                    {
                        <div style="font-size:14px;color:var(--muted2);margin-top:6px;">+@(tongTin - 1) tin khác bên dưới</div>
                    }
                </div>
            }
            else
            {
                <div style="width:150px;height:170px;border:2px dashed rgba(15,23,42,0.15);border-radius:16px;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:8px;">
                    <div style="font-size:36px;opacity:.2;">👕</div>
                    <div style="font-family:var(--ff-h);font-size:15px;letter-spacing:1.5px;color:rgba(15,23,42,0.30);text-transform:uppercase;">Chưa có tin</div>
                </div>
                <div style="font-size:15px;color:var(--muted);text-align:center;">Hãy là người đầu tiên!</div>
            }
        </div>

        <!-- GIỮA -->
        <div style="display:flex;flex-direction:column;align-items:center;gap:14px;position:relative;z-index:2;padding:0 8px;">
            <div style="text-align:center;">
                <div class="section-label" style="justify-content:center;margin-bottom:8px;">Cộng đồng</div>
                <h1 style="font-style:italic;line-height:0.92;color:#0F172A;font-size:clamp(1.6rem,3vw,2.4rem);">
                    TÌM ĐỘI<br><span class="text-green">ĐỐI THỦ</span>
                </h1>
            </div>
            <svg width="100%" height="auto" viewBox="0 0 280 188" fill="none" style="max-width:300px;">
                <rect x="2" y="2" width="276" height="178" rx="10" fill="#1a3d2b" stroke="#2a5a3f" stroke-width="2" />
                <rect x="2" y="2" width="40" height="178" fill="#1e4530" />
                <rect x="82" y="2" width="40" height="178" fill="#1e4530" />
                <rect x="162" y="2" width="40" height="178" fill="#1e4530" />
                <rect x="242" y="2" width="36" height="178" fill="#1e4530" />
                <rect x="8" y="8" width="264" height="172" rx="4" fill="none" stroke="rgba(255,255,255,0.62)" stroke-width="1.5" />
                <line x1="140" y1="8" x2="140" y2="180" stroke="rgba(255,255,255,0.62)" stroke-width="1.5" />
                <circle cx="140" cy="94" r="28" fill="none" stroke="rgba(255,255,255,0.62)" stroke-width="1.5" />
                <rect x="8" y="56" width="20" height="76" rx="2" fill="none" stroke="rgba(255,255,255,0.62)" stroke-width="1.5" />
                <rect x="252" y="56" width="20" height="76" rx="2" fill="none" stroke="rgba(255,255,255,0.62)" stroke-width="1.5" />
                <circle cx="52" cy="50" r="8" fill="#0EA86A" stroke="white" stroke-width="1.8" />
                <circle cx="52" cy="138" r="8" fill="#0EA86A" stroke="white" stroke-width="1.8" />
                <circle cx="90" cy="70" r="8" fill="#0EA86A" stroke="white" stroke-width="1.8" />
                <circle cx="90" cy="118" r="8" fill="#0EA86A" stroke="white" stroke-width="1.8" />
                <circle cx="112" cy="94" r="8" fill="#22C97E" stroke="white" stroke-width="1.8" />
                <circle cx="228" cy="50" r="8" fill="#EF6C00" stroke="white" stroke-width="1.8" />
                <circle cx="228" cy="138" r="8" fill="#EF6C00" stroke="white" stroke-width="1.8" />
                <circle cx="190" cy="70" r="8" fill="#EF6C00" stroke="white" stroke-width="1.8" />
                <circle cx="190" cy="118" r="8" fill="#EF6C00" stroke="white" stroke-width="1.8" />
                <circle cx="168" cy="94" r="8" fill="#F5922E" stroke="white" stroke-width="1.8" />
                <circle cx="140" cy="94" r="9" fill="white" stroke="#e0e0e0" stroke-width="1.5" />
            </svg>
            <div style="background:#0F172A;color:white;font-family:var(--ff-h);font-size:16px;font-weight:700;letter-spacing:4px;padding:7px 26px;border-radius:8px;">VS</div>
        </div>

        <!-- PHẢI -->
        <div style="display:flex;flex-direction:column;align-items:center;gap:16px;position:relative;z-index:2;padding:0 0 0 16px;">
            <svg width="150" height="170" viewBox="0 0 130 148" fill="none">
                <path d="M36 14 L8 36 L24 44 L24 136 L106 136 L106 44 L122 36 L94 14 L80 24 C74 28 56 28 50 24 Z" fill="#EF6C00" stroke="#c45500" stroke-width="2" />
                <path d="M50 24 C54 36 76 36 80 24" fill="none" stroke="#c45500" stroke-width="1.5" />
                <text x="65" y="98" text-anchor="middle" fill="white" font-family="Oswald,sans-serif" font-size="52" font-weight="700">?</text>
            </svg>
            <div style="text-align:center;">
                <div style="font-family:var(--ff-h);font-size:15px;font-weight:700;color:#0F172A;letter-spacing:1.5px;text-transform:uppercase;margin-bottom:10px;">Đội của bạn?</div>
                <div style="font-size:14px;color:var(--muted);margin-bottom:14px;">@(tongTin > 0 ? tongTin + " tin đang chờ đối thủ" : "Hãy là người đầu tiên!")</div>
                @if (daDangNhap)
                {
                    <button type="button"
                            onclick="mmMoPopupChonDon()"
                            style="display:inline-block;background:var(--green);color:#fff;
                                       font-family:var(--ff-h);font-size:14px;font-weight:700;
                                       letter-spacing:1.5px;text-transform:uppercase;
                                       padding:11px 28px;border-radius:999px;border:none;
                                       cursor:pointer;box-shadow:0 4px 16px rgba(14,168,106,0.30);">
                        + Đăng ký ngay
                    </button>
                }
                else
                {
                    <a href="/Auth/Login?returnUrl=/Matchmaking/Create"
                       style="display:inline-block;background:var(--green);color:#fff;font-family:var(--ff-h);font-size:14px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;padding:11px 28px;border-radius:999px;text-decoration:none;box-shadow:0 4px 16px rgba(14,168,106,0.30);">
                        + Đăng nhập để đăng tin
                    </a>
                }
            </div>
        </div>
    </div>
</div>

<div class="container section">



    <div class="stat-row">
        <div class="stat-mini"><div class="num" id="statTin">@tongTin</div><div class="lbl">Tin đang tìm</div></div>
        <div class="stat-mini"><div class="num">@tongNguoi</div><div class="lbl">Người cần thêm</div></div>
        <div class="stat-mini"><div class="num">@tongQuan</div><div class="lbl">Quận có tin</div></div>
    </div>

    <!-- FILTER REALTIME — không submit form, không reload -->
    <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px;margin-bottom:16px;">
        <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;" id="mmFilter">

            <!-- Autocomplete tên sân / quận -->
            <div class="mm-search-wrap">
                <span class="mm-search-icon">🔍</span>
                <input class="mm-search-inp" id="mmSearchInp"
                       placeholder="Tìm tên sân, quận..."
                       autocomplete="off"
                       oninput="mmHandleSearch(this.value)"
                       onfocus="mmHandleSearch(this.value)"
                       onkeydown="mmHandleKey(event)" />
                <div class="mm-ac-box" id="mmAcBox"></div>
            </div>

            <!-- Select loại sân -->
            <select id="mmSelLoaiSan"
                    style="padding:9px 14px;border:1.5px solid var(--border2);border-radius:10px;
                           font-family:var(--ff-b);font-size:15px;background:#fff;color:var(--text);cursor:pointer;min-width:130px;"
                    onchange="mmApplyFilter()">
                <option value="">Loại sân</option>
                <option value="5">Sân 5 người</option>
                <option value="7">Sân 7 người</option>
                <option value="11">Sân 11 người</option>
            </select>

            <!-- Nút xoá filter -->
            <button id="mmBtnClear" onclick="mmClearFilter()"
                    style="display:none;font-family:var(--ff-h);font-size:15px;font-weight:700;letter-spacing:1.5px;
                           text-transform:uppercase;padding:9px 14px;border:1.5px solid var(--border2);
                           border-radius:10px;background:#fff;color:var(--muted);cursor:pointer;">
                ✕ Xoá lọc
            </button>
        </div>

        @if (daDangNhap)
        {
            <button type="button" class="btn-ghost-glow"
                    onclick="mmMoPopupChonDon()"
                    style="padding:10px 20px;font-size:14px;cursor:pointer;border:none;">
                + Đăng tin tìm đội
            </button>
        }
        else
        {

            <a href="/Auth/Login?returnUrl=/Matchmaking/Create" class="btn-ghost-glow" style="padding:10px 20px;font-size:14px;">Đăng nhập để đăng tin</a>
        }
    </div>

    <!-- Filter tags realtime -->
    <div id="mmFilterTags" style="display:none;gap:6px;flex-wrap:wrap;margin-bottom:16px;"></div>

    <!-- EMPTY STATE khi filter không ra gì -->
    <div class="mm-no-result" id="mmNoResult">
        <div class="empty-icon">🔍</div>
        <h3 style="font-family:var(--ff-h);margin-bottom:8px;">Không tìm thấy tin nào</h3>
        <p style="color:var(--muted);">Thử tìm kiếm với từ khóa khác.</p>
    </div>

    <!-- DANH SÁCH TIN -->
    @if (!Model.Any())
    {
        <div class="empty-state">
            <div class="empty-icon">⚽</div>
            <h3 style="font-family:var(--ff-h);margin-bottom:8px;">Chưa có tin tìm đội nào</h3>
            <p style="color:var(--muted);">Hãy là người đầu tiên đăng tin!</p>
        </div>
    }
    else
    {
        <div class="mm-grid" id="mmGrid">
            @foreach (var mm in Model)
            {
                var san = mm.DatSan?.KhungGio?.SanBong;
                var kg = mm.DatSan?.KhungGio;
                var initials = mm.User?.HoTen?.Length > 0 ? mm.User.HoTen.Substring(0, 1).ToUpper() : "?";
                var elapsed = DateTime.Now - mm.NgayDang;
                var timeAgo = elapsed.TotalHours < 1 ? "Vừa đăng" : $"{(int)elapsed.TotalHours}h trước";
                var tenSan = san?.TenSan ?? "";
                var quanSan = san?.Quan ?? "";
                var loaiSan = san?.LoaiSan.ToString() ?? "";

                <div class="mm-card"
                     data-tieude="@mm.TieuDe.ToLower()"
                     data-tensan="@tenSan.ToLower()"
                     data-quan="@quanSan.ToLower()"
                     data-loaisan="@loaiSan">
                    <div class="mm-card-header">
                        <div class="mm-title">@mm.TieuDe</div>
                        <div class="need-badge">Cần @mm.SoNguoiCanThem người</div>
                    </div>
                    <div class="mm-info-row">
                        @if (san != null)
                        {
                            <div class="mm-info-item"><span class="icon">🏟️</span><strong>@san.TenSan</strong></div>
                            <div class="mm-info-item"><span class="icon">📍</span>@san.DiaChi — @san.Quan</div>
                        }
                        @if (kg != null && mm.DatSan != null)
                        {
                            <div class="mm-info-item">
                                <span class="icon">🕐</span>
                                @mm.DatSan.NgayThiDau.ToString("dd/MM/yyyy") &nbsp;|&nbsp;
                                @kg.GioBatDau.ToString(@"hh\:mm") – @kg.GioKetThuc.ToString(@"hh\:mm")
                            </div>
                            <div class="mm-info-item"><span class="icon">⚽</span>Sân @san?.LoaiSan người &nbsp;·&nbsp; @san?.LoaiCo</div>
                        }
                    </div>
                    @if (!string.IsNullOrEmpty(mm.MoTa))
                    {
                        <div class="mm-desc">"@mm.MoTa"</div>
                    }
                    <div class="mm-footer">
                        <div class="mm-author">
                            <div class="mm-avatar">@initials</div>
                            <div>
                                <div class="mm-author-name">@mm.User?.HoTen</div>
                                <div class="mm-author-time">@timeAgo</div>
                            </div>
                        </div>
                        <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
                            @if (currentUserId.HasValue && mm.UserId == currentUserId.Value)
                            {
                                <form method="post" action="/Matchmaking/DaDu" style="display:inline">
                                    <input type="hidden" name="id" value="@mm.Id" />
                                    <button type="submit"
                                            style="padding:8px 16px;font-size:13px;font-weight:700;
                                                           border-radius:999px;border:1px solid rgba(14,168,106,0.4);
                                                           background:rgba(14,168,106,0.08);color:var(--green);cursor:pointer;"
                                            onclick="return confirm('Xác nhận đã đủ người? Tin sẽ bị đóng.')">
                                        ✅ Đã đủ người
                                    </button>
                                </form>
                                <form method="post" action="/Matchmaking/Dong" style="display:inline">
                                    <input type="hidden" name="id" value="@mm.Id" />
                                    <button type="submit"
                                            style="padding:8px 16px;font-size:13px;font-weight:700;
                                                           border-radius:999px;border:1px solid rgba(239,68,68,0.3);
                                                           background:rgba(239,68,68,0.06);color:#EF4444;cursor:pointer;"
                                            onclick="return confirm('Hủy tin tìm đội này?')">
                                        ✕ Hủy tin
                                    </button>
                                </form>
                            }
                            else
                            {
                                @if (mm.User?.SoDienThoai != null)
                                {
                                    <button type="button" class="btn-lien-he"
                                            onclick="mmLienHe('@mm.User.SoDienThoai',
                                                                         '@(mm.User?.HoTen?.Replace("'", "\'") ?? "")',
                                                                         '@(mm.User?.Email ?? "")')">
                                        📞 Liên hệ
                                    </button>
                                }
                                else if (mm.User?.Email != null)
                                {
                                    <a href="mailto:@mm.User.Email" class="btn-lien-he">✉️ Email</a>
                                }
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>


<!-- POPUP CHỌN ĐƠN ĐẶT SÂN -->
<div id="mmChonDonModal"
     style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.50);
            z-index:9999;align-items:center;justify-content:center;"
     onclick="if(event.target===this)mmDongPopupChonDon()">
    <div style="background:var(--card);border-radius:20px;max-width:480px;width:92%;
                box-shadow:0 20px 60px rgba(0,0,0,0.22);overflow:hidden;
                max-height:80vh;display:flex;flex-direction:column;">
        <div style="background:var(--green);padding:18px 24px;
                    display:flex;align-items:center;justify-content:space-between;">
            <div>
                <div style="font-size:11px;letter-spacing:2px;color:rgba(255,255,255,0.75);
                            text-transform:uppercase;margin-bottom:4px;">
                    Bước 1 / 2
                </div>
                <div style="font-size:16px;font-weight:700;color:#fff;">
                    Chọn đơn đặt sân để đăng tin
                </div>
            </div>
            <button onclick="mmDongPopupChonDon()"
                    style="background:rgba(255,255,255,0.15);border:none;color:#fff;
                           width:32px;height:32px;border-radius:50%;font-size:18px;
                           cursor:pointer;display:flex;align-items:center;justify-content:center;">
                ✕
            </button>
        </div>
        <div style="padding:20px 24px;overflow-y:auto;flex:1;" id="mmDonList">
            <div style="text-align:center;padding:30px;color:var(--muted);font-size:14px;">
                Đang tải danh sách đơn...
            </div>
        </div>
        <div style="padding:14px 24px;border-top:1px solid var(--border);
                    font-size:12px;color:var(--muted);text-align:center;">
            Chỉ hiển thị đơn đã xác nhận và chưa có tin tìm đội
        </div>
    </div>
</div>

<!-- MODAL LIÊN HỆ -->
<div id="mmLienHeModal"
     style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.45);
            z-index:9999;align-items:center;justify-content:center;"
     onclick="if(event.target===this)mmCloseLienHe()">
    <div style="background:var(--card);border-radius:20px;padding:28px 32px;
                max-width:360px;width:90%;box-shadow:0 20px 60px rgba(0,0,0,0.2);
                position:relative;">
        <button onclick="mmCloseLienHe()"
                style="position:absolute;top:12px;right:14px;background:none;
                       border:none;font-size:20px;cursor:pointer;color:var(--muted);">
            ✕
        </button>
        <div style="font-size:11px;letter-spacing:2px;text-transform:uppercase;
                    color:var(--muted);margin-bottom:12px;font-weight:700;">
            Thông tin liên hệ
        </div>
        <div style="font-size:18px;font-weight:700;color:var(--text);
                    margin-bottom:18px;" id="mmLHName"></div>
        <div style="display:flex;flex-direction:column;gap:10px;">
            <a id="mmLHSdt" href="#"
               style="display:flex;align-items:center;gap:10px;background:var(--green);
                      color:#fff;padding:13px 18px;border-radius:12px;text-decoration:none;
                      font-size:15px;font-weight:700;">
                📞 <span id="mmLHSdtTxt"></span>
            </a>
            <a id="mmLHEmail" href="#"
               style="display:flex;align-items:center;gap:10px;background:var(--bg3);
                      color:var(--text);padding:13px 18px;border-radius:12px;text-decoration:none;
                      font-size:14px;border:1px solid var(--border);">
                ✉️ <span id="mmLHEmailTxt"></span>
            </a>
        </div>
        <div style="font-size:12px;color:var(--muted);margin-top:14px;text-align:center;line-height:1.5;">
            Bấm vào số để gọi · bấm email để nhắn tin
        </div>
    </div>
</div>
@section Scripts {
    <script>
        (function(){
          var acIdx = -1;

          // ── Lấy tất cả card ──
          function allCards(){
            return Array.from(document.querySelectorAll('#mmGrid .mm-card'));
          }

          // ── Build danh sách gợi ý từ data-* trên card ──
          function buildSuggestions(){
            var seen = {};
            var list = [];
            allCards().forEach(function(c){
              var tieude = c.dataset.tieude;
              var tensan = c.dataset.tensan;
              var quan   = c.dataset.quan;
              [tieude, tensan, quan].forEach(function(v){
                if(v && !seen[v]){ seen[v]=1; list.push({label:v, card:c}); }
              });
            });
            return list;
          }

          // ── Apply filter realtime ──
          function mmApplyFilter(){
            var kw = document.getElementById('mmSearchInp').value.trim().toLowerCase();
            var ls = document.getElementById('mmSelLoaiSan').value;
            var cards  = allCards();
            var visible = 0;

            cards.forEach(function(c){
              var kwMatch = !kw || c.dataset.tieude.includes(kw) || c.dataset.tensan.includes(kw) || c.dataset.quan.includes(kw);
              var lsMatch = !ls || c.dataset.loaisan === ls;
              var show    = kwMatch && lsMatch;
              c.classList.toggle('mm-hidden', !show);
              if(show) visible++;
            });

            // No result
            document.getElementById('mmNoResult').classList.toggle('show', visible === 0);

            // Stat count
            var statEl = document.getElementById('statTin');
            if(statEl) statEl.textContent = visible;

            // Filter tags
            renderTags(kw, ls);

            // Xoá lọc button
            document.getElementById('mmBtnClear').style.display = (kw || ls) ? 'inline-block' : 'none';
          }
          window.mmApplyFilter = mmApplyFilter;

          function renderTags(kw, ls){
            var wrap = document.getElementById('mmFilterTags');
            if(!kw && !ls){ wrap.style.display='none'; wrap.innerHTML=''; return; }
            var html = '';
            if(kw) html += '<span style="background:rgba(14,168,106,0.10);border:1px solid rgba(14,168,106,0.25);color:#0EA86A;font-family:var(--ff-h);font-size:15px;letter-spacing:1.5px;padding:3px 10px;border-radius:999px;">🔍 "'+kw+'"</span>';
            if(ls) html += '<span style="background:rgba(14,168,106,0.10);border:1px solid rgba(14,168,106,0.25);color:#0EA86A;font-family:var(--ff-h);font-size:15px;letter-spacing:1.5px;padding:3px 10px;border-radius:999px;">⚽ Sân '+ls+' người</span>';
            wrap.innerHTML = html;
            wrap.style.display = 'flex';
          }

          // ── Xoá filter ──
          window.mmClearFilter = function(){
            document.getElementById('mmSearchInp').value = '';
            document.getElementById('mmSelLoaiSan').value = '';
            mmCloseAC();
            mmApplyFilter();
          };

          // ── Autocomplete ──
          window.mmHandleSearch = function(val){
            acIdx = -1;
            var kw = val.trim().toLowerCase();
            mmApplyFilter();
            if(!kw){ mmCloseAC(); return; }

            var sugs = buildSuggestions().filter(function(s){ return s.label.includes(kw); }).slice(0,6);
            var box  = document.getElementById('mmAcBox');
            if(!sugs.length){ mmCloseAC(); return; }

            box.innerHTML = sugs.map(function(s, i){
              var hl  = s.label.replace(new RegExp('('+kw.replace(/[.*+?^${}()|[\]\\]/g,'\\$&')+')','gi'),'<span class="mm-ac-match">$1</span>');
              var icon = s.label === s.card.dataset.quan ? '📍' : s.label === s.card.dataset.tensan ? '🏟️' : '📋';
              return '<div class="mm-ac-item" data-idx="'+i+'" onmousedown="mmPickAC(\''+s.label.replace(/'/g,"\\'")+'\')">'
                + icon + ' <div><div>'+hl+'</div></div></div>';
            }).join('');
            box.classList.add('show');
          };

          window.mmPickAC = function(val){
            document.getElementById('mmSearchInp').value = val;
            mmCloseAC();
            mmApplyFilter();
          };

          window.mmHandleKey = function(e){
            var items = document.querySelectorAll('#mmAcBox .mm-ac-item');
            if(e.key==='ArrowDown'){ acIdx=Math.min(acIdx+1,items.length-1); mmHlAC(items); e.preventDefault(); }
            else if(e.key==='ArrowUp'){ acIdx=Math.max(acIdx-1,0); mmHlAC(items); e.preventDefault(); }
            else if(e.key==='Enter'){
              if(acIdx>=0&&items[acIdx]) items[acIdx].dispatchEvent(new MouseEvent('mousedown'));
              else mmApplyFilter();
              e.preventDefault();
            }
            else if(e.key==='Escape') mmCloseAC();
          };

          function mmHlAC(items){ items.forEach(function(el,i){ el.classList.toggle('ac-hl', i===acIdx); }); }
          function mmCloseAC(){ document.getElementById('mmAcBox').classList.remove('show'); }
          window.mmCloseAC = mmCloseAC;

          document.addEventListener('click', function(e){
            if(!e.target.closest('.mm-search-wrap')) mmCloseAC();
          });

          // Modal liên hệ
          window.mmLienHe = function(sdt, ten, email){
            var modal = document.getElementById('mmLienHeModal');
            document.getElementById('mmLHName').textContent = ten || 'Người đăng';
            document.getElementById('mmLHSdtTxt').textContent = sdt;
            document.getElementById('mmLHSdt').href = 'tel:' + sdt;
            var eEl = document.getElementById('mmLHEmail');
            var eTxt = document.getElementById('mmLHEmailTxt');
            if(email){ eTxt.textContent=email; eEl.href='mailto:'+email; eEl.style.display='flex'; }
            else { eEl.style.display='none'; }
            modal.style.display = 'flex';
          };
          window.mmCloseLienHe = function(){
            document.getElementById('mmLienHeModal').style.display = 'none';
          };

          // Popup chọn đơn đặt sân
          window.mmMoPopupChonDon = function(){
            document.getElementById('mmChonDonModal').style.display = 'flex';
            mmTaiDanhSachDon();
          };
          window.mmDongPopupChonDon = function(){
            document.getElementById('mmChonDonModal').style.display = 'none';
          };

          function mmTaiDanhSachDon(){
            var listEl = document.getElementById('mmDonList');
            listEl.innerHTML = '<div style="text-align:center;padding:30px;color:var(--muted);font-size:14px;">Đang tải...</div>';
            fetch('/Matchmaking/GetDonCuaToi')
              .then(function(r){ return r.json(); })
              .then(function(data){
                if(!data || !data.length){
                  listEl.innerHTML = '<div style="text-align:center;padding:30px;">'
                    + '<div style="font-size:40px;margin-bottom:12px;opacity:.4;">📋</div>'
                    + '<div style="font-size:15px;font-weight:700;color:var(--text);margin-bottom:8px;">Chưa có đơn phù hợp</div>'
                    + '<div style="font-size:14px;color:var(--muted);margin-bottom:16px;">Bạn cần có đơn đặt sân đã xác nhận và chưa đăng tin.</div>'
                    + '<a href="/Venues" style="background:var(--green);color:#fff;padding:10px 22px;'
                    + 'border-radius:999px;text-decoration:none;font-size:14px;font-weight:700;">Tìm sân ngay</a>'
                    + '</div>';
                  return;
                }
                var html = data.map(function(d){
                  return '<a href="/Matchmaking/Create?datSanId='+d.id+'" class="mm-don-item">'
                    + '<div class="mm-don-name">'+d.tenSan+'</div>'
                    + '<div class="mm-don-meta">📅 '+d.ngayThiDau+' &nbsp;·&nbsp; 🕐 '+d.gio+'</div>'
                    + '<div class="mm-don-meta">📍 '+d.diaChi+'</div>'
                    + '<div class="mm-don-badge">✓ Đã xác nhận — Chọn đơn này</div>'
                    + '</a>';
                }).join('');
                listEl.innerHTML = html;
              })
              .catch(function(){
                listEl.innerHTML = '<div style="text-align:center;padding:30px;color:#EF4444;font-size:14px;">Lỗi tải dữ liệu. Vui lòng thử lại.</div>';
              });
          }

          // Lọc tin hôm nay
          window.mmLocHomNay = function(){
            allCards().forEach(function(c){
              c.classList.toggle('mm-hidden', c.dataset.homNay !== '1');
            });
            var visible = allCards().filter(function(c){ return !c.classList.contains('mm-hidden'); }).length;
            document.getElementById('mmNoResult').classList.toggle('show', visible===0);
            var st = document.getElementById('statTin'); if(st) st.textContent = visible;
            document.getElementById('mmGrid').scrollIntoView({behavior:'smooth'});
          };

        })();
    </script>
}