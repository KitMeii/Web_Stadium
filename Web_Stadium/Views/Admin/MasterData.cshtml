@{
    ViewData["Title"] = "Master Data";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var vungs = ViewBag.Vungs as List<Web_Stadium.EFCore.VungKhuVuc> ?? new();
    var quans = ViewBag.Quans as List<Web_Stadium.EFCore.DanhMucQuan> ?? new();
    var dichVus = ViewBag.DichVus as List<Web_Stadium.EFCore.DanhMucDichVu> ?? new();
    var loaiSans = ViewBag.LoaiSans as List<Web_Stadium.EFCore.DanhMucLoaiSan> ?? new();
    var loaiCos = ViewBag.LoaiCos as List<Web_Stadium.EFCore.DanhMucLoaiCo> ?? new();
}

<div style="background:var(--bg2);padding:100px 0 40px;border-bottom:1px solid var(--border)">
    <div class="container">
        <div class="section-label">Admin</div>
        <h1 style="font-style:italic;line-height:0.9">MASTER DATA<br><span class="text-green">DANH MỤC HỆ THỐNG</span></h1>
        <p style="color:var(--muted)">Quản lý phân vùng, danh mục — Owner dùng khi đăng ký sân</p>
    </div>
</div>

<div style="background:var(--bg3);border-bottom:1px solid var(--border);padding:12px 0;position:sticky;top:0;z-index:100">
    <div class="container d-flex gap-2 flex-wrap justify-content-center align-items-center">
        <a href="/Admin" class="btn btn-outline-green rounded-pill">📊 Tổng quan</a>
        <a href="/Admin/DuyetSan" class="btn btn-outline-warning rounded-pill">🏟️ Duyệt sân</a>
        <a href="/Admin/QuanLyUser" class="btn btn-outline-info rounded-pill">👥 Tài khoản</a>
        <a href="/Admin/MasterData" class="btn btn-outline-green rounded-pill">🗂️ Master Data</a>
        <a href="/Admin/KhieuNai" class="btn btn-outline-warning rounded-pill">⚠️ Khiếu nại</a>
        <a href="/Admin/BaoCao" class="btn btn-outline-secondary rounded-pill">📈 Báo cáo</a>
        <a href="/Admin/AuditLog" class="btn btn-outline-secondary rounded-pill">🛡️ Audit Log</a>
        <a href="/Admin/TatCaHopDong" class="btn btn-outline-primary rounded-pill">📑 Hợp đồng</a>
    </div>
</div>

<div class="container py-5" style="max-width:1200px">

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">✅ @TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">❌ @TempData["Error"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    }

    <!-- ══ PHÂN VÙNG HOA HỒNG (ưu tiên hiển thị trước) ══ -->
    <div class="section-card p-0 overflow-hidden mb-4" data-aos="fade-up">
        <div style="background:linear-gradient(135deg,#1F5C99,#0F6E56);padding:16px 20px;display:flex;justify-content:space-between;align-items:center">
            <div>
                <div style="color:white;font-family:var(--ff-h);font-size:18px">🗺️ PHÂN VÙNG HOA HỒNG</div>
                <div style="color:rgba(255,255,255,0.6);font-size:14px;margin-top:4px">Admin quản lý — không cần code lại khi thêm vùng mới</div>
            </div>
            <button class="btn btn-sm btn-light rounded-pill" data-bs-toggle="modal" data-bs-target="#modalThemVung">+ Thêm vùng</button>
        </div>

        <!-- BẢNG VÙNG -->
        <div style="overflow-x:auto">
            <table class="table table-hover table mb-0">
                <thead style="background:var(--bg3)">
                    <tr>
                        <th style="color:var(--muted);font-size:13px;padding:12px 16px">Tên vùng</th>
                        <th style="color:var(--muted);font-size:13px">Mô tả (các quận thuộc vùng)</th>
                        <th style="color:var(--muted);font-size:13px;text-align:center">Tỷ lệ HH</th>
                        <th style="color:var(--muted);font-size:13px;text-align:center">Màu</th>
                        <th style="color:var(--muted);font-size:13px;text-align:center">Số quận</th>
                        <th style="color:var(--muted);font-size:13px;text-align:center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var v in vungs)
                    {
                        <tr>
                            <td style="padding:12px 16px">
                                <div style="display:flex;align-items:center;gap:8px">
                                    <div style="width:12px;height:12px;border-radius:50%;background:@v.MauSac;flex-shrink:0"></div>
                                    <strong style="font-size:15px;font-weight:600">@v.TenVung</strong>
                                </div>
                            </td>
                            <td style="color:var(--muted2);font-size:12px">
                                @string.Join(", ", (v.DanhMucQuans ?? new List<Web_Stadium.EFCore.DanhMucQuan>()).Take(5).Select(q => q.TenQuan))
                                @if ((v.DanhMucQuans?.Count ?? 0) > 5)
                                {
                                    <text>...</text>
                                }
                            </td>
                            <td style="text-align:center">
                                <span style="background:@(v.MauSac)22;color:@v.MauSac;border:1px solid @v.MauSac;padding:3px 12px;border-radius:12px;font-size:14px;font-weight:700">
                                    @((v.TyLeHoaHong * 100).ToString("F0"))%
                                </span>
                            </td>
                            <td style="text-align:center">
                                <div style="width:24px;height:24px;border-radius:6px;background:@v.MauSac;margin:auto"></div>
                            </td>
                            <td style="text-align:center;color:var(--muted2);font-size:15px;font-weight:600">@(v.DanhMucQuans?.Count ?? 0)</td>
                            <td style="text-align:center">
                                <button class="btn btn-sm btn-outline-light rounded-pill"
                                        onclick="moSuaVung(@v.Id,'@v.TenVung',@v.TyLeHoaHong,'@v.MauSac','@v.MoTa')"
                                        style="font-size:13px;padding:4px 12px">
                                    Sửa %
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- GÁN QUẬN VÀO VÙNG -->
        <div style="border-top:1px solid var(--border);padding:16px 20px;background:rgba(0,0,0,0.2)">
            <div style="color:var(--muted);font-size:13px;letter-spacing:1px;margin-bottom:14px">GÁN QUẬN/HUYỆN VÀO VÙNG</div>
            <div style="display:flex;flex-wrap:wrap;gap:6px">
                @foreach (var q in quans)
                {
                    var vungColor = q.VungKhuVuc?.MauSac ?? "#555";
                    var vungName = q.VungKhuVuc?.TenVung ?? "Chưa gán";
                    <div style="display:inline-flex;align-items:center;gap:6px;background:var(--bg3);border:1px solid var(--border);border-radius:10px;padding:6px 12px;font-size:14px">
                        <div style="width:8px;height:8px;border-radius:50%;background:@vungColor"></div>
                        <span>@q.TenQuan</span>
                        <form method="post" action="/Admin/GanQuanVaoVung" style="display:inline;margin:0">
                            <input type="hidden" name="quanId" value="@q.Id" />
                            <select name="vungId" onchange="this.form.submit()"
                                    style="background:transparent;border:none;color:@vungColor;font-size:13px;cursor:pointer;outline:none">
                                <option value="">-- Chưa gán --</option>
                                @foreach (var v in vungs)
                                {
                                    <option value="@v.Id" selected="@(q.VungKhuVucId == v.Id)">@v.TenVung (@((v.TyLeHoaHong * 100).ToString("F0"))%)</option>
                                }
                            </select>
                        </form>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- ══ HÀNG 2: QUẬN + DỊCH VỤ ══ -->
    <div class="row g-4 mb-4">
        <div class="col-md-6" data-aos="fade-up">
            <div class="section-card p-0 overflow-hidden">
                <div style="background:#1F5C99;padding:14px 18px;display:flex;justify-content:space-between;align-items:center">
                    <span style="color:white;font-family:var(--ff-h);font-size:16px">📍 QUẬN / HUYỆN</span>
                    <button class="btn btn-sm btn-light rounded-pill" data-bs-toggle="modal" data-bs-target="#modalThemQuan">+ Thêm</button>
                </div>
                <div style="max-height:300px;overflow-y:auto">
                    <table class="table table-hover table mb-0">
                        <tbody>
                            @foreach (var q in quans.OrderBy(q => q.ThuTu))
                            {
                                <tr style="@(!q.IsActive ? "opacity:0.4" : "")">
                                    <td style="padding:10px 16px">
                                        <div style="display:flex;align-items:center;gap:6px">
                                            <div style="width:8px;height:8px;border-radius:50%;background:@(q.VungKhuVuc?.MauSac ?? "#555")"></div>
                                            <span style="font-size:15px">@q.TenQuan</span>
                                        </div>
                                    </td>
                                    <td style="font-size:13px;color:var(--muted)">@(q.VungKhuVuc?.TenVung ?? "Chưa gán")</td>
                                    <td>
                                        <form method="post" action="/Admin/DoiTrangThaiQuan" style="display:inline">
                                            <input type="hidden" name="id" value="@q.Id" />
                                            <input type="hidden" name="isActive" value="@(!q.IsActive)" />
                                            <button class="btn btn-link btn-sm p-0" style="font-size:13px;color:@(q.IsActive ? "var(--muted)" : "var(--green)")">@(q.IsActive ? "Tắt" : "Bật")</button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <div class="col-md-6" data-aos="fade-up" data-aos-delay="100">
            <div class="section-card p-0 overflow-hidden">
                <div style="background:#0F6E56;padding:14px 18px;display:flex;justify-content:space-between;align-items:center">
                    <span style="color:white;font-family:var(--ff-h);font-size:16px">💼 DANH MỤC DỊCH VỤ</span>
                    <button class="btn btn-sm btn-light rounded-pill" data-bs-toggle="modal" data-bs-target="#modalThemDichVu">+ Thêm</button>
                </div>
                <div style="max-height:300px;overflow-y:auto">
                    <table class="table table-hover table mb-0">
                        <tbody>
                            @foreach (var dv in dichVus)
                            {
                                <tr style="@(!dv.IsActive ? "opacity:0.4" : "")">
                                    <td style="font-size:22px;padding:12px 16px">@dv.Icon</td>
                                    <td style="font-size:15px;font-weight:500">@dv.TenDichVu</td>
                                    <td style="font-size:13px;color:var(--muted)">@dv.MoTa</td>
                                    <td>
                                        <form method="post" action="/Admin/DoiTrangThaiDichVu" style="display:inline">
                                            <input type="hidden" name="id" value="@dv.Id" />
                                            <input type="hidden" name="isActive" value="@(!dv.IsActive)" />
                                            <button class="btn btn-link btn-sm p-0" style="font-size:13px;color:@(dv.IsActive ? "var(--muted)" : "var(--green)")">@(dv.IsActive ? "Tắt" : "Bật")</button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- ══ HÀNG 3: LOẠI SÂN + LOẠI CỎ ══ -->
    <div class="row g-4">
        <div class="col-md-6" data-aos="fade-up">
            <div class="section-card p-0 overflow-hidden">
                <div style="background:#6D3FA0;padding:14px 18px;display:flex;justify-content:space-between;align-items:center">
                    <span style="color:white;font-family:var(--ff-h);font-size:16px">⚽ LOẠI SÂN</span>
                    <button class="btn btn-sm btn-light rounded-pill" data-bs-toggle="modal" data-bs-target="#modalThemLoaiSan">+ Thêm</button>
                </div>
                <table class="table table-hover table mb-0">
                    <tbody>
                        @foreach (var ls in loaiSans)
                        {
                            <tr style="@(!ls.IsActive ? "opacity:0.4" : "")">
                                <td style="padding:12px 16px"><span class="badge b-blue" style="font-size:15px;font-weight:600">@ls.MaLoai người</span></td>
                                <td style="font-size:15px">@ls.TenLoai</td>
                                <td>
                                    <form method="post" action="/Admin/DoiTrangThaiLoaiSan" style="display:inline">
                                        <input type="hidden" name="id" value="@ls.Id" /><input type="hidden" name="isActive" value="@(!ls.IsActive)" />
                                        <button class="btn btn-link btn-sm p-0" style="font-size:13px;color:@(ls.IsActive ? "var(--muted)" : "var(--green)")">@(ls.IsActive ? "Tắt" : "Bật")</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <div class="col-md-6" data-aos="fade-up" data-aos-delay="100">
            <div class="section-card p-0 overflow-hidden">
                <div style="background:#5D6D2A;padding:14px 18px;display:flex;justify-content:space-between;align-items:center">
                    <span style="color:white;font-family:var(--ff-h);font-size:16px">🌱 LOẠI CỎ</span>
                    <button class="btn btn-sm btn-light rounded-pill" data-bs-toggle="modal" data-bs-target="#modalThemLoaiCo">+ Thêm</button>
                </div>
                <table class="table table-hover table mb-0">
                    <tbody>
                        @foreach (var lc in loaiCos)
                        {
                            <tr style="@(!lc.IsActive ? "opacity:0.4" : "")">
                                <td style="padding:12px 16px;font-size:12px;color:var(--muted2)">@lc.MaLoai</td>
                                <td style="font-size:15px">@lc.TenLoai</td>
                                <td>
                                    <form method="post" action="/Admin/DoiTrangThaiLoaiCo" style="display:inline">
                                        <input type="hidden" name="id" value="@lc.Id" /><input type="hidden" name="isActive" value="@(!lc.IsActive)" />
                                        <button class="btn btn-link btn-sm p-0" style="font-size:13px;color:@(lc.IsActive ? "var(--muted)" : "var(--green)")">@(lc.IsActive ? "Tắt" : "Bật")</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- ══ MODALS ══ -->
<!-- Modal Thêm Vùng -->
<div class="modal fade" id="modalThemVung" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content" style="background:var(--bg2);border:1px solid var(--border)">
            <div class="modal-header" style="border-color:var(--border)">
                <h5 class="modal-title">Thêm Vùng khu vực mới</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" action="/Admin/ThemVung">
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-8">
                            <label class="form-label" style="color:var(--muted)">Tên vùng *</label>
                            <input type="text" name="tenVung" class="form-control" required placeholder="VD: Nội ô trung tâm" style="background:var(--bg3);border-color:var(--border);color:white" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label" style="color:var(--muted)">Tỷ lệ hoa hồng * (%)</label>
                            <input type="number" name="tyLeHoaHong" class="form-control" step="0.01" min="0.01" max="0.50" value="0.10" required style="background:var(--bg3);border-color:var(--border);color:white" />
                            <div class="form-text" style="color:var(--muted)">VD: 0.10 = 10%</div>
                        </div>
                        <div class="col-md-8">
                            <label class="form-label" style="color:var(--muted)">Mô tả các quận thuộc vùng</label>
                            <input type="text" name="moTa" class="form-control" placeholder="VD: Hoàn Kiếm, Ba Đình, Đống Đa..." style="background:var(--bg3);border-color:var(--border);color:white" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label" style="color:var(--muted)">Màu sắc</label>
                            <input type="color" name="mauSac" class="form-control form-control-color" value="#1ed760" style="background:var(--bg3);border-color:var(--border)" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label" style="color:var(--muted)">Thứ tự</label>
                            <input type="number" name="thuTu" class="form-control" value="0" style="background:var(--bg3);border-color:var(--border);color:white" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label" style="color:var(--muted)">Vĩ độ trung tâm (Lat)</label>
                            <input type="number" name="lat" class="form-control" step="0.0001" value="21.0285" style="background:var(--bg3);border-color:var(--border);color:white" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label" style="color:var(--muted)">Kinh độ trung tâm (Lng)</label>
                            <input type="number" name="lng" class="form-control" step="0.0001" value="105.8542" style="background:var(--bg3);border-color:var(--border);color:white" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer" style="border-color:var(--border)">
                    <button type="button" class="btn btn-outline-secondary rounded-pill" data-bs-dismiss="modal">Huỷ</button>
                    <button type="submit" class="btn btn-success rounded-pill">Thêm vùng</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal Sửa Vùng -->
<div class="modal fade" id="modalSuaVung" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content" style="background:var(--bg2);border:1px solid var(--border)">
            <div class="modal-header" style="border-color:var(--border)">
                <h5 class="modal-title" id="suaVungTitle">Sửa Vùng</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" action="/Admin/SuaVung">
                <div class="modal-body">
                    <input type="hidden" name="id" id="suaVungId" />
                    <div class="mb-3">
                        <label class="form-label" style="color:var(--muted)">Tỷ lệ hoa hồng (%)</label>
                        <input type="number" name="tyLeHoaHong" id="suaVungTyLe" class="form-control" step="0.01" min="0.01" max="0.50" style="background:var(--bg3);border-color:var(--border);color:white" />
                        <div class="form-text" style="color:var(--muted)">Thay đổi này ảnh hưởng hợp đồng MỚI, không ảnh hưởng sân đã ký</div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label" style="color:var(--muted)">Mô tả</label>
                        <input type="text" name="moTa" id="suaVungMoTa" class="form-control" style="background:var(--bg3);border-color:var(--border);color:white" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label" style="color:var(--muted)">Màu sắc</label>
                        <input type="color" name="mauSac" id="suaVungMauSac" class="form-control form-control-color" style="background:var(--bg3)" />
                    </div>
                </div>
                <div class="modal-footer" style="border-color:var(--border)">
                    <button type="button" class="btn btn-outline-secondary rounded-pill" data-bs-dismiss="modal">Huỷ</button>
                    <button type="submit" class="btn btn-warning rounded-pill">Cập nhật</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal Thêm Quận -->
<div class="modal fade" id="modalThemQuan" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content" style="background:var(--bg2);border:1px solid var(--border)">
            <div class="modal-header" style="border-color:var(--border)"><h5 class="modal-title">Thêm Quận/Huyện</h5><button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button></div>
            <form method="post" action="/Admin/ThemQuan">
                <div class="modal-body">
                    <div class="mb-3"><label class="form-label" style="color:var(--muted)">Tên quận *</label><input type="text" name="tenQuan" class="form-control" required style="background:var(--bg3);border-color:var(--border);color:white" /></div>
                    <div class="mb-3"><label class="form-label" style="color:var(--muted)">Thành phố</label><input type="text" name="thanhPho" class="form-control" value="Hà Nội" style="background:var(--bg3);border-color:var(--border);color:white" /></div>
                    <div class="mb-3"><label class="form-label" style="color:var(--muted)">Thứ tự</label><input type="number" name="thuTu" class="form-control" value="0" style="background:var(--bg3);border-color:var(--border);color:white" /></div>
                </div>
                <div class="modal-footer" style="border-color:var(--border)"><button type="button" class="btn btn-outline-secondary rounded-pill" data-bs-dismiss="modal">Huỷ</button><button type="submit" class="btn btn-success rounded-pill">Thêm</button></div>
            </form>
        </div>
    </div>
</div>

<!-- Các modal khác giữ nguyên từ file cũ: ThemDichVu, ThemLoaiSan, ThemLoaiCo -->
<div class="modal fade" id="modalThemDichVu" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content" style="background:var(--bg2);border:1px solid var(--border)">
            <div class="modal-header" style="border-color:var(--border)"><h5 class="modal-title">Thêm Danh mục Dịch vụ</h5><button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button></div>
            <form method="post" action="/Admin/ThemDanhMucDichVu">
                <div class="modal-body">
                    <div class="mb-3"><label class="form-label" style="color:var(--muted)">Tên dịch vụ *</label><input type="text" name="tenDichVu" class="form-control" required style="background:var(--bg3);border-color:var(--border);color:white" /></div>
                    <div class="mb-3"><label class="form-label" style="color:var(--muted)">Icon emoji</label><input type="text" name="icon" class="form-control" placeholder="💧" style="background:var(--bg3);border-color:var(--border);color:white" /></div>
                    <div class="mb-3"><label class="form-label" style="color:var(--muted)">Mô tả</label><textarea name="moTa" class="form-control" rows="2" style="background:var(--bg3);border-color:var(--border);color:white"></textarea></div>
                </div>
