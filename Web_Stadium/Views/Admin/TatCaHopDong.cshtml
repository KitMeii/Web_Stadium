@model List<Web_Stadium.EFCore.SanBong>
@{
    ViewData["Title"] = "Tất cả hợp đồng";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var tuKhoa = ViewBag.TuKhoa as string ?? "";
    var sapXep = ViewBag.SapXep as string ?? "gan_nhat";
    var tongHD = (int)(ViewBag.TongHD ?? Model.Count);
}

<style>
    .hd-page {
        max-width: 1100px;
        margin: 0 auto;
        padding: 36px 0 72px;
    }

    .hd-filter-bar {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 16px 20px;
        display: flex;
        gap: 12px;
        align-items: center;
        flex-wrap: wrap;
        margin-bottom: 24px;
    }

    .hd-search-inp {
        flex: 1;
        min-width: 220px;
        padding: 10px 16px;
        border: 1.5px solid var(--border2);
        border-radius: 10px;
        font-size: 14px;
        background: var(--bg);
        color: var(--text);
        outline: none;
        font-family: 'Segoe UI',Arial,sans-serif;
        transition: border-color .2s;
    }

        .hd-search-inp:focus {
            border-color: var(--green);
            box-shadow: 0 0 0 3px rgba(14,168,106,.10);
        }

    .hd-sel {
        padding: 10px 14px;
        border: 1.5px solid var(--border2);
        border-radius: 10px;
        font-size: 14px;
        background: var(--bg);
        color: var(--text);
        cursor: pointer;
        min-width: 160px;
        font-family: 'Segoe UI',Arial,sans-serif;
    }

    .hd-card {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 22px 24px;
        display: flex;
        align-items: center;
        gap: 20px;
        transition: border-color .2s, box-shadow .2s;
        margin-bottom: 12px;
    }

        .hd-card:hover {
            border-color: rgba(14,168,106,.3);
            box-shadow: 0 4px 20px rgba(14,168,106,.08);
        }

    .hd-num {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: rgba(14,168,106,.10);
        color: var(--green);
        font-size: 14px;
        font-weight: 800;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .hd-info {
        flex: 1;
        min-width: 0;
    }

    .hd-name {
        font-size: 16px;
        font-weight: 700;
        color: var(--text);
        margin-bottom: 4px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .hd-meta {
        font-size: 13px;
        color: var(--muted);
        display: flex;
        gap: 16px;
        flex-wrap: wrap;
    }

    .hd-badge {
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 1px;
        padding: 3px 10px;
        border-radius: 999px;
        background: rgba(14,168,106,.10);
        color: var(--green);
        border: 1px solid rgba(14,168,106,.2);
    }

    .hd-actions {
        display: flex;
        gap: 8px;
        flex-shrink: 0;
        flex-wrap: wrap;
    }

    .btn-xem {
        padding: 8px 18px;
        font-size: 13px;
        font-weight: 700;
        border-radius: 999px;
        border: 1.5px solid var(--border2);
        background: var(--bg);
        color: var(--text);
        cursor: pointer;
        text-decoration: none;
        font-family: 'Segoe UI',Arial,sans-serif;
        transition: all .2s;
    }

        .btn-xem:hover {
            border-color: var(--green);
            color: var(--green);
        }

    .btn-word {
        padding: 8px 18px;
        font-size: 13px;
        font-weight: 700;
        border-radius: 999px;
        border: none;
        background: var(--green);
        color: #fff;
        cursor: pointer;
        text-decoration: none;
        font-family: 'Segoe UI',Arial,sans-serif;
        transition: opacity .2s;
    }

        .btn-word:hover {
            opacity: .85;
        }

    .empty-state {
        text-align: center;
        padding: 60px 24px;
    }

    .stat-card {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 18px 20px;
        text-align: center;
    }

    .stat-num {
        font-size: 2rem;
        font-weight: 800;
        color: var(--green);
        line-height: 1;
        margin-bottom: 4px;
    }

    .stat-lbl {
        font-size: 12px;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        color: var(--muted);
    }
</style>

<!-- HEADER -->
<div style="background:var(--bg2);padding:100px 0 36px;border-bottom:1px solid var(--border)">
    <div class="container">
        <div class="section-label">Admin — Quản lý hợp đồng</div>
        <h1 style="font-style:italic;line-height:0.9">HỢP ĐỒNG<br><span class="text-green">ĐÃ KÝ</span></h1>
        <p style="color:var(--muted);margin-top:8px;">Tất cả hợp đồng hợp tác kinh doanh với chủ sân trong hệ thống</p>
    </div>
</div>

<!-- NAV -->
<div style="background:var(--bg3);border-bottom:1px solid var(--border);padding:10px 0;position:sticky;top:0;z-index:100">
    <div class="container d-flex gap-2 flex-wrap justify-content-center align-items-center">
        <a href="/Admin" class="btn btn-outline-success rounded-pill btn-sm">📊 Tổng quan</a>
        <a href="/Admin/DuyetSan" class="btn btn-outline-warning rounded-pill btn-sm">🏟️ Duyệt sân</a>
        <a href="/Admin/QuanLyUser" class="btn btn-outline-info rounded-pill btn-sm">👥 Tài khoản</a>
        <a href="/Admin/MasterData" class="btn btn-outline-success rounded-pill btn-sm">🗂️ Master Data</a>
        <a href="/Admin/KhieuNai" class="btn btn-outline-warning rounded-pill btn-sm">⚠️ Khiếu nại</a>
        <a href="/Admin/BaoCao" class="btn btn-outline-secondary rounded-pill btn-sm">📈 Báo cáo</a>
        <a href="/Admin/TatCaHopDong" class="btn btn-success rounded-pill btn-sm">📑 Hợp đồng</a>
    </div>
</div>

<div class="container">
    <div class="hd-page">

        <!-- STATS -->
        @{
            var tongSan = Model.Count;
            var thangNay = Model.Count(s => s.NgayKyHopDong.HasValue
            && s.NgayKyHopDong.Value.Month == DateTime.Now.Month
            && s.NgayKyHopDong.Value.Year == DateTime.Now.Year);
        }
        <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-bottom:24px;">
            <div class="stat-card">
                <div class="stat-num">@tongSan</div>
                <div class="stat-lbl">Tổng hợp đồng</div>
            </div>
            <div class="stat-card">
                <div class="stat-num">@thangNay</div>
                <div class="stat-lbl">Ký trong tháng này</div>
            </div>
            <div class="stat-card">
                <div class="stat-num">@(tongSan - thangNay)</div>
                <div class="stat-lbl">Hợp đồng cũ</div>
            </div>
        </div>

        <!-- FILTER BAR -->
        <form method="get" action="/Admin/TatCaHopDong">
            <div class="hd-filter-bar">
                <input type="text" name="tuKhoa" value="@tuKhoa"
                       class="hd-search-inp"
                       placeholder="🔍 Tìm tên sân, chủ sân, quận..." />
                <select name="sapXep" class="hd-sel" onchange="this.form.submit()">
                    @if (sapXep == "cu_nhat")
                    {
                        <option value="gan_nhat">📅 Gần đây nhất</option>
                        <option value="cu_nhat" selected>🕰️ Cũ nhất trước</option>
                    }
                    else
                    {
                        <option value="gan_nhat" selected>📅 Gần đây nhất</option>
                        <option value="cu_nhat">🕰️ Cũ nhất trước</option>
                    }
                </select>
                <button type="submit" class="btn-word">Tìm kiếm</button>
                @if (!string.IsNullOrEmpty(tuKhoa))
                {
                    <a href="/Admin/TatCaHopDong" style="font-size:13px;color:var(--muted);
                           text-decoration:none;padding:10px 14px;border:1.5px solid var(--border2);
                           border-radius:10px;">✕ Xóa lọc</a>
                }
            </div>
        </form>

        <!-- KET QUA -->
        <div style="font-size:13px;color:var(--muted);margin-bottom:16px;">
            Hiển thị <strong style="color:var(--text)">@tongHD</strong> hợp đồng
            @if (!string.IsNullOrEmpty(tuKhoa))
            {
                <span> — kết quả cho "<strong style="color:var(--green)">@tuKhoa</strong>"</span>
            }
        </div>

        <!-- DANH SACH -->
        @if (!Model.Any())
        {
            <div class="empty-state">
                <div style="font-size:48px;opacity:.3;margin-bottom:12px;">📑</div>
                <div style="font-size:18px;font-weight:700;margin-bottom:8px;">Không tìm thấy hợp đồng nào</div>
                <div style="font-size:14px;color:var(--muted);">Thử tìm kiếm với từ khóa khác.</div>
            </div>
        }
        else
        {
            @for (int i = 0; i < Model.Count; i++)
            {
                var san = Model[i];
                var ngayKy = san.NgayKyHopDong?.ToString("HH:mm — dd/MM/yyyy") ?? "—";
                var ownerName = san.Owner?.HoTen ?? "—";
                var ownerSdt = san.Owner?.SoDienThoai ?? "";
                <div class="hd-card">
                    <div class="hd-num">@(i + 1)</div>
                    <div class="hd-info">
                        <div class="hd-name">@san.TenSan</div>
                        <div class="hd-meta">
                            <span>👤 @ownerName @(!string.IsNullOrEmpty(ownerSdt) ? "· " + ownerSdt : "")</span>
                            <span>📍 @san.DiaChi — @san.Quan</span>
                            <span>🕐 @ngayKy</span>
                        </div>
                    </div>
                    <div style="display:flex;flex-direction:column;align-items:flex-end;gap:8px;">
                        <span class="hd-badge">✅ Đã ký điện tử</span>
                        <div class="hd-actions">
                            <a href="/Admin/XemHopDong?sanId=@san.Id" class="btn-xem">👁 Xem</a>
                            <a href="/Admin/XuatWordHopDong?sanId=@san.Id" class="btn-word">📄 Xuất Word</a>
                        </div>
                    </div>
                </div>
            }
        }

    </div>
</div>
