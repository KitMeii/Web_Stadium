@model List<Web_Stadium.EFCore.User>
@{
    ViewData["Title"] = "Quản lý Tài khoản";
}

<div class="container-fluid py-4">
    <h4 class="mb-4"><i class="bi bi-people me-2"></i>Quản lý Tài khoản</h4>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Bộ lọc -->
    <form method="get" class="row g-2 mb-4">
        <div class="col-auto">
            <select name="vaiTro" class="form-select">
                <option value="">-- Tất cả vai trò --</option>
                <option value="Admin" selected="@(ViewBag.VaiTro == "Admin")">Admin</option>
                <option value="Owner" selected="@(ViewBag.VaiTro == "Owner")">Owner</option>
                <option value="Staff" selected="@(ViewBag.VaiTro == "Staff")">Staff</option>
                <option value="User" selected="@(ViewBag.VaiTro == "User")">User</option>
            </select>
        </div>
        <div class="col-auto">
            <input type="text" name="tuKhoa" class="form-control" placeholder="Tìm tên hoặc email..."
                   value="@ViewBag.TuKhoa" />
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-search me-1"></i>Tìm
            </button>
        </div>
    </form>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Họ tên</th>
                        <th>Email</th>
                        <th>Vai trò</th>
                        <th>Ngày tạo</th>
                        <th>Trạng thái</th>
                        <th class="text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var u in Model)
                    {
                        <tr class="@(!u.IsActive ? "table-secondary" : "")">
                            <td><small class="text-muted">#@u.Id</small></td>
                            <td>
                                <strong>@u.HoTen</strong>
                                @if (!u.IsActive)
                                {
                                    <br />
                            
                                    <small class="text-danger"><i class="bi bi-lock-fill me-1"></i>Đã khoá</small>
                                }
                            </td>
                            <td><small>@u.Email</small></td>
                            <td>
                                @{
                                    var badgeColor = u.VaiTro switch
                                    {
                                        "Admin" => "bg-danger",
                                        "Owner" => "bg-primary",
                                        "Staff" => "bg-warning text-dark",
                                        _ => "bg-secondary"
                                    };
                                }
                                <span class="badge @badgeColor">@u.VaiTro</span>
                            </td>
                            <td><small>@u.NgayTao.ToString("dd/MM/yyyy")</small></td>
                            <td>
                                <span class="badge @(u.IsActive ? "bg-success" : "bg-secondary")">
                                    @(u.IsActive ? "Hoạt động" : "Đã khoá")
                                </span>
                            </td>
                            <td class="text-center">
                                @if (u.VaiTro != "Admin")
                                {
                                    <form method="post" action="/Admin/DoiTrangThaiTaiKhoan"
                                          style="display:inline"
                                          onsubmit="return confirm('@(u.IsActive ? $"Khoá tài khoản {u.HoTen}?" : $"Mở khoá tài khoản {u.HoTen}?")')">
                                        <input type="hidden" name="id" value="@u.Id" />
                                        <input type="hidden" name="isActive" value="@(!u.IsActive)" />
                                        <button class="btn btn-sm @(u.IsActive ? "btn-outline-danger" : "btn-outline-success") rounded-pill">
                                            <i class="bi @(u.IsActive ? "bi-lock" : "bi-unlock") me-1"></i>
                                            @(u.IsActive ? "Khoá" : "Mở khoá")
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <span class="text-muted small">—</span>
                                }
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted py-4">Không tìm thấy tài khoản nào.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
