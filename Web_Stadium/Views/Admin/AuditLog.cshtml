@model List<Web_Stadium.EFCore.AuditLog>
@{
    ViewData["Title"] = "Audit Log";
}

<div class="container-fluid py-4">
    <h4 class="mb-4"><i class="bi bi-shield-check me-2"></i>Nhật ký hành động (Audit Log)</h4>

    <!-- Bộ lọc -->
    <form method="get" class="row g-2 mb-4 align-items-end">
        <div class="col-auto">
            <label class="form-label small">Loại hành động</label>
            <select name="hanhDong" class="form-select form-select-sm">
                <option value="">-- Tất cả --</option>
                @foreach (var h in ViewBag.DanhSachHanhDong as List<string>)
                {
                    <option value="@h" selected="@(ViewBag.HanhDong == h)">@h</option>
                }
            </select>
        </div>
        <div class="col-auto">
            <label class="form-label small">Từ ngày</label>
            <input type="date" name="tuNgay" class="form-control form-control-sm" value="@ViewBag.TuNgay" />
        </div>
        <div class="col-auto">
            <label class="form-label small">Đến ngày</label>
            <input type="date" name="denNgay" class="form-control form-control-sm" value="@ViewBag.DenNgay" />
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-primary btn-sm">
                <i class="bi bi-search me-1"></i>Lọc
            </button>
            <a href="/Admin/AuditLog" class="btn btn-outline-secondary btn-sm ms-1">Reset</a>
        </div>
        <div class="col-auto ms-auto">
            <small class="text-muted">Tổng: <strong>@ViewBag.TongSo</strong> bản ghi</small>
        </div>
    </form>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover table-sm align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Thời gian</th>
                        <th>Người thực hiện</th>
                        <th>Vai trò</th>
                        <th>Hành động</th>
                        <th>Đối tượng</th>
                        <th>Mô tả</th>
                        <th>IP</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var log in Model)
                    {
                        <tr>
                            <td><small class="text-muted">@log.ThoiGian.ToString("dd/MM HH:mm:ss")</small></td>
                            <td>
                                <small>
                                    <strong>@log.User?.HoTen</strong><br />
                                    <span class="text-muted">@log.User?.Email</span>
                                </small>
                            </td>
                            <td>
                                @{
                                    var roleColor = log.VaiTro switch
                                    {
                                        "Admin" => "bg-danger",
                                        "Owner" => "bg-primary",
                                        "Staff" => "bg-warning text-dark",
                                        _ => "bg-secondary"
                                    };
                                }
                                <span class="badge @roleColor">@log.VaiTro</span>
                            </td>
                            <td>
                                @{
                                    var actionColor = log.HanhDong.Contains("Khoa") || log.HanhDong.Contains("TuChoi") ? "text-danger" :
                                    log.HanhDong.Contains("MoKhoa") || log.HanhDong.Contains("PheDuyet") || log.HanhDong.Contains("HoanCoc") ? "text-success" :
                                    "text-primary";
                                }
                                <span class="@actionColor fw-bold small">@log.HanhDong</span>
                            </td>
                            <td>
                                <small class="badge bg-light text-dark border">
                                    @log.DoiTuong #@log.DoiTuongId
                                </small>
                            </td>
                            <td><small>@log.MoTa</small></td>
                            <td><small class="text-muted">@log.IpAddress</small></td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted py-4">
                                Không có dữ liệu log.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Phân trang -->
    @if ((int)ViewBag.TongTrang > 1)
    {
        <nav class="mt-3">
            <ul class="pagination pagination-sm justify-content-center">
                @for (int i = 1; i <= (int)ViewBag.TongTrang; i++)
                {
                    <li class="page-item @(i == (int)ViewBag.Trang ? "active" : "")">
                        <a class="page-link"
                           href="/Admin/AuditLog?trang=@i&hanhDong=@ViewBag.HanhDong&tuNgay=@ViewBag.TuNgay&denNgay=@ViewBag.DenNgay">
                            @i
                        </a>
                    </li>
                }
            </ul>
        </nav>
    }
</div>
