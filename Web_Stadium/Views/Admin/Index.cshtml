@{
    ViewData["Title"] = "Dashboard Admin";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <style>
        /* ── ADMIN DASHBOARD ── */
        .adm-page {
            background: var(--bg);
            min-height: 100vh;
        }

        /* Header */
        .adm-hdr {
            background: linear-gradient(135deg,var(--bg2) 0%,var(--bg) 100%);
            border-bottom: 1px solid var(--border);
            padding: 88px 0 32px;
        }

        /* Sticky sub-nav */
        .adm-nav {
            background: var(--bg3);
            border-bottom: 1px solid var(--border);
            padding: 10px 0;
            position: sticky;
            top: 0;
            z-index: 100;
        }

            .adm-nav .inner {
                display: flex;
                gap: 8px;
                flex-wrap: wrap;
                justify-content: center;
                align-items: center;
            }

        .adm-navbtn {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            font-family: var(--ff-h);
            font-size: 10px;
            font-weight: 700;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            padding: 7px 16px;
            border-radius: 999px;
            text-decoration: none;
            border: 1px solid var(--border2);
            background: var(--bg);
            color: var(--muted);
            transition: all .2s;
            white-space: nowrap;
        }

            .adm-navbtn:hover {
                border-color: var(--green);
                color: var(--green);
            }

            .adm-navbtn.warn {
                border-color: rgba(246,170,56,.4);
                color: #f6aa38;
            }

                .adm-navbtn.warn:hover {
                    background: #f6aa38;
                    color: #000;
                    border-color: #f6aa38;
                }

            .adm-navbtn.danger {
                border-color: rgba(231,76,60,.4);
                color: #e74c3c;
            }

                .adm-navbtn.danger:hover {
                    background: #e74c3c;
                    color: #fff;
                    border-color: #e74c3c;
                }

        .nav-badge {
            background: #e74c3c;
            color: #fff;
            font-size: 9px;
            font-weight: 700;
            padding: 1px 6px;
            border-radius: 999px;
            min-width: 18px;
            text-align: center;
        }

        /* KPI GRID — 5 cards */
        .kpi5 {
            display: grid;
            grid-template-columns: repeat(5,1fr);
            gap: 14px;
            margin-bottom: 24px;
        }

        @@media(max-width:992px) {
            .kpi5 {
                grid-template-columns: repeat(3,1fr);
            }
        }

        @@media(max-width:576px) {
            .kpi5 {
                grid-template-columns: repeat(2,1fr);
            }
        }

        .kpi5-card {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: var(--r-lg);
            padding: 20px 16px;
            transition: all .22s;
            cursor: default;
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

            .kpi5-card:hover {
                transform: translateY(-3px);
                box-shadow: 0 8px 24px rgba(0,0,0,0.18);
            }

            .kpi5-card.clickable {
                cursor: pointer;
            }

            .kpi5-card.warn {
                border-color: rgba(246,170,56,.35);
            }

                .kpi5-card.warn:hover {
                    border-color: #f6aa38;
                }

            .kpi5-card.danger {
                border-color: rgba(231,76,60,.35);
            }

                .kpi5-card.danger:hover {
                    border-color: #e74c3c;
                }

        .kpi5-icon {
            font-size: 1.6rem;
        }

        .kpi5-num {
            font-family: var(--ff-h);
            font-size: 2.4rem;
            font-weight: 700;
            color: var(--green);
            line-height: 1;
        }

            .kpi5-num.blue {
                color: #6caee0;
            }

            .kpi5-num.yellow {
                color: #f6aa38;
            }

            .kpi5-num.red {
                color: #e74c3c;
            }

        .kpi5-lbl {
            font-size: 12px;
            color: var(--muted);
            letter-spacing: .5px;
        }

        /* Main 2-col layout */
        .adm-2col {
            display: grid;
            grid-template-columns: 5fr 7fr;
            gap: 20px;
            margin-bottom: 20px;
        }

        @@media(max-width:768px) {
            .adm-2col {
                grid-template-columns: 1fr;
            }
        }

        /* Section card */
        .adm-card {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: var(--r-lg);
            padding: 22px;
        }

        .adm-card-title {
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            color: var(--muted);
            margin-bottom: 4px;
        }

        .adm-card-val {
            font-family: var(--ff-h);
            font-size: 2.6rem;
            font-weight: 700;
            color: var(--green);
            line-height: 1;
            margin-bottom: 4px;
        }

        .adm-card-sub {
            font-size: 13px;
            color: var(--muted2);
            margin-bottom: 20px;
        }

        /* Status rows */
        .status-row {
            display: flex;
            justify-content: space-between;
            font-size: 14px;
            padding: 6px 0;
            border-bottom: 1px solid var(--border);
        }

            .status-row:last-child {
                border-bottom: none;
            }

        .status-dot {
            display: inline-block;
            width: 8px;
            height: 8px;
            border-radius: 50%;
            margin-right: 7px;
        }

        /* Top san progress */
        .top-row {
            margin-bottom: 14px;
        }

        .top-header {
            display: flex;
            justify-content: space-between;
            font-size: 13px;
            margin-bottom: 5px;
        }

        .top-track {
            height: 5px;
            background: rgba(255,255,255,0.06);
            border-radius: 999px;
            overflow: hidden;
        }

        .top-fill {
            height: 100%;
            background: var(--green);
            border-radius: 999px;
            transition: width .9s ease;
        }

        /* Chart mini */
        .adm-chart-wrap {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: var(--r-lg);
            padding: 22px;
            margin-bottom: 20px;
        }

        /* Quick access grid */
        .qa-grid {
            display: grid;
            grid-template-columns: repeat(4,1fr);
            gap: 14px;
        }

        @@media(max-width:992px) {
            .qa-grid {
                grid-template-columns: repeat(2,1fr);
            }
        }

        .qa-card {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: var(--r-lg);
            padding: 18px;
            text-decoration: none;
            display: block;
            transition: all .22s;
        }

            .qa-card:hover {
                border-color: var(--green);
                transform: translateY(-2px);
                box-shadow: 0 6px 20px rgba(0,0,0,0.15);
            }

                .qa-card:hover .qa-icon {
                    transform: scale(1.15);
                }

        .qa-icon {
            font-size: 1.8rem;
            margin-bottom: 10px;
            transition: transform .2s;
        }

        .qa-name {
            font-family: var(--ff-h);
            font-size: 14px;
            font-weight: 700;
            color: var(--text);
            margin-bottom: 4px;
            letter-spacing: .5px;
        }

        .qa-desc {
            font-size: 12px;
            color: var(--muted);
            line-height: 1.5;
        }
    </style>
}

<div style="background:var(--bg2);padding:100px 0 40px;border-bottom:1px solid var(--border)">
    <div class="container">
        <div class="section-label">Quản trị viên hệ thống</div>
        <h1 style="font-style:italic;line-height:0.9">DASHBOARD<br><span class="text-green">ADMIN HQ</span></h1>
        <p style="color:var(--muted)">Tổng quan hệ thống PitchHub — tất cả chi nhánh</p>
    </div>
</div>
<div style="background:var(--bg3);border-bottom:1px solid var(--border);padding:12px 0;position:sticky;top:0;z-index:100">
    <div class="container d-flex gap-2 flex-wrap justify-content-center align-items-center">
        <a href="/Admin" class="btn btn-outline-green rounded-pill">📊 Tổng quan</a>
        <a href="/Admin/DuyetSan" class="btn btn-outline-warning rounded-pill">
            🏟️ Duyệt sân
            @if (ViewBag.ChoPheDuyet > 0)
            {
                <span class="badge bg-danger ms-1">@ViewBag.ChoPheDuyet</span>
            }
        </a>
        <a href="/Admin/QuanLyUser" class="btn btn-outline-info rounded-pill">👥 Tài khoản</a>
        <a href="/Admin/MasterData" class="btn btn-outline-green rounded-pill">🗂️ Master Data</a>
        <a href="/Admin/KhieuNai" class="btn btn-outline-warning rounded-pill">
            ⚠️ Khiếu nại
            @if (ViewBag.KhieuNaiChoXuLy > 0)
            {
                <span class="badge bg-danger ms-1">@ViewBag.KhieuNaiChoXuLy</span>
            }
        </a>
        <a href="/Admin/BaoCao" class="btn btn-outline-secondary rounded-pill">📈 Báo cáo</a>
        <a href="/Admin/AuditLog" class="btn btn-outline-secondary rounded-pill">🛡️ Audit Log</a>
        <a href="/Admin/TatCaHopDong" class="btn btn-outline-primary rounded-pill">📑 Hợp đồng</a>
    </div>
</div>

<div class="adm-page">
    <div class="container py-4">

        <!-- KPI 5 CARDS -->
        <div class="kpi5">
            <div class="kpi5-card" data-aos="fade-up">
                <div class="kpi5-icon">&#127967;</div>
                <div class="kpi5-num">@ViewBag.TongSan</div>
                <div class="kpi5-lbl">Tổng sân</div>
            </div>
            <div class="kpi5-card" data-aos="fade-up" data-aos-delay="60">
                <div class="kpi5-icon">&#128203;</div>
                <div class="kpi5-num blue">@ViewBag.TongDatSan</div>
                <div class="kpi5-lbl">Lượt đặt sân</div>
            </div>
            <div class="kpi5-card" data-aos="fade-up" data-aos-delay="120">
                <div class="kpi5-icon">&#128101;</div>
                <div class="kpi5-num">@ViewBag.TongUser</div>
                <div class="kpi5-lbl">Người dùng</div>
            </div>
            <div class="kpi5-card clickable warn" data-aos="fade-up" data-aos-delay="180"
                 onclick="window.location='/Admin/DuyetSan'">
                <div class="kpi5-icon">&#9203;</div>
                <div class="kpi5-num yellow">@ViewBag.ChoPheDuyet</div>
                <div class="kpi5-lbl">Chờ duyệt sân</div>
                <a href="/Admin/DuyetSan" class="btn-primary-glow"
                   style="font-size:10px;padding:5px 12px;clip-path:none;margin-top:4px;display:inline-block;">
                    Xem ngay
                </a>
            </div>
            <div class="kpi5-card clickable @(ViewBag.KhieuNaiChoXuLy > 0 ? "danger" : "")"
                 data-aos="fade-up" data-aos-delay="240"
                 onclick="window.location='/Admin/KhieuNai'">
                <div class="kpi5-icon">&#9888;</div>
                <div class="kpi5-num @(ViewBag.KhieuNaiChoXuLy > 0 ? "red" : "")">
                    @ViewBag.KhieuNaiChoXuLy
                </div>
                <div class="kpi5-lbl">Khiếu nại chờ xử lý</div>
                @if (ViewBag.KhieuNaiChoXuLy > 0)
                {
                    <a href="/Admin/KhieuNai"
                       style="font-size:10px;padding:5px 12px;margin-top:4px;display:inline-block;
                                  background:#e74c3c;color:#fff;border-radius:999px;text-decoration:none;
                                  font-family:var(--ff-h);letter-spacing:1px;">
                        Xử lý ngay
                    </a>
                }
            </div>
        </div>

        <!-- MAIN 2 COL: Doanh thu + Top san -->
        <div class="adm-2col" data-aos="fade-up">

            <!-- Doanh thu thang -->
            <div class="adm-card">
                <div class="adm-card-title">Doanh thu tháng này</div>
                <div class="adm-card-val">
                    @(((decimal)(ViewBag.DoanhThuThang ?? 0m) / 1_000_000m).ToString("F1"))
                    <span style="font-size:1rem;color:var(--muted);">triệu VND</span>
                </div>
                <div class="adm-card-sub">Tiền cọc đã xác nhận + hoàn thành</div>
                <div style="font-size:11px;font-weight:700;letter-spacing:1.5px;
                        text-transform:uppercase;color:var(--muted);margin-bottom:12px;">
                    Theo trạng thái đơn
                </div>
                @if (ViewBag.TheoTrangThai != null)
                {
                    foreach (var tt in ViewBag.TheoTrangThai)
                    {
                        var color = ((string)tt.TrangThai) switch
                        {
                            "DaXacNhan" => "#1ed760",
                            "HoanThanh" => "#6caee0",
                            "DangSuDung" => "#f39c12",
                            "DaHuy" => "#e74c3c",
                            _ => "#aaa"
                        };
                        var label = ((string)tt.TrangThai) switch
                        {
                            "ChoDuyet" => "Chờ duyệt",
                            "DaXacNhan" => "Đã xác nhận",
                            "DangSuDung" => "Đang sử dụng",
                            "HoanThanh" => "Hoàn thành",
                            "DaHuy" => "Đã hủy",
                            _ => tt.TrangThai
                        };
                        <div class="status-row">
                            <span style="color:var(--muted2);">
                                <span class="status-dot" style="background:@color;"></span>@label
                            </span>
                            <span style="color:@color;font-weight:700;">@tt.SoLuong</span>
                        </div>
                    }
                }
                <div style="margin-top:16px;">
                    <a href="/Admin/BaoCao" style="font-size:13px;color:var(--green);text-decoration:none;">
                        Xem báo cáo đầy đủ theo năm &rarr;
                    </a>
                </div>
            </div>

            <!-- Top 5 san -->
            <div class="adm-card">
                <div class="adm-card-title" style="margin-bottom:18px;">Top 5 sân được đặt nhiều nhất</div>
                @if (ViewBag.TopSan != null)
                {
                    int rank = 1;
                    int maxLuot = (int)(ViewBag.TopSan as IEnumerable<dynamic>)
                    .Select(s => (int)s.SoLuot).DefaultIfEmpty(1).Max();
                    foreach (var s in ViewBag.TopSan)
                    {
                        var pct = maxLuot > 0 ? (int)((double)(int)s.SoLuot / maxLuot * 100) : 0;
                        var medal = rank == 1 ? "🥇" : rank == 2 ? "🥈" : rank == 3 ? "🥉" : "  ";
                        <div class="top-row">
                            <div class="top-header">
                                <span style="color:var(--muted2);">
                                    @medal <strong style="color:var(--text);">@s.Ten</strong>
                                </span>
                                <span style="color:var(--green);font-weight:700;">@s.SoLuot lượt</span>
                            </div>
                            <div class="top-track">
                                <div class="top-fill" style="width:@pct%;"></div>
                            </div>
                        </div>
                        rank++;
                    }
                }
            </div>

        </div>

        <!-- BIEU DO 6 THANG -->
        <div class="adm-chart-wrap" data-aos="fade-up">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;">
                <div>
                    <div class="adm-card-title">Doanh thu 6 tháng gần nhất</div>
                    <div style="font-size:12px;color:var(--muted2);">Triệu VND</div>
                </div>
                <a href="/Admin/BaoCao"
                   style="font-size:13px;color:var(--green);text-decoration:none;font-family:var(--ff-h);
                      letter-spacing:1px;font-size:11px;text-transform:uppercase;">
                    Báo cáo đầy đủ &rarr;
                </a>
            </div>
            <div style="position:relative;height:220px;">
                <canvas id="chartMini"></canvas>
            </div>
        </div>

        <!-- TRUY CAP NHANH -->
        <div data-aos="fade-up">
            <div class="adm-card-title" style="margin-bottom:16px;">Truy cập nhanh</div>
            <div class="qa-grid">
                <a href="/Admin/DuyetSan" class="qa-card">
                    <div class="qa-icon">🏟️</div>
                    <div class="qa-name">Duyệt sân</div>
                    <div class="qa-desc">Phê duyệt Owner đăng ký sân mới</div>
                </a>
                <a href="/Admin/QuanLyUser" class="qa-card">
                    <div class="qa-icon">👥</div>
                    <div class="qa-name">Tài khoản</div>
                    <div class="qa-desc">Quản lý, khoá/mở tài khoản người dùng</div>
                </a>
                <a href="/Admin/MasterData" class="qa-card">
                    <div class="qa-icon">🗂️</div>
                    <div class="qa-name">Master Data</div>
                    <div class="qa-desc">Quận/Huyện, loại sân, danh mục dịch vụ</div>
                </a>
                <a href="/Admin/KhieuNai" class="qa-card">
                    <div class="qa-icon">⚠️</div>
                    <div class="qa-name">Khiếu nại</div>
                    <div class="qa-desc">Xử lý hoàn cọc User theo yêu cầu</div>
                </a>
                <a href="/Admin/BaoCao" class="qa-card">
                    <div class="qa-icon">📈</div>
                    <div class="qa-name">Báo cáo</div>
                    <div class="qa-desc">Doanh thu toàn hệ thống theo năm</div>
                </a>
                <a href="/Admin/AuditLog" class="qa-card">
                    <div class="qa-icon">🛡️</div>
                    <div class="qa-name">Audit Log</div>
                    <div class="qa-desc">Nhật ký hành động bảo mật</div>
                </a>
                <a href="/Admin/TatCaHopDong" class="qa-card">
                    <div class="qa-icon">📑</div>
                    <div class="qa-name">Hợp đồng</div>
                    <div class="qa-desc">Tất cả hợp đồng chủ sân</div>
                </a>
                <a href="/Venues" class="qa-card">
                    <div class="qa-icon">🔍</div>
                    <div class="qa-name">Xem trang chủ</div>
                    <div class="qa-desc">Giao diện người dùng PitchHub</div>
                </a>
            </div>
        </div>

    </div><!-- /container -->
</div><!-- /adm-page -->
@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
    <script>
        @if (ViewBag.DoanhThu6Thang != null)
        {
                    var labels6 = Newtonsoft.Json.JsonConvert.SerializeObject(
                                    ((System.Collections.Generic.List<object>)ViewBag.DoanhThu6Thang)
                                                    .Select(x => ((dynamic)x).thang));
                    var data6 = Newtonsoft.Json.JsonConvert.SerializeObject(
                                    ((System.Collections.Generic.List<object>)ViewBag.DoanhThu6Thang)
                                                    .Select(x => Math.Round((double)((dynamic)x).dt / 1_000_000, 2)));
                    <text>
                new Chart(document.getElementById('chartMini'),{
                    type:'bar',
                    data:{
                        labels:@Html.Raw(labels6),
                        datasets:[{
                            label:'Triệu VND',
                            data:@Html.Raw(data6),
                            backgroundColor:'rgba(30,215,96,0.18)',
                            borderColor:'#1ed760',
                            borderWidth:1,
                            borderRadius:6,
                            hoverBackgroundColor:'rgba(30,215,96,0.38)'
                        }]
                    },
                    options:{
                        responsive:true,
                        maintainAspectRatio:false,
                        plugins:{legend:{display:false}},
                        scales:{
                            x:{grid:{color:'rgba(255,255,255,0.04)'},
                               ticks:{color:'#ffffff60',font:{size:11}}},
                            y:{grid:{color:'rgba(255,255,255,0.04)'},
                               ticks:{color:'#ffffff60',font:{size:11},
                                      callback:function(v){return v+'M';}}}
                        }
                    }
                });
                    </text>
        }
    </script>
}

