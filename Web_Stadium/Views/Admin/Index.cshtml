@{
    ViewData["Title"] = "Dashboard Admin";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- ══ HEADER ══════════════════════════════════════════════════ -->
<div style="background:var(--bg2); padding:100px 0 50px; border-bottom:1px solid var(--border)">
    <div class="container">
        <div class="section-label">Quản trị viên hệ thống</div>
        <h1 style="font-style:italic; line-height:0.9; margin-bottom:8px">
            DASHBOARD<br>
            <span class="text-green">ADMIN HQ</span>
        </h1>
        <p style="color:var(--muted)">Tổng quan hệ thống PitchHub — tất cả chi nhánh</p>
    </div>
</div>

<!-- ══ MENU ADMIN ═════════════════════════════════════════════ -->
<div style="background:var(--bg3); border-bottom:1px solid var(--border); padding:12px 0; position:sticky; top:0; z-index:100">
    <div class="container d-flex gap-2 flex-wrap align-items-center">
        <a href="/Admin" class="btn btn-sm btn-success rounded-pill">📊 Tổng quan</a>
        <a href="/Admin/DuyetSan" class="btn btn-sm btn-outline-warning rounded-pill">
            🏟️ Duyệt sân
            @if (ViewBag.ChoPheDuyet > 0)
            {
                <span class="badge bg-danger ms-1">@ViewBag.ChoPheDuyet</span>
            }
        </a>
        <a href="/Admin/QuanLyUser" class="btn btn-sm btn-outline-info rounded-pill">👥 Tài khoản</a>
        <a href="/Admin/MasterData" class="btn btn-sm btn-outline-light rounded-pill">🗂️ Master Data</a>
        <a href="/Admin/KhieuNai" class="btn btn-sm btn-outline-warning rounded-pill">
            ⚠️ Khiếu nại
            @if (ViewBag.KhieuNaiChoXuLy > 0)
            {
                <span class="badge bg-danger ms-1">@ViewBag.KhieuNaiChoXuLy</span>
            }
        </a>
        <a href="/Admin/BaoCao" class="btn btn-sm btn-outline-light rounded-pill">📈 Báo cáo</a>
        <a href="/Admin/AuditLog" class="btn btn-sm btn-outline-secondary rounded-pill">🛡️ Audit Log</a>
    </div>
</div>

<div class="container py-5">

    <!-- ══ HÀNG 1: 5 KPI CARDS ══════════════════════════════════ -->
    <div class="row g-3 mb-5">

        <div class="col-6 col-md-4 col-lg" data-aos="fade-up">
            <div class="section-card text-center p-4">
                <div style="font-size:2rem">🏟️</div>
                <div style="font-family:var(--ff-h); font-size:2.2rem; color:var(--green)">
                    @ViewBag.TongSan
                </div>
                <p style="color:var(--muted); font-size:12px; margin:0">Tổng sân</p>
            </div>
        </div>

        <div class="col-6 col-md-4 col-lg" data-aos="fade-up" data-aos-delay="80">
            <div class="section-card text-center p-4">
                <div style="font-size:2rem">📋</div>
                <div style="font-family:var(--ff-h); font-size:2.2rem; color:var(--green)">
                    @ViewBag.TongDatSan
                </div>
                <p style="color:var(--muted); font-size:12px; margin:0">Lượt đặt</p>
            </div>
        </div>

        <div class="col-6 col-md-4 col-lg" data-aos="fade-up" data-aos-delay="160">
            <div class="section-card text-center p-4">
                <div style="font-size:2rem">👥</div>
                <div style="font-family:var(--ff-h); font-size:2.2rem; color:var(--green)">
                    @ViewBag.TongUser
                </div>
                <p style="color:var(--muted); font-size:12px; margin:0">Người dùng</p>
            </div>
        </div>

        <div class="col-6 col-md-6 col-lg" data-aos="fade-up" data-aos-delay="240"
             style="cursor:pointer" onclick="window.location='/Admin/DuyetSan'">
            <div class="section-card text-center p-4" style="border:1px solid var(--yellow)">
                <div style="font-size:2rem">⏳</div>
                <div style="font-family:var(--ff-h); font-size:2.2rem; color:var(--yellow)">
                    @ViewBag.ChoPheDuyet
                </div>
                <p style="color:var(--muted); font-size:12px; margin:0 0 10px">Chờ duyệt sân</p>
                <a href="/Admin/DuyetSan" class="btn btn-warning btn-sm rounded-pill">Xem ngay</a>
            </div>
        </div>

        <div class="col-6 col-md-6 col-lg" data-aos="fade-up" data-aos-delay="320"
             style="cursor:pointer" onclick="window.location='/Admin/KhieuNai'">
            <div class="section-card text-center p-4"
                 style="@(ViewBag.KhieuNaiChoXuLy > 0 ? "border:1px solid #e74c3c" : "")">
                <div style="font-size:2rem">⚠️</div>
                <div style="font-family:var(--ff-h); font-size:2.2rem;
                            color:@(ViewBag.KhieuNaiChoXuLy > 0 ? "#e74c3c" : "var(--muted)")">
                    @ViewBag.KhieuNaiChoXuLy
                </div>
                <p style="color:var(--muted); font-size:12px; margin:0 0 10px">Khiếu nại chờ</p>
                @if (ViewBag.KhieuNaiChoXuLy > 0)
                {
                    <a href="/Admin/KhieuNai" class="btn btn-danger btn-sm rounded-pill">Xử lý ngay</a>
                }
            </div>
        </div>

    </div>

    <!-- ══ HÀNG 2: DOANH THU + TOP SÂN ═════════════════════════ -->
    <div class="row g-4 mb-5">

        <div class="col-md-5" data-aos="fade-up">
            <div class="section-card p-4 h-100">
                <div style="color:var(--muted); font-size:11px; letter-spacing:1px; margin-bottom:4px">
                    DOANH THU THÁNG NÀY
                </div>
                <div style="font-family:var(--ff-h); font-size:2.4rem; color:var(--green); margin-bottom:4px">
                    @(((decimal)ViewBag.DoanhThuThang / 1_000_000m).ToString("F1"))M
                    <span style="font-size:1rem; color:var(--muted)">VND</span>
                </div>
                <div style="color:var(--muted2); font-size:12px; margin-bottom:20px">
                    Tiền cọc đã xác nhận + hoàn thành
                </div>
                <hr style="border-color:var(--border)">
                <div style="color:var(--muted); font-size:11px; letter-spacing:1px; margin:16px 0 10px">
                    THEO TRẠNG THÁI ĐƠN
                </div>
                @if (ViewBag.TheoTrangThai != null)
                {
                    foreach (var tt in ViewBag.TheoTrangThai)
                    {
                        var color = ((string)tt.TrangThai) switch
                        {
                            "DaXacNhan" => "#1ed760",
                            "HoanThanh" => "#6caee0",
                            "DangSuDung" => "#f39c12",
                            "DaHuy" => "#e74c3c",
                            _ => "#aaa"
                        };
                        var label = ((string)tt.TrangThai) switch
                        {
                            "ChoDuyet" => "Chờ duyệt",
                            "DaXacNhan" => "Đã xác nhận",
                            "DangSuDung" => "Đang sử dụng",
                            "HoanThanh" => "Hoàn thành",
                            "DaHuy" => "Đã huỷ",
                            _ => tt.TrangThai
                        };
                        <div style="display:flex; justify-content:space-between;
                                            font-size:13px; margin-bottom:6px">
                            <span style="color:var(--muted2)">
                                <span style="display:inline-block; width:8px; height:8px;
                                                     border-radius:50%; background:@color;
                                                     margin-right:6px"></span>
                                @label
                            </span>
                            <span style="color:@color; font-weight:600">@tt.SoLuong</span>
                        </div>
                    }
                }
            </div>
        </div>

        <div class="col-md-7" data-aos="fade-up" data-aos-delay="100">
            <div class="section-card p-4 h-100">
                <div style="color:var(--muted); font-size:11px; letter-spacing:1px; margin-bottom:16px">
                    TOP 5 SÂN ĐƯỢC ĐẶT NHIỀU NHẤT
                </div>
                @if (ViewBag.TopSan != null)
                {
                    int rank = 1;
                    int maxLuot = (int)(ViewBag.TopSan as IEnumerable<dynamic>)
                    .Select(s => (int)s.SoLuot).DefaultIfEmpty(1).Max();
                    foreach (var s in ViewBag.TopSan)
                    {
                        var pct = maxLuot > 0 ? (int)((double)(int)s.SoLuot / maxLuot * 100) : 0;
                        var medal = rank == 1 ? "🥇" : rank == 2 ? "🥈" : rank == 3 ? "🥉" : "  ";
                        <div style="margin-bottom:14px">
                            <div style="display:flex; justify-content:space-between;
                                                font-size:13px; margin-bottom:4px">
                                <span style="color:var(--muted2)">
                                    @medal <strong>@s.Ten</strong>
                                </span>
                                <span style="color:var(--green)">@s.SoLuot lượt</span>
                            </div>
                            <div style="background:rgba(255,255,255,0.06);
                                                border-radius:4px; height:4px; overflow:hidden">
                                <div style="background:var(--green); width:@pct%;
                                                    height:100%; border-radius:4px;
                                                    transition:width 0.8s ease"></div>
                            </div>
                        </div>
                        rank++;
                    }
                }
                <hr style="border-color:var(--border)">
                <a href="/Admin/BaoCao" style="font-size:12px; color:var(--green)">
                    Xem báo cáo đầy đủ theo năm →
                </a>
            </div>
        </div>

    </div>

    <!-- ══ BIỂU ĐỒ 6 THÁNG ════════════════════════════════════ -->
    <div class="section-card p-4 mb-5" data-aos="fade-up">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:4px">
            <div style="color:var(--muted); font-size:11px; letter-spacing:1px">
                DOANH THU 6 THÁNG GẦN NHẤT
            </div>
            <a href="/Admin/BaoCao" style="font-size:12px; color:var(--green)">
                Báo cáo đầy đủ →
            </a>
        </div>
        <div style="position:relative; height:220px">
            <canvas id="chartMini"></canvas>
        </div>
    </div>

    <!-- ══ HÀNG 3: MENU NHANH ═══════════════════════════════════ -->
    <div data-aos="fade-up">
        <div style="color:var(--muted); font-size:11px; letter-spacing:1px; margin-bottom:16px">
            TRUY CẬP NHANH
        </div>
        <div class="row g-3">

            <div class="col-6 col-md-4 col-lg-3">
                <a href="/Admin/DuyetSan" class="section-card p-3 d-block text-decoration-none"
                   style="transition:border-color 0.2s"
                   onmouseover="this.style.borderColor='var(--yellow)'"
                   onmouseout="this.style.borderColor='var(--border)'">
                    <div style="font-size:1.6rem; margin-bottom:8px">🏟️</div>
                    <div style="font-family:var(--ff-h); font-size:14px; margin-bottom:4px">DUYỆT SÂN</div>
                    <div style="font-size:12px; color:var(--muted)">Phê duyệt Owner đăng ký sân mới</div>
                </a>
            </div>

            <div class="col-6 col-md-4 col-lg-3">
                <a href="/Admin/QuanLyUser" class="section-card p-3 d-block text-decoration-none"
                   onmouseover="this.style.borderColor='#6caee0'"
                   onmouseout="this.style.borderColor='var(--border)'">
                    <div style="font-size:1.6rem; margin-bottom:8px">👥</div>
                    <div style="font-family:var(--ff-h); font-size:14px; margin-bottom:4px">TÀI KHOẢN</div>
                    <div style="font-size:12px; color:var(--muted)">Quản lý, khoá/mở tài khoản người dùng</div>
                </a>
            </div>

            <div class="col-6 col-md-4 col-lg-3">
                <a href="/Admin/MasterData" class="section-card p-3 d-block text-decoration-none"
                   onmouseover="this.style.borderColor='var(--green)'"
                   onmouseout="this.style.borderColor='var(--border)'">
                    <div style="font-size:1.6rem; margin-bottom:8px">🗂️</div>
                    <div style="font-family:var(--ff-h); font-size:14px; margin-bottom:4px">MASTER DATA</div>
                    <div style="font-size:12px; color:var(--muted)">Quận/Huyện, loại sân, danh mục dịch vụ</div>
                </a>
            </div>

            <div class="col-6 col-md-4 col-lg-3">
                <a href="/Admin/KhieuNai" class="section-card p-3 d-block text-decoration-none"
                   onmouseover="this.style.borderColor='#e74c3c'"
                   onmouseout="this.style.borderColor='var(--border)'">
                    <div style="font-size:1.6rem; margin-bottom:8px">⚠️</div>
                    <div style="font-family:var(--ff-h); font-size:14px; margin-bottom:4px">KHIẾU NẠI</div>
                    <div style="font-size:12px; color:var(--muted)">Xử lý hoàn cọc User theo yêu cầu</div>
                </a>
            </div>

            <div class="col-6 col-md-4 col-lg-3">
                <a href="/Admin/BaoCao" class="section-card p-3 d-block text-decoration-none"
                   onmouseover="this.style.borderColor='var(--green)'"
                   onmouseout="this.style.borderColor='var(--border)'">
                    <div style="font-size:1.6rem; margin-bottom:8px">📈</div>
                    <div style="font-family:var(--ff-h); font-size:14px; margin-bottom:4px">BÁO CÁO</div>
                    <div style="font-size:12px; color:var(--muted)">Doanh thu toàn hệ thống theo năm</div>
                </a>
            </div>

            <div class="col-6 col-md-4 col-lg-3">
                <a href="/Admin/AuditLog" class="section-card p-3 d-block text-decoration-none"
                   onmouseover="this.style.borderColor='#aaa'"
                   onmouseout="this.style.borderColor='var(--border)'">
                    <div style="font-size:1.6rem; margin-bottom:8px">🛡️</div>
                    <div style="font-family:var(--ff-h); font-size:14px; margin-bottom:4px">AUDIT LOG</div>
                    <div style="font-size:12px; color:var(--muted)">Nhật ký hành động bảo mật</div>
                </a>
            </div>

        </div>
    </div>

</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
    <script>
        @if (ViewBag.DoanhThu6Thang != null)
        {
                var labels6 = Newtonsoft.Json.JsonConvert.SerializeObject(
                        ((System.Collections.Generic.List<object>)ViewBag.DoanhThu6Thang)
                                .Select(x => ((dynamic)x).thang));
                var data6 = Newtonsoft.Json.JsonConvert.SerializeObject(
                        ((System.Collections.Generic.List<object>)ViewBag.DoanhThu6Thang)
                                .Select(x => Math.Round((double)((dynamic)x).dt / 1_000_000, 2)));
                <text>
                new Chart(document.getElementById('chartMini'), {
                    type: 'bar',
                    data: {
                        labels: @Html.Raw(labels6),
                        datasets: [{
                            label: 'Triệu VND',
                            data: @Html.Raw(data6),
                            backgroundColor: 'rgba(30,215,96,0.18)',
                            borderColor: '#1ed760',
                            borderWidth: 1,
                            borderRadius: 5,
                            hoverBackgroundColor: 'rgba(30,215,96,0.38)'
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: { legend: { display: false } },
                        scales: {
                            x: {
                                grid: { color: 'rgba(255,255,255,0.04)' },
                                ticks: { color: '#ffffff60', font: { size: 11 } }
                            },
                            y: {
                                grid: { color: 'rgba(255,255,255,0.04)' },
                                ticks: { color: '#ffffff60', font: { size: 11 },
                                         callback: v => v + 'M' }
                            }
                        }
                    }
                });
                </text>
        }
    </script>
}
