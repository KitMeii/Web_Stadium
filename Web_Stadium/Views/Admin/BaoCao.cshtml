@{
    ViewData["Title"] = "Báo cáo doanh thu";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var doanhThuNam = (ViewBag.DoanhThuNam
        as IEnumerable<dynamic>) ?? Enumerable.Empty<dynamic>();
    var tyLe = (ViewBag.TyLe
        as IEnumerable<dynamic>) ?? Enumerable.Empty<dynamic>();
    var tongDT = doanhThuNam.Sum(d => (double)d.dt);
    var tongLuot = doanhThuNam.Sum(d => (int)d.soLuot);
    var bestThang = doanhThuNam
        .OrderByDescending(d => (double)d.dt).FirstOrDefault();
    var tbMoiLuot = tongLuot > 0 ? tongDT / tongLuot : 0;
}

@section Styles {
    <link rel="stylesheet" href="~/css/baocao.css" />
}

<!-- HEADER -->
<div class="report-header">
    <div class="container">
        <div class="section-label">Admin</div>
        <h1 style="font-style:italic; line-height:0.9; margin-bottom:16px">
            BÁO CÁO<br>
            <span class="text-green">DOANH THU</span>
        </h1>
        <div style="display:flex; align-items:center; gap:16px">
            <span style="color:var(--muted); font-size:14px">Năm:</span>
            <div class="year-nav">
                <a href="/Admin/BaoCao?nam=@(ViewBag.Nam - 1)"
                   class="year-btn">
                    ← @(ViewBag.Nam - 1)
                </a>
                <span style="font-family:var(--ff-h); font-size:20px;
                             color:var(--green)">
                    @ViewBag.Nam
                </span>
                <a href="/Admin/BaoCao?nam=@(ViewBag.Nam + 1)"
                   class="year-btn">
                    @(ViewBag.Nam + 1) →
                </a>
            </div>
        </div>
    </div>
</div>

<div class="container section">

    <!-- TỔNG QUAN -->
    <div class="summary-grid">
        <div class="s-card">
            <div class="s-num">
                @((tongDT / 1000000).ToString("F1"))M
            </div>
            <div class="s-lbl">Tổng doanh thu (VND)</div>
        </div>
        <div class="s-card">
            <div class="s-num">@tongLuot</div>
            <div class="s-lbl">Lượt đặt sân</div>
        </div>
        <div class="s-card">
            <div class="s-num">@bestThang?.thang</div>
            <div class="s-lbl">Tháng cao nhất</div>
        </div>
        <div class="s-card">
            <div class="s-num">
                @((tbMoiLuot / 1000).ToString("F0"))K
            </div>
            <div class="s-lbl">TB mỗi lượt (VND)</div>
        </div>
    </div>

    <!-- BIỂU ĐỒ DOANH THU 12 THÁNG -->
    <div class="chart-card">
        <div class="chart-title">Doanh thu theo tháng</div>
        <div class="chart-sub">
            Tiền cọc đã thu trong năm @ViewBag.Nam
        </div>
        <div style="position:relative; height:280px">
            <canvas id="chartDT" role="img"
                    aria-label="Biểu đồ doanh thu 12 tháng">
            </canvas>
        </div>
    </div>

    <!-- 2 BIỂU ĐỒ NHỎ -->
    <div class="charts-two-col">

        <div class="chart-card">
            <div class="chart-title">Số lượt đặt sân</div>
            <div class="chart-sub">Theo từng tháng</div>
            <div style="position:relative; height:220px">
                <canvas id="chartLuot" role="img"
                        aria-label="Biểu đồ số lượt đặt">
                </canvas>
            </div>
        </div>

        <div class="chart-card">
            <div class="chart-title">Tỷ lệ lấp đầy sân</div>
            <div class="chart-sub">
                Khung giờ đã đặt / tổng khung giờ
            </div>
            @foreach (var san in tyLe.Take(6))
            {
                var pct = san.Tong > 0
                ? (int)((double)san.DaDat
                / (double)san.Tong * 100)
                : 0;
                <div class="lap-day-bar">
                    <div class="lap-name">@san.Ten</div>
                    <div class="lap-bar-wrap">
                        <div class="lap-bar-fill"
                             style="width:@pct%">
                        </div>
                    </div>
                    <div class="lap-pct">@pct%</div>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
    <script>
        var labels   = [@Html.Raw(string.Join(",", doanhThuNam.Select(d => $"'{d.thang}'")))];
        var dtData   = [@Html.Raw(string.Join(",", doanhThuNam.Select(d =>
                    ((double)d.dt / 1000000).ToString("F2",
                            System.Globalization.CultureInfo.InvariantCulture))))];
    var luotData = [@Html.Raw(string.Join(",", doanhThuNam.Select(d => (int)d.soLuot)))];

        var baseOpts = {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
                x: { grid: { color: 'rgba(255,255,255,0.04)' },
                     ticks: { color: '#ffffff80', font: { size: 11 } } },
                y: { grid: { color: 'rgba(255,255,255,0.04)' },
                     ticks: { color: '#ffffff80', font: { size: 11 },
                              callback: v => v + 'M' } }
            }
        };

        new Chart(document.getElementById('chartDT'), {
            type: 'bar',
            data: {
                labels,
                datasets: [{
                    label: 'Doanh thu (triệu VND)',
                    data: dtData,
                    backgroundColor: 'rgba(30,215,96,0.2)',
                    borderColor: '#1ed760',
                    borderWidth: 1,
                    borderRadius: 4,
                    hoverBackgroundColor: 'rgba(30,215,96,0.4)'
                }]
            },
            options: baseOpts
        });

        new Chart(document.getElementById('chartLuot'), {
            type: 'line',
            data: {
                labels,
                datasets: [{
                    label: 'Lượt đặt',
                    data: luotData,
                    borderColor: '#6caee0',
                    backgroundColor: 'rgba(108,174,224,0.08)',
                    borderWidth: 2,
                    pointBackgroundColor: '#6caee0',
                    pointRadius: 4,
                    tension: 0.4,
                    fill: true
                }]
            },
            options: {
                ...baseOpts,
                scales: {
                    x: baseOpts.scales.x,
                    y: { ...baseOpts.scales.y,
                         ticks: { color: '#ffffff80',
                                   font: { size: 11 },
                                   callback: v => v } }
                }
            }
        });
    </script>
}
