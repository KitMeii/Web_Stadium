<!-- FILTER BAR -->
<div style="background:var(--bg2);padding:16px 0;border-bottom:1px solid var(--border);position:sticky;top:53px;z-index:90;">
    <div class="container">
        <form method="get" action="/Admin/BaoCao" id="filterForm"
              style="display:flex;flex-wrap:wrap;align-items:center;gap:12px;">

            <!-- Loai bao cao -->
            <div style="display:flex;align-items:center;gap:6px;">
                <span style="font-size:12px;color:var(--muted);letter-spacing:1px;text-transform:uppercase;">Xem theo</span>
                <div style="display:flex;gap:4px;">
                    @foreach (var (lbl, val) in new[] { ("Ngày", "ngay"), ("Tuần", "tuan"), ("Tháng", "thang"), ("Quý", "quy"), ("Năm", "nam") })
                    {
                        <button type="button" onclick="setLoai('@val')"
                                class="loai-btn @(ViewBag.Loai == val ? "loai-on" : "")">
                            @lbl
                        </button>
                    }
                </div>
            </div>

            <div style="width:1px;height:28px;background:var(--border);"></div>

            <!-- Nam -->
            <div style="display:flex;align-items:center;gap:6px;">
                <span style="font-size:12px;color:var(--muted);letter-spacing:1px;text-transform:uppercase;">Năm</span>
                <select name="nam" id="selNam" onchange="autoSubmit()"
                        style="background:var(--bg3);border:1px solid var(--border2);color:var(--text);
                               border-radius:8px;padding:5px 10px;font-size:13px;cursor:pointer;">
                    @for (int y = DateTime.Now.Year + 1; y >= 2020; y--)
                    {
                        if (ViewBag.Nam == y)
                        {
                            <option value="@y" selected>@y</option>
                        }
                        else
                        {
                            <option value="@y">@y</option>
                        }
                    }
                </select>
            </div>

            <!-- Thang (an khi loai = nam/quy) -->
            <div id="wrapThang" style="display:flex;align-items:center;gap:6px;">
                <span style="font-size:12px;color:var(--muted);letter-spacing:1px;text-transform:uppercase;">Tháng</span>
                <select name="thang" id="selThang" onchange="autoSubmit()"
                        style="background:var(--bg3);border:1px solid var(--border2);color:var(--text);
                               border-radius:8px;padding:5px 10px;font-size:13px;cursor:pointer;">
                    @for (int m = 1; m <= 12; m++)
                    {
                        if (ViewBag.Thang == m)
                        {
                            <option value="@m" selected>Tháng @m</option>
                        }
                        else
                        {
                            <option value="@m">Tháng @m</option>
                        }
                    }
                </select>
            </div>

            <input type="hidden" name="loai" id="hidLoai" value="@ViewBag.Loai" />

            <!-- Nut loc -->
            <button type="submit"
                    style="background:var(--green);color:#fff;border:none;border-radius:8px;
                           padding:6px 16px;font-size:13px;font-weight:600;cursor:pointer;
                           display:flex;align-items:center;gap:6px;">
                🔍 Lọc
            </button>

            <!-- Toggle calendar -->
            <button type="button" onclick="toggleCal()"
                    style="background:var(--bg3);border:1px solid var(--border2);color:var(--muted);
                           border-radius:8px;padding:6px 14px;font-size:13px;cursor:pointer;
                           display:flex;align-items:center;gap:6px;">
                📅 Lịch
            </button>
        </form>

        <!-- MINI CALENDAR -->
        <div id="miniCal" style="display:none;margin-top:14px;
                                  background:var(--bg3);border:1px solid var(--border2);
                                  border-radius:12px;padding:16px;max-width:320px;">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;">
                <button onclick="calPrev()" style="background:none;border:none;color:var(--muted);font-size:18px;cursor:pointer;">‹</button>
                <span id="calTitle" style="font-weight:700;color:var(--text);font-size:14px;"></span>
                <button onclick="calNext()" style="background:none;border:none;color:var(--muted);font-size:18px;cursor:pointer;">›</button>
            </div>
            <div style="display:grid;grid-template-columns:repeat(7,1fr);gap:2px;text-align:center;">
                @foreach (var d in new[] { "CN", "T2", "T3", "T4", "T5", "T6", "T7" })
                {
                    <div style="font-size:10px;color:var(--muted);padding:4px 0;font-weight:700;">@d</div>
                }
            </div>
            <div id="calBody" style="display:grid;grid-template-columns:repeat(7,1fr);gap:2px;text-align:center;margin-top:4px;"></div>
            <div id="calInfo" style="margin-top:10px;padding:8px;background:rgba(14,168,106,0.1);
                                      border-radius:8px;font-size:12px;color:var(--green);text-align:center;display:none;"></div>
        </div>
    </div>
</div>

<style>
    .loai-btn {
        background: var(--bg3);
        border: 1px solid var(--border2);
        color: var(--muted);
        border-radius: 6px;
        padding: 5px 12px;
        font-size: 12px;
        font-weight: 600;
        cursor: pointer;
        transition: all .15s;
    }

        .loai-btn:hover {
            border-color: var(--green);
            color: var(--green);
        }

        .loai-btn.loai-on {
            background: var(--green);
            border-color: var(--green);
            color: #fff;
        }

    .cal-day {
        font-size: 12px;
        padding: 5px 2px;
        border-radius: 6px;
        cursor: pointer;
        color: var(--muted2);
        transition: background .15s;
        line-height: 1.2;
    }

        .cal-day:hover {
            background: rgba(14,168,106,0.15);
            color: var(--green);
        }

        .cal-day.today {
            background: rgba(14,168,106,0.25);
            color: var(--green);
            font-weight: 700;
        }

        .cal-day.selected {
            background: var(--green);
            color: #fff;
            font-weight: 700;
        }

        .cal-day.other-month {
            color: var(--muted);
            opacity: .4;
        }

        .cal-day.sun {
            color: #e74c3c;
        }

        .cal-day.sat {
            color: #6caee0;
        }
</style>

<script>
    (function () {
        var loaiHideThang = ['nam', 'quy'];
        var loaiHideNam = [];

        function updateWrap() {
            var l = document.getElementById('hidLoai').value;
            document.getElementById('wrapThang').style.display =
                loaiHideThang.includes(l) ? 'none' : 'flex';
        }

        window.setLoai = function (v) {
            document.getElementById('hidLoai').value = v;
            document.querySelectorAll('.loai-btn').forEach(function (b) { b.classList.remove('loai-on'); });
            event.target.classList.add('loai-on');
            updateWrap();
            document.getElementById('filterForm').submit();
        };

        window.autoSubmit = function () {
            document.getElementById('filterForm').submit();
        };

        updateWrap();

        // ── MINI CALENDAR ──
        var calYear = @ViewBag.Nam;
        var calMonth = @ViewBag.Thang - 1; // 0-based
        var selectedDate = null;
        var today = new Date();
        var thu = ['Chủ nhật','Thứ Hai','Thứ Ba','Thứ Tư','Thứ Năm','Thứ Sáu','Thứ Bảy'];
        var thangNames = ['Tháng 1','Tháng 2','Tháng 3','Tháng 4','Tháng 5','Tháng 6',
                          'Tháng 7','Tháng 8','Tháng 9','Tháng 10','Tháng 11','Tháng 12'];

        function renderCal() {
            document.getElementById('calTitle').textContent = thangNames[calMonth] + ' / ' + calYear;
            var body = document.getElementById('calBody');
            body.innerHTML = '';
            var first = new Date(calYear, calMonth, 1).getDay();
            var days = new Date(calYear, calMonth + 1, 0).getDate();
            var prevDays = new Date(calYear, calMonth, 0).getDate();

            // cells from prev month
            for (var i = 0; i < first; i++) {
                var d = prevDays - first + 1 + i;
                var el = document.createElement('div');
                el.className = 'cal-day other-month';
                el.textContent = d;
                body.appendChild(el);
            }
            // current month
            for (var d = 1; d <= days; d++) {
                var el = document.createElement('div');
                var dow = new Date(calYear, calMonth, d).getDay();
                var cls = 'cal-day';
                if (dow === 0) cls += ' sun';
                else if (dow === 6) cls += ' sat';
                if (d === today.getDate() && calMonth === today.getMonth() && calYear === today.getFullYear()) cls += ' today';
                if (selectedDate && d === selectedDate.getDate() && calMonth === selectedDate.getMonth() && calYear === selectedDate.getFullYear()) cls += ' selected';
                el.className = cls;
                el.textContent = d;
                (function (day, weekday) {
                    el.addEventListener('click', function () {
                        selectedDate = new Date(calYear, calMonth, day);
                        var info = document.getElementById('calInfo');
                        info.style.display = 'block';
                        info.textContent = thu[weekday] + ', ' + day + '/' + (calMonth + 1) + '/' + calYear;
                        renderCal();
                    });
                })(d, dow);
                body.appendChild(el);
            }
            // fill remaining
            var rem = 7 - ((first + days) % 7);
            if (rem < 7) {
                for (var i = 1; i <= rem; i++) {
                    var el = document.createElement('div');
                    el.className = 'cal-day other-month';
                    el.textContent = i;
                    body.appendChild(el);
                }
            }
        }

        window.calPrev = function () { calMonth--; if (calMonth < 0) { calMonth = 11; calYear--; } renderCal(); };
        window.calNext = function () { calMonth++; if (calMonth > 11) { calMonth = 0; calYear++; } renderCal(); };
        window.toggleCal = function () {
            var c = document.getElementById('miniCal');
            c.style.display = c.style.display === 'none' ? 'block' : 'none';
            if (c.style.display === 'block') renderCal();
        };
    })();
</script>

<div class="container py-4">

    <!-- KPI CARDS -->
    <div id="overview" class="kpi-grid" style="padding-top:8px;">
        <div class="kpi-card">
            <div class="kpi-icon">💰</div>
            <div class="kpi-num">@((tongDT / 1_000_000).ToString("F1"))M</div>
            <div class="kpi-lbl">Tổng doanh thu (VND)</div>
        </div>
        <div class="kpi-card">
            <div class="kpi-icon">📋</div>
            <div class="kpi-num blue">@tongLuot</div>
            <div class="kpi-lbl">Lượt đặt sân</div>
        </div>
        <div class="kpi-card">
            <div class="kpi-icon">🏆</div>
            <div class="kpi-num yellow">T@(bestThang?.thang ?? "-")</div>
            <div class="kpi-lbl">Tháng cao nhất</div>
        </div>
        <div class="kpi-card">
            <div class="kpi-icon">📊</div>
            <div class="kpi-num">@((tbMoiLuot / 1_000).ToString("F0"))K</div>
            <div class="kpi-lbl">TB mỗi lượt (VND)</div>
        </div>
    </div>

    <!-- BIEU DO DOANH THU 12 THANG -->
    <div id="monthly" class="chart-card2">
        <div class="chart-title2">Doanh thu theo tháng</div>
        <div class="chart-sub2">Tiền cọc đã thu trong năm @ViewBag.Nam</div>
        <div style="position:relative;height:280px;">
            <canvas id="chartDT"></canvas>
        </div>
    </div>

    <!-- 2 BIEU DO NHO -->
    <div class="charts-2col" id="occupancy">

        <div class="chart-card2">
            <div class="chart-title2">Số lượt đặt sân</div>
            <div class="chart-sub2">Theo từng tháng trong năm</div>
            <div style="position:relative;height:220px;">
                <canvas id="chartLuot"></canvas>
            </div>
        </div>

        <div class="chart-card2">
            <div class="chart-title2">Tỷ lệ lấp đầy sân</div>
            <div class="chart-sub2">Khung giờ đã đặt / tổng khung giờ</div>
            @if (!tyLe.Any())
            {
                <p style="color:var(--muted);text-align:center;padding:40px 0;font-size:13px;">
                    Chưa có dữ liệu
                </p>
            }
            else
            {
                foreach (var san in tyLe.Take(6))
                {
                    int pct = 0;
                    try { pct = san.Tong > 0 ? (int)((double)san.DaDat / (double)san.Tong * 100) : 0; } catch { }
                    <div class="prog-row">
                        <div class="prog-header">
                            <span class="prog-name">@san.Ten</span>
                            <span class="prog-val" style="color:var(--green);">@pct%</span>
                        </div>
                        <div class="prog-track">
                            <div class="prog-fill" style="width:@pct%;"></div>
                        </div>
                    </div>
                }
            }
        </div>

    </div>

    <!-- OWNER -->
    <div class="charts-2col" id="owners">

        <div class="chart-card2">
            <div class="chart-title2">Doanh thu theo Owner</div>
            <div class="chart-sub2">Top chủ sân đóng góp nhiều nhất</div>
            @if (!ownerData2.Any())
            {
                <p style="color:var(--muted);text-align:center;padding:40px 0;font-size:13px;">
                    Chưa có dữ liệu doanh thu
                </p>
            }
            else
            {
                double maxOwDT = 1;
                try { maxOwDT = ownerData2.Max(o => (double)o.DoanhThu); if (maxOwDT <= 0) maxOwDT = 1; } catch { }
                foreach (var o in ownerData2.Take(8))
                {
                    int pct = 0;
                    double oDT = 0;
                    try { oDT = (double)o.DoanhThu; pct = (int)(oDT / maxOwDT * 100); } catch { }
                    <div class="prog-row">
                        <div class="prog-header">
                            <span class="prog-name">@o.Owner</span>
                            <span class="prog-val" style="color:#6caee0;">
                                @((oDT / 1_000_000).ToString("F1"))M
                            </span>
                        </div>
                        <div class="prog-track">
                            <div class="prog-fill blue" style="width:@pct%;"></div>
                        </div>
                    </div>
                }
            }
        </div>

        <div class="chart-card2">
            <div class="chart-title2">Phân bổ doanh thu</div>
            <div class="chart-sub2">Tỷ lệ % theo từng Owner</div>
            <div style="position:relative;height:260px;">
                <canvas id="chartOwner"></canvas>
            </div>
        </div>

    </div>

</div><!-- /container -->
</div><!-- /bc-page -->
@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
    <script>
        (function(){
          var labels   = @Html.Raw(labelsJson);
          var dtData   = @Html.Raw(dtJson);
          var lượtData = @Html.Raw(lượtJson);

          var baseOpts = {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
              x: { grid:{color:'rgba(255,255,255,0.04)'},
                   ticks:{color:'#ffffff70',font:{size:11}} },
              y: { grid:{color:'rgba(255,255,255,0.04)'},
                   ticks:{color:'#ffffff70',font:{size:11},
                          callback:function(v){return v+'M';}} }
            }
          };

          // Bar chart doanh thu
          new Chart(document.getElementById('chartDT'),{
            type:'bar',
            data:{
              labels:labels,
              datasets:[{
                label:'Doanh thu (triệu VND)',
                data:dtData,
                backgroundColor:'rgba(30,215,96,0.18)',
                borderColor:'#1ed760',
                borderWidth:1,
                borderRadius:6,
                hoverBackgroundColor:'rgba(30,215,96,0.38)'
              }]
            },
            options:baseOpts
          });

          // Line chart lượt dat
          new Chart(document.getElementById('chartLuot'),{
            type:'line',
            data:{
              labels:labels,
              datasets:[{
                label:'Lượt đặt',
                data:lượtData,
                borderColor:'#6caee0',
                backgroundColor:'rgba(108,174,224,0.08)',
                borderWidth:2,
                pointBackgroundColor:'#6caee0',
                pointRadius:4,
                tension:0.4,
                fill:true
              }]
            },
            options:{
              responsive:true,
              maintainAspectRatio:false,
              plugins:{legend:{display:false}},
              scales:{
                x:baseOpts.scales.x,
                y:{grid:{color:'rgba(255,255,255,0.04)'},
                   ticks:{color:'#ffffff70',font:{size:11}}}
              }
            }
          });

          // Doughnut owner
          var ownerLabels = @Html.Raw(ownerLblJson);
          var ownerDt     = @Html.Raw(ownerDtJson);
          if(ownerLabels.length > 0){
            new Chart(document.getElementById('chartOwner'),{
              type:'doughnut',
              data:{
                labels:ownerLabels,
                datasets:[{
                  data:ownerDt,
                  backgroundColor:[
                    'rgba(30,215,96,0.75)','rgba(108,174,224,0.75)',
                    'rgba(246,170,56,0.75)','rgba(229,77,77,0.75)',
                    'rgba(167,119,227,0.75)','rgba(80,200,180,0.75)'
                  ],
                  borderWidth:0,
                  hoverOffset:8
                }]
              },
              options:{
                responsive:true,
                maintainAspectRatio:false,
                plugins:{
                  legend:{
                    position:'bottom',
                    labels:{color:'#ffffff80',font:{size:11},padding:12}
                  }
                }
              }
            });
          }

          // Smooth scroll cho sub-nav
          document.querySelectorAll('.bc-tab').forEach(function(tab){
            tab.addEventListener('click',function(e){
              e.preventDefault();
              var id=this.getAttribute('href').replace('#','');
              var el=document.getElementById(id);
              if(el) el.scrollIntoView({behavior:'smooth',block:'start'});
              document.querySelectorAll('.bc-tab').forEach(function(t){t.classList.remove('on');});
              this.classList.add('on');
            });
          });
        })();
    </script>
}

