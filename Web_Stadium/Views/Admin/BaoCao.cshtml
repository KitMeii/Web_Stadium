@{
    ViewData["Title"] = "Báo cáo doanh thu";
    Layout = "~/Views/Shared/_Layout.cshtml";

    // Safe cast helpers tránh null exception
    var doanhThuNam = (ViewBag.DoanhThuNam as IEnumerable<dynamic>)
                     ?? Enumerable.Empty<dynamic>();
    var tyLe = (ViewBag.TyLe as IEnumerable<dynamic>)
                     ?? Enumerable.Empty<dynamic>();
    var ownerData2 = (ViewBag.DoanhThuTheoOwner as IEnumerable<dynamic>)
                     ?? Enumerable.Empty<dynamic>();

    double tongDT = 0;
    int tongLuot = 0;
    foreach (var d in doanhThuNam)
    {
        try { tongDT += (double)d.dt; } catch { }
        try { tongLuot += (int)d.soLuot; } catch { }
    }
    dynamic bestThang = null;
    double bestDT = -1;
    foreach (var d in doanhThuNam)
    {
        try { if ((double)d.dt > bestDT) { bestDT = (double)d.dt; bestThang = d; } } catch { }
    }
    var tbMoiLuot = tongLuot > 0 ? tongDT / tongLuot : 0;

    // JSON helpers cho Chart.js
    string labelsJson = "[" + string.Join(",",
        doanhThuNam.Select(d => { try { return "\"" + d.thang + "\""; } catch { return "\"?\""; } })) + "]";
    string dtJson = "[" + string.Join(",",
        doanhThuNam.Select(d =>
        {
            try
            {
                return ((double)d.dt / 1000000).ToString("F2",
                System.Globalization.CultureInfo.InvariantCulture);
            }
            catch { return "0"; }
        })) + "]";
    string lượtJson = "[" + string.Join(",",
        doanhThuNam.Select(d => { try { return ((int)d.soLuot).ToString(); } catch { return "0"; } })) + "]";

    string ownerLblJson = "[" + string.Join(",",
        ownerData2.Select(o => { try { return "\"" + ((string)o.Owner).Replace("\"", "") + "\""; } catch { return "\"?\""; } })) + "]";
    string ownerDtJson = "[" + string.Join(",",
        ownerData2.Select(o =>
        {
            try
            {
                return ((double)o.DoanhThu / 1000000).ToString("F2",
                System.Globalization.CultureInfo.InvariantCulture);
            }
            catch { return "0"; }
        })) + "]";
}

@section Styles {
    <link rel="stylesheet" href="~/css/baocao.css" />
    <style>
        .bc-page {
            background: var(--bg);
            min-height: 100vh;
        }

        /* Header */
        .bc-hdr {
            background: linear-gradient(135deg, var(--bg2) 0%, var(--bg) 100%);
            border-bottom: 1px solid var(--border);
            padding: 88px 0 36px;
        }

            .bc-hdr h1 {
                font-style: italic;
                line-height: .9;
                margin-bottom: 16px;
            }

        /* Year nav */
        .yr-nav {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .yr-btn {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: var(--bg3);
            border: 1px solid var(--border2);
            color: var(--muted);
            font-family: var(--ff-h);
            font-size: 12px;
            letter-spacing: 1px;
            text-transform: uppercase;
            padding: 7px 16px;
            border-radius: 999px;
            text-decoration: none;
            transition: all .2s;
        }

            .yr-btn:hover {
                border-color: var(--green);
                color: var(--green);
            }

        .yr-cur {
            font-family: var(--ff-h);
            font-size: 22px;
            font-weight: 700;
            color: var(--green);
            padding: 0 8px;
        }

        /* KPI grid */
        .kpi-grid {
            display: grid;
            grid-template-columns: repeat(4,1fr);
            gap: 16px;
            margin-bottom: 28px;
        }

        @@media(max-width:768px) {
            .kpi-grid {
                grid-template-columns: repeat(2,1fr);
            }
        }

        .kpi-card {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: var(--r-lg);
            padding: 22px 20px;
            transition: border-color .2s, transform .2s;
        }

            .kpi-card:hover {
                border-color: var(--green);
                transform: translateY(-2px);
            }

        .kpi-icon {
            font-size: 1.4rem;
            margin-bottom: 10px;
        }

        .kpi-num {
            font-family: var(--ff-h);
            font-size: 2rem;
            font-weight: 700;
            color: var(--green);
            line-height: 1;
            margin-bottom: 6px;
        }

            .kpi-num.blue {
                color: #6caee0;
            }

            .kpi-num.yellow {
                color: #f6aa38;
            }

            .kpi-num.red {
                color: #e74c3c;
            }

        .kpi-lbl {
            font-size: 12px;
            color: var(--muted);
            letter-spacing: 1px;
            text-transform: uppercase;
        }

        /* Chart cards */
        .chart-card2 {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: var(--r-lg);
            padding: 24px;
            margin-bottom: 20px;
        }

        .chart-title2 {
            font-family: var(--ff-h);
            font-size: 15px;
            font-weight: 700;
            color: var(--text);
            letter-spacing: .5px;
            margin-bottom: 4px;
        }

        .chart-sub2 {
            font-size: 12px;
            color: var(--muted);
            margin-bottom: 20px;
        }

        /* Two col charts */
        .charts-2col {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-bottom: 20px;
        }

        @@media(max-width:768px) {
            .charts-2col {
                grid-template-columns: 1fr;
            }
        }

        /* Progress bars */
        .prog-row {
            margin-bottom: 14px;
        }

        .prog-header {
            display: flex;
            justify-content: space-between;
            font-size: 13px;
            margin-bottom: 5px;
        }

        .prog-name {
            color: var(--muted2);
            font-weight: 500;
        }

        .prog-val {
            font-weight: 700;
        }

        .prog-track {
            height: 6px;
            background: rgba(255,255,255,0.06);
            border-radius: 999px;
            overflow: hidden;
        }

        .prog-fill {
            height: 100%;
            border-radius: 999px;
            background: var(--green);
            transition: width .8s ease;
        }

            .prog-fill.blue {
                background: #6caee0;
            }

        /* Sticky sub-nav */
        .bc-subnav {
            background: var(--bg3);
            border-bottom: 1px solid var(--border);
            padding: 10px 0;
            position: sticky;
            top: 0;
            z-index: 100;
        }

            .bc-subnav .inner {
                display: flex;
                gap: 8px;
                flex-wrap: wrap;
                justify-content: center;
                align-items: center;
            }

        .bc-tab {
            font-family: var(--ff-h);
            font-size: 10px;
            font-weight: 700;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            padding: 7px 16px;
            border-radius: 999px;
            background: var(--bg);
            border: 1px solid var(--border2);
            color: var(--muted);
            text-decoration: none;
            transition: all .2s;
        }

            .bc-tab:hover, .bc-tab.on {
                background: var(--green);
                border-color: var(--green);
                color: #fff;
            }
    </style>
}

