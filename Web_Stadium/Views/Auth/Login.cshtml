@section Styles {
    <link rel="stylesheet" href="~/css/login.css" asp-append-version="true" />
}

@{
    ViewData["Title"] = "Đăng nhập";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="rm-auth-wrap">
    <div class="rm-auth-container">

        <div class="rm-auth-side rm-left">
            <a href="/" class="rm-logo">Pitch<span>Hub</span></a>

            <h2 class="rm-title">Đăng nhập</h2>

            @if (ViewBag.Error != null)
            {
                <div class="auth-error">
                    <span>⚠</span> @ViewBag.Error
                </div>
            }

            <form method="post" action="/Auth/Login" class="rm-form">
                <div class="rm-input-group">
                    <input class="rm-input" type="email" name="email" placeholder="Email của bạn" required autocomplete="email" />
                </div>

                <div class="rm-input-group">
                    <input class="rm-input" type="password" name="matkhau" placeholder="Mật khẩu" required autocomplete="current-password" />
                </div>

                <button type="submit" class="rm-btn rm-btn-primary">Tiếp tục</button>
            </form>

            <div class="rm-helper-links">
                <a href="/Auth/ForgotPassword" class="rm-link-text">Quên mật khẩu</a>
                <span class="rm-dot-divider">•</span>
                <a href="/Auth/Register" class="rm-link-text">Đăng ký tài khoản</a>
            </div>

            <div class="rm-divider">
                <span>HOẶC</span>
            </div>

            <div class="rm-social-group">
                <a href="/Auth/GoogleLogin" class="rm-btn rm-btn-outline">
                    <div class="google-icon"></div>
                    Tiếp tục với Google
                </a>
            </div>
        </div>

        <div class="rm-vertical-divider"></div>

        <div class="rm-auth-side rm-right">
            <h2 class="rm-title">Chưa có tài khoản? Đăng ký ngay</h2>

            <div class="rm-tiers">
                <a href="/Auth/Register" class="rm-tier-card active">
                    <div class="rm-tier-info">
                        <span class="rm-tier-name">Thành viên Cơ bản</span>
                        <span class="rm-tier-price">Miễn phí</span>
                    </div>
                    <div class="rm-tier-arrow">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6" /></svg>
                    </div>
                </a>

                <a href="/Auth/Register?plan=vip" class="rm-tier-card premium">
                    <div class="rm-tier-info">
                        <span class="rm-tier-name">Thành viên VIP</span>
                        <span class="rm-tier-price">Từ 50.000đ/tháng</span>
                    </div>
                    <div class="rm-tier-arrow">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6" /></svg>
                    </div>
                </a>

                <a href="/Auth/Register?plan=business" class="rm-tier-card platinum">
                    <div class="rm-tier-info">
                        <span class="rm-tier-name">Đối tác Chủ Sân</span>
                        <span class="rm-tier-price">Dành riêng cho doanh nghiệp</span>
                    </div>
                    <div class="rm-tier-arrow">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6" /></svg>
                    </div>
                </a>
            </div>
        </div>

    </div>
</div>