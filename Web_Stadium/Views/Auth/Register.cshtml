@section Styles {
    <link rel="stylesheet" href="~/css/register.css" asp-append-version="true" />
}

@{
    ViewData["Title"] = "Đăng ký";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="rm-auth-wrap">
    <div class="rm-auth-container">

        <div class="rm-auth-side rm-left">
            <a href="/" class="rm-logo">Pitch<span>Hub</span>.vn</a>
            <h2 class="rm-title">Tạo tài khoản miễn phí</h2>

            @if (ViewBag.Error != null)
            {
                <div class="auth-error">⚠ @ViewBag.Error</div>
            }

            <form method="post" action="/Auth/Register" id="registerForm" class="rm-form">
                <div class="rm-row">
                    <div class="rm-input-group">
                        <input class="rm-input" type="text" name="ho" placeholder="Họ" required />
                    </div>
                    <div class="rm-input-group">
                        <input class="rm-input" type="text" name="ten" placeholder="Tên" required />
                    </div>
                </div>

                <div class="rm-input-group">
                    <input class="rm-input" type="email" name="email" placeholder="Email (ten@email.com)" required autocomplete="email" />
                </div>

                <div class="rm-input-group">
                    <input class="rm-input" type="tel" name="soDienThoai" placeholder="Số điện thoại" />
                </div>

                <div class="rm-role-section">
                    <label class="rm-label-small">Bạn là:</label>
                    <input type="hidden" name="vaiTro" id="vaiTroInput" value="User" />
                    <div class="rm-role-group">
                        <div class="rm-role-btn active" onclick="chonVaiTro(this, 'User')">
                            ⚽ Người đặt
                        </div>
                        <div class="rm-role-btn" onclick="chonVaiTro(this, 'Owner')">
                            🏟️ Chủ sân
                        </div>
                        <div class="rm-role-btn" onclick="chonVaiTro(this, 'Staff')">
                            👷 Nhân viên
                        </div>
                    </div>
                </div>

                <div class="rm-row">
                    <div class="rm-input-group">
                        <input class="rm-input" type="password" name="matkhau" id="pwInput" placeholder="Mật khẩu" required />
                    </div>
                    <div class="rm-input-group">
                        <input class="rm-input" type="password" id="pwConfirm" placeholder="Xác nhận lại" required />
                    </div>
                </div>

                <button type="submit" class="rm-btn rm-btn-primary">Tạo tài khoản ngay</button>

                <div class="terms-text" style="color: #666; font-size: 11px; text-align: center; margin-bottom: 15px;">
                    Bằng cách đăng ký, bạn đồng ý với <a href="/terms" style="color:#5b5bff">Điều khoản</a> và <a href="/privacy" style="color:#5b5bff">Bảo mật</a>
                </div>
            </form>

            <div class="rm-divider"><span>hoặc</span></div>

            <a href="/Auth/GoogleLogin" class="rm-btn rm-btn-outline">
                <div class="google-icon"></div> Tiếp tục với Google
            </a>

            <div class="rm-helper-links">
                <span style="color: #888">Đã có tài khoản?</span>
                <a href="/Auth/Login" class="rm-link-text">Đăng nhập →</a>
            </div>
        </div>

        <div class="rm-vertical-divider"></div>

        <div class="rm-auth-side rm-right">
            <h2 class="rm-title" style="letter-spacing: 2px; color: #1ed760;">3 BƯỚC ĐỂ BẮT ĐẦU</h2>

            <div class="rm-steps-container">
                <div class="rm-step-card">
                    <div class="step-badge">1</div>
                    <div class="step-info">
                        <span class="step-name">Tạo tài khoản</span>
                        <span class="step-sub">Điền thông tin cơ bản & chọn vai trò</span>
                    </div>
                </div>
                <div class="rm-step-card">
                    <div class="step-badge">2</div>
                    <div class="step-info">
                        <span class="step-name">Tìm sân gần bạn</span>
                        <span class="step-sub">Lọc theo quận, loại sân, xem 360°</span>
                    </div>
                </div>
                <div class="rm-step-card">
                    <div class="step-badge">3</div>
                    <div class="step-info">
                        <span class="step-name">Đặt sân & thi đấu</span>
                        <span class="step-sub">Chọn khung giờ & thanh toán dễ dàng</span>
                    </div>
                </div>
            </div>

            <div class="rm-quote-box">
                <p>"Trước đây tìm sân mất cả buổi. Giờ chỉ cần 30 giây là xong, lịch hiện ngay tại chỗ."</p>
                <div class="quote-user">
                    <div class="user-avt">TK</div>
                    <div>
                        <strong>Tuấn Kiệt</strong>
                        <span>Đội trưởng FC Sunrise</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function chonVaiTro(el, val) {
            document.querySelectorAll('.rm-role-btn').forEach(b => b.classList.remove('active'));
            el.classList.add('active');
            document.getElementById('vaiTroInput').value = val;
        }

        document.getElementById('registerForm').addEventListener('submit', function(e) {
            var pw = document.getElementById('pwInput').value;
            var cf = document.getElementById('pwConfirm').value;
            if (pw !== cf) {
                e.preventDefault();
                alert('Mật khẩu xác nhận không khớp!');
            }
        });
    </script>
}
