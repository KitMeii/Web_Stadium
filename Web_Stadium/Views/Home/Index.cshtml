            <style>
                /* Slide wrapper */
                .pitch-slide {
                    position: relative;
                    width: 100%;
                    height: 100%;
                    min-height: 500px;
                    overflow: hidden;
                    border-radius: var(--r-lg);
                }

                /* Ảnh fill toàn bộ */
                .pitch-slide-img {
                    width: 100%;
                    height: 100%;
                    object-fit: cover;
                    object-position: center;
                    display: block;
                    transition: transform 6s ease;
                }

                /* Ken Burns effect — ảnh zoom nhẹ khi đang active */
                .carousel-item.active .pitch-slide-img {
                    transform: scale(1.06);
                }

                .carousel-item .pitch-slide-img {
                    transform: scale(1.0);
                }

                /* Gradient overlay */
                .pitch-slide-overlay {
                    position: absolute;
                    inset: 0;
                    background: linear-gradient( to top, rgba(5,8,15,0.70) 0%, rgba(5,8,15,0.10) 45%, transparent 100% );
                    pointer-events: none;
                }

                /* Tên sân góc dưới trái */
                .pitch-slide-info {
                    position: absolute;
                    bottom: 20px;
                    left: 20px;
                    z-index: 5;
                }

                .pitch-slide-label {
                    color: rgba(255,255,255,0.55);
                    font-family: var(--ff-h, 'Oswald', sans-serif);
                    font-size: 9px;
                    letter-spacing: 2.5px;
                    text-transform: uppercase;
                    margin-bottom: 4px;
                }

                .pitch-slide-name {
                    color: #ffffff;
                    font-family: var(--ff-h, 'Oswald', sans-serif);
                    font-size: 16px;
                    font-weight: 700;
                    letter-spacing: 1px;
                    text-shadow: 0 2px 8px rgba(0,0,0,0.4);
                }

                /* Số thứ tự góc trên phải */
                .pitch-slide-num {
                    position: absolute;
                    top: 16px;
                    right: 16px;
                    background: rgba(5,8,15,0.72);
                    backdrop-filter: blur(8px);
                    color: #fff;
                    font-family: var(--ff-h, 'Oswald', sans-serif);
                    font-size: 10px;
                    letter-spacing: 1.5px;
                    padding: 5px 12px;
                    border-radius: 999px;
                    border: 1px solid rgba(255,255,255,0.12);
                    z-index: 5;
                }

                /* Mũi tên prev/next */
                .pitch-arrow {
                    width: 40px !important;
                    height: 40px !important;
                    background: rgba(5,8,15,0.72) !important;
                    backdrop-filter: blur(8px);
                    border-radius: 50% !important;
                    border: 1px solid rgba(255,255,255,0.14) !important;
                    top: 50% !important;
                    transform: translateY(-50%) !important;
                    position: absolute !important;
                    opacity: 1 !important;
                    transition: background .2s, border-color .2s !important;
                }

                    .pitch-arrow:hover {
                        background: #0EA86A !important;
                        border-color: #0EA86A !important;
                    }

                .carousel-control-prev.pitch-arrow {
                    left: 14px !important;
                }

                .carousel-control-next.pitch-arrow {
                    right: 14px !important;
                }

                /* Dots */
                #pitchCarousel .carousel-indicators [data-bs-slide-to] {
                    width: 8px !important;
                    height: 8px !important;
                    border-radius: 50% !important;
                    border: none !important;
                    background: rgba(255,255,255,0.35) !important;
                    opacity: 1 !important;
                    transition: background .3s, transform .3s !important;
                    margin: 0 3px !important;
                }

                #pitchCarousel .carousel-indicators .active {
                    background: #0EA86A !important;
                    transform: scale(1.35) !important;
                }

                /* Fade transition mượt */
                #pitchCarousel .carousel-item {
                    transition: opacity .65s ease-in-out !important;
                }
            </style>

            <!-- Nội dung -->
            <div class="col-lg-6 d-flex flex-column
                        justify-content-center text-center"
                 data-aos="fade-left">

                <div class="section-label mx-auto mb-3">
                    Về chúng tôi
                </div>
                <h2 class="section-title mb-4">
                    <span>TRẢI NGHIỆM BÓNG ĐÁ</span><br/>
                    <span class="text-green">
                        ĐẲNG CẤP CHUYÊN NGHIỆP
