<!-- STADIUM VIEWER v3 - Bernabeu 960x640 HQ base64 -->
<section class="section" style="background:var(--bg2);border-top:1px solid var(--border)">
    <div class="container text-center">
        <div class="section-label mx-auto mb-2" data-aos="fade-up">Trải nghiệm tương tác</div>
        <h2 class="section-title mb-3" data-aos="fade-up">
            MÔ PHỎNG SÂN <span class="text-green">3D THẾ HỆ MỚI</span>
        </h2>
        <p style="color:var(--muted);margin-bottom:1.5rem" data-aos="fade-up">
            Kéo, xoay và khám phá sân trước khi sử dụng các dịch vụ của PitchHub 
        </p>

        <div id="stadWrap" data-aos="zoom-in"
             style="position:relative;border-radius:var(--r-lg);overflow:hidden;
                border:1px solid var(--border);box-shadow:var(--shadow-lg);
                background:#06070d;user-select:none;height:520px;cursor:grab;">

            <!-- Canvas render anh - tranh bug CSS transform goc -->
            <canvas id="stadCanvas"
                    style="position:absolute;inset:0;width:100%;height:100%;
                     pointer-events:none;"></canvas>

            <!-- Gradient overlays -->
            <div style="position:absolute;inset:0;pointer-events:none;z-index:2;
           background:linear-gradient(to top,rgba(6,7,13,0.60) 0%,transparent 38%),
                       radial-gradient(ellipse at center,transparent 42%,rgba(6,7,13,0.28) 100%);"></div>

            <!-- Badge -->
            <div style="position:absolute;top:14px;left:14px;z-index:10;pointer-events:none;
                  display:flex;align-items:center;gap:8px;
                  background:rgba(6,7,13,0.82);backdrop-filter:blur(12px);
                  padding:8px 16px;border-radius:999px;
                  border:1px solid rgba(255,255,255,0.12);">
                <div style="width:9px;height:9px;border-radius:50%;background:#BE0000;
                    box-shadow:0 0 10px #BE0000;"></div>
                <span style="color:#fff;font-family:'Oswald',sans-serif;
                     font-size:11px;font-weight:700;letter-spacing:2px;">SANTIAGO BERNABEU</span>
            </div>

            <!-- Zoom badge -->
            <div id="zoomBadge"
                 style="position:absolute;top:14px;right:14px;z-index:10;pointer-events:none;
                  background:rgba(6,7,13,0.82);backdrop-filter:blur(12px);
                  color:rgba(255,255,255,0.80);font-family:'Oswald',sans-serif;
                  font-size:11px;font-weight:700;letter-spacing:1.5px;
                  padding:8px 14px;border-radius:999px;
                  border:1px solid rgba(255,255,255,0.10);">
                1.0x
            </div>

            <!-- Hint -->
            <div id="stadHint"
                 style="position:absolute;bottom:64px;left:50%;transform:translateX(-50%);
                  z-index:10;pointer-events:none;transition:opacity 0.6s;
                  background:rgba(6,7,13,0.72);backdrop-filter:blur(8px);
                  color:rgba(255,255,255,0.65);font-family:'Oswald',sans-serif;
                  font-size:10px;letter-spacing:2px;text-transform:uppercase;
                  padding:7px 18px;border-radius:999px;
                  border:1px solid rgba(255,255,255,0.10);">
                Keo di chuyen &nbsp;&#183;&nbsp; Scroll zoom &nbsp;&#183;&nbsp; Dbl-click phong to
            </div>

            <!-- Buttons -->
            <div style="position:absolute;bottom:16px;left:50%;transform:translateX(-50%);
                  display:flex;gap:7px;z-index:10;flex-wrap:wrap;justify-content:center;">
                <button class="svb on" onclick="goView('full',this)">Toan canh</button>
                <button class="svb" onclick="goView('pitch',this)">Mat co</button>
                <button class="svb" onclick="goView('stand',this)">Khan dai</button>
                <button class="svb" onclick="goView('goal',this)">Khung thanh</button>
                <button class="svb" onclick="goView('roof',this)">Mai vong</button>
                <button class="svb" id="autoPanBtn" onclick="toggleAuto(this)">&#9654; Auto Pan</button>
            </div>
        </div>

        <div style="margin-top:24px" data-aos="fade-up">
            <a href="/Venues" class="btn-primary-glow">ĐẶT SÂN NGAY</a>
        </div>
    </div>
</section>

<style>
    .svb {
        background: rgba(6,7,13,0.82);
        border: 1px solid rgba(255,255,255,0.18);
        color: rgba(255,255,255,0.90);
        font-family: var(--ff-h,'Oswald',sans-serif);
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 1.2px;
        text-transform: uppercase;
        padding: 7px 15px;
        border-radius: 999px;
        cursor: pointer;
        backdrop-filter: blur(10px);
        transition: all .2s;
        white-space: nowrap;
    }

        .svb:hover, .svb.on {
            background: #0EA86A;
            border-color: #0EA86A;
            color: #fff;
        }

    #stadWrap:active {
        cursor: grabbing;
    }
</style>

<script>
    (function(){
      var wrap   = document.getElementById('stadWrap');
      var canvas = document.getElementById('stadCanvas');
      var ctx    = canvas.getContext('2d');
      var zBadge = document.getElementById('zoomBadge');
      var hint   = document.getElementById('stadHint');

      // Load anh tu base64
      var img = new Image();
      img.src = 'data:image/jpeg;base64,';

      // State: offX/offY = pixel offset tu center, scale
      var state  = {ox:0, oy:0, sc:1};
      var target = {ox:0, oy:0, sc:1};
      var SC_MIN=1.0, SC_MAX=4.5;
      var autoPan=false, wpIdx=0, wpProg=0, hinted=false, dragging=false;
      var dsx=0, dsy=0, dox=0, doy=0;
      var imgW=0, imgH=0, cW=0, cH=0;
      var ready=false;

      img.onload = function(){
        imgW=img.naturalWidth; imgH=img.naturalHeight;
        ready=true;
        resize();
        loop();
      };

      function resize(){
        cW = wrap.offsetWidth;
        cH = wrap.offsetHeight;
        canvas.width  = cW;
        canvas.height = cH;
      }

      // Ve anh len canvas - dung drawImage de co maxOff chinh xac
      function draw(){
        if(!ready) return;
        ctx.clearRect(0,0,cW,cH);

        // Tinh base scale de cover canvas (object-fit:cover logic)
        var scBase = Math.max(cW/imgW, cH/imgH);
        var sc     = scBase * state.sc;
        var dw     = imgW * sc;
        var dh     = imgH * sc;

        // Center + offset
        var dx = (cW - dw)/2 + state.ox;
        var dy = (cH - dh)/2 + state.oy;

        ctx.imageSmoothingEnabled = true;
        ctx.imageSmoothingQuality = 'high';
        ctx.drawImage(img, dx, dy, dw, dh);
      }

      function maxOff(sc){
        var scBase = Math.max(cW/imgW, cH/imgH);
        var dw = imgW * scBase * sc;
        var dh = imgH * scBase * sc;
        return {x: Math.max(0,(dw-cW)/2), y: Math.max(0,(dh-cH)/2)};
      }

      function clampState(){
        var mo = maxOff(target.sc);
        target.ox = Math.max(-mo.x, Math.min(mo.x, target.ox));
        target.oy = Math.max(-mo.y, Math.min(mo.y, target.oy));
      }

      function lerp(a,b,t){return a+(b-a)*t;}
      function ease(t){return t<0.5?2*t*t:1-Math.pow(-2*t+2,2)/2;}
      function hideHint(){if(!hinted){hinted=true;hint.style.opacity='0';}}

      // Preset views: sc=zoom level, ox/oy=pixel offset
      // Tinh theo anh 960x640, canvas ~1160x520
      var views = {
        full:  {sc:1.0, ox:0,    oy:0},
        pitch: {sc:2.0, ox:0,    oy:120},   // zoom xuong mat co
        stand: {sc:2.2, ox:180,  oy:-60},   // khan dai phai
        goal:  {sc:2.8, ox:-220, oy:60},    // khung thanh trai
        roof:  {sc:1.6, ox:0,    oy:-140}   // mai vong phia tren
      };

      // Waypoints cho auto pan (ox,oy theo pixel, sc theo zoom)
      var wp = [
        {sc:1.0, ox:0,    oy:0},
        {sc:1.8, ox:0,    oy:100},
        {sc:2.2, ox:180,  oy:-50},
        {sc:2.8, ox:-210, oy:60},
        {sc:1.6, ox:60,   oy:-120},
        {sc:2.0, ox:200,  oy:80},
        {sc:1.4, ox:-80,  oy:-80},
        {sc:1.0, ox:0,    oy:0}
      ];

      window.goView = function(v, btn){
        document.querySelectorAll('.svb').forEach(function(b){b.classList.remove('on');});
        btn.classList.add('on');
        autoPan = false;
        document.getElementById('autoPanBtn').classList.remove('on');
        var vd = views[v];
        target.sc = vd.sc; target.ox = vd.ox; target.oy = vd.oy;
        clampState();
      };

      window.toggleAuto = function(btn){
        autoPan = !autoPan; btn.classList.toggle('on', autoPan);
        document.querySelectorAll('.svb:not(#autoPanBtn)').forEach(function(b){b.classList.remove('on');});
        if(autoPan){wpIdx=0; wpProg=0;}
      };

      function loop(){
        requestAnimationFrame(loop);

        if(autoPan && !dragging){
          wpProg += 0.0018;
          if(wpProg >= 1){wpProg=0; wpIdx=(wpIdx+1)%wp.length;}
          var a=wp[wpIdx], b=wp[(wpIdx+1)%wp.length], e=ease(wpProg);
          target.sc = lerp(a.sc, b.sc, e);
          target.ox = lerp(a.ox, b.ox, e);
          target.oy = lerp(a.oy, b.oy, e);
        }

        var spd = autoPan ? 0.014 : 0.10;
        state.sc = lerp(state.sc, target.sc, spd);
        state.ox = lerp(state.ox, target.ox, spd);
        state.oy = lerp(state.oy, target.oy, spd);

        draw();
        zBadge.textContent = state.sc.toFixed(1)+'x';
      }

      // MOUSE DRAG
      wrap.addEventListener('mousedown', function(e){
        dragging=true; dsx=e.clientX; dsy=e.clientY; dox=target.ox; doy=target.oy;
        autoPan=false; document.getElementById('autoPanBtn').classList.remove('on');
        e.preventDefault();
      });
      window.addEventListener('mouseup', function(){dragging=false;});
      window.addEventListener('mousemove', function(e){
        if(!dragging) return;
        hideHint();
        target.ox = dox + (e.clientX-dsx);
        target.oy = doy + (e.clientY-dsy);
        clampState();
      });

      // TOUCH DRAG + PINCH
      var tc={sx:0,sy:0,sox:0,soy:0,p0:0,sp0:1};
      wrap.addEventListener('touchstart', function(e){
        if(e.touches.length===1){
          tc.sx=e.touches[0].clientX; tc.sy=e.touches[0].clientY;
          tc.sox=target.ox; tc.soy=target.oy;
          autoPan=false; document.getElementById('autoPanBtn').classList.remove('on');
        }
        if(e.touches.length===2){
          tc.p0=Math.hypot(e.touches[0].clientX-e.touches[1].clientX,
                           e.touches[0].clientY-e.touches[1].clientY);
          tc.sp0=target.sc;
        }
      },{passive:true});
      wrap.addEventListener('touchmove', function(e){
        if(e.touches.length===1){
          hideHint();
          target.ox = tc.sox+(e.touches[0].clientX-tc.sx);
          target.oy = tc.soy+(e.touches[0].clientY-tc.sy);
          clampState();
        }
        if(e.touches.length===2){
          var d=Math.hypot(e.touches[0].clientX-e.touches[1].clientX,
                           e.touches[0].clientY-e.touches[1].clientY);
          target.sc = Math.max(SC_MIN, Math.min(SC_MAX, tc.sp0*(d/tc.p0)));
          clampState();
        }
      },{passive:true});

      // SCROLL ZOOM - zoom vao vi tri con tro
      wrap.addEventListener('wheel', function(e){
        e.preventDefault(); hideHint();
        autoPan=false; document.getElementById('autoPanBtn').classList.remove('on');
        var oldSc = target.sc;
        var delta = e.deltaY>0 ? -0.18 : 0.18;
        target.sc = Math.max(SC_MIN, Math.min(SC_MAX, target.sc+delta));
        // Zoom toward mouse position
        var ratio = target.sc / oldSc;
        var mx = e.offsetX - cW/2;
        var my = e.offsetY - cH/2;
        target.ox = mx + (target.ox - mx) * ratio;
        target.oy = my + (target.oy - my) * ratio;
        clampState();
      },{passive:false});

      // DOUBLE CLICK zoom to/from
      wrap.addEventListener('dblclick', function(e){
        hideHint();
        autoPan=false; document.getElementById('autoPanBtn').classList.remove('on');
        if(target.sc < 2.2){
          var mx = e.offsetX - cW/2;
          var my = e.offsetY - cH/2;
          var newSc = 2.8;
          var ratio = newSc / target.sc;
          target.sc = newSc;
          target.ox = mx + (target.ox - mx) * ratio;
          target.oy = my + (target.oy - my) * ratio;
          clampState();
        } else {
          target.sc=1.0; target.ox=0; target.oy=0;
        }
      });

      // RESIZE
      window.addEventListener('resize', function(){
        resize();
        clampState();
      });

      // Cho anh load xong roi loop
      if(img.complete) { imgW=img.naturalWidth; imgH=img.naturalHeight; ready=true; resize(); loop(); }
    })();
</script>

