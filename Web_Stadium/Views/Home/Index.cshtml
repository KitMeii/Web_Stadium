@{
    ViewData["Title"] = "Trang chủ";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- ════ HERO ════ -->
<section class="hero-section">
    <video class="hero-video" autoplay muted loop playsinline>
        <source src="~/videos/san-bong-hero.mp4" type="video/mp4">
    </video>
    <div class="hero-overlay"></div>

    <div class="hero-content container" data-aos="fade-up">
        <span class="badge-sport mb-4">
            Nền tảng đặt sân số 1 Việt Nam
        </span>
        <h1 class="mb-4">
            ĐẶT SÂN BÓNG<br />
            <span class="highlight">NHANH CHÓNG</span><br />
            MỌI LÚC MỌI NƠI
        </h1>
        <p class="lead mb-5 mx-auto"
           style="color:var(--muted); max-width:560px; font-size:16px">
            Hơn 200 sân bóng chất lượng cao đang chờ bạn khám phá.
            Trải nghiệm hệ thống đặt sân chuẩn chuyên nghiệp.
        </p>
        <div class="d-flex gap-3 justify-content-center flex-wrap">
            <a href="/Venues" class="btn-primary-glow">
                TÌM SÂN NGAY
            </a>
            <a href="/Matchmaking" class="btn-ghost-glow">
                TÌM ĐỐI THỦ
            </a>
            @if (Context.Request.Cookies["jwt"] == null)
            {
                <a href="/Auth/Register" class="btn-ghost-glow">
                    ĐĂNG KÝ MIỄN PHÍ
                </a>
            }
            else
            {
                <a href="/Booking/MyBookings" class="btn-ghost-glow">
                    LỊCH ĐẶT CỦA TÔI
                </a>
            }
        </div>
    </div>

    <!-- Scroll indicator -->
    <div class="position-absolute bottom-0 start-50
                translate-middle-x mb-5"
         style="z-index:3">
        <div class="scroll-arrow"><span></span></div>
    </div>
</section>

<!-- ════ GIỚI THIỆU ════ -->
<section class="about-section section">
    <div class="container">
        <div class="row align-items-stretch g-5">

            <!-- Ảnh / Carousel — 5 tấm ảnh local, tự chuyển 3s -->
            <div class="col-lg-6" data-aos="fade-right">
                <div class="featured-images-wrap h-100">
                    <div id="pitchCarousel"
                         class="carousel slide carousel-fade h-100"
                         data-bs-ride="carousel"
                         data-bs-interval="2500">

                        <!-- Dots indicator -->
                        <div class="carousel-indicators" style="margin-bottom:12px;gap:6px;">
                            <button type="button" data-bs-target="#pitchCarousel" data-bs-slide-to="0" class="active" aria-current="true"></button>
                            <button type="button" data-bs-target="#pitchCarousel" data-bs-slide-to="1"></button>
                            <button type="button" data-bs-target="#pitchCarousel" data-bs-slide-to="2"></button>
                            <button type="button" data-bs-target="#pitchCarousel" data-bs-slide-to="3"></button>
                            <button type="button" data-bs-target="#pitchCarousel" data-bs-slide-to="4"></button>
                        </div>

                        <div class="carousel-inner h-100" style="border-radius:var(--r-lg);overflow:hidden;">

                            <!-- Slide 1 -->
                            <div class="carousel-item active h-100">
                                <div class="pitch-slide">
                                    <img src="~/images/index/anh1.png" alt="San bong 1" class="pitch-slide-img" />
                                    <div class="pitch-slide-overlay"></div>
                                    <div class="pitch-slide-info">
                                        <div class="pitch-slide-label">Những gì bạn cần biết về</div>
                                        <div class="pitch-slide-name">Hệ thống quản lý sân bóng PitchHub</div>
                                    </div>
                                    <div class="pitch-slide-num">1 / 5</div>
                                </div>
                            </div>

                            <!-- Slide 2 -->
                            <div class="carousel-item h-100">
                                <div class="pitch-slide">
                                    <img src="~/images/index/anh2.png" alt="San bong 2" class="pitch-slide-img" />
                                    <div class="pitch-slide-overlay"></div>
                                    <div class="pitch-slide-info">
                                        <div class="pitch-slide-label">Những gì bạn cần biết về</div>
                                        <div class="pitch-slide-name">Hệ thống quản lý sân bóng PitchHub</div>
                                    </div>
                                    <div class="pitch-slide-num">2 / 5</div>
                                </div>
                            </div>

                            <!-- Slide 3 -->
                            <div class="carousel-item h-100">
                                <div class="pitch-slide">
                                    <img src="~/images/index/anh3.png" alt="San bong 3" class="pitch-slide-img" />
                                    <div class="pitch-slide-overlay"></div>
                                    <div class="pitch-slide-info">
                                        <div class="pitch-slide-label">Những gì bạn cần biết về</div>
                                        <div class="pitch-slide-name">Hệ thống quản lý sân bóng PitchHub</div>
                                    </div>
                                    <div class="pitch-slide-num">3 / 5</div>
                                </div>
                            </div>

                            <!-- Slide 4 -->
                            <div class="carousel-item h-100">
                                <div class="pitch-slide">
                                    <img src="~/images/index/anh4.png" alt="San bong 4" class="pitch-slide-img" />
                                    <div class="pitch-slide-overlay"></div>
                                    <div class="pitch-slide-info">
                                        <div class="pitch-slide-label">Những gì bạn cần biết về</div>
                                        <div class="pitch-slide-name">Hệ thống quản lý sân bóng PitchHub</div>
                                    </div>
                                    <div class="pitch-slide-num">4 / 5</div>
                                </div>
                            </div>

                            <!-- Slide 5 -->
                            <div class="carousel-item h-100">
                                <div class="pitch-slide">
                                    <img src="~/images/index/anh5.png" alt="San bong 5" class="pitch-slide-img" />
                                    <div class="pitch-slide-overlay"></div>
                                    <div class="pitch-slide-info">
                                        <div class="pitch-slide-label">Những gì bạn cần biết về</div>
                                        <div class="pitch-slide-name">Hệ thống quản lý sân bóng PitchHub</div>
                                    </div>
                                    <div class="pitch-slide-num">5 / 5</div>
                                </div>
                            </div>

                        </div><!-- /carousel-inner -->
                        <!-- Prev -->
                        <button class="carousel-control-prev pitch-arrow" type="button"
                                data-bs-target="#pitchCarousel" data-bs-slide="prev">
                            <span class="carousel-control-prev-icon" style="width:14px;height:14px;"></span>
                        </button>
                        <!-- Next -->
                        <button class="carousel-control-next pitch-arrow" type="button"
                                data-bs-target="#pitchCarousel" data-bs-slide="next">
                            <span class="carousel-control-next-icon" style="width:14px;height:14px;"></span>
