@{
    ViewData["Title"] = "Liên hệ";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="section contact-section">
    <div class="container">

        <!-- HEADER -->
        <div class="text-center mb-5">

            <div class="section-label mx-auto mb-3">
                LIÊN HỆ
            </div>

            <h1 class="section-title mb-4">
                KẾT NỐI
                <span class="text-green">
                    VỚI CHÚNG TÔI
                </span>
            </h1>

            <p class="contact-intro">
                PITCHHUB luôn sẵn sàng lắng nghe mọi ý kiến đóng góp,
                hỗ trợ người dùng trong quá trình đặt sân và giải đáp
                các vấn đề liên quan đến hệ thống.
            </p>

        </div>

        <div class="row g-4 align-items-stretch">

            <!-- LEFT INFO -->
            <div class="col-lg-5">

                <div class="contact-info-card h-100">

                    <div class="contact-badge">
                        HỖ TRỢ 24/7
                    </div>

                    <h3 class="contact-title">
                        Thông tin liên hệ
                    </h3>

                    <p class="contact-desc">
                        Đội ngũ chăm sóc khách hàng của PITCHHUB
                        hoạt động liên tục nhằm mang đến trải nghiệm
                        tốt nhất cho người dùng trên toàn quốc.
                    </p>

                    <!-- ITEM -->
                    <div class="contact-item">
                        <div class="contact-icon">
                            📍
                        </div>

                        <div>
                            <h5>Địa chỉ</h5>

                            <p>
                                123 Nguyễn Văn Linh, Quận 7,
                                TP. Hồ Chí Minh, Việt Nam
                            </p>
                        </div>
                    </div>

                    <!-- ITEM -->
                    <div class="contact-item">
                        <div class="contact-icon">
                            📞
                        </div>

                        <div>
                            <h5>Hotline</h5>

                            <p>
                                0123 456 789
                            </p>
                        </div>
                    </div>

                    <!-- ITEM -->
                    <div class="contact-item">
                        <div class="contact-icon">
                            ✉
                        </div>

                        <div>
                            <h5>Email hỗ trợ</h5>

                            <p>
                                support@pitchhub.vn
                            </p>
                        </div>
                    </div>

                    <!-- ITEM -->
                    <div class="contact-item">
                        <div class="contact-icon">
                            🕒
                        </div>

                        <div>
                            <h5>Giờ làm việc</h5>

                            <p>
                                Hoạt động 24/7 tất cả các ngày trong tuần
                            </p>
                        </div>
                    </div>

                    <!-- SOCIAL -->
                    <div class="contact-socials mt-4">

                        <a href="#">
                            <i class="bi bi-facebook"></i>
                        </a>

                        <a href="#">
                            <i class="bi bi-instagram"></i>
                        </a>

                        <a href="#">
                            <i class="bi bi-youtube"></i>
                        </a>

                        <a href="#">
                            <i class="bi bi-tiktok"></i>
                        </a>

                    </div>

                </div>

            </div>

            <!-- RIGHT FORM -->
            <div class="col-lg-7">

                <div class="contact-form-card h-100">

                    <div class="mb-4">

                        <div class="section-label mb-3">
                            GỬI TIN NHẮN
                        </div>

                        <h3 class="contact-title">
                            Chúng tôi sẽ phản hồi sớm nhất
                        </h3>

                        <p class="contact-desc">
                            Hãy để lại thông tin và nội dung cần hỗ trợ.
                            Đội ngũ PITCHHUB sẽ liên hệ với bạn trong thời gian sớm nhất.
                        </p>

                    </div>

                    <form>

                        <div class="row">

                            <div class="col-md-6 mb-3">

                                <label class="contact-label">
                                    Họ và tên
                                </label>

                                <input type="text"
                                       class="contact-input"
                                       placeholder="Nhập họ và tên">

                            </div>

                            <div class="col-md-6 mb-3">

                                <label class="contact-label">
                                    Số điện thoại
                                </label>

                                <input type="text"
                                       class="contact-input"
                                       placeholder="Nhập số điện thoại">

                            </div>

                        </div>

                        <div class="mb-3">

                            <label class="contact-label">
                                Email
                            </label>

                            <input type="email"
                                   class="contact-input"
                                   placeholder="Nhập email">

                        </div>

                        <div class="mb-3">

                            <label class="contact-label">
                                Chủ đề
                            </label>

                            <select class="contact-input">

                                <option>
                                    Hỗ trợ đặt sân
                                </option>

                                <option>
                                    Thanh toán
                                </option>

                                <option>
                                    Báo lỗi hệ thống
                                </option>

                                <option>
                                    Hợp tác kinh doanh
                                </option>

                            </select>

                        </div>

                        <div class="mb-4">

                            <label class="contact-label">
                                Nội dung
                            </label>

                            <textarea rows="6"
                                      class="contact-input"
                                      placeholder="Nhập nội dung cần hỗ trợ">
                            </textarea>

                        </div>

                        <button type="submit"
                                class="btn-primary-glow">
                            GỬI LIÊN HỆ
                        </button>

                    </form>

                </div>

            </div>

        </div>

    </div>
</section>

<!-- ════ FOOTER ════ -->
<footer class="footer-premium">
    <div class="container">

        <div class="row g-5">

            <!-- Brand -->
            <div class="col-lg-4">
                <div class="footer-brand">
                    <h3 class="mb-3">
                        <span class="text-green">PITCH</span><span style="color:#fff">HUB</span>
                    </h3>

                    <p class="footer-desc">
                        Nền tảng đặt sân bóng hiện đại giúp người chơi
                        kết nối, đặt sân và tìm đối thủ nhanh chóng trên
                        toàn quốc.
                    </p>

                    <div class="footer-socials mt-4">
                        <a href="#"><i class="bi bi-facebook"></i></a>
                        <a href="#"><i class="bi bi-instagram"></i></a>
                        <a href="#"><i class="bi bi-youtube"></i></a>
                        <a href="#"><i class="bi bi-tiktok"></i></a>
                    </div>
                </div>
            </div>

            <!-- Liên kết -->
            <div class="col-lg-2 col-md-4">
                <h5 class="footer-title">Khám phá</h5>

                <ul class="footer-links">
                    <li><a href="/Venues">Danh sách sân</a></li>
                    <li><a href="/Matchmaking">Tìm đối thủ</a></li>
                    <li><a href="/Booking/MyBookings">Lịch đặt</a></li>
                    <li><a href="/Auth/Register">Đăng ký</a></li>
                </ul>
            </div>

            <!-- Hỗ trợ -->
            <div class="col-lg-3 col-md-4">
                <h5 class="footer-title">Hỗ trợ</h5>

                <ul class="footer-links">
                    <li><a href="/Support">Trung tâm hỗ trợ</a></li>
                    <li><a href="/Support/Terms">Điều khoản</a></li>
                    <li><a href="/Support/Privacy">Chính sách bảo mật</a></li>
                    <li><a href="/Support/Contact">Liên hệ</a></li>
                </ul>
            </div>

            <!-- Contact -->
            <div class="col-lg-3 col-md-4">
                <h5 class="footer-title">Liên hệ</h5>

                <ul class="footer-contact">
                    <li>📍 TP. Hồ Chí Minh, Việt Nam</li>
                    <li>📞 0123 456 789</li>
                    <li>✉ support@pitchhub.vn</li>
                </ul>
            </div>

        </div>

        <!-- Bottom -->
        <div class="footer-bottom">
            <p>
                © @DateTime.Now.Year PITCHHUB.
                All rights reserved.
            </p>
        </div>

    </div>
</footer>