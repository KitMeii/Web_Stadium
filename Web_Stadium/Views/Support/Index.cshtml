@{
    ViewData["Title"] = "Trung tâm hỗ trợ";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="section">
    <div class="container">

        <!-- HEADER -->
        <div class="text-center mb-5">

            <div class="section-label mx-auto mb-3">
                HỖ TRỢ KHÁCH HÀNG
            </div>

            <h1 class="section-title mb-4">
                TRUNG TÂM
                <span class="text-green">
                    HỖ TRỢ
                </span>
            </h1>

            <p style="
                color:rgba(0,0,0,1);
                max-width:850px;
                margin:auto;
                line-height:1.9;
                font-size:17px;
            ">
                PITCHHUB luôn đồng hành cùng người chơi trong toàn bộ quá trình
                trải nghiệm dịch vụ — từ tìm sân, đặt lịch, thanh toán cho đến
                kết nối cộng đồng bóng đá. Chúng tôi xây dựng hệ thống hỗ trợ
                chuyên nghiệp nhằm mang lại trải nghiệm nhanh chóng, minh bạch
                và tiện lợi nhất cho khách hàng trên toàn quốc.
            </p>

        </div>

        <!-- FEATURE CARDS -->
        <div class="row g-4 mb-5">

            <!-- BOOKING -->
            <div class="col-lg-4 col-md-6">
                <div class="feature-card h-100">

                    <div class="feature-icon">📅</div>

                    <h3 class="feature-title mb-3">
                        Hỗ trợ đặt sân nhanh
                    </h3>

                    <p class="feature-desc mb-4">
                        Hệ thống hỗ trợ người dùng tìm kiếm và đặt sân bóng
                        trực tuyến chỉ trong vài phút với giao diện đơn giản,
                        trực quan và tối ưu cho mọi thiết bị.
                    </p>

                    <ul class="support-list">
                        <li>Tìm sân theo quận/huyện</li>
                        <li>Lọc theo loại sân & mặt cỏ</li>
                        <li>Xem lịch trống theo thời gian thực</li>
                        <li>Giữ chỗ tự động trong 10 phút</li>
                        <li>Xác nhận đặt sân tức thì</li>
                    </ul>

                </div>
            </div>

            <!-- PAYMENT -->
            <div class="col-lg-4 col-md-6">
                <div class="feature-card h-100">

                    <div class="feature-icon">💳</div>

                    <h3 class="feature-title mb-3">
                        Thanh toán & hoàn tiền
                    </h3>

                    <p class="feature-desc mb-4">
                        Chúng tôi tích hợp nhiều phương thức thanh toán an toàn
                        và hỗ trợ hoàn tiền linh hoạt theo chính sách của từng sân.
                    </p>

                    <ul class="support-list">
                        <li>Thanh toán online bảo mật</li>
                        <li>Hỗ trợ ví điện tử & chuyển khoản</li>
                        <li>Xác nhận giao dịch tự động</li>
                        <li>Hủy sân trực tuyến dễ dàng</li>
                        <li>Hỗ trợ xử lý hoàn tiền nhanh</li>
                    </ul>

                </div>
            </div>

            <!-- SUPPORT -->
            <div class="col-lg-4 col-md-12">
                <div class="feature-card h-100">

                    <div class="feature-icon">📞</div>

                    <h3 class="feature-title mb-3">
                        Chăm sóc khách hàng 24/7
                    </h3>

                    <p class="feature-desc mb-4">
                        Đội ngũ hỗ trợ luôn sẵn sàng giải đáp mọi thắc mắc
                        và xử lý các vấn đề phát sinh trong quá trình sử dụng dịch vụ.
                    </p>

                    <ul class="support-list">
                        <li>Hỗ trợ trực tuyến mọi lúc</li>
                        <li>Tư vấn đặt sân phù hợp</li>
                        <li>Giải quyết sự cố thanh toán</li>
                        <li>Tiếp nhận phản hồi người dùng</li>
                        <li>Hỗ trợ kết nối đội bóng giao lưu</li>
                    </ul>

                </div>
            </div>

        </div>

        <!-- FAQ -->
        <div class="support-faq">

            <div class="text-center mb-5">

                <div class="section-label mx-auto mb-3">
                    CÂU HỎI THƯỜNG GẶP
                </div>

                <h2 class="section-title">
                    GIẢI ĐÁP
                    <span class="text-green">
                        THẮC MẮC
                    </span>
                </h2>

            </div>

            <div class="row g-4">

                <div class="col-lg-6">

                    <div class="faq-card">

                        <h4>
                            Tôi có thể hủy lịch đặt sân không?
                        </h4>

                        <p>
                            Có. Người dùng có thể hủy lịch đặt trực tiếp
                            trên hệ thống trước thời gian thi đấu tối thiểu
                            theo quy định của sân bóng.
                        </p>

                    </div>

                </div>

                <div class="col-lg-6">

                    <div class="faq-card">

                        <h4>
                            Sau khi thanh toán bao lâu thì xác nhận?
                        </h4>

                        <p>
                            Hệ thống xác nhận tự động ngay sau khi giao dịch
                            thành công và gửi thông báo qua email hoặc tài khoản.
                        </p>

                    </div>

                </div>

                <div class="col-lg-6">

                    <div class="faq-card">

                        <h4>
                            Tôi có thể tìm đối thủ giao lưu ở đâu?
                        </h4>

                        <p>
                            Bạn có thể đăng bài trong mục “Tìm đối thủ”
                            để kết nối các đội bóng khác theo khu vực.
                        </p>

                    </div>

                </div>

                <div class="col-lg-6">

                    <div class="faq-card">

                        <h4>
                            Hệ thống có hỗ trợ trên điện thoại không?
                        </h4>

                        <p>
                            Có. PITCHHUB được tối ưu responsive cho cả
                            điện thoại, tablet và desktop.
                        </p>

                    </div>

                </div>

            </div>

        </div>

        <!-- CONTACT -->
        <div class="support-contact mt-5">

            <div class="row align-items-center">

                <div class="col-lg-8">

                    <h2 class="section-title mb-3">
                        CẦN THÊM
                        <span class="text-green">
                            HỖ TRỢ?
                        </span>
                    </h2>

                    <p style="
                        color:rgba(0,0,0,1);
                        line-height:1.8;
                        margin:0;
                    ">
                        Nếu bạn gặp bất kỳ vấn đề nào trong quá trình sử dụng,
                        đội ngũ chăm sóc khách hàng của PITCHHUB luôn sẵn sàng hỗ trợ.
                    </p>

                </div>

                <div class="col-lg-4 text-lg-end mt-4 mt-lg-0">

                    <a href="/Support/Contact"
                       class="btn-primary-glow">
                        LIÊN HỆ NGAY
                    </a>

                </div>

            </div>

        </div>

    </div>
</section>

<!-- ════ FOOTER ════ -->
<footer class="footer-premium">
    <div class="container">

        <div class="row g-5">

            <!-- Brand -->
            <div class="col-lg-4">
                <div class="footer-brand">
                    <h3 class="mb-3">
                        <span class="text-green">PITCH</span><span style="color:#fff">HUB</span>
                    </h3>

                    <p class="footer-desc">
                        Nền tảng đặt sân bóng hiện đại giúp người chơi
                        kết nối, đặt sân và tìm đối thủ nhanh chóng trên
                        toàn quốc.
                    </p>

                    <div class="footer-socials mt-4">
                        <a href="#"><i class="bi bi-facebook"></i></a>
                        <a href="#"><i class="bi bi-instagram"></i></a>
                        <a href="#"><i class="bi bi-youtube"></i></a>
                        <a href="#"><i class="bi bi-tiktok"></i></a>
                    </div>
                </div>
            </div>

            <!-- Liên kết -->
            <div class="col-lg-2 col-md-4">
                <h5 class="footer-title">Khám phá</h5>

                <ul class="footer-links">
                    <li><a href="/Venues">Danh sách sân</a></li>
                    <li><a href="/Matchmaking">Tìm đối thủ</a></li>
                    <li><a href="/Booking/MyBookings">Lịch đặt</a></li>
                    <li><a href="/Auth/Register">Đăng ký</a></li>
                </ul>
            </div>

            <!-- Hỗ trợ -->
            <div class="col-lg-3 col-md-4">
                <h5 class="footer-title">Hỗ trợ</h5>

                <ul class="footer-links">
                    <li><a href="/Support">Trung tâm hỗ trợ</a></li>
                    <li><a href="/Support/Terms">Điều khoản</a></li>
                    <li><a href="/Support/Privacy">Chính sách bảo mật</a></li>
                    <li><a href="/Support/Contact">Liên hệ</a></li>
                </ul>
            </div>

            <!-- Contact -->
            <div class="col-lg-3 col-md-4">
                <h5 class="footer-title">Liên hệ</h5>

                <ul class="footer-contact">
                    <li>📍 TP. Hồ Chí Minh, Việt Nam</li>
                    <li>📞 0123 456 789</li>
                    <li>✉ support@sportbook.vn</li>
                </ul>
            </div>

        </div>

        <!-- Bottom -->
        <div class="footer-bottom">
            <p>
                © @DateTime.Now.Year SPORTBOOK.
                All rights reserved.
            </p>
        </div>

    </div>
</footer>