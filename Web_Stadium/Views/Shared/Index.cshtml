<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,
    initial-scale=1.0" />
    <title>@ViewData["Title"] - ⚽ SânBóng.vn</title>
    <!-- Tất cả CSS đã liệt kê ở mục 8.1 -->
    <link rel="stylesheet" href="~/css/custom.css" />
</head>
<body>

    <!-- NAVBAR CỐ ĐỊNH -->
    <nav class="navbar navbar-expand-lg navbar-custom
  fixed-top">
        <div class="container">
            <a class="navbar-brand" href="/">
                ⚽ SânBóng.vn
            </a>
            <button class="navbar-toggler"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#navMenu">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse"
                 id="navMenu">
                <ul class="navbar-nav ms-auto gap-2">
                    <li class="nav-item">
                        <a class="nav-link text-white"
                           href="/Venues">Tìm sân</a>
                    </li>
                    @if (Context.Request.Cookies["jwt"] != null)
                    {
                        <li class="nav-item">
                            <a class="nav-link text-white"
                               href="/Booking/MyBookings">
                                Đặt sân của tôi
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="btn btn-outline-warning
                  btn-sm" href="/Auth/Logout">
                                Đăng xuất
                            </a>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link text-white"
                               href="/Auth/Login">
                                Đăng nhập
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="btn btn-warning btn-sm"
                               href="/Auth/Register">
                                Đăng ký miễn phí
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <!-- THÔNG BÁO TOAST -->
    @if (TempData["Success"] != null)
    {
        <div class="position-fixed top-0 end-0 p-3"
             style="z-index:9999">
            <div class="toast show align-items-center
          text-bg-success border-0">
                <div class="d-flex">
                    <div class="toast-body">
                        ✅ @TempData["Success"]
                    </div>
                </div>
            </div>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="position-fixed top-0 end-0 p-3"
             style="z-index:9999">
            <div class="toast show align-items-center
          text-bg-danger border-0">
                <div class="d-flex">
                    <div class="toast-body">
                        ❌ @TempData["Error"]
                    </div>
                </div>
            </div>
        </div>
    }

    @RenderBody()

    <!-- Tất cả JS đã liệt kê ở mục 8.1 -->
</body>
</html>
